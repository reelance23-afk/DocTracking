<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["DocTracking.styles.css"]" />
    <link rel="stylesheet" href="mobile.css" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveAuto" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
</head>




<body>
    <div id="app-loading">
        <div class="splash-bg"></div>

        <div class="splash-content">
            <div class="splash-logo">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14 2H6C4.9 2 4 2.9 4 4V20C4 21.1 4.9 22 6 22H18C19.1 22 20 21.1 20 20V8L14 2Z" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5" />
                    <path d="M14 2V8H20" stroke="white" stroke-width="1.5" stroke-linecap="round" fill="none" />
                    <path d="M8 13H16M8 17H13" stroke="white" stroke-width="1.5" stroke-linecap="round" />
                </svg>
            </div>
            <p class="splash-sub">Online Document Tracking System</p>

            <div class="splash-spinner">
                <div class="ring ring-1"></div>
                <div class="ring ring-2"></div>
                <div class="ring ring-3"></div>
            </div>
        </div>
    </div>

    <style>
        #app-loading {
            position: fixed;
            inset: 0;
            z-index: 9999;
            overflow: hidden;
        }

        .splash-bg {
            position: absolute;
            inset: 0;
            background: linear-gradient(160deg, #0d47a1 0%, #1976d2 45%, #42a5f5 100%);
        }

            .splash-bg::before {
                content: '';
                position: absolute;
                width: 600px;
                height: 600px;
                background: rgba(255,255,255,0.04);
                border-radius: 50%;
                top: -200px;
                right: -150px;
            }

            .splash-bg::after {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                background: rgba(255,255,255,0.04);
                border-radius: 50%;
                bottom: -100px;
                left: -100px;
            }

        .splash-content {
            position: relative;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
        }

        .splash-logo {
            width: 72px;
            height: 72px;
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.25);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 0.5rem;
            animation: logo-in 0.6s ease-out both;
        }

            .splash-logo svg {
                width: 36px;
                height: 36px;
            }

        .splash-title {
            margin: 0;
            font-family: 'Roboto', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            color: white;
            letter-spacing: 1px;
            animation: fade-up 0.6s ease-out 0.1s both;
        }

        .splash-sub {
            margin: 0;
            font-family: 'Roboto', sans-serif;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.65);
            letter-spacing: 0.5px;
            animation: fade-up 0.6s ease-out 0.2s both;
        }

        .splash-spinner {
            position: relative;
            width: 48px;
            height: 48px;
            margin-top: 2rem;
            animation: fade-up 0.6s ease-out 0.3s both;
        }

        .ring {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            border: 2px solid transparent;
        }

        .ring-1 {
            border-top-color: rgba(255,255,255,0.9);
            animation: spin 1s linear infinite;
        }

        .ring-2 {
            inset: 6px;
            border-right-color: rgba(255,255,255,0.5);
            animation: spin 1.4s linear infinite reverse;
        }

        .ring-3 {
            inset: 12px;
            border-bottom-color: rgba(255,255,255,0.3);
            animation: spin 1.8s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        @@keyframes fade-up {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes logo-in {
            from {
                opacity: 0;
                transform: scale(0.7);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }
    </style>

    <CascadingAuthenticationState>
        <Routes @rendermode="InteractiveAuto" />
    </CascadingAuthenticationState>
    <script src="_framework/blazor.web.js"></script>
    <script>
        window.qrScanner = (() => {
            let stream = null;
            let rafId = null;
            return {
                async start(videoId, dotnet) {
                    if (!('BarcodeDetector' in window)) {
                        dotnet.invokeMethodAsync('OnUnsupported');
                        return;
                    }
                    const video = document.getElementById(videoId);
                    stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
                    video.srcObject = stream;
                    const detector = new BarcodeDetector({ formats: ['qr_code'] });
                    const scan = async () => {
                        if (video.readyState === video.HAVE_ENOUGH_DATA) {
                            const codes = await detector.detect(video);
                            if (codes.length > 0) {
                                window.qrScanner.stop();
                                dotnet.invokeMethodAsync('OnScanned', codes[0].rawValue);
                                return;
                            }
                        }
                        rafId = requestAnimationFrame(scan);
                    };
                    rafId = requestAnimationFrame(scan);
                },
                stop() {
                    if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
                    if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
                }
            };
        })();
    </script>
</body>

</html>
