<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["DocTracking.styles.css"]" />
    <link rel="stylesheet" href="mobile.css" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveAuto" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
</head>




<body>
    <div id="app-loading">
        <div class="splash-bg">
            <div class="particle p1"></div>
            <div class="particle p2"></div>
            <div class="particle p3"></div>
            <div class="particle p4"></div>
        </div>

        <div class="splash-content">
            <div class="splash-logo">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14 2H6C4.9 2 4 2.9 4 4V20C4 21.1 4.9 22 6 22H18C19.1 22 20 21.1 20 20V8L14 2Z" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5" />
                    <path d="M14 2V8H20" stroke="white" stroke-width="1.5" stroke-linecap="round" fill="none" />
                    <path d="M8 13H16M8 17H13" stroke="white" stroke-width="1.5" stroke-linecap="round" />
                </svg>
            </div>
            <h1 class="splash-title">DocTracking</h1>
            <p class="splash-sub">Online Document Tracking System</p>

            <div class="splash-spinner">
                <div class="ring ring-1"></div>
                <div class="ring ring-2"></div>
                <div class="ring ring-3"></div>
            </div>

            <div class="splash-dots">
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
            </div>
        </div>
    </div>


    <style>
        body:has(#app-loading) {
            overflow: hidden;
        }

        #app-loading {
            position: fixed;
            inset: 0;
            z-index: 9999;
            overflow: hidden;
            transition: opacity 0.5s ease;
        }

            #app-loading.hide {
                opacity: 0;
                pointer-events: none;
            }

        .splash-bg {
            position: absolute;
            inset: 0;
            background: linear-gradient(160deg, #0d47a1 0%, #1976d2 45%, #42a5f5 100%);
            overflow: hidden;
        }

            .splash-bg::before {
                content: '';
                position: absolute;
                width: 600px;
                height: 600px;
                background: rgba(255,255,255,0.04);
                border-radius: 50%;
                top: -200px;
                right: -150px;
            }

            .splash-bg::after {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                background: rgba(255,255,255,0.04);
                border-radius: 50%;
                bottom: -100px;
                left: -100px;
            }

        .particle {
            position: absolute;
            border-radius: 50%;
            background: rgba(255,255,255,0.06);
            animation: float linear infinite;
        }

        .p1 {
            width: 80px;
            height: 80px;
            left: 10%;
            top: 20%;
            animation-duration: 8s;
            animation-delay: 0s;
        }

        .p2 {
            width: 50px;
            height: 50px;
            left: 80%;
            top: 15%;
            animation-duration: 6s;
            animation-delay: 1s;
        }

        .p3 {
            width: 100px;
            height: 100px;
            left: 60%;
            top: 70%;
            animation-duration: 10s;
            animation-delay: 2s;
        }

        .p4 {
            width: 40px;
            height: 40px;
            left: 25%;
            top: 75%;
            animation-duration: 7s;
            animation-delay: 0.5s;
        }

        .splash-content {
            position: relative;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
        }

        .splash-logo {
            width: 80px;
            height: 80px;
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.25);
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 0.5rem;
            animation: logo-in 0.6s ease-out both;
            box-shadow: 0 0 0 0 rgba(255,255,255,0.3);
            animation: logo-in 0.6s ease-out both, logo-pulse 2.5s ease-in-out 0.6s infinite;
        }

            .splash-logo svg {
                width: 40px;
                height: 40px;
            }

        .splash-title {
            margin: 0;
            font-family: 'Roboto', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            color: white;
            letter-spacing: 2px;
            animation: fade-up 0.6s ease-out 0.1s both;
        }

        .splash-sub {
            margin: 0;
            font-family: 'Roboto', sans-serif;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.65);
            letter-spacing: 0.5px;
            animation: fade-up 0.6s ease-out 0.2s both;
        }

        .splash-spinner {
            position: relative;
            width: 48px;
            height: 48px;
            margin-top: 2rem;
            animation: fade-up 0.6s ease-out 0.3s both;
        }

        .ring {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            border: 2px solid transparent;
        }

        .ring-1 {
            border-top-color: rgba(255,255,255,0.9);
            animation: spin 1s linear infinite;
        }

        .ring-2 {
            inset: 6px;
            border-right-color: rgba(255,255,255,0.5);
            animation: spin 1.4s linear infinite reverse;
        }

        .ring-3 {
            inset: 12px;
            border-bottom-color: rgba(255,255,255,0.3);
            animation: spin 1.8s linear infinite;
        }

        .splash-dots {
            display: flex;
            gap: 6px;
            margin-top: 1rem;
            animation: fade-up 0.6s ease-out 0.4s both;
        }

        .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: rgba(255,255,255,0.6);
            animation: dot-bounce 1.2s ease-in-out infinite;
        }

            .dot:nth-child(2) {
                animation-delay: 0.2s;
            }

            .dot:nth-child(3) {
                animation-delay: 0.4s;
            }

        @@keyframes spin {
            to

        {
            transform: rotate(360deg);
        }

        }

        @@keyframes fade-up {
            from

        {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        @@keyframes logo-in {
            from

        {
            opacity: 0;
            transform: scale(0.7);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }

        }

        @@keyframes logo-pulse {
            0%, 100%

        {
            box-shadow: 0 0 0 0 rgba(255,255,255,0.2);
        }

        50% {
            box-shadow: 0 0 0 12px rgba(255,255,255,0);
        }

        }

        @@keyframes float {
            0%

        {
            transform: translateY(0) rotate(0deg);
            opacity: 0.6;
        }

        50% {
            opacity: 0.3;
        }

        100% {
            transform: translateY(-100vh) rotate(360deg);
            opacity: 0;
        }

        }

        @@keyframes dot-bounce {
            0%, 80%, 100%

        {
            transform: scale(0.6);
            opacity: 0.4;
        }

        40% {
            transform: scale(1);
            opacity: 1;
        }

        }
    </style>

    <CascadingAuthenticationState>
        <DocTracking.Client.Routes @rendermode="InteractiveAuto" />
    </CascadingAuthenticationState>
    <script src="_framework/blazor.web.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
    <script>
        window.qrScanner = (() => {
            let stream = null;
            let scanning = false;
            let animFrame = null;

            return {
                async start(videoId, dotnet) {
                    const video = document.getElementById(videoId);
                    if (!video) { dotnet.invokeMethodAsync('OnUnsupported'); return; }

                    try {
                        stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
                        video.srcObject = stream;
                        await video.play();
                    } catch (e) {
                        dotnet.invokeMethodAsync('OnUnsupported');
                        return;
                    }

                    const canvas = document.createElement('canvas');
                    const ctx = canvas.getContext('2d');
                    scanning = true;

                    function tick() {
                        if (!scanning) return;
                        if (video.readyState === video.HAVE_ENOUGH_DATA) {
                            canvas.width = video.videoWidth;
                            canvas.height = video.videoHeight;
                            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                            const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                            const code = jsQR(imageData.data, imageData.width, imageData.height);
                            if (code) {
                                window.qrScanner.stop();
                                dotnet.invokeMethodAsync('OnScanned', code.data);
                                return;
                            }
                        }
                        animFrame = requestAnimationFrame(tick);
                    }
                    animFrame = requestAnimationFrame(tick);
                },
                stop() {
                    scanning = false;
                    if (animFrame) { cancelAnimationFrame(animFrame); animFrame = null; }
                    if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
                }
            };
        })();
    </script>

    <script>
        window.downloadCsv = function (base64, filename) {
            const bytes = Uint8Array.from(atob(base64), c => c.charCodeAt(0));
            const blob = new Blob([bytes], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        };
    </script>


</body>

</html>
