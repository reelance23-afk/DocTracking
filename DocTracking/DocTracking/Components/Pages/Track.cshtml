@page "/track/{referenceNumber}"
@model DocTracking.Components.Pages.TrackModel
@{
    Layout = null;
    var doc = Model.Doc;
    var logs = Model.Logs;

    string StatusColor(string? s) => s switch {
        "Completed" => "#4caf50",
        "Received" => "#2196f3",
        "In Motion" => "#ff9800",
        _ => "#9e9e9e"
    };
    string PriorityColor(string? p) => p switch {
        "Emergency" => "#f44336",
        "Urgent" => "#ff9800",
        "Medium" => "#2196f3",
        "Low" => "#4caf50",
        _ => "#9e9e9e"
    };
    string ActionIcon(string? a) => a switch {
        "Created" => "📄",
        "Forwarded" => "➡️",
        "Received" => "📥",
        "Completed" => "✅",
        _ => "•"
    };
    string LocationLabel(string? a) => a is "Created" or "Forwarded" ? "Sent to" : "Location";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <title>Track @doc?.ReferenceNumber</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Roboto, sans-serif; background: #f5f5f5; color: #212121; }
        .container { max-width: 800px; margin: 0 auto; padding: 16px; }
        .card { background: white; border-radius: 12px; padding: 20px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
        .title { font-size: 1.25rem; font-weight: 700; }
        .chip { display: inline-block; padding: 4px 12px; border-radius: 16px; font-size: 0.75rem; font-weight: 600; color: white; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 4px; }
        .label { font-size: 0.7rem; color: #757575; text-transform: uppercase; margin-bottom: 2px; }
        .value { font-size: 0.9rem; font-weight: 500; }
        .sub { font-size: 0.78rem; color: #757575; }
        .section-title { font-size: 1rem; font-weight: 700; margin-bottom: 12px; }
        .log-item { border-left: 3px solid #1976d2; padding: 10px 14px; margin-bottom: 10px; background: white; border-radius: 0 8px 8px 0; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
        .log-action { font-weight: 700; font-size: 0.95rem; }
        .log-meta { font-size: 0.78rem; color: #757575; margin-top: 4px; }
        .not-found { text-align: center; padding: 60px 20px; color: #757575; }
        .ref-chip { display: inline-block; padding: 2px 10px; border-radius: 12px; border: 1px solid #1976d2; color: #1976d2; font-size: 0.75rem; margin-top: 4px; }
        .empty { text-align: center; padding: 40px; color: #757575; background: white; border-radius: 12px; }
    </style>
</head>
<body>
<div class="container">
    @if (doc == null)
    {
        <div class="not-found">
            <div style="font-size:3rem">🔍</div>
            <p style="font-size:1.1rem;margin-top:12px">Document not found</p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="header">
                <div>
                    <div class="title">@doc.Name</div>
                    <div class="ref-chip">@doc.ReferenceNumber</div>
                </div>
                <span class="chip" style="background:@StatusColor(doc.Status)">@doc.Status</span>
            </div>
            <div class="grid">
                <div>
                    <div class="label">Type</div>
                    <div class="value">@doc.Type</div>
                </div>
                <div>
                    <div class="label">Priority</div>
                    <span class="chip" style="background:@PriorityColor(doc.Priority)">@doc.Priority</span>
                </div>
                <div>
                    <div class="label">Current Location</div>
                    <div class="value">@(doc.CurrentOffice?.Name ?? "—")</div>
                    @if (doc.CurrentUnit != null) { <div class="sub">↳ @doc.CurrentUnit.Name</div> }
                </div>
                <div>
                    <div class="label">Next Destination</div>
                    <div class="value">@(doc.NextOffice?.Name ?? "—")</div>
                    @if (doc.NextUnit != null) { <div class="sub">↳ @doc.NextUnit.Name</div> }
                </div>
            </div>
        </div>

        <div class="section-title">📋 Tracking Timeline</div>

        @if (!logs.Any())
        {
            <div class="empty">No tracking history yet.</div>
        }
        else
        {
            @foreach (var log in logs)
            {
                <div class="log-item">
                    <div class="log-action">@ActionIcon(log.Action) @log.Action</div>
                    <div class="log-meta">
                        By: <strong>@(log.AppUser?.Name ?? log.UserName ?? "System")</strong>
                        &nbsp;•&nbsp; @log.TimeStamp.ToLocalTime().ToString("MMM dd, yyyy • hh:mm tt")
                    </div>
                    @if (log.Office != null || !string.IsNullOrEmpty(log.OfficeName))
                    {
                        <div class="log-meta">
                            📍 @LocationLabel(log.Action): <strong>@(log.Office?.Name ?? log.OfficeName)</strong>
                            @if (log.Unit != null || !string.IsNullOrEmpty(log.UnitName))
                            {
                                <span> ↳ @(log.Unit?.Name ?? log.UnitName)</span>
                            }
                        </div>
                    }
                </div>
            }
        }
    }
</div>
</body>
</html>
