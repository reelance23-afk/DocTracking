@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using Microsoft.AspNetCore.Components.Forms
@inject DocumentService DocService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Class="font-weight-bold">Edit Document</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Filled.Info" Class="mb-4">
            <MudText Typo="Typo.caption">
                You can only edit this document before it has been received by an office.
            </MudText>
        </MudAlert>
        <MudGrid Spacing="3">
            <MudItem xs="12">
                <MudTextField @bind-Value="Doc.Name" Label="Document Title" Variant="Variant.Outlined"
                              Required="true" RequiredError="Document title is required" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="string" @bind-Value="Doc.Type" Label="Document Type" Variant="Variant.Outlined"
                           Required="true" RequiredError="Please select a document type">
                    <MudSelectItem Value="@("Memo")">Memo</MudSelectItem>
                    <MudSelectItem Value="@("Letter")">Letter</MudSelectItem>
                    <MudSelectItem Value="@("Voucher")">Voucher</MudSelectItem>
                    <MudSelectItem Value="@("Report")">Report</MudSelectItem>
                    <MudSelectItem Value="@("Notice")">Notice</MudSelectItem>
                    <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="string" @bind-Value="Doc.Priority" Label="Priority Level" Variant="Variant.Outlined"
                           Required="true" RequiredError="Please select priority">
                    <MudSelectItem Value="@("Emergency")">Emergency</MudSelectItem>
                    <MudSelectItem Value="@("Urgent")">Urgent</MudSelectItem>
                    <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
                    <MudSelectItem Value="@("Low")">Low</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Doc.Description" Label="Description / Notes" Variant="Variant.Outlined"
                              Lines="3" />
            </MudItem>
            @if (!Doc.HasBeenReceived)
            {
                <MudItem xs="12" md="@(_selectedOffice != null && _units.Any() ? 8 : 12)">
                    <MudAutocomplete T="Office"
                                     Label="Route to Office"
                                     Value="_selectedOffice"
                                     ValueChanged="OnOfficeAutoChanged"
                                     SearchFunc="SearchOffices"
                                     ToStringFunc="@(o => o == null ? string.Empty : $"{o.Name}{(string.IsNullOrEmpty(o.ReceivingSchedule) ? "" : $" ({o.ReceivingSchedule})")}")"
                                     Variant="Variant.Outlined"
                                     AdornmentIcon="@Icons.Material.Filled.Business"
                                     AdornmentColor="Color.Primary"
                                     CoerceText="false"
                                     CoerceValue="false"
                                     ResetValueOnEmptyText="true"
                                     MaxItems="null" />
                </MudItem>
                @if (_selectedOffice != null && _units.Any())
                {
                    <MudItem xs="12" md="4">
                        <MudAutocomplete T="Unit"
                                         Label="Specific Unit"
                                         Value="_selectedUnit"
                                         ValueChanged="OnUnitAutoChanged"
                                         SearchFunc="SearchUnits"
                                         ToStringFunc="@(u => u?.Name ?? string.Empty)"
                                         Variant="Variant.Outlined"
                                         AdornmentIcon="@Icons.Material.Filled.Group"
                                         AdornmentColor="Color.Secondary"
                                         CoerceText="false"
                                         CoerceValue="false"
                                         ResetValueOnEmptyText="true"
                                         Placeholder="— No specific unit —"
                                         MaxItems="null" />
                    </MudItem>
                }
            }
            <MudItem xs="12">
                <MudFileUpload T="IBrowserFile" FilesChanged="OnFileSelected"
                               Accept=".pdf,.doc,.docx,.jpg,.png" DragAndDrop="true" />
                @if (!string.IsNullOrEmpty(Doc.FilePath) && selectedFile == null)
                {
                    <MudPaper Elevation="0" Class="pa-3 mt-3" Style="border-left: 4px solid var(--mud-palette-info); background: rgba(33,150,243,0.06);">
                        <div class="d-flex align-center justify-space-between">
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.AttachFile" Color="Color.Info" Class="mr-2" />
                                <div>
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@Doc.FileName</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Current attachment</MudText>
                                </div>
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Download" Color="Color.Primary"
                                           Size="Size.Small" Href="@Doc.FilePath" Target="_blank" />
                        </div>
                    </MudPaper>
                }
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudSpacer />
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Save" Disabled="@isSaving" OnClick="Submit">
            @(isSaving ? "Saving..." : "Save Changes")
        </MudButton>
        @if (CanDelete)
        {
            <MudButton Color="Color.Error" Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteDocument">Delete</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Document Doc { get; set; } = new();

    private bool CanDelete => Doc.CurrentOfficeId == null && Doc.NextOfficeId != null;
    private IBrowserFile? selectedFile;
    private bool isSaving;
    private static readonly string[] AllowedExtensions = { ".pdf", ".doc", ".docx", ".jpg", ".png" };

    private List<Office> _offices = new();
    private List<Unit> _units = new();
    private Office? _selectedOffice;
    private Unit? _selectedUnit;

    private void OnFileSelected(IBrowserFile file)
    {
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (!AllowedExtensions.Contains(ext))
        {
            Snackbar.Add($"File type '{ext}' is not allowed.", Severity.Error);
            return;
        }
        selectedFile = file;
        Doc.FileName = file.Name;
    }

    private async Task Submit()
    {
        isSaving = true;
        string? uploadedPath = null;
        try
        {
            if (selectedFile != null)
            {
                uploadedPath = await DocService.UploadFileAsync(selectedFile);
                if (uploadedPath != null) Doc.FilePath = uploadedPath;
                else Snackbar.Add("File upload failed, saving without new file.", Severity.Warning);
            }

            var (ok, error) = await DocService.UpdateDocumentAsync(Doc);
            if (!ok)
            {
                if (uploadedPath != null)
                    try { await DocService.DeleteUploadAsync(uploadedPath); } catch { }
                Snackbar.Add(error ?? "Failed to save document.", Severity.Error);
                return;
            }

            Snackbar.Add("Document updated successfully.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(Doc));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[UserEditDoc] Submit error: {ex.Message}");
            Snackbar.Add("An unexpected error occurred.", Severity.Error);
            if (uploadedPath != null)
                try { await DocService.DeleteUploadAsync(uploadedPath); } catch { }
        }
        finally { isSaving = false; }
    }

    private async Task DeleteDocument()
    {
        if (!CanDelete)
        {
            Snackbar.Add("Cannot delete a document that has already been received.", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters
    {
        { "Message", $"Delete '{Doc.Name}'? This cannot be undone." },
        { "YesText", "Delete" },
        { "CancelText", "Cancel" }
    };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Document", parameters);
        var result = await dialog.Result;
        if (result.Canceled) return;

        var (ok, error) = await DocService.DeleteDocumentAsync(Doc.Id);
        if (!ok) { Snackbar.Add(error ?? "Failed to delete document.", Severity.Error); return; }
        Snackbar.Add("Document deleted.", Severity.Success);
        MudDialog.Close(DialogResult.Ok("deleted"));
    }

    protected override async Task OnInitializedAsync()
    {
        _offices = await DocService.GetOfficesSimpleAsync();
        if (Doc.NextOfficeId.HasValue)
        {
            _selectedOffice = _offices.FirstOrDefault(o => o.Id == Doc.NextOfficeId);
            _units = await DocService.GetUnitsByOfficeAsync(Doc.NextOfficeId.Value);
            _selectedUnit = _units.FirstOrDefault(u => u.Id == Doc.NextUnitId);
        }
    }

    private Task<IEnumerable<Office>> SearchOffices(string value, CancellationToken ct)
    {
        var results = string.IsNullOrWhiteSpace(value)
            ? _offices
            : _offices.Where(o => o.Name!.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult<IEnumerable<Office>>(results);
    }

    private Task<IEnumerable<Unit>> SearchUnits(string value, CancellationToken ct)
    {
        var results = string.IsNullOrWhiteSpace(value)
            ? _units
            : _units.Where(u => u.Name!.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult<IEnumerable<Unit>>(results);
    }

    private async Task OnOfficeAutoChanged(Office? office)
    {
        _selectedOffice = office;
        _selectedUnit = null;
        Doc.NextOfficeId = office?.Id;
        Doc.NextUnitId = null;
        _units = office != null ? await DocService.GetUnitsByOfficeAsync(office.Id) : new();
    }

    private void OnUnitAutoChanged(Unit? unit)
    {
        _selectedUnit = unit;
        Doc.NextUnitId = unit?.Id;
    }

    private void Cancel() => MudDialog.Cancel();
}
