@attribute [Authorize]
@using System.Security.Claims
@using DocTracking.Client
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@inject NotificationService NotifService
@inject AuthenticationStateProvider AuthStateProvider
@inject DocumentService DocService
@inject IDialogService DialogService
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

    <div class="d-flex align-center mb-4">
        <div>
            <MudText Typo="Typo.h5" Class="font-weight-bold">@_greeting, @(_profile?.Name ?? "there")</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Here's what's happening with your documents.</MudText>
        </div>
    </div>

    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-warning);">
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Warning">@pendingCount</MudText>
                        <MudText Typo="Typo.body2">In Progress</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="Size.Large" Color="Color.Warning" />
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-success);">
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Success">@completedCount</MudText>
                        <MudText Typo="Typo.body2">Completed</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-info);">
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Info">@myDocsCount</MudText>
                        <MudText Typo="Typo.body2">Total Documents</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Info" />
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (stuckDocs.Any())
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4" Icon="@Icons.Material.Filled.Warning">
            <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">
                @stuckDocs.Count document@(stuckDocs.Count > 1 ? "s have" : " has") been idle for more than 1 day
            </MudText>
            @foreach (var doc in stuckDocs)
            {
                var idleDays = (int)(DateTime.UtcNow - (doc.LastActionDate ?? doc.CreatedAt)).TotalDays;
                <div class="d-flex align-center justify-space-between mb-1">
                    <MudText Typo="Typo.body2">@doc.Name</MudText>
                    <div class="d-flex align-center gap-2">
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                            @idleDays day@(idleDays > 1 ? "s" : "") idle
                        </MudChip>
                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Warning"
                                       OnClick="@(async () => await OpenViewDialog(doc))" />
                    </div>
                </div>
            }
        </MudAlert>
    }

    <MudGrid Class="mb-6">

        <MudItem xs="12" md="7">
            <MudPaper Elevation="2" Class="pa-4" Style="height: 100%;">
                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.ViewKanban" Class="mr-2" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">Kanban</MudText>
                </div>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="0" Class="pa-3" Style="background: rgba(var(--mud-palette-warning-rgb), 0.08); border-radius: 8px; min-height: 200px;">
                            <MudText Typo="Typo.subtitle2" Color="Color.Warning" Class="mb-3 font-weight-bold">In Progress</MudText>
                            @foreach (var doc in pendingDocs)
                            {
                                <MudPaper Elevation="1" Class="pa-3 mb-2">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold mb-1">@doc.Name</MudText>
                                    @if (doc.NextOfficeId != null)
                                    {
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Info" Class="mr-1" />
                                            <MudText Typo="Typo.caption" Color="Color.Info">@(doc.NextOffice?.Name ?? "Forwarded")</MudText>
                                        </div>
                                    }
                                    else if (doc.CurrentOffice != null)
                                    {
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Default" Class="mr-1" />
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@doc.CurrentOffice.Name</MudText>
                                        </div>
                                    }
                                    <div class="d-flex justify-space-between align-center">
                                        <MudChip T="string" Size="Size.Small" Color="@DocHelpers.GetPriorityColor(doc.Priority)" Variant="Variant.Filled">@doc.Priority</MudChip>
                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Primary"
                                                       OnClick="@(async () => await OpenViewDialog(doc))" />
                                    </div>
                                </MudPaper>
                            }
                            @if (!pendingDocs.Any())
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">No pending documents</MudText>
                            }
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="0" Class="pa-3" Style="background: rgba(var(--mud-palette-success-rgb), 0.08); border-radius: 8px; min-height: 200px;">
                            <MudText Typo="Typo.subtitle2" Color="Color.Success" Class="mb-3 font-weight-bold">Completed</MudText>
                            @foreach (var doc in completedDocs)
                            {
                                <MudPaper Elevation="1" Class="pa-3 mb-2">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold mb-1">@doc.Name</MudText>
                                    @if (doc.CurrentOffice != null)
                                    {
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Default" Class="mr-1" />
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@doc.CurrentOffice.Name</MudText>
                                        </div>
                                    }
                                    <div class="d-flex justify-space-between align-center">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Done</MudChip>
                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Primary"
                                                       OnClick="@(async () => await OpenViewDialog(doc))" />
                                    </div>
                                </MudPaper>
                            }
                            @if (!completedDocs.Any())
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">No completed documents</MudText>
                            }
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Elevation="2" Class="pa-4" Style="height: 100%;">
                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Class="mr-2" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">Recent Activity</MudText>
                </div>
                @if (!recentDocs.Any())
                {
                    <div class="text-center pa-6">
                        <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Style="opacity: 0.3;" />
                        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">No recent activity</MudText>
                    </div>
                }
                else
                {
                    <MudTimeline TimelinePosition="TimelinePosition.Start">
                        @foreach (var doc in recentDocs.Take(4))
                        {
                            <MudTimelineItem Color="@(doc.Status == "Completed" ? Color.Success : Color.Warning)" Size="Size.Small">
                                <ItemContent>
                                    <MudCard Elevation="1" Class="mb-1">
                                        <MudCardContent Class="pa-3">
                                            <div class="d-flex justify-space-between align-center">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@doc.Name</MudText>
                                                <MudChip T="string" Size="Size.Small"
                                                         Color="@(doc.Status == "Completed" ? Color.Success : Color.Warning)"
                                                         Variant="Variant.Outlined">
                                                    @doc.Status
                                                </MudChip>
                                            </div>
                                            <div class="d-flex align-center justify-space-between mt-2">
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-1" />
                                                    @(doc.CurrentOffice?.Name ?? "No location")
                                                </MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                    @doc.LastActionDate?.ToLocalTime().ToString("MMM dd, hh:mm tt")
                                                </MudText>
                                            </div>
                                        </MudCardContent>
                                    </MudCard>
                                </ItemContent>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                }
            </MudPaper>
        </MudItem>

    </MudGrid>

</MudContainer>

@code {
    private int myDocsCount, pendingCount, completedCount;
    private List<Document> recentDocs = new();
    private List<Document> pendingDocs = new();
    private List<Document> completedDocs = new();
    private List<Document> stuckDocs = new();
    private AppUser? _profile;
    private string _greeting = "Hello";
    private string _userEmail = "";
    private readonly DebounceHelper _debounce = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var hour = DateTime.Now.Hour;
            _greeting = hour < 12 ? "Good morning" : hour < 17 ? "Good afternoon" : "Good evening";

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _userEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value ?? authState.User.Identity?.Name ?? "";

            _profile = await DocService.GetProfileAsync();

            if (!string.IsNullOrEmpty(_userEmail))
            {
                var result = await DocService.GetUserDocumentsAsync(_userEmail, page: 1, pageSize: 100);
                var allDocs = result.Items;
                if (allDocs != null)
                {
                    myDocsCount = result.TotalCount;
                    pendingCount = allDocs.Count(d => d.Status != "Completed");
                    completedCount = allDocs.Count(d => d.Status == "Completed");
                    pendingDocs = allDocs.Where(d => d.Status != "Completed").Take(5).ToList();
                    completedDocs = allDocs.Where(d => d.Status == "Completed").Take(5).ToList();
                    recentDocs = allDocs.OrderByDescending(d => d.LastActionDate).Take(5).ToList();
                    stuckDocs = allDocs
                        .Where(d => d.Status != "Completed" &&
                               (DateTime.UtcNow - (d.LastActionDate ?? d.CreatedAt)).TotalDays >= 1)
                        .OrderByDescending(d => d.LastActionDate ?? d.CreatedAt)
                        .ToList();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            NotifService.OnChange += OnNotificationReceived;
        return Task.CompletedTask;
    }

    private async Task OpenViewDialog(Document doc)
    {
        var parameters = new DialogParameters<DocumentViewDialog>
        {
            { x => x.Doc, doc }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<DocumentViewDialog>("Document Details", parameters, options);
    }

    private void OnNotificationReceived() =>
        _debounce.Trigger(async () =>
        {
            if (!string.IsNullOrEmpty(_userEmail))
            {
                var result = await DocService.GetUserDocumentsAsync(_userEmail, page: 1, pageSize: 100);
                var allDocs = result.Items;
                myDocsCount = result.TotalCount;
                pendingCount = allDocs.Count(d => d.Status != "Completed");
                completedCount = allDocs.Count(d => d.Status == "Completed");
                pendingDocs = allDocs.Where(d => d.Status != "Completed").Take(5).ToList();
                completedDocs = allDocs.Where(d => d.Status == "Completed").Take(5).ToList();
                recentDocs = allDocs.OrderByDescending(d => d.LastActionDate).Take(5).ToList();
                stuckDocs = allDocs
                    .Where(d => d.Status != "Completed" &&
                           (DateTime.UtcNow - (d.LastActionDate ?? d.CreatedAt)).TotalDays >= 1)
                    .OrderByDescending(d => d.LastActionDate ?? d.CreatedAt)
                    .ToList();
            }
            await InvokeAsync(StateHasChanged);
        });

    public void Dispose()
    {
        NotifService.OnChange -= OnNotificationReceived;
        _debounce.Dispose();
    }
}
