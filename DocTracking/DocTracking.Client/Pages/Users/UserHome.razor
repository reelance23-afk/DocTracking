@attribute [Authorize]
@using DocTracking.Client
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@inject NotificationService NotifService
@inject DocumentService DocService
@inject IDialogService DialogService
@implements IDisposable
@rendermode @(new InteractiveAutoRenderMode(prerender: false))

<style>
    .fade-slide-up {
        animation: fadeSlideUp 0.5s ease-out both;
    }

    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    @if (isLoading)
    {
        <div class="d-flex align-center mb-6">
            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" Class="mr-3" />
            <div>
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="180px" Height="32px" Class="mb-1" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="280px" />
            </div>
        </div>

        <MudGrid Class="mb-6">
            @for (int i = 0; i < 3; i++)
            {
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="2" Class="pa-4">
                        <div class="d-flex justify-space-between align-center">
                            <div style="flex: 1;">
                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="60px" Height="48px" Class="mb-1" />
                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="120px" />
                            </div>
                            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

        <MudGrid Class="mb-6">
            <MudItem xs="12" md="7">
                <MudPaper Elevation="2" Class="pa-4" Style="min-height: 500px;">
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="160px" />
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" />
                    </div>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" Class="mb-3" />
                            @for (int i = 0; i < 4; i++)
                            {
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="64px" Class="mb-2" />
                            }
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="100px" Class="mb-3" />
                            @for (int i = 0; i < 4; i++)
                            {
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="64px" Class="mb-2" />
                            }
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="5">
                <MudPaper Elevation="2" Class="pa-4" Style="min-height: 500px;">
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="140px" Class="mb-4" />
                    @for (int i = 0; i < 5; i++)
                    {
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="72px" Class="mb-3" />
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    else
    {
        <div class="d-flex align-center mb-6 fade-slide-up">
            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
            <div>
                <MudText Typo="Typo.h4" Class="font-weight-bold">@_greeting, @(_profile?.Name ?? "there")</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Here's what's happening with your documents.</MudText>
            </div>
        </div>

        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="4" Style="animation: fadeSlideUp 0.5s ease-out 0.1s both;">
                <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-warning);">
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Warning">@pendingCount</MudText>
                            <MudText Typo="Typo.body2">In Progress</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="Size.Large" Color="Color.Warning" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4" Style="animation: fadeSlideUp 0.5s ease-out 0.2s both;">
                <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-success);">
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Success">@completedCount</MudText>
                            <MudText Typo="Typo.body2">Completed</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4" Style="animation: fadeSlideUp 0.5s ease-out 0.3s both;">
                <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-info);">
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Info">@myDocsCount</MudText>
                            <MudText Typo="Typo.body2">Total Documents</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Info" />
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @if (stuckDocs.Any())
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4" Icon="@Icons.Material.Filled.Warning" Dense="true"
                      Style="animation: fadeSlideUp 0.5s ease-out 0.4s both;">
                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">
                    @stuckDocs.Count document@(stuckDocs.Count > 1 ? "s have" : " has") been idle for more than 1 day
                </MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @string.Join(", ", stuckDocs.Select(d => d.Name))
                </MudText>
            </MudAlert>
        }

        <MudGrid Class="mb-6" Style="align-items: stretch; animation: fadeSlideUp 0.5s ease-out 0.5s both;">
            <MudItem xs="12" md="7" Style="display: flex; flex-direction: column;">
                <MudPaper Elevation="2" Class="pa-4 flex-grow-1" Style="display: flex; flex-direction: column;">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.ViewKanban" Class="mr-2" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Kanban</MudText>
                    </div>

                    <MudHidden Breakpoint="Breakpoint.SmAndDown">
                        <div class="d-flex gap-4 flex-grow-1" style="min-height: 0;">
                            <div style="flex: 1; background: rgba(var(--mud-palette-warning-rgb), 0.08); border-radius: 8px; padding: 12px; max-height: 400px; overflow-y: auto;">
                                <MudText Typo="Typo.subtitle2" Color="Color.Warning" Class="mb-3 font-weight-bold">In Progress</MudText>
                                @foreach (var doc in pendingDocs)
                                {
                                    <MudPaper Elevation="1" Class="pa-3 mb-2">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold mb-1">@doc.Name</MudText>
                                        @if (doc.NextOfficeId != null)
                                        {
                                            <div class="d-flex align-center mb-1">
                                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Info" Class="mr-1" />
                                                <MudText Typo="Typo.caption" Color="Color.Info">@(doc.NextOffice?.Name ?? "Forwarded")</MudText>
                                            </div>
                                        }
                                        else if (doc.CurrentOffice != null)
                                        {
                                            <div class="d-flex align-center mb-1">
                                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Default" Class="mr-1" />
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@doc.CurrentOffice.Name</MudText>
                                            </div>
                                        }
                                        <div class="d-flex justify-space-between align-center">
                                            <MudChip T="string" Size="Size.Small" Color="@DocHelpers.GetPriorityColor(doc.Priority)" Variant="Variant.Filled">@doc.Priority</MudChip>
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Primary"
                                                           OnClick="@(async () => await OpenViewDialog(doc))" />
                                        </div>
                                    </MudPaper>
                                }
                                @if (!pendingDocs.Any())
                                {
                                    <div class="d-flex flex-column align-center pa-4">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Size="Size.Large" Color="Color.Success" Style="opacity:0.5;" />
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">No pending documents</MudText>
                                    </div>
                                }
                            </div>
                            <div style="flex: 1; background: rgba(var(--mud-palette-success-rgb), 0.08); border-radius: 8px; padding: 12px; max-height: 400px; overflow-y: auto;">
                                <MudText Typo="Typo.subtitle2" Color="Color.Success" Class="mb-3 font-weight-bold">Completed</MudText>
                                @foreach (var doc in completedDocs)
                                {
                                    <MudPaper Elevation="1" Class="pa-3 mb-2">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold mb-1">@doc.Name</MudText>
                                        @if (doc.CurrentOffice != null)
                                        {
                                            <div class="d-flex align-center mb-1">
                                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Default" Class="mr-1" />
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@doc.CurrentOffice.Name</MudText>
                                            </div>
                                        }
                                        <div class="d-flex justify-space-between align-center">
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Done</MudChip>
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Primary"
                                                           OnClick="@(async () => await OpenViewDialog(doc))" />
                                        </div>
                                    </MudPaper>
                                }
                                @if (!completedDocs.Any())
                                {
                                    <div class="d-flex flex-column align-center pa-4">
                                        <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Default" Style="opacity:0.3;" />
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">No completed documents</MudText>
                                    </div>
                                }
                            </div>
                        </div>
                    </MudHidden>

                    <MudHidden Breakpoint="Breakpoint.MdAndUp">
                        <MudTabs Elevation="0" Rounded="true" Color="Color.Primary">
                            <MudTabPanel Text="In Progress">
                                <div style="background: rgba(var(--mud-palette-warning-rgb), 0.08); border-radius: 8px; padding: 12px; margin-top: 8px;">
                                    @foreach (var doc in pendingDocs)
                                    {
                                        <MudPaper Elevation="1" Class="pa-3 mb-2">
                                            <MudText Typo="Typo.body2" Class="font-weight-bold mb-1">@doc.Name</MudText>
                                            @if (doc.NextOfficeId != null)
                                            {
                                                <div class="d-flex align-center mb-1">
                                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Info" Class="mr-1" />
                                                    <MudText Typo="Typo.caption" Color="Color.Info">@(doc.NextOffice?.Name ?? "Forwarded")</MudText>
                                                </div>
                                            }
                                            else if (doc.CurrentOffice != null)
                                            {
                                                <div class="d-flex align-center mb-1">
                                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Default" Class="mr-1" />
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@doc.CurrentOffice.Name</MudText>
                                                </div>
                                            }
                                            <div class="d-flex justify-space-between align-center">
                                                <MudChip T="string" Size="Size.Small" Color="@DocHelpers.GetPriorityColor(doc.Priority)" Variant="Variant.Filled">@doc.Priority</MudChip>
                                                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(async () => await OpenViewDialog(doc))" />
                                            </div>
                                        </MudPaper>
                                    }
                                    @if (!pendingDocs.Any())
                                    {
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">No pending documents</MudText>
                                    }
                                </div>
                            </MudTabPanel>
                            <MudTabPanel Text="Completed">
                                <div style="background: rgba(var(--mud-palette-success-rgb), 0.08); border-radius: 8px; padding: 12px; margin-top: 8px;">
                                    @foreach (var doc in completedDocs)
                                    {
                                        <MudPaper Elevation="1" Class="pa-3 mb-2">
                                            <MudText Typo="Typo.body2" Class="font-weight-bold mb-1">@doc.Name</MudText>
                                            @if (doc.CurrentOffice != null)
                                            {
                                                <div class="d-flex align-center mb-1">
                                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Default" Class="mr-1" />
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@doc.CurrentOffice.Name</MudText>
                                                </div>
                                            }
                                            <div class="d-flex justify-space-between align-center">
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Done</MudChip>
                                                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(async () => await OpenViewDialog(doc))" />
                                            </div>
                                        </MudPaper>
                                    }
                                    @if (!completedDocs.Any())
                                    {
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">No completed documents</MudText>
                                    }
                                </div>
                            </MudTabPanel>
                        </MudTabs>
                    </MudHidden>

                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="5" Style="display: flex; flex-direction: column;">
                <MudPaper Elevation="2" Class="pa-4 flex-grow-1" Style="display: flex; flex-direction: column;">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Timeline" Class="mr-2" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Recent Activity</MudText>
                    </div>
                    <div style="flex-grow: 1; overflow-y: auto;">
                        @if (!recentDocs.Any())
                        {
                            <div class="d-flex flex-column align-center pa-6">
                                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Style="opacity: 0.3; font-size: 4rem;" />
                                <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">No recent activity</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Documents will appear here once created</MudText>
                            </div>
                        }
                        else
                        {
                            <MudTimeline TimelinePosition="TimelinePosition.Start">
                                @foreach (var doc in recentDocs.Take(4))
                                {
                                    <MudTimelineItem Color="@(doc.Status == "Completed" ? Color.Success : Color.Warning)"
                                                     Size="Size.Small" TimelineAlign="TimelineAlign.Default">
                                        <ItemContent>
                                            <MudCard Elevation="1" Class="mb-1" Style="min-width:0;">
                                                <MudCardContent Class="pa-3">
                                                    <MudText Typo="Typo.body2" Class="font-weight-bold text-truncate">@doc.Name</MudText>
                                                    <div class="d-flex align-center justify-space-between mt-1 flex-wrap gap-1">
                                                        <MudChip T="string" Size="Size.Small"
                                                                 Color="@(doc.Status == "Completed" ? Color.Success : Color.Warning)"
                                                                 Variant="Variant.Outlined">
                                                            @doc.Status
                                                        </MudChip>
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                            @doc.LastActionDate?.ToLocalTime().ToString("MMM dd, hh:mm tt")
                                                        </MudText>
                                                    </div>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-1" />
                                                        @(doc.CurrentOffice?.Name ?? "No location")
                                                    </MudText>
                                                </MudCardContent>
                                            </MudCard>
                                        </ItemContent>
                                    </MudTimelineItem>
                                }
                            </MudTimeline>
                        }
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

</MudContainer>

@code {
    private int myDocsCount, pendingCount, completedCount;
    private List<Document> recentDocs = new();
    private List<Document> pendingDocs = new();
    private List<Document> completedDocs = new();
    private List<Document> stuckDocs = new();
    private AppUser? _profile;
    private string _greeting = "Hello";
    private string _userEmail = "";
    private bool isLoading = true;
    private readonly DebounceHelper _debounce = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var hour = DateTime.Now.Hour;
            _greeting = hour < 12 ? "Good morning" : hour < 17 ? "Good afternoon" : "Good evening";
            _profile = await DocService.GetProfileAsync();
            _userEmail = _profile?.Email ?? "";

            if (!string.IsNullOrEmpty(_userEmail))
                await LoadData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally { isLoading = false; }
    }

    private async Task LoadData()
    {
        var data = await DocService.GetUserHomeDataAsync(_userEmail);
        myDocsCount = data.TotalDocumentsCount;
        pendingCount = data.TotalInProgressCount;
        completedCount = data.TotalCompletedCount;
        pendingDocs = data.InProgressDoc;
        completedDocs = data.CompletedDoc;
        recentDocs = data.RecentDocuments;
        stuckDocs = data.StuckDocuments;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            NotifService.OnChange += OnNotificationReceived;
        return Task.CompletedTask;
    }

    private async Task OpenViewDialog(Document doc)
    {
        var parameters = new DialogParameters<DocumentViewDialog> { { x => x.Doc, doc } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<DocumentViewDialog>("Document Details", parameters, options);
    }

    private void OnNotificationReceived() =>
        _debounce.Trigger(async () =>
        {
            if (!string.IsNullOrEmpty(_userEmail))
                await LoadData();
            await InvokeAsync(StateHasChanged);
        });

    public void Dispose()
    {
        NotifService.OnChange -= OnNotificationReceived;
        _debounce.Dispose();
    }
}
