@page "/create-document"
@attribute [Authorize]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Forms
@inject DocumentService DocService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@rendermode InteractiveAuto

<style>
    .fade-slide-up {
        animation: fadeSlideUp 0.5s ease-out both;
    }

    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>


<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <div class="d-flex align-center mb-6 fade-slide-up">
        <MudIcon Icon="@Icons.Material.Filled.NoteAdd" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold">Create New Document</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Fill in the details below to submit and route a new document through the system</MudText>
        </div>
    </div>

    @if (isLoadingOffices)
    {
        <div class="text-center pa-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Class="mt-4">Loading form...</MudText>
        </div>
    }
    else
    {
        <MudForm @bind-IsValid="success">
            <MudGrid Spacing="3">

                <MudItem xs="12" Style="animation: fadeSlideUp 0.5s ease-out 0.1s both;">
                    <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-primary);">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Document Information</MudText>
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="newDocument.Name"
                                              Label="Document Title"
                                              Variant="Variant.Outlined"
                                              Required="true"
                                              RequiredError="Document title is required" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" @bind-Value="newDocument.Type"
                                           Label="Document Type"
                                           Variant="Variant.Outlined"
                                           Required="true"
                                           RequiredError="Please select a document type">
                                    <MudSelectItem Value="@("Memo")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Class="mr-2" Color="Color.Info" />Memo
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Letter")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Mail" Size="Size.Small" Class="mr-2" Color="Color.Info" />Letter
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Voucher")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Class="mr-2" Color="Color.Info" />Voucher
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Report")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Small" Class="mr-2" Color="Color.Info" />Report
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Notice")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Announcement" Size="Size.Small" Class="mr-2" Color="Color.Info" />Notice
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Other")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Size="Size.Small" Class="mr-2" Color="Color.Info" />Other
                                        </div>
                                    </MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" @bind-Value="newDocument.Priority"
                                           Label="Priority Level"
                                           Variant="Variant.Outlined"
                                           Required="true"
                                           RequiredError="Please select priority">
                                    <MudSelectItem Value="@("Emergency")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.PriorityHigh" Size="Size.Small" Class="mr-2" Color="Color.Error" />Emergency
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Urgent")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-2" Color="Color.Warning" />Urgent
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Medium")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-2" Color="Color.Info" />Medium
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Low")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.LowPriority" Size="Size.Small" Class="mr-2" Color="Color.Success" />Low
                                        </div>
                                    </MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="newDocument.Description"
                                              Label="Description / Notes"
                                              Variant="Variant.Outlined"
                                              Lines="3"
                                              HelperText="Optional: Add any additional details" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" Style="animation: fadeSlideUp 0.5s ease-out 0.2s both;">
                    <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-info);">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Routing</MudText>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="@(newDocument.NextOfficeId.HasValue && GetUnitsForOffice(newDocument.NextOfficeId.Value).Any() ? 8 : 12)">
                                <MudSelect T="int?" Value="newDocument.NextOfficeId" ValueChanged="OnOfficeChanged"
                                           Label="Route to Office"
                                           Variant="Variant.Outlined"
                                           Required="true"
                                           RequiredError="Destination office required">
                                    @foreach (var off in RoutableOffices)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)off.Id)">
                                            <div class="d-flex align-center">
                                                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Class="mr-2" Color="Color.Primary" />
                                                @off.Name @off.ReceivingSchedule
                                            </div>
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            @if (newDocument.NextOfficeId.HasValue && GetUnitsForOffice(newDocument.NextOfficeId.Value).Any())
                            {
                                <MudItem xs="12" md="4">
                                    <MudSelect T="int?" @bind-Value="newDocument.NextUnitId"
                                               Label="Specific Unit"
                                               Variant="Variant.Outlined"
                                               ToStringFunc="@(id => GetUnitsForOffice(newDocument.NextOfficeId!.Value).FirstOrDefault(u => u.Id == id)?.Name ?? string.Empty)">
                                        <MudSelectItem T="int?" Value="@((int?)null)">— No specific unit —</MudSelectItem>
                                        @foreach (var unit in GetUnitsForOffice(newDocument.NextOfficeId.Value))
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)unit.Id)">
                                                <div class="d-flex align-center">
                                                    <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                                    @unit.Name
                                                </div>
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" Style="animation: fadeSlideUp 0.5s ease-out 0.3s both;">
                    <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-success);">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Attachment</MudText>
                        <MudFileUpload T="IBrowserFile" FilesChanged="OnFileSelected"
                                       Accept=".pdf,.doc,.docx,.jpg,.png" DragAndDrop="true" />
                    </MudPaper>
                </MudItem>
                <MudItem xs="12">
                    <div class="d-flex gap-3 justify-end">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Size="Size.Large"
                                   OnClick="@(() => Navigation.NavigateTo("/"))"
                                   StartIcon="@Icons.Material.Filled.Cancel">
                            Cancel
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   Disabled="@(!success || isSaving || selectedFile == null)"
                                   OnClick="SubmitDocument"
                                   StartIcon="@(isSaving ? Icons.Material.Filled.Sync : Icons.Material.Filled.Send)">
                            @(isSaving ? "Submitting..." : "Submit Document")
                        </MudButton>
                    </div>
                </MudItem>

            </MudGrid>
        </MudForm>
    }
</MudContainer>

@code {
    private Document newDocument = new();
    private List<Office> offices = new();
    private List<Unit> _selectedOfficeUnits = new();
    private bool success = true;
    private bool isSaving;
    private bool isLoadingOffices = true;
    private IBrowserFile? selectedFile;
    private bool isOfficeRole;
    private int? myOfficeId;
    private int? myUnitId;
    private static readonly string[] AllowedExtensions = { ".pdf", ".doc", ".docx", ".jpg", ".png" };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isOfficeRole = authState.User.IsInRole("Office");

        try
        {
            offices = await DocService.GetOfficesSimpleAsync();

            if (isOfficeRole)
            {
                var profile = await DocService.GetProfileAsync();
                myOfficeId = profile?.OfficeId ?? profile?.Unit?.OfficeId;
                myUnitId = profile?.UnitId;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            Snackbar.Add("Failed to load routing options.", Severity.Error);
        }
        finally { isLoadingOffices = false; }
    }

    private IEnumerable<Office> RoutableOffices => isOfficeRole
        ? offices.Where(o => o.Id != myOfficeId)
        : offices;

    private void OnFileSelected(IBrowserFile file)
    {
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (!AllowedExtensions.Contains(ext))
        {
            Snackbar.Add($"File type '{ext}' is not allowed. Use PDF, DOC, DOCX, JPG, or PNG.", Severity.Error);
            return;
        }
        selectedFile = file;
        newDocument.FileName = file.Name;
    }

    private async Task OnOfficeChanged(int? officeId)
    {
        newDocument.NextOfficeId = officeId;
        newDocument.NextUnitId = null;
        _selectedOfficeUnits = officeId.HasValue
            ? await DocService.GetUnitsByOfficeAsync(officeId.Value)
            : new();
    }

    private IEnumerable<Unit> GetUnitsForOffice(int officeId) => _selectedOfficeUnits;

    public async Task SubmitDocument()
    {
        var parameters = new DialogParameters
    {
        { "Message", "Submit and route this document? This cannot be edited after submission." },
        { "YesText", "Submit" },
        { "CancelText", "Cancel" }
    };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Confirm Submit", parameters);
        var result = await dialog.Result;
        if (result.Canceled) return;

        isSaving = true;
        string? uploadedPath = null;
        try
        {
            if (selectedFile != null)
            {
                Snackbar.Add("Uploading file...", Severity.Info);
                uploadedPath = await DocService.UploadFileAsync(selectedFile);
                if (uploadedPath != null) newDocument.FilePath = uploadedPath;
                else Snackbar.Add("File upload failed, saving anyway.", Severity.Warning);
            }

            var (success, error) = await DocService.CreateDocumentAsync(newDocument);
            if (success)
            {
                Snackbar.Add("Document created & routed successfully!", Severity.Success);
                Navigation.NavigateTo(isOfficeRole ? "/office-desk" : "/my-tracking");
            }
            else
            {
                if (uploadedPath != null)
                {
                    try { await DocService.DeleteUploadAsync(uploadedPath); }
                    catch (Exception ex) { Console.WriteLine($"[CreateDoc] File cleanup failed: {ex.Message}"); }
                }
                Snackbar.Add(error ?? "Error saving document.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Save Error: {ex.Message}");
            if (uploadedPath != null)
            {
                try { await DocService.DeleteUploadAsync(uploadedPath); }
                catch (Exception cleanupEx) { Console.WriteLine($"[CreateDoc] File cleanup failed: {cleanupEx.Message}"); }
            }
            Snackbar.Add("Error saving document. Please try again.", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }


    private void RemoveFile()
    {
        selectedFile = null;
        newDocument.FileName = string.Empty;
    }
}
