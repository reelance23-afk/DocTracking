@page "/create-document"
@attribute [Authorize]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims;
@inject DocumentService DocService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@rendermode InteractiveAuto

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">

    <MudPaper Elevation="4" Class="pa-8 rounded-lg border-t-4 border-solid mud-border-primary">
        <MudText Typo="Typo.h5" Class="mb-6 font-weight-bold">Create New Document</MudText>

        @if (isLoadingOffices)
        {
            <div class="d-flex flex-column align-center my-4">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mb-2" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Loading routing options...</MudText>
            </div>
        }
        else
        {
            <MudForm @bind-IsValid="success">
                <MudGrid>

                    <MudItem xs="12">
                        <MudTextField @bind-Value="newDocument.Name"
                                      Label="Document Title / Subject"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="Document title is required" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudSelect T="string" @bind-Value="newDocument.Type" Label="Document Type" Variant="Variant.Outlined" Required="true" RequiredError="Please select a document type">
                            <MudSelectItem Value="@("Memo")">Memo</MudSelectItem>
                            <MudSelectItem Value="@("Letter")">Letter</MudSelectItem>
                            <MudSelectItem Value="@("Voucher")">Voucher</MudSelectItem>
                            <MudSelectItem Value="@("Report")">Report</MudSelectItem>
                            <MudSelectItem Value="@("Notice")">Notice</MudSelectItem>
                            <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12">
                        <MudSelect T="int?" Value="newDocument.NextOfficeId" ValueChanged="OnOfficeChanged"
                                   Label="Route to Office..." Variant="Variant.Outlined" Required="true" RequiredError="Destination Office Required">
                            @foreach (var office in offices)
                            {
                                <MudSelectItem T="int?" Value="@((int?)office.Id)">@office.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @if (newDocument.NextOfficeId.HasValue)
                    {
                        <MudItem xs="12">
                            <MudSelect @bind-Value="newDocument.NextUnitId" Label="Route to Specific Unit (Optional)" Variant="Variant.Outlined">
                                @foreach (var unit in GetUnitsForOffice(newDocument.NextOfficeId.Value))
                                {
                                    <MudSelectItem T="int?" Value="@((int?)unit.Id)">@unit.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    }

                    <MudItem xs="12" Class="d-flex justify-end mt-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Disabled="@(!success || isSaving)" OnClick="SubmitDocument">
                            @(isSaving ? "Routing..." : "Submit & Route Document")
                        </MudButton>
                    </MudItem>

                </MudGrid>
            </MudForm>
        }
    </MudPaper>

</MudContainer>

@code {
    private Document newDocument = new();
    private List<Office> offices = new();
    private bool success;
    private bool isSaving = false;
    private bool isLoadingOffices = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                offices = await DocService.GetOfficesAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading offices: {ex.Message}");
                Snackbar.Add("Failed to load routing options.", Severity.Error);
            }
            finally
            {
                isLoadingOffices = false;
                StateHasChanged();
            }
        }
    }

    private void OnOfficeChanged(int? officeId)
    {
        newDocument.NextOfficeId = officeId;
        newDocument.NextUnitId = null;
    }

    private IEnumerable<Unit> GetUnitsForOffice(int officeId)
    {
        return offices.FirstOrDefault(d => d.Id == officeId)?.Units ?? new List<Unit>();
    }

    public async Task SubmitDocument()
    {
        isSaving = true;
        try
        {
                await DocService.CreateDocumentAsync(newDocument);

                Snackbar.Add("Document Created & Routed Successfully!", Severity.Success);

                Navigation.NavigateTo("/my-tracking");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Save Error: {ex.Message}");
            Snackbar.Add("Error Saving Document. Please try again.", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }
}