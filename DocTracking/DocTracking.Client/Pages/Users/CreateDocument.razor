@page "/create-document"
@attribute [Authorize]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Forms
@inject DocumentService DocService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@rendermode InteractiveAuto

<style>
    .fade-slide-up {
        animation: fadeSlideUp 0.5s ease-out both;
    }

    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>


<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <div class="d-flex align-center justify-space-between mb-6 fade-slide-up flex-wrap gap-2">
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.NoteAdd" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
            <div>
                <MudText Typo="Typo.h4" Class="font-weight-bold">Create New Document</MudText>
            </div>
        </div>
        <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Filled.Info" Style="width: fit-content; margin: 0;">
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Fill in all required fields and attach a file. Once submitted, the document cannot be edited after it has been received.
            </MudText>
        </MudAlert>
    </div>

    @if (isLoadingOffices)
    {
        <MudGrid Spacing="3">
            <MudItem xs="12" Style="animation: fadeSlideUp 0.5s ease-out 0.1s both;">
                <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-primary);">
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="180px" Class="mb-4" />
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="56px" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="56px" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="56px" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="96px" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" Style="animation: fadeSlideUp 0.5s ease-out 0.2s both;">
                <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-info);">
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" Class="mb-4" />
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="56px" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" Style="animation: fadeSlideUp 0.5s ease-out 0.3s both;">
                <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-success);">
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="100px" Class="mb-4" />
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="80px" />
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <div class="d-flex gap-3 justify-end">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100px" Height="42px" />
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="160px" Height="42px" />
                </div>
            </MudItem>
        </MudGrid>
    }
    else
    {
        <MudForm @bind-IsValid="success">
            <MudGrid Spacing="3">

                <MudItem xs="12" Style="animation: fadeSlideUp 0.5s ease-out 0.1s both;">
                    <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-primary);">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Document Information</MudText>
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="newDocument.Name"
                                              Label="Document Title"
                                              Variant="Variant.Outlined"
                                              Required="true"
                                              RequiredError="Document title is required" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" @bind-Value="newDocument.Type"
                                           Label="Document Type"
                                           Variant="Variant.Outlined"
                                           Required="true"
                                           RequiredError="Please select a document type">
                                    <MudSelectItem Value="@("Memo")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Class="mr-2" Color="Color.Info" />Memo
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Letter")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Mail" Size="Size.Small" Class="mr-2" Color="Color.Info" />Letter
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Voucher")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Class="mr-2" Color="Color.Info" />Voucher
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Report")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Small" Class="mr-2" Color="Color.Info" />Report
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Notice")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Announcement" Size="Size.Small" Class="mr-2" Color="Color.Info" />Notice
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Other")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Size="Size.Small" Class="mr-2" Color="Color.Info" />Other
                                        </div>
                                    </MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" @bind-Value="newDocument.Priority"
                                           Label="Priority Level"
                                           Variant="Variant.Outlined"
                                           Required="true"
                                           RequiredError="Please select priority">
                                    <MudSelectItem Value="@("Emergency")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.PriorityHigh" Size="Size.Small" Class="mr-2" Color="Color.Error" />Emergency
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Urgent")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-2" Color="Color.Warning" />Urgent
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Medium")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-2" Color="Color.Info" />Medium
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Low")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.LowPriority" Size="Size.Small" Class="mr-2" Color="Color.Success" />Low
                                        </div>
                                    </MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="newDocument.Description"
                                              Label="Description / Notes"
                                              Variant="Variant.Outlined"
                                              Lines="3"
                                              HelperText="Optional: Add any additional details" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" Style="animation: fadeSlideUp 0.5s ease-out 0.2s both;">
                    <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-info);">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Routing</MudText>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="@(newDocument.NextOfficeId.HasValue && GetUnitsForOffice(newDocument.NextOfficeId.Value).Any() ? 8 : 12)">
                                <MudAutocomplete T="Office"
                                                 Label="Route to Office"
                                                 Value="_selectedOffice"
                                                 ValueChanged="OnOfficeAutoChanged"
                                                 SearchFunc="SearchOffices"
                                                 ToStringFunc="@(o => o == null ? string.Empty : $"{o.Name}{(string.IsNullOrEmpty(o.ReceivingSchedule) ? "" : $" ({o.ReceivingSchedule})")}")"
                                                 Variant="Variant.Outlined"
                                                 Required="true"
                                                 RequiredError="Destination office required"
                                                 AdornmentIcon="@Icons.Material.Filled.Business"
                                                 AdornmentColor="Color.Primary"
                                                 CoerceText="false"
                                                 CoerceValue="false"
                                                 ResetValueOnEmptyText="true"
                                                 MaxItems="null" />
                            </MudItem>
                            @if (newDocument.NextOfficeId.HasValue && GetUnitsForOffice(newDocument.NextOfficeId.Value).Any())
                            {
                                <MudItem xs="12" md="4">
                                    <MudAutocomplete T="Unit"
                                                     Label="Specific Unit"
                                                     Value="_selectedUnit"
                                                     ValueChanged="OnUnitAutoChanged"
                                                     SearchFunc="SearchUnits"
                                                     ToStringFunc="@(u => u?.Name ?? string.Empty)"
                                                     Variant="Variant.Outlined"
                                                     AdornmentIcon="@Icons.Material.Filled.Group"
                                                     AdornmentColor="Color.Secondary"
                                                     CoerceText="false"
                                                     CoerceValue="false"
                                                     ResetValueOnEmptyText="true"
                                                     Placeholder="— No specific unit —"
                                                     MaxItems="null" />
                                </MudItem>
                            }
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" Style="animation: fadeSlideUp 0.5s ease-out 0.3s both;">
                    <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-success);">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Attachment</MudText>
                            <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="OnFilesSelected"
                                           Accept=".pdf,.doc,.docx,.jpg,.png" DragAndDrop="true" Multiple="true">
                                <ActivatorContent>
                                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AttachFile">
                                        Select Files
                                    </MudButton>
                                </ActivatorContent>
                            </MudFileUpload>

                    </MudPaper>
                </MudItem>
                <MudItem xs="12">
                    <div class="d-flex gap-3 justify-end">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Size="Size.Large"
                                   OnClick="@(() => Navigation.NavigateTo("/"))"
                                   StartIcon="@Icons.Material.Filled.Cancel">
                            Cancel
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   Disabled="@(!success || isSaving)"
                                   OnClick="SubmitDocument"
                                   StartIcon="@(isSaving ? Icons.Material.Filled.Sync : Icons.Material.Filled.Send)">
                            @(isSaving ? "Submitting..." : "Submit Document")
                        </MudButton>
                    </div>
                </MudItem>

            </MudGrid>
        </MudForm>
    }
</MudContainer>

@code {
    private Document newDocument = new();
    private List<Office> offices = new();
    private List<Unit> _selectedOfficeUnits = new();
    private bool success = true;
    private bool isSaving;
    private bool isLoadingOffices = true;
    private List<IBrowserFile> selectedFiles = new();
    private bool isOfficeRole;
    private int? myOfficeId;
    private int? myUnitId;
    private Office? _selectedOffice;
    private Unit? _selectedUnit;
    private static readonly string[] AllowedExtensions = { ".pdf", ".doc", ".docx", ".jpg", ".png" };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isOfficeRole = authState.User.IsInRole("Office");

        try
        {
            offices = await DocService.GetOfficesSimpleAsync();

            if (isOfficeRole)
            {
                var profile = await DocService.GetProfileAsync();
                myOfficeId = profile?.OfficeId ?? profile?.Unit?.OfficeId;
                myUnitId = profile?.UnitId;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            Snackbar.Add("Failed to load routing options.", Severity.Error);
        }
        finally { isLoadingOffices = false; }
    }

    private IEnumerable<Office> RoutableOffices => isOfficeRole
        ? offices.Where(o => o.Id != myOfficeId)
        : offices;

    private void OnFilesSelected(IReadOnlyList<IBrowserFile> files)
    {
        if (files == null) return;
        foreach (var file in files)
        {
            var ext = Path.GetExtension(file.Name).ToLowerInvariant();
            if (!AllowedExtensions.Contains(ext))
            {
                Snackbar.Add($"'{file.Name}' is not allowed. Use PDF, DOC, DOCX, JPG, or PNG.", Severity.Error);
                continue;
            }
            if (!selectedFiles.Any(f => f.Name == file.Name))
                selectedFiles.Add(file);
        }
    }

    private async Task OnOfficeChanged(int? officeId)
    {
        newDocument.NextOfficeId = officeId;
        newDocument.NextUnitId = null;
        _selectedOfficeUnits = officeId.HasValue
            ? await DocService.GetUnitsByOfficeAsync(officeId.Value)
            : new();
    }

    private IEnumerable<Unit> GetUnitsForOffice(int officeId) => _selectedOfficeUnits;

    public async Task SubmitDocument()
    {
        var parameters = new DialogParameters
    {
        { "Message", "Submit and route this document? This cannot be edited after submission." },
        { "YesText", "Submit" },
        { "CancelText", "Cancel" }
    };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Confirm Submit", parameters);
        var result = await dialog.Result;
        if (result.Canceled) return;

        isSaving = true;
        try
        {
            var (success, error, createdDoc) = await DocService.CreateDocumentAsync(newDocument);
            if (success)
            {
                if (createdDoc != null && selectedFiles.Any())
                {
                    Snackbar.Add("Uploading files...", Severity.Info);
                    foreach (var file in selectedFiles)
                    {
                        var path = await DocService.UploadFileAsync(file);
                        if (path != null)
                            await DocService.AddAttachmentAsync(createdDoc.Id, file.Name, path);
                        else
                            Snackbar.Add($"Failed to upload '{file.Name}'.", Severity.Warning);
                    }
                }
                Snackbar.Add("Document created & routed successfully!", Severity.Success);
                Navigation.NavigateTo(isOfficeRole ? "/office-desk" : "/my-tracking");
            }
            else
            {
                Snackbar.Add(error ?? "Error saving document.", Severity.Error);
            }

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Save Error: {ex.Message}");
            Snackbar.Add("Error saving document. Please try again.", Severity.Error);
        }
        finally { isSaving = false; }
    }

    private Task<IEnumerable<Office>> SearchOffices(string value, CancellationToken ct)
    {
        var results = string.IsNullOrWhiteSpace(value)
            ? RoutableOffices
            : RoutableOffices.Where(o => o.Name!.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(results);
    }

    private Task<IEnumerable<Unit>> SearchUnits(string value, CancellationToken ct)
    {
        var units = newDocument.NextOfficeId.HasValue
            ? GetUnitsForOffice(newDocument.NextOfficeId.Value)
            : Enumerable.Empty<Unit>();
        var results = string.IsNullOrWhiteSpace(value)
            ? units
            : units.Where(u => u.Name!.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(results);
    }

    private async Task OnOfficeAutoChanged(Office? office)
    {
        _selectedOffice = office;
        _selectedUnit = null;
        await OnOfficeChanged(office?.Id);
    }

    private void OnUnitAutoChanged(Unit? unit)
    {
        _selectedUnit = unit;
        newDocument.NextUnitId = unit?.Id;
    }
}
