@page "/my-tracking"
@attribute [Authorize]
@using System.Security.Claims
@using DocTracking.Client
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@inject NotificationService NotifService
@inject DocumentService DocService
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService
@implements IDisposable
@rendermode InteractiveAuto

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <div class="mb-6">
        <div class="d-flex justify-space-between align-center mb-4">
            <div>
                <MudText Typo="Typo.h4" Class="font-weight-bold">My Document Tracking</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Personal record of document.</MudText>
            </div>
        </div>

        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudPaper Style="border-top: 4px solid var(--mud-palette-warning);" Elevation="2" Class="pa-4 rounded-lg">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Warning">@_stats.TotalInMotionCount</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Warning">In Motion</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.DirectionsWalk" Size="Size.Large" Color="Color.Warning" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Style="border-top: 4px solid var(--mud-palette-success);" Elevation="2" Class="pa-4 rounded-lg">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Success">@_stats.TotalReceivedCount</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Success">Received</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Style="border-top: 4px solid var(--mud-palette-info);" Elevation="2" Class="pa-4 rounded-lg">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Info">@_stats.TotalCompletedCount</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Info">Completed Documents</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Info" />
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </div>

    @if (isLoading)
    {
        <MudPaper Elevation="2" Class="pa-8 text-center rounded-lg">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mb-4" />
            <MudText>Loading your documents...</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="3" Class="pa-4 pa-md-6 rounded-lg">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6">All My Documents</MudText>
            </div>

            <div class="mb-4">
                <div style="width:100%;" class="mb-2">
                    <MudTextField Value="@searchString"
                                  ValueChanged="@((string v) => OnSearchChanged(v))"
                                  Placeholder="Search documents..."
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </div>
                <div class="d-flex gap-2 align-center flex-wrap">
                    <div style="position:relative;">
                        <MudBadge Content="@ActiveFilterCount" Color="Color.Error" Overlap="true"
                                  Visible="@(ActiveFilterCount > 0)">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.FilterList"
                                       OnClick="@(() => _filterOpen = !_filterOpen)">
                                Filters
                            </MudButton>
                        </MudBadge>
                        <MudPopover Open="_filterOpen" AnchorOrigin="Origin.BottomLeft"
                                    TransformOrigin="Origin.TopLeft" Paper="true" Class="pa-4"
                                    Style="min-width:300px; z-index:1300;">
                            <div class="d-flex justify-space-between align-center mb-3">
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Filters</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               OnClick="@(() => _filterOpen = false)" />
                            </div>
                            <MudSelect T="string" Value="statusFilter" Label="Status" Variant="Variant.Outlined"
                                       Margin="Margin.Dense" FullWidth="true" Class="mb-3"
                                       ValueChanged="@(async (string v) => { statusFilter = v; await LoadDocuments(); })">
                                <MudSelectItem T="string" Value="@("")">All Statuses</MudSelectItem>
                                <MudSelectItem T="string" Value="@("In Motion")">In Motion</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Received")">Received</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Completed")">Completed</MudSelectItem>
                            </MudSelect>
                            <MudSelect T="string" Value="typeFilter" Label="Type" Variant="Variant.Outlined"
                                       Margin="Margin.Dense" FullWidth="true" Class="mb-3"
                                       ValueChanged="@(async (string v) => { typeFilter = v; await LoadDocuments(); })">
                                <MudSelectItem T="string" Value="@("")">All Types</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Memo")">Memo</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Letter")">Letter</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Notice")">Notice</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Voucher")">Voucher</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Report")">Report</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Other")">Other</MudSelectItem>
                            </MudSelect>
                            <MudSelect T="string" Value="priorityFilter" Label="Priority" Variant="Variant.Outlined"
                                       Margin="Margin.Dense" FullWidth="true" Class="mb-3"
                                       ValueChanged="@(async (string v) => { priorityFilter = v; await LoadDocuments(); })">
                                <MudSelectItem T="string" Value="@("")">All Priorities</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Emergency")">Emergency</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Urgent")">Urgent</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Medium")">Medium</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Low")">Low</MudSelectItem>
                            </MudSelect>
                            @if (ActiveFilterCount > 0)
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Error" FullWidth="true"
                                           StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearFilters">
                                    Clear All Filters
                                </MudButton>
                            }
                        </MudPopover>
                    </div>
                </div>
            </div>


            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudTable @ref="_table" ServerData="LoadServerData" Hover="true" T="Document" SortLabel="Sort By">
                    <HeaderContent>
                        <MudTh>Document</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Priority</MudTh>
                        <MudTh>Created</MudTh>
                        <MudTh>Current Location</MudTh>
                        <MudTh>Next Destination</MudTh>
                        <MudTh>Action</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Document"><strong>@context.Name</strong></MudTd>
                        <MudTd DataLabel="Type">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info">@context.Type</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Color="@(context.Status == "Received" ? Color.Success : Color.Warning)" Size="Size.Small" Variant="Variant.Outlined">
                                @context.Status
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Priority">
                            <MudChip T="string" Color="@DocHelpers.GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">
                                @context.Priority
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("MMM dd, hh:mm tt")</MudTd>
                        <MudTd DataLabel="Current Location">
                            @if (context.CurrentOffice != null)
                            {
                                <strong>@context.CurrentOffice.Name</strong>
                                @if (context.CurrentUnit != null)
                                {
                                    <br />
                                    <span style="color: gray; font-size: 0.85em;">↳ @context.CurrentUnit.Name</span>
                                }
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Default"><em>None</em></MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Next Destination">
                            @if (context.NextOffice != null)
                            {
                                <strong>@context.NextOffice.Name</strong>
                                @if (context.NextUnit != null)
                                {
                                    <br />
                                    <span style="color: gray; font-size: 0.85em;">↳ @context.NextUnit.Name</span>
                                }
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Default"><em>None</em></MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Action">
                            <div @onclick:stopPropagation="true" class="d-flex gap-2">
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Visibility"
                                           OnClick="@(async () => await OpenViewDialog(context))">View</MudButton>
                                <MudIconButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                                               Icon="@Icons.Material.Filled.QrCode"
                                               OnClick="@(async () => await OpenQRDialog(context))" />
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <div class="pa-8 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Style="opacity: 0.3; font-size: 4rem;" Class="mb-4" />
                            <MudText Typo="Typo.h6" Class="mud-text-secondary">@(string.IsNullOrEmpty(searchString) ? "No documents found" : "No matching documents")</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@(string.IsNullOrEmpty(searchString) ? "You haven't created any documents yet" : "Try adjusting your search terms")</MudText>
                        </div>
                    </NoRecordsContent>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            </MudHidden>

            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                @if (!myDocuments.Any())
                {
                    <div class="pa-8 text-center">
                        <MudIcon Icon="@(string.IsNullOrEmpty(searchString) ? Icons.Material.Filled.Inbox : Icons.Material.Filled.SearchOff)" Size="Size.Large" Style="opacity: 0.3; font-size: 4rem;" Class="mb-4" />
                        <MudText Typo="Typo.h6" Class="mud-text-secondary">@(string.IsNullOrEmpty(searchString) ? "No documents found" : "No matching documents")</MudText>
                        @if (string.IsNullOrEmpty(searchString))
                        {
                            <MudButton Href="create-document" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="mt-4" FullWidth="true">
                                Create Your First Document
                            </MudButton>
                        }
                    </div>
                }
                else
                {
                    @foreach (var doc in myDocuments)
                    {
                        <MudCard Elevation="2" Class="mb-3">
                            <MudCardContent Class="pa-4">
                                <div class="d-flex justify-space-between align-start mb-2">
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@doc.Name</MudText>
                                    <MudChip T="string" Color="@DocHelpers.GetPriorityColor(doc.Priority)" Size="Size.Small" Variant="Variant.Filled">
                                        @doc.Priority
                                    </MudChip>
                                </div>
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined" Class="mb-2">@doc.Type</MudChip>
                                <MudChip T="string" Color="@(doc.Status == "Received" ? Color.Success : Color.Warning)" Size="Size.Small" Variant="Variant.Filled" Class="mb-3">
                                    @doc.Status
                                </MudChip>
                                <MudText Typo="Typo.body2" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-1" />
                                    Current: <strong>@(doc.CurrentOffice?.Name ?? "None")</strong>
                                </MudText>
                                <MudText Typo="Typo.body2" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="mr-1" />
                                    Next: <strong>@(doc.NextOffice?.Name ?? "None")</strong>
                                </MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                    @doc.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")
                                </MudText>
                            </MudCardContent>
                            <MudCardActions Class="pa-4 pt-0">
                                <div @onclick:stopPropagation="true" style="width:100%" class="d-flex gap-2">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Style="flex:1"
                                               StartIcon="@Icons.Material.Filled.Visibility"
                                               OnClick="@(async () => await OpenViewDialog(doc))">View</MudButton>
                                    <MudIconButton Variant="Variant.Outlined" Color="Color.Secondary"
                                                   Icon="@Icons.Material.Filled.QrCode"
                                                   OnClick="@(async () => await OpenQRDialog(doc))" />
                                </div>
                            </MudCardActions>
                        </MudCard>
                    }
                }
            </MudHidden>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4">
                    Error loading data: @errorMessage
                </MudAlert>
            }
        </MudPaper>
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "ref")] public string? RefParam { get; set; }

    private PagedResult<Document> _pagedResult = new();
    private List<Document> myDocuments => _pagedResult.Items;
    private MudTable<Document>? _table;
    private bool isLoading = true;
    private string? errorMessage;
    private string email = "";
    private bool dialogOpened = false;
    private UserDocumentStats _stats = new();
    private readonly DebounceHelper _debounce = new();

    private string searchString = "";
    private string statusFilter = "";
    private string typeFilter = "";
    private string priorityFilter = "";

    private bool _filterOpen = false;

    private int ActiveFilterCount =>
        (string.IsNullOrEmpty(statusFilter) ? 0 : 1) +
        (string.IsNullOrEmpty(typeFilter) ? 0 : 1) +
        (string.IsNullOrEmpty(priorityFilter) ? 0 : 1);
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profile = await DocService.GetProfileAsync();
            if (profile == null || string.IsNullOrEmpty(profile.Email))
            {
                errorMessage = "Could not load your profile.";
                return;
            }
            email = profile.Email;
            _stats = await DocService.GetUserDocumentStatsAsync(email) ?? new();
            await LoadMobileData();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isLoading = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            NotifService.OnChange += OnNotificationReceived;

        if (!dialogOpened && !isLoading && !string.IsNullOrEmpty(RefParam))
        {
            dialogOpened = true;
            var doc = myDocuments.FirstOrDefault(d => d.ReferenceNumber == RefParam)
                      ?? await DocService.GetDocumentByRefAsync(RefParam);
            if (doc != null) await OpenViewDialog(doc);
        }
    }

    private void OnNotificationReceived() =>
        _debounce.Trigger(async () =>
        {
            await LoadDocuments();
            await InvokeAsync(StateHasChanged);
        });

    private async Task LoadMobileData()
    {
        if (string.IsNullOrEmpty(email)) return;
        try
        {
            _pagedResult = await DocService.GetUserDocumentsAsync(
                email, page: 1, pageSize: 25,
                search: searchString, status: statusFilter,
                priority: priorityFilter, type: typeFilter);
        }
        catch (Exception ex) { Console.WriteLine($"[MyTracking] LoadMobileData error: {ex.Message}"); }
    }

    private async Task<TableData<Document>> LoadServerData(TableState state, CancellationToken ct)
    {
        if (string.IsNullOrEmpty(email)) return new TableData<Document>();
        try
        {
            _stats = await DocService.GetUserDocumentStatsAsync(email) ?? new();
            _pagedResult = await DocService.GetUserDocumentsAsync(
                email, page: state.Page + 1, pageSize: state.PageSize,
                search: searchString, status: statusFilter,
                priority: priorityFilter, type: typeFilter);
            await InvokeAsync(StateHasChanged);
            return new TableData<Document> { Items = _pagedResult.Items, TotalItems = _pagedResult.TotalCount };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MyTracking] LoadServerData error: {ex.Message}");
            return new TableData<Document>();
        }
    }

    private async Task LoadDocuments()
    {
        await LoadMobileData();
        if (_table != null) await _table.ReloadServerData();
    }

    private async void OnSearchChanged(string value)
    {
        searchString = value;
        await LoadDocuments();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ClearFilters()
    {
        statusFilter = "";
        typeFilter = "";
        priorityFilter = "";
        await LoadDocuments();
    }

    private async Task OpenViewDialog(Document doc)
    {
        var parameters = new DialogParameters<DocumentViewDialog> { { x => x.Doc, doc } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<DocumentViewDialog>("Document Details", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadDocuments();
    }

    private async Task OpenQRDialog(Document doc)
    {
        var parameters = new DialogParameters<QRCodeDialog>
        {
            { x => x.DocumentId, doc.Id },
            { x => x.ReferenceNumber, doc.ReferenceNumber }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<QRCodeDialog>("QR Code", parameters, options);
    }

    public void Dispose()
    {
        NotifService.OnChange -= OnNotificationReceived;
        _debounce.Dispose();
    }
}


