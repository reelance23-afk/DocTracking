@page "/track-document/{DocumentId:int}"
@attribute [Authorize]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Pages.Shared
@using Microsoft.AspNetCore.Components.Authorization
@inject DocumentService DocService
@inject NavigationManager Navigation
@rendermode InteractiveAuto

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-8">
    <div class="d-flex align-center mb-6">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default" OnClick="Back" Class="mr-2" Size="Size.Large" />
        <div class="d-flex flex-column flex-sm-row align-start align-sm-center gap-2">
            <MudText Typo="Typo.h4" Class="font-weight-bold">Document Tracking</MudText>
            @if (documentLogs.Any() && documentLogs.First().Document?.ReferenceNumber != null)
            {
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Medium">
                    @documentLogs.First().Document?.ReferenceNumber
                </MudChip>
            }
        </div>
    </div>

    <TrackingTimeline Logs="documentLogs" IsLoading="isLoading" ErrorMessage="errorMessage" />
</MudContainer>

@code {
    [Parameter] public int DocumentId { get; set; }
    [Parameter][SupplyParameterFromQuery(Name = "ReturnUrl")] public string? ReturnUrl { get; set; }

    private List<DocumentLog> documentLogs = new();
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            documentLogs = await DocService.GetDocumentLogsAsync(DocumentId);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void Back()
    {
        var target = string.IsNullOrEmpty(ReturnUrl) ? "my-tracking" : ReturnUrl;
        Navigation.NavigateTo($"/{target}");
    }
}
