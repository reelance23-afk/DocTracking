@page "/office-desk"
@attribute [Authorize(Roles = "Office")]
@using System.Security.Claims
@using DocTracking.Client
@using DocTracking.Client.Models
@using DocTracking.Client.Pages.Offices
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService
@inject NotificationService NotifService
@implements IDisposable
@rendermode InteractiveAuto

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

    @if (isLoadingInitial)
    {
        <div class="d-flex flex-column align-center mt-10">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mb-4" />
            <MudText>Loading your desk...</MudText>
        </div>
    }
    else if (myOffice != null)
    {
        <div class="d-flex align-center justify-space-between mb-6">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Class="mr-3" Color="Color.Primary" />
                <div>
                    @if (myUnitId.HasValue)
                    {
                        <MudText Typo="Typo.h4" Class="font-weight-bold">@myUnitName</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.h4" Class="font-weight-bold">@myOffice?.Name</MudText>
                    }
                    <div class="d-flex align-center gap-2 mt-1">
                        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Office Desk</MudText>
                        @if (!string.IsNullOrEmpty(myOffice?.ReceivingSchedule))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                                     Icon="@Icons.Material.Filled.Schedule">
                                @myOffice.ReceivingSchedule
                            </MudChip>
                        }
                    </div>
                </div>
            </div>
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.EditCalendar" OnClick="OpenScheduleDialog">
                    @(string.IsNullOrEmpty(myOffice?.ReceivingSchedule) ? "Set Schedule" : "Edit Schedule")
                </MudButton>
            </MudHidden>
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <MudIconButton Icon="@Icons.Material.Filled.EditCalendar" Color="Color.Primary"
                               Variant="Variant.Outlined" Size="Size.Small" OnClick="OpenScheduleDialog"
                               Title="@(string.IsNullOrEmpty(myOffice?.ReceivingSchedule) ? "Set Schedule" : "Edit Schedule")" />
            </MudHidden>
        </div>

        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="border-top: 4px solid var(--mud-palette-error);">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Error">@incomingDocs.Count</MudText>
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Incoming</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Error" Style="opacity:0.4;" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="border-top: 4px solid var(--mud-palette-warning);">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Warning">@deskDocs.Count</MudText>
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">On Desk</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Large" Color="Color.Warning" Style="opacity:0.4;" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="border-top: 4px solid var(--mud-palette-info);">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Info">@outgoingDocs.Count</MudText>
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Outgoing</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Large" Color="Color.Info" Style="opacity:0.4;" />
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @if (IdleDeskDocs.Any())
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4" Icon="@Icons.Material.Filled.AccessTime" Dense="true">
                <strong>@IdleDeskDocs.Count document@(IdleDeskDocs.Count > 1 ? "s have" : " has")</strong>
                been sitting on your desk for over 24 hours:
                @string.Join(", ", IdleDeskDocs.Select(d => d.Name))
            </MudAlert>
        }

        <MudPaper Elevation="3" Class="pa-4 pa-md-6 rounded-lg">
            <MudTabs Elevation="4" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4 pa-md-6 pb-0" Color="Color.Primary" AlwaysShowScrollButtons="false">

                <MudTabPanel BadgeData="@incomingDocs.Count" BadgeColor="Color.Error">
                    <TabContent>
                        <div class="d-flex align-center gap-1 px-2">
                            <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Small" />
                            <span>Incoming</span>
                        </div>
                    </TabContent>
                    <ChildContent>
                        <MudTextField Value="@incomingSearch"
                                      ValueChanged="@((string v) => OnIncomingSearchChanged(v))"
                                      Placeholder="Search incoming..."
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      DebounceInterval="400"
                                      Class="mb-3 mx-5" />
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <MudTable Items="@incomingDocs" Hover="true" Loading="@isLoading" T="Document">
                                <HeaderContent>
                                    <MudTh>Document</MudTh>
                                    <MudTh>Type</MudTh>
                                    <MudTh>Priority</MudTh>
                                    <MudTh>Sender</MudTh>
                                    <MudTh>Date Sent</MudTh>
                                    <MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Document"><strong>@context.Name</strong></MudTd>
                                    <MudTd DataLabel="Type">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info">@context.Type</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Priority">
                                        <MudChip T="string" Color="@DocHelpers.GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">@context.Priority</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Sender">@context.Creator?.Name</MudTd>
                                    <MudTd DataLabel="Date">@context.CreatedAt.ToLocalTime().ToString("MMM dd, hh:mm tt")</MudTd>
                                    <MudTd DataLabel="Actions">
                                        <div class="d-flex gap-2">
                                            <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                                                       StartIcon="@Icons.Material.Filled.Visibility"
                                                       OnClick="@(async () => await OpenDeskDialog(context, OfficeDeskViewDialog.DeskTab.Incoming))">
                                                View Details
                                            </MudButton>
                                            <MudIconButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                                                           Icon="@Icons.Material.Filled.QrCode"
                                                           OnClick="@(async () => await OpenQRDialog(context))" />
                                        </div>
                                    </MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <div class="pa-8 text-center">
                                        <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Style="opacity:0.3; font-size:4rem;" Class="mb-4" />
                                        <MudText Typo="Typo.h6" Class="mud-text-secondary">No incoming documents</MudText>
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Your inbox is empty</MudText>
                                    </div>
                                </NoRecordsContent>
                            </MudTable>
                        </MudHidden>
                        <MudHidden Breakpoint="Breakpoint.MdAndUp">
                            @if (isLoading)
                            {
                                <MudProgressLinear Indeterminate="true" Class="mb-4" />
                            }
                            @if (!incomingDocs.Any())
                            {
                                <MudPaper Elevation="0" Class="pa-8 text-center">
                                    <MudText Class="mud-text-secondary">No incoming documents at this time.</MudText>
                                </MudPaper>
                            }
                            else
                            {
                                <div class="mb-n3">
                                    @foreach (var doc in incomingDocs)
                                    {
                                        <MudCard Elevation="2" Class="mb-3">
                                            <MudCardContent Class="pa-4">
                                                <div class="d-flex justify-space-between align-start mb-2">
                                                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@doc.Name</MudText>
                                                    <MudChip T="string" Color="@DocHelpers.GetPriorityColor(doc.Priority)" Size="Size.Small" Variant="Variant.Filled">@doc.Priority</MudChip>
                                                </div>
                                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined" Class="mb-2">@doc.Type</MudChip>
                                                <MudText Typo="Typo.body2" Class="mb-2">
                                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                                                    From: <strong>@doc.Creator?.Name</strong>
                                                </MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                                    @doc.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")
                                                </MudText>
                                            </MudCardContent>
                                            <MudCardActions Class="pa-4 pt-0">
                                                <div class="d-flex gap-2" style="width:100%">
                                                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Style="flex:1" Size="Size.Large"
                                                               StartIcon="@Icons.Material.Filled.Visibility"
                                                               OnClick="@(async () => await OpenDeskDialog(doc, OfficeDeskViewDialog.DeskTab.Incoming))">
                                                        View Details
                                                    </MudButton>
                                                    <MudIconButton Variant="Variant.Outlined" Color="Color.Secondary"
                                                                   Icon="@Icons.Material.Filled.QrCode"
                                                                   OnClick="@(async () => await OpenQRDialog(doc))" />
                                                </div>
                                            </MudCardActions>
                                        </MudCard>
                                    }
                                </div>
                            }
                        </MudHidden>
                    </ChildContent>
                </MudTabPanel>

                <MudTabPanel BadgeData="@deskDocs.Count" BadgeColor="Color.Warning">
                    <TabContent>
                        <div class="d-flex align-center gap-1 px-2">
                            <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" />
                            <span>On Desk</span>
                        </div>
                    </TabContent>
                    <ChildContent>
                        <MudTextField Value="@deskSearch"
                                      ValueChanged="@((string v) => OnDeskSearchChanged(v))"
                                      Placeholder="Search on desk..."
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      DebounceInterval="400"
                                      Class="mb-3 mx-5" />
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <MudTable Items="@deskDocs" Hover="true" Loading="@isLoading" T="Document">
                                <HeaderContent>
                                    <MudTh>Document</MudTh>
                                    <MudTh>Type</MudTh>
                                    <MudTh>Priority</MudTh>
                                    <MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Document"><strong>@context.Name</strong></MudTd>
                                    <MudTd DataLabel="Type">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info">@context.Type</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Priority">
                                        <MudChip T="string" Color="@DocHelpers.GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">@context.Priority</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Actions">
                                        <div class="d-flex gap-2">
                                            <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                                                       StartIcon="@Icons.Material.Filled.Visibility"
                                                       OnClick="@(async () => await OpenDeskDialog(context, OfficeDeskViewDialog.DeskTab.OnDesk))">
                                                View Details
                                            </MudButton>
                                            <MudIconButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                                                           Icon="@Icons.Material.Filled.QrCode"
                                                           OnClick="@(async () => await OpenQRDialog(context))" />
                                        </div>
                                    </MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <div class="pa-8 text-center">
                                        <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Size="Size.Large" Style="opacity:0.3; font-size:4rem;" Class="mb-4" />
                                        <MudText Typo="Typo.h6" Class="mud-text-secondary">Your desk is clear</MudText>
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No documents to process</MudText>
                                    </div>
                                </NoRecordsContent>
                            </MudTable>
                        </MudHidden>
                        <MudHidden Breakpoint="Breakpoint.MdAndUp">
                            @if (isLoading)
                            {
                                <MudProgressLinear Indeterminate="true" Class="mb-4" />
                            }
                            @if (!deskDocs.Any())
                            {
                                <MudPaper Elevation="0" Class="pa-8 text-center">
                                    <MudText Class="mud-text-secondary">Your desk is clear.</MudText>
                                </MudPaper>
                            }
                            else
                            {
                                <div class="mb-n3">
                                    @foreach (var doc in deskDocs)
                                    {
                                        <MudCard Elevation="2" Class="mb-3">
                                            <MudCardContent Class="pa-4">
                                                <div class="d-flex justify-space-between align-start mb-2">
                                                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@doc.Name</MudText>
                                                    <MudChip T="string" Color="@DocHelpers.GetPriorityColor(doc.Priority)" Size="Size.Small" Variant="Variant.Filled">@doc.Priority</MudChip>
                                                </div>
                                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined">@doc.Type</MudChip>
                                            </MudCardContent>
                                            <MudCardActions Class="pa-4 pt-0">
                                                <div class="d-flex gap-2" style="width:100%">
                                                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Style="flex:1" Size="Size.Large"
                                                               StartIcon="@Icons.Material.Filled.Visibility"
                                                               OnClick="@(async () => await OpenDeskDialog(doc, OfficeDeskViewDialog.DeskTab.OnDesk))">
                                                        View Details
                                                    </MudButton>
                                                    <MudIconButton Variant="Variant.Outlined" Color="Color.Secondary"
                                                                   Icon="@Icons.Material.Filled.QrCode"
                                                                   OnClick="@(async () => await OpenQRDialog(doc))" />
                                                </div>
                                            </MudCardActions>
                                        </MudCard>
                                    }
                                </div>
                            }
                        </MudHidden>
                    </ChildContent>
                </MudTabPanel>

                <MudTabPanel BadgeData="@outgoingDocs.Count" BadgeColor="Color.Info">
                    <TabContent>
                        <div class="d-flex align-center gap-1 px-2">
                            <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Small" />
                            <span>Outgoing</span>
                        </div>
                    </TabContent>
                    <ChildContent>
                        <MudTextField Value="@outgoingSearch"
                                      ValueChanged="@((string v) => OnOutgoingSearchChanged(v))"
                                      Placeholder="Search outgoing..."
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      DebounceInterval="400"
                                      Class="mb-3 mx-5" />
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <MudTable Items="@outgoingDocs" Hover="true" Loading="@isLoading" T="Document">
                                <HeaderContent>
                                    <MudTh>Document</MudTh>
                                    <MudTh>Type</MudTh>
                                    <MudTh>Priority</MudTh>
                                    <MudTh>Routing To</MudTh>
                                    <MudTh>Date Forwarded</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Document"><strong>@context.Name</strong></MudTd>
                                    <MudTd DataLabel="Type">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info">@context.Type</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Priority">
                                        <MudChip T="string" Color="@DocHelpers.GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">@context.Priority</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Destination">
                                        <strong>@context.NextOffice?.Name</strong>
                                        @if (context.NextUnit != null)
                                        {
                                            <br />
                                            <span style="color: gray; font-size: 0.85em;">↳ @context.NextUnit.Name</span>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Forwarded">@(context.LastActionDate?.ToLocalTime().ToString("MMM dd, hh:mm tt") ?? context.CreatedAt.ToLocalTime().ToString("MMM dd, hh:mm tt"))</MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <div class="pa-8 text-center">
                                        <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Large" Style="opacity:0.3; font-size:4rem;" Class="mb-4" />
                                        <MudText Typo="Typo.h6" Class="mud-text-secondary">No outgoing documents</MudText>
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No documents in transit</MudText>
                                    </div>
                                </NoRecordsContent>
                            </MudTable>
                        </MudHidden>
                        <MudHidden Breakpoint="Breakpoint.MdAndUp">
                            @if (isLoading)
                            {
                                <MudProgressLinear Indeterminate="true" Class="mb-4" Color="Color.Primary" />
                            }
                            @if (!outgoingDocs.Any())
                            {
                                <div class="pa-4 text-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Large" Style="opacity:0.3; font-size:3rem;" Class="mb-3" />
                                    <MudText Typo="Typo.body1" Class="mud-text-secondary">No outgoing documents</MudText>
                                </div>
                            }
                            else
                            {
                                <div class="mb-n3">
                                    @foreach (var doc in outgoingDocs)
                                    {
                                        <MudCard Elevation="2" Class="mb-3 rounded-lg">
                                            <MudCardContent Class="pa-4">
                                                <div class="d-flex justify-space-between align-start mb-3">
                                                    <div style="flex: 1;">
                                                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-1">@doc.Name</MudText>
                                                        <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text" Class="pa-0">@doc.Type</MudChip>
                                                    </div>
                                                    <MudChip T="string" Color="@DocHelpers.GetPriorityColor(doc.Priority)" Size="Size.Small" Variant="Variant.Filled">@doc.Priority</MudChip>
                                                </div>
                                                <MudDivider Class="mb-3" />
                                                <div class="d-flex flex-column gap-2">
                                                    <div class="d-flex align-center">
                                                        <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Class="mr-2" Color="Color.Info" />
                                                        <div>
                                                            <MudText Typo="Typo.body2"><strong>@doc.NextOffice?.Name</strong></MudText>
                                                            @if (doc.NextUnit != null)
                                                            {
                                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">↳ @doc.NextUnit.Name</MudText>
                                                            }
                                                        </div>
                                                    </div>
                                                    <div class="d-flex align-center">
                                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                            @(doc.LastActionDate?.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt") ?? doc.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt"))
                                                        </MudText>
                                                    </div>
                                                </div>
                                            </MudCardContent>
                                        </MudCard>
                                    }
                                </div>
                            }
                        </MudHidden>
                    </ChildContent>
                </MudTabPanel>

            </MudTabs>
        </MudPaper>
    }

</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "ref")] public string? RefParam { get; set; }
    [SupplyParameterFromQuery(Name = "tab")] public string? TabParam { get; set; }

    private bool dialogOpened = false;
    private Office? myOffice;
    private int? myUnitId;
    private bool isOfficeHead = false;
    private List<Office> allOffices = new();
    private List<Document> incomingDocs = new();
    private List<Document> deskDocs = new();
    private List<Document> outgoingDocs = new();
    private readonly DebounceHelper _debounce = new();
    private string userEmail = "";
    private string? myUnitName;
    private bool isLoadingInitial = true;
    private bool isLoading = false;
    private string incomingSearch = "";
    private string deskSearch = "";
    private string outgoingSearch = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profile = await DocService.GetProfileAsync();
            if (profile != null)
            {
                userEmail = profile.Email ?? "Unknown";
                myUnitId = profile.UnitId;
                myUnitName = profile.Unit?.Name;
                isOfficeHead = myUnitId == null;

                var officeId = profile.Unit?.OfficeId ?? profile.OfficeId;
                if (officeId != null)
                {
                    myOffice = await DocService.GetOfficeByIdAsync(officeId.Value);
                }
            }

            if (myOffice != null)
                await RefreshQueues();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            Snackbar.Add("Error loading office data", Severity.Error);
        }
        finally
        {
            isLoadingInitial = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            NotifService.OnChange += OnNotificationReceived;

        if (!dialogOpened && !isLoadingInitial && !string.IsNullOrEmpty(RefParam))
        {
            dialogOpened = true;
            var allDocs = incomingDocs.Concat(deskDocs).Concat(outgoingDocs);
            var doc = allDocs.FirstOrDefault(d => d.ReferenceNumber == RefParam)
                      ?? await DocService.GetDocumentByRefAsync(RefParam);
            if (doc != null)
            {
                var tab = TabParam switch
                {
                    "Incoming" => OfficeDeskViewDialog.DeskTab.Incoming,
                    "OnDesk" => OfficeDeskViewDialog.DeskTab.OnDesk,
                    _ => OfficeDeskViewDialog.DeskTab.Outgoing
                };
                await OpenDeskDialog(doc, tab);
            }
        }
    }

    private async void OnIncomingSearchChanged(string value)
    {
        incomingSearch = value;
        incomingDocs = await DocService.GetIncomingAsync(myOffice!.Id, myUnitId, incomingSearch);
        await InvokeAsync(StateHasChanged);
    }

    private async void OnDeskSearchChanged(string value)
    {
        deskSearch = value;
        deskDocs = await DocService.GetDeskDocumentsAsync(myOffice!.Id, isOfficeHead ? null : myUnitId, deskSearch);
        await InvokeAsync(StateHasChanged);
    }

    private async void OnOutgoingSearchChanged(string value)
    {
        outgoingSearch = value;
        outgoingDocs = await DocService.GetOutgoingAsync(outgoingSearch);
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshQueues()
    {
        if (myOffice == null) return;
        isLoading = true;
        StateHasChanged();
        try
        {
            incomingDocs = await DocService.GetIncomingAsync(myOffice.Id, myUnitId, incomingSearch);
            deskDocs = await DocService.GetDeskDocumentsAsync(myOffice.Id, isOfficeHead ? null : myUnitId, deskSearch);
            outgoingDocs = await DocService.GetOutgoingAsync(outgoingSearch);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[OfficeDesk] RefreshQueues error: {ex.Message}");
            Snackbar.Add("Failed to refresh documents.", Severity.Warning);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OpenDeskDialog(Document doc, OfficeDeskViewDialog.DeskTab tab)
    {

        if (!allOffices.Any())
        allOffices = await DocService.GetOfficesAsync();

        var parameters = new DialogParameters<OfficeDeskViewDialog>
        {
            { x => x.Doc, doc },
            { x => x.Tab, tab },
            { x => x.AllOffices, allOffices }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<OfficeDeskViewDialog>("Document Details", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await RefreshQueues();
    }

    private async Task OpenQRDialog(Document doc)
    {
        var parameters = new DialogParameters<QRCodeDialog>
        {
            { x => x.DocumentId, doc.Id },
            { x => x.ReferenceNumber, doc.ReferenceNumber }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<QRCodeDialog>("QR Code", parameters, options);
    }

    private async Task OpenScheduleDialog()
    {
        if (myOffice == null) return;
        var parameters = new DialogParameters<ReceivingScheduleDialog>
        {
            { x => x.OfficeId, myOffice.Id },
            { x => x.OfficeName, myOffice.Name },
            { x => x.CurrentSchedule, myOffice.ReceivingSchedule }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<ReceivingScheduleDialog>("Receiving Schedule", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            myOffice.ReceivingSchedule = result.Data as string;
            var idx = allOffices.FindIndex(o => o.Id == myOffice.Id);
            if (idx >= 0) allOffices[idx] = myOffice;
            StateHasChanged();
        }
    }

    private void OnNotificationReceived() =>
        _debounce.Trigger(async () =>
        {
            await RefreshQueues();
            await InvokeAsync(StateHasChanged);
        });

    public void Dispose()
    {
        NotifService.OnChange -= OnNotificationReceived;
        _debounce.Dispose();
    }

    private List<Document> IdleDeskDocs =>
        deskDocs.Where(d =>
            d.LastActionDate.HasValue &&
            (DateTime.UtcNow - d.LastActionDate.Value).TotalHours >= 24)
        .ToList();
}



