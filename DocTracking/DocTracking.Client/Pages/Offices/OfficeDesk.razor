@page "/office-desk"
@attribute [Authorize(Roles = "Office")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using System.Security.Claims;
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveAuto

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    @if (isLoadingInitial)
    {
        <div class="d-flex flex-column align-center mt-10">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mb-4" />
            <MudText>Loading your desk...</MudText>
        </div>
    }
    else if (myOffice != null)
    {
        <MudText Typo="Typo.h4" Class="mb-6">Workspace: @myOffice.Name</MudText>

        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">

            <MudTabPanel Text="Incoming Queue" BadgeData="@incomingDocs.Count" BadgeColor="Color.Error">
                <MudTable Items="@incomingDocs" Hover="true" Loading="@isLoading" T="Document" OnRowClick="RowClicked" RowClass="cursor-pointer">
                    <HeaderContent>
                        <MudTh>Document</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Sender</MudTh>
                        <MudTh>Date Sent</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><strong>@context.Name</strong></MudTd>
                        <MudTd>@context.Type</MudTd>
                        <MudTd>@context.Creator?.Email</MudTd>
                        <MudTd>@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
                        <MudTd>
                            <div @onclick:stopPropagation="true">
                                <MudButton Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" OnClick="@(() => ReceiveDoc(context.Id))">
                                    Receive Document
                                </MudButton>
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4">No incoming documents at this time.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudTabPanel>

            <MudTabPanel Text="On My Desk" BadgeData="@deskDocs.Count" BadgeColor="Color.Info">
                <MudTable Items="@deskDocs" Hover="true" Loading="@isLoading" T="Document" OnRowClick="RowClicked" RowClass="cursor-pointer">
                    <HeaderContent>
                        <MudTh>Document</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Route To...</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><strong>@context.Name</strong></MudTd>
                        <MudTd>@context.Type</MudTd>

                        <MudTd>
                            <div class="d-flex flex-column gap-2" style="min-width: 200px;" @onclick:stopPropagation="true">
                                <MudSelect T="int?" Value="routingSelections[context.Id].OfficeId"
                                           ValueChanged="@((int? val) => OnOfficeSelected(context.Id, val))"
                                           Margin="Margin.Dense" Variant="Variant.Outlined" Label="Select Office">
                                    @foreach (var off in allOffices)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)off.Id)">@off.Name</MudSelectItem>
                                    }
                                </MudSelect>

                                @if (routingSelections[context.Id].OfficeId.HasValue)
                                {
                                    <MudSelect @bind-Value="routingSelections[context.Id].UnitId"
                                               Margin="Margin.Dense" Variant="Variant.Outlined" Label="Select Unit">
                                        @foreach (var unit in GetUnitsForOffice(routingSelections[context.Id].OfficeId.Value))
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)unit.Id)">@unit.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                            </div>
                        </MudTd>

                        <MudTd>
                            <div class="d-flex gap-2" @onclick:stopPropagation="true">
                                <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                                           Disabled="@(routingSelections[context.Id].OfficeId == null)"
                                           OnClick="@(() => ForwardDoc(context.Id))">
                                    Forward
                                </MudButton>

                                <MudButton Color="Color.Dark" Variant="Variant.Filled" Size="Size.Small"
                                           OnClick="@(() => FinishDoc(context.Id))">
                                    Finish
                                </MudButton>
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4">Your desk is clear.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudTabPanel>

            <MudTabPanel Text="Outgoing / Forwarded" BadgeData="@outgoingDocs.Count" BadgeColor="Color.Warning">
                <MudTable Items="@outgoingDocs" Hover="true" Loading="@isLoading" T="Document" OnRowClick="RowClicked" RowClass="cursor-pointer">
                    <HeaderContent>
                        <MudTh>Document</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Routing To</MudTh>
                        <MudTh>Date Forwarded</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><strong>@context.Name</strong></MudTd>
                        <MudTd>@context.Type</MudTd>
                        <MudTd>
                            <strong>@context.NextOffice?.Name</strong>
                            @if (context.NextUnit != null)
                            {
                                <br />
                                <span style="color: gray; font-size: 0.85em;">↳ @context.NextUnit.Name</span>
                            }
                        </MudTd>
                        <MudTd>@(context.LastActionDate?.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt") ?? context.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt"))</MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4">No outgoing documents in transit.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudTabPanel>

        </MudTabs>
    }

    <MudDialog @bind-Visible="isDialogVisible" Options="dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2 mb-n1" /> Document Details
            </MudText>
        </TitleContent>
        <DialogContent>
            @if (selectedDocument != null)
            {
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Document Title</MudText>
                        <MudText Typo="Typo.body1" Class="font-weight-bold">@selectedDocument.Name</MudText>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Document Type</MudText>
                        <MudText Typo="Typo.body1">@selectedDocument.Type</MudText>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                        <div>
                            <MudChip T="string" Color="@(selectedDocument.Status == "Received" ? Color.Success : Color.Warning)" Size="Size.Small">
                                @selectedDocument.Status
                            </MudChip>
                        </div>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Created On</MudText>
                        <MudText Typo="Typo.body2">@selectedDocument.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</MudText>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Current Location</MudText>
                        @if (selectedDocument.CurrentOffice != null)
                        {
                            <MudText Typo="Typo.body1" Class="font-weight-bold">@selectedDocument.CurrentOffice.Name</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">↳ @selectedDocument.CurrentUnit?.Name</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body1" Color="Color.Default"><em>None</em></MudText>
                        }
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Next Destination</MudText>
                        @if (selectedDocument.NextOffice != null)
                        {
                            <MudText Typo="Typo.body1" Class="font-weight-bold">@selectedDocument.NextOffice.Name</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">↳ @selectedDocument.NextUnit?.Name</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body1" Color="Color.Default"><em>None</em></MudText>
                        }
                    </MudItem>

                    @if (!string.IsNullOrEmpty(selectedDocument.Description))
                    {
                        <MudItem xs="12">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Description / Notes</MudText>
                            <MudPaper Elevation="0" Class="pa-3 mt-1 mud-background-gray rounded">
                                <MudText Typo="Typo.body2">@selectedDocument.Description</MudText>
                            </MudPaper>
                        </MudItem>
                    }

                    @if (!string.IsNullOrEmpty(selectedDocument.FileName))
                    {
                        <MudItem xs="12">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Attached File</MudText>
                            <div class="d-flex align-center mt-1">
                                <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" Class="mr-2" />
                                <MudText Typo="Typo.body2" Class="mr-4">@selectedDocument.FileName</MudText>

                                <MudButton Href="@selectedDocument.FilePath"
                                           Target="_blank"
                                           Variant="Variant.Outlined"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Download">
                                    Download
                                </MudButton>
                            </div>
                        </MudItem>
                    }
                </MudGrid>
            }
        </DialogContent>
        <DialogActions>     
            <MudButton Color="Color.Primary" OnClick="CloseDialog">Close</MudButton>
        </DialogActions>
    </MudDialog>

</MudContainer>

@code {
    private Office? myOffice;
    private int? myUnitId;
    private List<Office> allOffices = new();

    private List<Document> incomingDocs = new();
    private List<Document> deskDocs = new();
    private List<Document> outgoingDocs = new();

    private string userEmail = "";
    private bool isLoadingInitial = true;
    private bool isLoading = false;
    private bool isDialogVisible;
    private Document? selectedDocument;
    private DialogOptions dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };

    private class RoutingSelection
    {
        public int? OfficeId { get; set; }
        public int? UnitId { get; set; }
    }

    private Dictionary<int, RoutingSelection> routingSelections = new();

    protected override async Task OnInitializedAsync()
    {
      
            try
            {
                var profile = await DocService.GetProfileAsync();
                if (profile != null)
                {
                    userEmail = profile.Email ?? "Unknown";
                    myUnitId = profile.UnitId;

                    if (profile.Unit?.OfficeId != null)
                    {
                        allOffices = await DocService.GetOfficesAsync();
                        myOffice = allOffices.FirstOrDefault(o => o.Id == profile.Unit.OfficeId);
                    }
                }

                if (myOffice != null)
                {
                    await RefreshQueues();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error: {ex.Message}");
                Snackbar.Add("Error loading office data", Severity.Error);
            }
            finally
            {
                isLoadingInitial = false;
            }
        
    }

    private async Task RefreshQueues()
    {
        if (myOffice == null) return;
        isLoading = true;
        StateHasChanged();

        try
        {
            incomingDocs = await DocService.GetIncomingAsync(myOffice.Id, myUnitId);
            var allDocs = await DocService.GetAllDocumentsAsync();

            deskDocs = allDocs.Where(d =>
                d.CurrentOfficeId == myOffice.Id &&
                d.Status == "Received" &&
                (myUnitId.HasValue ? (d.CurrentUnitId == null || d.CurrentUnitId == myUnitId) : d.CurrentUnitId == null)
            ).ToList();

            outgoingDocs = await DocService.GetOutgoingAsync(userEmail);

            foreach (var doc in deskDocs)
            {
                if (!routingSelections.ContainsKey(doc.Id))
                {
                    routingSelections[doc.Id] = new RoutingSelection();
                }
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void RowClicked(TableRowClickEventArgs<Document> args)
    {
        selectedDocument = args.Item;
        isDialogVisible = true;
    }

    private void CloseDialog()
    {
        isDialogVisible = false;
    }

    private void OnOfficeSelected(int docId, int? officeId)
    {
        routingSelections[docId].OfficeId = officeId;
        routingSelections[docId].UnitId = null;
    }

    private IEnumerable<Unit> GetUnitsForOffice(int officeId)
    {
        return allOffices.FirstOrDefault(o => o.Id == officeId)?.Units ?? new List<Unit>();
    }

    private async Task ReceiveDoc(int docId)
    {
        await DocService.ReceivedDocumentAsync(docId);
        await RefreshQueues();
        Snackbar.Add("Document received!", Severity.Success);
    }

    private async Task ForwardDoc(int docId)
    {
        var selection = routingSelections[docId];
        if (selection.OfficeId.HasValue)
        {
            await DocService.ForwardDocumentAsync(docId, selection.OfficeId.Value, selection.UnitId);
            await RefreshQueues();
            Snackbar.Add("Document forwarded successfully!", Severity.Success);
        }
    }

    private async Task FinishDoc(int docId)
    {
        await DocService.FinishDocumentAsync(docId);
        await RefreshQueues();
        Snackbar.Add("Document completed");
    }
}