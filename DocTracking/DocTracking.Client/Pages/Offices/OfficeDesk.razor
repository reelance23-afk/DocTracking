@page "/office-desk"
@attribute [Authorize(Roles = "Office")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using System.Security.Claims;
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService
@rendermode InteractiveAuto

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    @if (isLoadingInitial)
    {
        <div class="d-flex flex-column align-center mt-10">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mb-4" />
            <MudText>Loading your desk...</MudText>
        </div>
    }
    else if (myOffice != null)
    {
        <div class="d-flex align-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Class="mr-3" Color="Color.Primary" />
            <div>
                <MudText Typo="Typo.h4" Class="font-weight-bold">@myOffice.Name</MudText>
                <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Office Desk</MudText>
            </div>
        </div>

   
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="border-top: 4px solid var(--mud-palette-error);">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Error">@incomingDocs.Count</MudText>
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Incoming</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Error" Style="opacity:0.4;" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="border-top: 4px solid var(--mud-palette-warning);">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Warning">@deskDocs.Count</MudText>
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">On Desk</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Large" Color="Color.Warning" Style="opacity:0.4;" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="border-top: 4px solid var(--mud-palette-info);">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Info">@outgoingDocs.Count</MudText>
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Outgoing</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Large" Color="Color.Info" Style="opacity:0.4;" />
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudTabs Elevation="3" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4 pa-md-6" Color="Color.Primary">

            <MudTabPanel Icon="@Icons.Material.Filled.Inbox" Text="Incoming" BadgeData="@incomingDocs.Count" BadgeColor="Color.Error">
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudTable Items="@incomingDocs" Hover="true" Loading="@isLoading" T="Document" OnRowClick="RowClicked" RowClass="cursor-pointer">
                        <HeaderContent>
                            <MudTh>Document</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Priority</MudTh>
                            <MudTh>Sender</MudTh>
                            <MudTh>Date Sent</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Document"><strong>@context.Name</strong></MudTd>
                            <MudTd DataLabel="Type">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info">@context.Type</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Priority">
                                <MudChip T="string" Color="@GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">@context.Priority</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Sender">@context.Creator?.Name</MudTd>
                            <MudTd DataLabel="Date">@context.CreatedAt.ToLocalTime().ToString("MMM dd, hh:mm tt")</MudTd>
                            <MudTd DataLabel="Actions">
                                <div @onclick:stopPropagation="true">
                                    <MudButton Color="Color.Success" Variant="Variant.Filled" Size="Size.Small"
                                               OnClick="@(() => ReceiveDoc(context.Id))" StartIcon="@Icons.Material.Filled.CheckCircle">
                                        Receive
                                    </MudButton>
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <div class="pa-8 text-center">
                                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Style="opacity:0.3; font-size:4rem;" Class="mb-4" />
                                <MudText Typo="Typo.h6" Class="mud-text-secondary">No incoming documents</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">Your inbox is empty</MudText>
                            </div>
                        </NoRecordsContent>
                    </MudTable>
                </MudHidden>

                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    @if (isLoading)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mb-4" />
                    }
                    @if (!incomingDocs.Any())
                    {
                        <MudPaper Elevation="0" Class="pa-8 text-center">
                            <MudText Class="mud-text-secondary">No incoming documents at this time.</MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var doc in incomingDocs)
                        {
                            <MudCard Elevation="2" Class="mb-3" @onclick="@(() => { selectedDocument = doc; isDialogVisible = true; })">
                                <MudCardContent Class="pa-4">
                                    <div class="d-flex justify-space-between align-start mb-2">
                                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@doc.Name</MudText>
                                        <MudChip T="string" Color="@GetPriorityColor(doc.Priority)" Size="Size.Small" Variant="Variant.Filled">@doc.Priority</MudChip>
                                    </div>
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined" Class="mb-2">@doc.Type</MudChip>
                                    <MudText Typo="Typo.body2" Class="mb-2">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                                        From: <strong>@doc.Creator?.Name</strong>
                                    </MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                        @doc.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")
                                    </MudText>
                                </MudCardContent>
                                <MudCardActions Class="pa-4 pt-0">
                                    <div @onclick:stopPropagation="true">
                                        <MudButton Color="Color.Success" Variant="Variant.Filled" FullWidth="true" Size="Size.Large"
                                                   OnClick="@(() => ReceiveDoc(doc.Id))" StartIcon="@Icons.Material.Filled.Inbox">
                                            Receive Document
                                        </MudButton>
                                    </div>
                                </MudCardActions>
                            </MudCard>
                        }
                    }
                </MudHidden>
            </MudTabPanel>

            <MudTabPanel Icon="@Icons.Material.Filled.Assignment" Text="On Desk" BadgeData="@deskDocs.Count" BadgeColor="Color.Warning">
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudTable Items="@deskDocs" Hover="true" Loading="@isLoading" T="Document" OnRowClick="RowClicked" RowClass="cursor-pointer">
                        <HeaderContent>
                            <MudTh>Document</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Priority</MudTh>
                            <MudTh>Route To...</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Document"><strong>@context.Name</strong></MudTd>
                            <MudTd DataLabel="Type">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info">@context.Type</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Priority">
                                <MudChip T="string" Color="@GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">@context.Priority</MudChip>
                            </MudTd>
                            <MudTd>
                                <div class="d-flex flex-column gap-2" style="min-width: 200px;" @onclick:stopPropagation="true">
                                    <MudSelect T="int?" Value="routingSelections[context.Id].OfficeId"
                                               ValueChanged="@((int? val) => OnOfficeSelected(context.Id, val))"
                                               Margin="Margin.Dense" Variant="Variant.Outlined" Label="Select Office">
                                        @foreach (var off in allOffices)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)off.Id)">@off.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                    @if (routingSelections[context.Id].OfficeId.HasValue)
                                    {
                                        <MudSelect @bind-Value="routingSelections[context.Id].UnitId"
                                                   Margin="Margin.Dense" Variant="Variant.Outlined" Label="Select Unit">
                                            @foreach (var unit in GetUnitsForOffice(routingSelections[context.Id].OfficeId.Value))
                                            {
                                                <MudSelectItem T="int?" Value="@((int?)unit.Id)">@unit.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                </div>
                            </MudTd>
                            <MudTd>
                                <div class="d-flex gap-2" @onclick:stopPropagation="true">
                                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                                               Disabled="@(routingSelections[context.Id].OfficeId == null)"
                                               OnClick="@(() => ForwardDoc(context.Id))" StartIcon="@Icons.Material.Filled.Send">
                                        Forward
                                    </MudButton>
                                    <MudButton Color="Color.Success" Variant="Variant.Filled" Size="Size.Small"
                                               OnClick="@(() => FinishDoc(context.Id))" StartIcon="@Icons.Material.Filled.Done">
                                        Finish
                                    </MudButton>
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <div class="pa-8 text-center">
                                <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Size="Size.Large" Style="opacity:0.3; font-size:4rem;" Class="mb-4" />
                                <MudText Typo="Typo.h6" Class="mud-text-secondary">Your desk is clear</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">No documents to process</MudText>
                            </div>
                        </NoRecordsContent>
                    </MudTable>
                </MudHidden>

                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    @if (isLoading)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mb-4" />
                    }
                    @if (!deskDocs.Any())
                    {
                        <MudPaper Elevation="0" Class="pa-8 text-center">
                            <MudText Class="mud-text-secondary">Your desk is clear.</MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var doc in deskDocs)
                        {
                            <MudCard Elevation="2" Class="mb-4">
                                <MudCardContent Class="pa-4" @onclick="@(() => { selectedDocument = doc; isDialogVisible = true; })">
                                    <div class="d-flex justify-space-between align-start mb-2">
                                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@doc.Name</MudText>
                                        <MudChip T="string" Color="@GetPriorityColor(doc.Priority)" Size="Size.Small" Variant="Variant.Filled">@doc.Priority</MudChip>
                                    </div>
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined" Class="mb-3">@doc.Type</MudChip>
                                </MudCardContent>
                                <MudCardContent Class="pa-4 pt-0">
                                    <MudText Typo="Typo.body2" Class="mb-3 font-weight-bold">Route To:</MudText>
                                    <MudSelect T="int?" Value="routingSelections[doc.Id].OfficeId"
                                               ValueChanged="@((int? val) => OnOfficeSelected(doc.Id, val))"
                                               Variant="Variant.Outlined" Label="Select Office" Class="mb-3" FullWidth="true">
                                        @foreach (var off in allOffices)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)off.Id)">@off.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                    @if (routingSelections[doc.Id].OfficeId.HasValue)
                                    {
                                        <MudSelect @bind-Value="routingSelections[doc.Id].UnitId"
                                                   Variant="Variant.Outlined" Label="Select Unit" Class="mb-3" FullWidth="true">
                                            @foreach (var unit in GetUnitsForOffice(routingSelections[doc.Id].OfficeId.Value))
                                            {
                                                <MudSelectItem T="int?" Value="@((int?)unit.Id)">@unit.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                </MudCardContent>
                                <MudCardActions Class="pa-4 pt-0">
                                    <MudGrid>
                                        <MudItem xs="6">
                                            <MudButton Color="Color.Primary" Variant="Variant.Filled" FullWidth="true" Size="Size.Large"
                                                       Disabled="@(routingSelections[doc.Id].OfficeId == null)"
                                                       OnClick="@(() => ForwardDoc(doc.Id))" StartIcon="@Icons.Material.Filled.Send">
                                                Forward
                                            </MudButton>
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudButton Color="Color.Success" Variant="Variant.Filled" FullWidth="true" Size="Size.Large"
                                                       OnClick="@(() => FinishDoc(doc.Id))" StartIcon="@Icons.Material.Filled.Done">
                                                Finish
                                            </MudButton>
                                        </MudItem>
                                    </MudGrid>
                                </MudCardActions>
                            </MudCard>
                        }
                    }
                </MudHidden>
            </MudTabPanel>

            <MudTabPanel Icon="@Icons.Material.Filled.Send" Text="Outgoing" BadgeData="@outgoingDocs.Count" BadgeColor="Color.Info">
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudTable Items="@outgoingDocs" Hover="true" Loading="@isLoading" T="Document" OnRowClick="RowClicked" RowClass="cursor-pointer">
                        <HeaderContent>
                            <MudTh>Document</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Priority</MudTh>
                            <MudTh>Routing To</MudTh>
                            <MudTh>Date Forwarded</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Document"><strong>@context.Name</strong></MudTd>
                            <MudTd DataLabel="Type">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info">@context.Type</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Priority">
                                <MudChip T="string" Color="@GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">@context.Priority</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Destination">
                                <strong>@context.NextOffice?.Name</strong>
                                @if (context.NextUnit != null)
                                {
                                    <br />
                            
                                    <span style="color: gray; font-size: 0.85em;">↳ @context.NextUnit.Name</span>
                                }
                            </MudTd>
                            <MudTd DataLabel="Forwarded">@(context.LastActionDate?.ToLocalTime().ToString("MMM dd, hh:mm tt") ?? context.CreatedAt.ToLocalTime().ToString("MMM dd, hh:mm tt"))</MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <div class="pa-8 text-center">
                                <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Large" Style="opacity:0.3; font-size:4rem;" Class="mb-4" />
                                <MudText Typo="Typo.h6" Class="mud-text-secondary">No outgoing documents</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">No documents in transit</MudText>
                            </div>
                        </NoRecordsContent>
                    </MudTable>
                </MudHidden>

                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    @if (isLoading)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mb-4" Color="Color.Primary" />
                    }
                    @if (!outgoingDocs.Any())
                    {
                        <div class="pa-8 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Large" Style="opacity:0.3; font-size:3rem;" Class="mb-3" />
                            <MudText Typo="Typo.body1" Class="mud-text-secondary">No outgoing documents</MudText>
                        </div>
                    }
                    else
                    {
                        @foreach (var doc in outgoingDocs)
                        {
                            <MudCard Elevation="2" Class="mb-3 rounded-lg" @onclick="@(() => { selectedDocument = doc; isDialogVisible = true; })">
                                <MudCardContent Class="pa-4">
                                    <div class="d-flex justify-space-between align-start mb-3">
                                        <div style="flex: 1;">
                                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-1">@doc.Name</MudText>
                                            <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text" Class="pa-0">@doc.Type</MudChip>
                                        </div>
                                        <MudChip T="string" Color="@GetPriorityColor(doc.Priority)" Size="Size.Small" Variant="Variant.Filled">@doc.Priority</MudChip>
                                    </div>
                                    <MudDivider Class="mb-3" />
                                    <div class="d-flex flex-column gap-2">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Class="mr-2" Color="Color.Info" />
                                            <div>
                                                <MudText Typo="Typo.body2"><strong>@doc.NextOffice?.Name</strong></MudText>
                                                @if (doc.NextUnit != null)
                                                {
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">↳ @doc.NextUnit.Name</MudText>
                                                }
                                            </div>
                                        </div>
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @(doc.LastActionDate?.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt") ?? doc.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt"))
                                            </MudText>
                                        </div>
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        }
                    }
                    else
                    {
                    <div class="d-flex flex-column align-center mt-10">
                        <MudIcon Icon="@Icons.Material.Filled.BusinessCenter" Size="Size.Large" Style="opacity:0.3; font-size:4rem;" Class="mb-4" />
                        <MudText Typo="Typo.h6" Class="mud-text-secondary">No Office assigned</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Contact your Admin</MudText>

                    </div>
                    }
                </MudHidden>
            </MudTabPanel>

        </MudTabs>
    }

    <MudDialog @bind-Visible="isDialogVisible" Options="dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2 mb-n1" /> Document Details
            </MudText>
        </TitleContent>
        <DialogContent>
            @if (selectedDocument != null)
            {
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Document Title</MudText>
                        <MudText Typo="Typo.body1" Class="font-weight-bold">@selectedDocument.Name</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Document Type</MudText>
                        <MudText Typo="Typo.body1">@selectedDocument.Type</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                        <MudChip T="string" Color="@(selectedDocument.Status == "Received" ? Color.Success : Color.Warning)" Size="Size.Small">
                            @selectedDocument.Status
                        </MudChip>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Priority</MudText>
                        <MudChip T="string" Color="@GetPriorityColor(selectedDocument.Priority)" Size="Size.Small">@selectedDocument.Priority</MudChip>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Created On</MudText>
                        <MudText Typo="Typo.body2">@selectedDocument.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Current Location</MudText>
                        @if (selectedDocument.CurrentOffice != null)
                        {
                            <MudText Typo="Typo.body1" Class="font-weight-bold">@selectedDocument.CurrentOffice.Name</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">↳ @selectedDocument.CurrentUnit?.Name</MudText>
                        }
                        else
                        {

                            <MudText Typo="Typo.body1"><em>None</em></MudText>
                        }
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Next Destination</MudText>
                        @if (selectedDocument.NextOffice != null)
                        {
                            <MudText Typo="Typo.body1" Class="font-weight-bold">@selectedDocument.NextOffice.Name</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">↳ @selectedDocument.NextUnit?.Name</MudText>
                        }
                        else
                        {

                            <MudText Typo="Typo.body1"><em>None</em></MudText>
                        }
                    </MudItem>
                    @if (!string.IsNullOrEmpty(selectedDocument.Description))
                    {
                        <MudItem xs="12">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Description / Notes</MudText>
                            <MudPaper Elevation="0" Class="pa-3 mt-1 mud-background-gray rounded">
                                <MudText Typo="Typo.body2">@selectedDocument.Description</MudText>
                            </MudPaper>
                        </MudItem>
                    }
                    @if (!string.IsNullOrEmpty(selectedDocument.FileName))
                    {
                        <MudItem xs="12">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Attached File</MudText>
                            <div class="d-flex align-center mt-1">
                                <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" Class="mr-2" />
                                <MudText Typo="Typo.body2" Class="mr-4">@selectedDocument.FileName</MudText>
                                <MudButton Href="@selectedDocument.FilePath" Target="_blank" Variant="Variant.Outlined"
                                           Size="Size.Small" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Download">
                                    Download
                                </MudButton>
                            </div>
                        </MudItem>
                    }
                </MudGrid>
            }
        </DialogContent>
        <DialogActions>
            <MudButton Color="Color.Primary" OnClick="CloseDialog">Close</MudButton>
        </DialogActions>
    </MudDialog>

</MudContainer>

@code {
    private Office? myOffice;
    private int? myUnitId;
    private List<Office> allOffices = new();
    private List<Document> incomingDocs = new();
    private List<Document> deskDocs = new();
    private List<Document> outgoingDocs = new();
    private string userEmail = "";
    private bool isLoadingInitial = true;
    private bool isLoading = false;
    private bool isDialogVisible;
    private Document? selectedDocument;
    private DialogOptions dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };

    private class RoutingSelection
    {
        public int? OfficeId { get; set; }
        public int? UnitId { get; set; }
    }

    private Dictionary<int, RoutingSelection> routingSelections = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profile = await DocService.GetProfileAsync();
            if (profile != null)
            {
                userEmail = profile.Email ?? "Unknown";
                myUnitId = profile.UnitId;

                var officeId = profile.Unit?.OfficeId ?? profile.OfficeId;

                if (officeId != null)
                {
                    allOffices = await DocService.GetOfficesAsync();
                    myOffice = allOffices.FirstOrDefault(o => o.Id == officeId);
                }
            }

            if (myOffice != null)
                await RefreshQueues();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            Snackbar.Add("Error loading office data", Severity.Error);
        }
        finally
        {
            isLoadingInitial = false;
        }
    }

    private async Task RefreshQueues()
    {
        if (myOffice == null) return;
        isLoading = true;
        StateHasChanged();

        try
        {
            incomingDocs = await DocService.GetIncomingAsync(myOffice.Id, myUnitId);
            var allDocs = await DocService.GetAllDocumentsAsync();

            deskDocs = allDocs.Where(d =>
                d.CurrentOfficeId == myOffice.Id &&
                d.Status == "Received" &&
                (myUnitId.HasValue ? (d.CurrentUnitId == null || d.CurrentUnitId == myUnitId) : d.CurrentUnitId == null)
            ).ToList();

            outgoingDocs = await DocService.GetOutgoingAsync(userEmail);

            foreach (var doc in deskDocs)
            {
                if (!routingSelections.ContainsKey(doc.Id))
                    routingSelections[doc.Id] = new RoutingSelection();
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void RowClicked(TableRowClickEventArgs<Document> args)
    {
        selectedDocument = args.Item;
        isDialogVisible = true;
    }

    private void CloseDialog() => isDialogVisible = false;

    private void OnOfficeSelected(int docId, int? officeId)
    {
        routingSelections[docId].OfficeId = officeId;
        routingSelections[docId].UnitId = null;
    }

    private IEnumerable<Unit> GetUnitsForOffice(int officeId) =>
        allOffices.FirstOrDefault(o => o.Id == officeId)?.Units ?? new List<Unit>();

    private async Task ReceiveDoc(int docId)
    {
        var result = await DialogService.ShowMessageBox("Confirm Receive", "Accept this document onto your desk?", "Receive", cancelText: "Cancel");
        if (result != true) return;

        var response = await DocService.ReceivedDocumentAsync(docId);
        if (!response)
        {
            Snackbar.Add("This document was already received by another worker", Severity.Warning);
        }
        else
        {
            Snackbar.Add("Document received!", Severity.Success);
        }
        await RefreshQueues();
    }

    private async Task ForwardDoc(int docId)
    {
        var selection = routingSelections[docId];
        if (!selection.OfficeId.HasValue) return;
        var doc = deskDocs.FirstOrDefault(d => d.Id == docId);
        if(doc?.CurrentOfficeId == selection.OfficeId && doc?.CurrentUnitId == selection.UnitId)
        {
            Snackbar.Add("Cannot Forward to the same office and unit", Severity.Warning);
            return;
        }
        var dest = allOffices.FirstOrDefault(o => o.Id == selection.OfficeId)?.Name;
        var result = await DialogService.ShowMessageBox("Confirm Forward", $"Forward this document to {dest}?", "Forward", cancelText: "Cancel");
        if (result != true) return;
        await DocService.ForwardDocumentAsync(docId, selection.OfficeId.Value, selection.UnitId);
        await RefreshQueues();
        Snackbar.Add("Document forwarded successfully!", Severity.Success);
    }

    private async Task FinishDoc(int docId)
    {
        var result = await DialogService.ShowMessageBox("Confirm Finish", "Mark this document as completed? This cannot be undone.", "Finish", cancelText: "Cancel", options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });
        if (result != true) return;
        await DocService.FinishDocumentAsync(docId);
        await RefreshQueues();
        Snackbar.Add("Document completed", Severity.Success);
    }

    private Color GetPriorityColor(string? priority) => priority switch
    {
        "Emergency" => Color.Error,
        "Urgent" => Color.Warning,
        "Medium" => Color.Info,
        "Low" => Color.Success,
        _ => Color.Default
    };
}