@attribute [Authorize(Roles = "Office")]
@using DocTracking.Client
@using DocTracking.Client.Pages.Offices
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject NotificationService NotifService
@inject IDialogService DialogService
@implements IDisposable
@rendermode InteractiveAuto

<style>
    .fade-slide-up {
        animation: fadeSlideUp 0.5s ease-out both;
    }

    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    @if (isLoadingInitial)
    {
        <div class="d-flex align-center mb-6">
            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" Class="mr-3" />
            <div>
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="180px" Height="32px" Class="mb-1" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="280px" />
            </div>
        </div>

        <MudGrid Class="mb-6">
            @for (int i = 0; i < 3; i++)
            {
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="2" Class="pa-4">
                        <div class="d-flex justify-space-between align-center">
                            <div style="flex: 1;">
                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="60px" Height="48px" Class="mb-1" />
                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="120px" />
                            </div>
                            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

        <MudGrid Class="mb-6">
            <MudItem xs="12" md="7">
                <MudPaper Elevation="2" Class="pa-4" Style="min-height: 500px;">
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="160px" />
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" />
                    </div>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" Class="mb-3" />
                            @for (int i = 0; i < 4; i++)
                            {
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="64px" Class="mb-2" />
                            }
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="100px" Class="mb-3" />
                            @for (int i = 0; i < 4; i++)
                            {
                                <MudSkeleton SkeletonType="SkeletonType.Text" Class="mb-2" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="8px" Class="mb-3 rounded-lg" />
                            }
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="5">
                <MudPaper Elevation="2" Class="pa-4" Style="min-height: 500px;">
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="140px" Class="mb-4" />
                    @for (int i = 0; i < 5; i++)
                    {
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="72px" Class="mb-3" />
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    else
    {
        <div class="d-flex align-center mb-6 fade-slide-up">
            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
            <div>
                @if(myUnitId.HasValue){
                <MudText Typo="Typo.h4" Class="font-weight-bold">@myUnitName</MudText>
                }       
                else
                 {
               <MudText Typo="Typo.h4" Class="font-weight-bold">@myOffice?.Name</MudText>
                 }
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Dashboard</MudText>
            </div>
        </div>

        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="4" Style="animation: fadeSlideUp 0.5s ease-out 0.1s both;">
                <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-error);">
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Error">@incomingDocs.Count</MudText>
                            <MudText Typo="Typo.body2">Incoming</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Error" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4" Style="animation: fadeSlideUp 0.5s ease-out 0.2s both;">
                <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-warning);">
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Warning">@deskDocs.Count</MudText>
                            <MudText Typo="Typo.body2">On Desk</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Large" Color="Color.Warning" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4" Style="animation: fadeSlideUp 0.5s ease-out 0.3s both;">
                <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-info);">
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Info">@outgoingDocs.Count</MudText>
                            <MudText Typo="Typo.body2">Outgoing</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Large" Color="Color.Info" />
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudGrid Class="mb-6" Style="align-items: stretch; animation: fadeSlideUp 0.5s ease-out 0.4s both;">
            <MudItem xs="12" md="7" Style="display: flex; flex-direction: column;">
                <MudPaper Elevation="2" Class="pa-4 flex-grow-1" Style="display: flex; flex-direction: column;">
                    <div class="d-flex align-center justify-space-between mb-4">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.ViewKanban" Class="mr-2" Color="Color.Primary" />
                            <MudText Typo="Typo.h6">Document Queue</MudText>
                        </div>
                        <MudButton Href="/office-desk" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">
                            Manage
                        </MudButton>
                    </div>
                    <div class="d-flex gap-4" style="flex: 1; min-height: 0; align-items: stretch;">
                        <div style="flex: 1; background: rgba(var(--mud-palette-error-rgb), 0.08); border-radius: 8px; padding: 12px; overflow-y: auto;">
                            <MudText Typo="Typo.subtitle2" Color="Color.Error" Class="mb-3 font-weight-bold">Incoming</MudText>
                            @{
                                int incomingIndex = 0;
                            }
                            @foreach (var doc in incomingDocs.Take(5))
                            {
                                <MudPaper Elevation="1" Class="pa-3 mb-2" Style="@($"animation: fadeSlideUp 0.3s ease both; animation-delay: {incomingIndex++ * 60}ms;")">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold mb-1">@doc.Name</MudText>
                                    <div class="d-flex justify-space-between align-center">
                                        <MudChip T="string" Size="Size.Small" Color="@DocHelpers.GetPriorityColor(doc.Priority)" Variant="Variant.Filled">@doc.Priority</MudChip>
                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Primary"
                                                       OnClick="@(async () => await OpenDeskDialog(doc, OfficeDeskViewDialog.DeskTab.Incoming))" />
                                    </div>
                                </MudPaper>
                            }
                            @if (!incomingDocs.Any())
                            {
                                <div class="d-flex flex-column align-center pa-4">
                                    <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Error" Style="opacity:0.5;" />
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">No incoming documents</MudText>
                                </div>
                            }
                        </div>
                        <div style="flex: 1; background: rgba(var(--mud-palette-warning-rgb), 0.08); border-radius: 8px; padding: 12px; overflow-y: auto;">
                            <MudText Typo="Typo.subtitle2" Color="Color.Warning" Class="mb-3 font-weight-bold">On Desk</MudText>
                            @{
                                int deskIndex = 0;
                            }
                            @foreach (var doc in deskDocs.Take(5))
                            {
                                <MudPaper Elevation="1" Class="pa-3 mb-2" Style="@($"animation: fadeSlideUp 0.3s ease both; animation-delay: {deskIndex++ * 60}ms;")">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold mb-1">@doc.Name</MudText>
                                    <div class="d-flex justify-space-between align-center">
                                        <MudChip T="string" Size="Size.Small" Color="@DocHelpers.GetPriorityColor(doc.Priority)" Variant="Variant.Filled">@doc.Priority</MudChip>
                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Primary"
                                                       OnClick="@(async () => await OpenDeskDialog(doc, OfficeDeskViewDialog.DeskTab.OnDesk))" />
                                    </div>
                                </MudPaper>
                            }
                            @if (!deskDocs.Any())
                            {
                                <div class="d-flex flex-column align-center pa-4">
                                    <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Size="Size.Large" Color="Color.Warning" Style="opacity:0.5;" />
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">Desk is clear</MudText>
                                </div>
                            }
                        </div>
                    </div>
                </MudPaper>
            </MudItem>


            <MudItem xs="12" md="5" Style="display: flex; flex-direction: column;">
                <MudPaper Elevation="2" Class="pa-4 flex-grow-1">
                    <div style="flex-grow: 1; overflow-y: auto; max-height: 400px;">
                        <MudIcon Icon="@Icons.Material.Filled.Timeline" Class="mr-2" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Recent Activity</MudText>
                    </div>
                    <div style="flex-grow: 1; overflow-y: auto;">
                        @if (!recentDocs.Any())
                        {
                            <div class="text-center pa-6">
                                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Style="opacity: 0.3;" />
                                <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">No recent activity</MudText>
                            </div>
                        }
                        else
                        {
                            <MudTimeline TimelinePosition="TimelinePosition.Start">
                                @foreach (var doc in recentDocs.Take(4))
                                {
                                    <MudTimelineItem Color="@DocHelpers.GetStatusColor(doc.Status)"
                                                     Size="Size.Small" TimelineAlign="TimelineAlign.Default">
                                        <ItemContent>
                                            <MudCard Elevation="1" Class="mb-1" Style="min-width:0;">
                                                <MudCardContent Class="pa-3">
                                                    <MudText Typo="Typo.body2" Class="font-weight-bold text-truncate">@doc.Name</MudText>
                                                    <div class="d-flex align-center justify-space-between mt-1 flex-wrap gap-1">
                                                        <MudChip T="string" Size="Size.Small"
                                                                 Color="@DocHelpers.GetStatusColor(doc.Status)"
                                                                 Variant="Variant.Outlined">
                                                            @doc.Status
                                                        </MudChip>
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                            @doc.LastActionDate?.ToLocalTime().ToString("MMM dd, hh:mm tt")
                                                        </MudText>
                                                    </div>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                                                        @doc.Creator?.Name
                                                    </MudText>
                                                </MudCardContent>
                                            </MudCard>
                                        </ItemContent>
                                    </MudTimelineItem>
                                }
                            </MudTimeline>
                        }
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

    }
</MudContainer>

@code {
    private Office? myOffice;
    private int? myUnitId;
    private List<Document> incomingDocs = new();
    private List<Document> deskDocs = new();
    private List<Document> outgoingDocs = new();
    private List<Document> recentDocs = new();
    private readonly DebounceHelper _debounce = new();
    private string userEmail = "";
    private bool isLoadingInitial = true;

    private string? myUnitName;


    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profile = await DocService.GetProfileAsync();
            if (profile != null)
            {
                userEmail = profile.Email ?? "";
                myUnitId = profile.UnitId;
                myUnitName = profile.Unit?.Name;

                var officeId = profile.Unit?.OfficeId ?? profile.OfficeId;

                if (officeId != null)
                {
                    myOffice = await DocService.GetOfficeByIdAsync(officeId.Value);
                }
            }

            if (myOffice != null)
                await RefreshData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            Snackbar.Add("Error loading dashboard", Severity.Error);
        }
        finally { isLoadingInitial = false; }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            NotifService.OnChange += OnNotificationReceived;
        return Task.CompletedTask;
    }

    private void OnNotificationReceived() =>
    _debounce.Trigger(async () =>
    {
        await RefreshData();
        await InvokeAsync(StateHasChanged);
    });

    private async Task RefreshData()
    {
        if (myOffice == null) return;
        try
        {
            incomingDocs = await DocService.GetIncomingAsync(myOffice.Id, myUnitId);
            deskDocs = await DocService.GetDeskDocumentsAsync(myOffice.Id, myUnitId.HasValue ? myUnitId : null);
            outgoingDocs = await DocService.GetOutgoingAsync();

            var officeDocs = myUnitId.HasValue
                ? await DocService.GetUnitHistoryAsync(myUnitId.Value, page: 1, pageSize: 5)
                : await DocService.GetOfficeHistoryAsync(myOffice.Id, page: 1, pageSize: 5);
            recentDocs = officeDocs.Items;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[OfficeHome] RefreshData error: {ex.Message}");
            Snackbar.Add("Failed to refresh dashboard.", Severity.Warning);
        }
    }

    private async Task OpenDeskDialog(Document doc, OfficeDeskViewDialog.DeskTab tab)
    {
        var parameters = new DialogParameters<OfficeDeskViewDialog>
    {
        { x => x.Doc, doc },
        { x => x.Tab, tab }
    };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<OfficeDeskViewDialog>("Document Details", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await RefreshData();
    }

    public void Dispose()
    {
        NotifService.OnChange -= OnNotificationReceived;
        _debounce.Dispose();
    }
}