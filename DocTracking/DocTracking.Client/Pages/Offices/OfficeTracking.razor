@page "/office-track-document/{DocumentId:int}"
@attribute [Authorize(Roles = "Office")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Pages.Shared
@using Microsoft.AspNetCore.Components.Authorization
@inject DocumentService DocService
@inject NavigationManager Navigation
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-8">
    <div class="d-flex align-center mb-6">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default" OnClick="Back" Class="mr-2" Size="Size.Large" />
        <div class="d-flex flex-column flex-sm-row align-start align-sm-center gap-2">
            <MudText Typo="Typo.h4" Class="font-weight-bold">Document Tracking</MudText>
            @if (documentLogs.Any() && documentLogs.First().Document?.ReferenceNumber != null)
            {
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Medium">
                    @documentLogs.First().Document?.ReferenceNumber
                </MudChip>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-center mt-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (!isAuthorized)
    {
        <MudPaper Elevation="0" Class="pa-8 text-center mud-background-gray rounded-xl border-solid border-2 mud-border-error">
            <MudIcon Icon="@Icons.Material.Filled.GppBad" Size="Size.Large" Color="Color.Error" Class="mb-4" Style="font-size: 4rem;" />
            <MudText Typo="Typo.h5" Class="font-weight-bold mb-2">Access Denied</MudText>
            <MudText Typo="Typo.body1" Class="mud-text-secondary">You do not have authorization to view this document's history because it has not been routed through your office.</MudText>
        </MudPaper>
    }
    else
    {
        <TrackingTimeline Logs="documentLogs" IsLoading="false" ErrorMessage="errorMessage" />
    }
</MudContainer>

@code {
    [Parameter] public int DocumentId { get; set; }
    [Parameter][SupplyParameterFromQuery(Name = "ReturnUrl")] public string? ReturnUrl { get; set; }

    private List<DocumentLog> documentLogs = new();
    private bool isLoading = true;
    private bool isAuthorized = false;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        isAuthorized = false;
        try
        {
            var profile = await DocService.GetProfileAsync();
            int? myUnitId = profile?.UnitId;
            int? myOfficeId = profile?.Unit?.OfficeId ?? profile?.OfficeId;
            documentLogs = await DocService.GetDocumentLogsAsync(DocumentId);
            isAuthorized = (myUnitId.HasValue && documentLogs.Any(log => log.UnitId == myUnitId)) ||
               (myOfficeId.HasValue && documentLogs.Any(log => log.OfficeId == myOfficeId));
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void Back()
    {
        if (string.IsNullOrEmpty(ReturnUrl))
            Navigation.NavigateTo("/");
        else
            Navigation.NavigateTo(ReturnUrl.StartsWith('/') ? ReturnUrl : $"/{ReturnUrl}");
    }
}
