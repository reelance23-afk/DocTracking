@page "/office-track-document/{DocumentId:int}"
@attribute [Authorize(Roles = "Office")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject DocumentService DocService
@inject NavigationManager Navigation
@rendermode @(new InteractiveAutoRenderMode(prerender: false))

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-8">
    <div class="d-flex align-center mb-6">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default" OnClick="Back" Class="mr-2" />
        <MudText Typo="Typo.h4" Class="font-weight-bold">Document Tracking</MudText>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-center mt-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (!isAuthorized)
    {
        <MudPaper Elevation="0" Class="pa-8 text-center mud-background-gray rounded-xl border-solid border-2 mud-border-error">
            <MudIcon Icon="@Icons.Material.Filled.GppBad" Size="Size.Large" Color="Color.Error" Class="mb-4" Style="font-size: 4rem;" />
            <MudText Typo="Typo.h5" Class="font-weight-bold mb-2">Access Denied</MudText>
            <MudText Typo="Typo.body1" Class="mud-text-secondary">You do not have authorization to view this document's history because it has not been routed through your office.</MudText>
        </MudPaper>
    }
    else if (!documentLogs.Any())
    {
        <MudPaper Elevation="0" Class="pa-8 text-center mud-background-gray rounded-xl">
            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Style="opacity: 0.5; font-size: 4rem;" Class="mb-4" />
            <MudText Typo="Typo.h6" Class="mud-text-secondary">No tracking history found.</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="3" Class="pa-6 rounded-xl">

            <MudTimeline TimelinePosition="TimelinePosition.Start" Class="w-100">
                @for (int i = 0; i < documentLogs.Count; i++)
                {
                    var log = documentLogs[i];
                    bool isCurrent = (i == 0);

                    Color dotColor = isCurrent ? Color.Success : Color.Default;
                    Size dotSize = isCurrent ? Size.Large : Size.Small;
                    bool fillDot = isCurrent;
                    string dotIcon = GetIconForAction(log.Action);
                    string paperOpacity = isCurrent ? "opacity-100" : "opacity-60";
                    string paperBorder = isCurrent ? "border-solid border-l-4 mud-border-success" : "";

                    <MudTimelineItem Color="@dotColor" Size="@dotSize" Variant="@(fillDot? Variant.Filled: Variant.Outlined)" Icon="@dotIcon">
                        <ItemContent>
                            <MudPaper Elevation="@(isCurrent ? 2 : 0)" Class="@($"pa-4 mb-2 rounded-lg {paperBorder} {paperOpacity}")" Style="@(!isCurrent ? "background-color: transparent;" : "")">

                                <div class="d-flex align-center gap-2 mb-1">
                                    <MudText Typo="Typo.caption" Class="@(isCurrent ? "mud-text-success font-weight-bold" : "mud-text-secondary")">
                                        @log.TimeStamp.ToLocalTime().ToString("MMM dd, yyyy • hh:mm tt")
                                    </MudText>
                                </div>

                                <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">@log.Action</MudText>

                                <div class="d-flex flex-column gap-1">
                                    <MudText Typo="Typo.body2">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1 mb-n1 mud-text-secondary" />
                                        By: <strong>@(log.AppUser?.Email ?? "System")</strong>
                                    </MudText>

                                    @if (log.Action == "Created" || log.Action == "Forwarded")
                                    {
                                        <MudText Typo="Typo.body2">
                                            <MudIcon Icon="@Icons.Material.Filled.DirectionsWalk" Size="Size.Small" Class="mr-1 mb-n1 mud-text-secondary" />
                                            Heading to: <strong>@(log.Office?.Name ?? "N/A")</strong>
                                            <span class="mud-text-secondary">@(log.Unit != null ? $" ↳ {log.Unit.Name}" : "")</span>
                                        </MudText>
                                    }
                                    else if (log.Action == "Received" || log.Action == "Completed")
                                    {
                                        <MudText Typo="Typo.body2">
                                            <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Class="mr-1 mb-n1 mud-text-secondary" />
                                            At: <strong>@(log.Office?.Name ?? "N/A")</strong>
                                            <span class="mud-text-secondary">@(log.Unit != null ? $" ↳ {log.Unit.Name}" : "")</span>
                                        </MudText>
                                    }
                                </div>

                            </MudPaper>
                        </ItemContent>
                    </MudTimelineItem>
                }
            </MudTimeline>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4">
                    Error loading data: @errorMessage
                </MudAlert>
            }
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter]
    public int DocumentId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "ReturnUrl")]
    public string? ReturnUrl { get; set; }

    private List<DocumentLog> documentLogs = new();
    private bool isLoading = true;
    private bool isAuthorized = false;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        isAuthorized = false;

        try
        {

            var profile = await DocService.GetProfileAsync();
            int? myUnitId = profile?.UnitId;


            documentLogs = await DocService.GetDocumentLogsAsync(DocumentId);


            if (myUnitId.HasValue && documentLogs.Any(log => log.UnitId == myUnitId.Value))
            {
                isAuthorized = true; 
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"Error loading logs: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetIconForAction(string? action)
    {
        return action switch
        {
            "Created" => Icons.Material.Filled.NoteAdd,
            "Forwarded" => Icons.Material.Filled.DirectionsWalk,
            "Received" => Icons.Material.Filled.Inbox,
            "Completed" => Icons.Material.Filled.CheckCircle,
            _ => Icons.Material.Filled.Circle
        };
    }

    private void Back()
    {
        Navigation.NavigateTo($"/{ReturnUrl}");
    }
}