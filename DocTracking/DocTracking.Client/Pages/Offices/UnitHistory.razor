@page "/unit-history"
@attribute [Authorize(Roles = "Office")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject DocumentService DocService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@rendermode @(new InteractiveAutoRenderMode(prerender: false))

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">
    <div class="mb-6">
        <div class="d-flex align-center mb-4">
            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Class="mr-3" Color="Color.Primary" />
            <MudText Typo="Typo.h4" Class="font-weight-bold">@(isOfficeHead ? "Office History" : "Unit History")</MudText>
        </div>
        <MudText Typo="Typo.body1" Class="mud-text-secondary mb-4">A complete record of all documents processed by @myUnitName.</MudText>
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudPaper Style="border-top: 4px solid var(--mud-palette-warning);" Elevation="2" Class="pa-4 rounded-lg">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Warning">@historyDocs.Count(d => d.Status != "Received" && d.Status != "Completed")</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Warning">In Motion</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.DirectionsWalk" Size="Size.Large" Color="Color.Warning" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Style="border-top: 4px solid var(--mud-palette-success);" Elevation="2" Class="pa-4 rounded-lg">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Success">@historyDocs.Count(d => d.Status == "Received")</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Success">Received</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Style="border-top: 4px solid var(--mud-palette-info);" Elevation="2" Class="pa-4 rounded-lg">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Info">@historyDocs.Count(d => d.Status == "Completed")</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Info">Completed</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Info" />
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </div>

    @if (isLoading)
    {
        <MudPaper Elevation="2" Class="pa-8 text-center rounded-lg">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mb-4" />
            <MudText>Loading history...</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="3" Class="pa-4 pa-md-6 rounded-lg">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6">@myUnitName Records</MudText>
                <MudTextField @bind-Value="searchString" Placeholder="Search documents..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" />
            </div>

            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudTable Items="@filteredDocs" Hover="true" T="Document">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<Document, object>(x => x.Name)">Document Title</MudTableSortLabel></MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Priority</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<Document, object>(x => x.CreatedAt)">Created On</MudTableSortLabel></MudTh>
                        <MudTh>Current Location</MudTh>
                        <MudTh>Action</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Document Title"><strong>@context.Name</strong></MudTd>
                        <MudTd DataLabel="Type">@context.Type</MudTd>
                        <MudTd DataLabel="Priority">
                            <MudChip T="string" Color="@GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">@context.Priority</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Color="@(context.Status == "Completed" ? Color.Success : context.Status == "Received" ? Color.Info : Color.Warning)" Size="Size.Small" Variant="Variant.Filled">@context.Status</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Created On">@context.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</MudTd>
                        <MudTd DataLabel="Current Location">
                            @if (context.CurrentOffice != null)
                            {
                                <MudText Typo="Typo.body2"><strong>@context.CurrentOffice.Name</strong><br /><span style="color: gray; font-size: 0.85em;">↳ @(context.CurrentUnit?.Name)</span></MudText>
                            }
                            else if (context.NextOffice != null)
                            {
                                <MudText Typo="Typo.body2"><span style="color: #ff9800; font-size: 0.85em; font-style: italic;">Routing to:</span><br /><strong>@context.NextOffice.Name</strong></MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Default"><em>Completed / None</em></MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Action">
                            <MudButton Href="@($"/office-track-document/{context.Id}?ReturnUrl=unit-history")" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Timeline">Track</MudButton>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4">@(isOfficeHead ? "Your office has not handled any documents yet." : "Your unit has not handled any documents yet.")</MudText>
                    </NoRecordsContent>
                    <PagerContent><MudTablePager /></PagerContent>
                </MudTable>
            </MudHidden>

            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                @if (!filteredDocs.Any())
                {
                    <MudPaper Elevation="0" Class="pa-8 text-center">
                        <MudText Class="mud-text-secondary">@(isOfficeHead ? "Your office has not handled any documents yet." : "Your unit has not handled any documents yet.")</MudText>
                    </MudPaper>
                }
                else
                {
                    @foreach (var doc in filteredDocs)
                    {
                        <MudCard Elevation="2" Class="mb-3">
                            <MudCardContent Class="pa-4">
                                <div class="d-flex justify-space-between align-start mb-2">
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@doc.Name</MudText>
                                    <MudChip T="string" Color="@GetPriorityColor(doc.Priority)" Size="Size.Small" Variant="Variant.Filled">@doc.Priority</MudChip>
                                </div>
                                <div class="d-flex gap-2 mb-2">
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined">@doc.Type</MudChip>
                                    <MudChip T="string" Color="@(doc.Status == "Completed" ? Color.Success : doc.Status == "Received" ? Color.Info : Color.Warning)" Size="Size.Small" Variant="Variant.Filled">@doc.Status</MudChip>
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                    @doc.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                                </MudText>
                                @if (doc.CurrentOffice != null)
                                {
                                    <MudText Typo="Typo.body2" Class="mb-2">
                                        <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Class="mr-1" />
                                        <strong>@doc.CurrentOffice.Name</strong>
                                        @if (doc.CurrentUnit != null)
                                        {
                                            <span class="mud-text-secondary"> ↳ @doc.CurrentUnit.Name</span>
                                        }
                                    </MudText>
                                }
                                else if (doc.NextOffice != null)
                                {
                                    <MudText Typo="Typo.body2" Class="mb-2">
                                        <MudIcon Icon="@Icons.Material.Filled.DirectionsWalk" Size="Size.Small" Class="mr-1" />
                                        <span style="color:#ff9800;">Routing to: </span><strong>@doc.NextOffice.Name</strong>
                                    </MudText>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2" Class="mb-2 mud-text-secondary">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" />Completed
                                    </MudText>
                                }
                            </MudCardContent>
                            <MudCardActions Class="pa-4 pt-0">
                                <MudButton Href="@($"/office-track-document/{doc.Id}?ReturnUrl=unit-history")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Timeline" FullWidth="true" Size="Size.Large">Track Document</MudButton>
                            </MudCardActions>
                        </MudCard>
                    }
                }
            </MudHidden>
        </MudPaper>
    }
</MudContainer>

@code {
    private List<Document> historyDocs = new();
    private bool isLoading = true;
    private string myUnitName = "Unit";
    private bool isOfficeHead = false;
    private string searchString = "";

    private IEnumerable<Document> filteredDocs => historyDocs.Where(d =>
        string.IsNullOrWhiteSpace(searchString) ||
        d.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true ||
        d.Type?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true ||
        d.Status?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true ||
        d.CurrentOffice?.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profile = await DocService.GetProfileAsync();
            if (profile?.UnitId != null)
            {
                myUnitName = profile.Unit?.Name ?? "Unit";
                historyDocs = await DocService.GetUnitHistoryAsync(profile.UnitId.Value);
            }
            else if (profile?.OfficeId != null)
            {
                isOfficeHead = true;
                myUnitName = profile.Office?.Name ?? "Office";
                historyDocs = await DocService.GetOfficeHistoryAsync(profile.OfficeId.Value);
            }
        }
        catch (Exception ex) { Console.WriteLine($"Error loading history: {ex.Message}"); }
        finally { isLoading = false; StateHasChanged(); }
    }

    private Color GetPriorityColor(string? priority) => priority switch
    {
        "Emergency" => Color.Error,
        "Urgent" => Color.Warning,
        "Medium" => Color.Info,
        "Low" => Color.Success,
        _ => Color.Default
    };
}
