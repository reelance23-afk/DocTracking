@page "/unit-history"
@attribute [Authorize(Roles = "Office,Admin")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject NotificationService NotifService
@implements IDisposable
@rendermode @(new InteractiveAutoRenderMode(prerender: false))

<style>
    .fade-slide-up {
        animation: fadeSlideUp 0.5s ease-out both;
    }

    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes rowFadeIn {
        from {
            opacity: 0;
            transform: translateX(-20px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@media (max-width: 600px) {
        .actions-cell {
            text-align: right;
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">
    <div class="mb-6 fade-slide-up">
        <div class="d-flex align-center mb-4">
            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Class="mr-3" Color="Color.Primary" />
            <MudText Typo="Typo.h4" Class="font-weight-bold">@(isOfficeHead ? "Office History" : "Unit History")</MudText>
        </div>
        <MudText Typo="Typo.body1" Class="mud-text-secondary mb-4">A complete record of all documents processed by @myUnitName.</MudText>
        @if (isLoading)
        {
            <MudGrid>
                @for (int i = 0; i < 3; i++)
                {
                    <MudItem xs="12" sm="4">
                        <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                            <div class="d-flex align-center justify-space-between">
                                <div>
                                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="60px" Height="48px" Class="mb-1" />
                                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" />
                                </div>
                                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                            </div>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
        else
        {
            <DocStatCards InMotion="@_stats.InMotion" Received="@_stats.Received" Completed="@_stats.Completed" />
        }

    </div>

    @if (isLoading)
    {
        <MudPaper Elevation="3" Class="pa-4 pa-md-6 rounded-lg" Style="animation: fadeSlideUp 0.5s ease-out 0.1s both;">
            <div class="d-flex justify-space-between align-center mb-4">
                <div>
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="160px" Height="28px" Class="mb-1" />
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="220px" />
                </div>
            </div>
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="40px" Class="mb-4" />
            @for (int i = 0; i < 8; i++)
            {
                <div class="d-flex align-center justify-space-between pa-3">
                    <div class="d-flex align-center gap-2" style="flex:1;">
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="180px" Class="mb-1" />
                    </div>
                    <div class="d-flex gap-2">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="60px" Height="24px" />
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="60px" Height="24px" />
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="90px" Height="32px" />
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" />
                    </div>
                </div>
                @if (i < 7)
                {
                    <MudDivider />
                }
            }
        </MudPaper>
    }

    else
    {

        <div class="d-flex justify-space-between align-center mb-4" Style="animation: fadeSlideUp 0.5s ease-out 0.1s both;">
            <div>
                <MudText Typo="Typo.h6" Class="font-weight-bold">@myUnitName Records</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">All documents processed by @myUnitName.</MudText>
            </div>
        </div>

        <MudTextField @bind-Value="searchString"
                      @bind-Value:after="OnSearchChanged"
                      DebounceInterval="400"
                      Placeholder="Search documents..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" Variant="Variant.Outlined" Margin="Margin.Dense"
                      Class="mb-4" Style="animation: fadeSlideUp 0.5s ease-out 0.2s both;" />

        <MudPaper Elevation="3" Style="animation: fadeSlideUp 0.5s ease-out 0.3s both;">
            <MudTable Items="@historyResult.Items" Hover="true" T="Document" Elevation="0"
                      Dense="true" Breakpoint="Breakpoint.Sm"
                      RowStyleFunc="@((item, index) => $"animation: rowFadeIn 0.3s ease both; animation-delay: {Math.Min(index, 10) * 40}ms;")">
                <HeaderContent>
                    <MudTh>Document</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Priority</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Created</MudTh>
                    <MudTh>Location</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Document"><strong>@context.Name</strong></MudTd>
                    <MudTd DataLabel="Type">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info">@context.Type</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Priority">
                        <MudChip T="string" Color="@DocHelpers.GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">
                            @context.Priority
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="@DocHelpers.GetStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Outlined">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("MMM dd, hh:mm tt")</MudTd>
                    <MudTd DataLabel="Location">
                        @if (context.CurrentOffice != null)
                        {
                            <MudText Typo="Typo.body2">
                                <strong>@context.CurrentOffice.Name</strong>
                                @if (context.CurrentUnit != null)
                                {
                                    <br />
                        
                                    <span style="color: gray; font-size: 0.85em;">↳ @context.CurrentUnit.Name</span>
                                }
                            </MudText>
                        }
                        else if (context.NextOffice != null)
                        {
                            <MudText Typo="Typo.body2">
                                <span style="color: #ff9800; font-size: 0.85em; font-style: italic;">Routing to:</span><br />
                                <strong>@context.NextOffice.Name</strong>
                                @if (context.NextUnit != null)
                                {
                                    <br />
                        
                                    <span style="color: gray; font-size: 0.85em;">↳ @context.NextUnit.Name</span>
                                }
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Default"><em>None</em></MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align:left;">
                        <div class="actions-cell">
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Visibility"
                                       OnClick="@(async () => await OpenViewDialog(context))">View</MudButton>
                            <MudIconButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                                           Icon="@Icons.Material.Filled.QrCode"
                                           OnClick="@(async () => await OpenQRDialog(context))" />
                        </div>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="pa-8 text-center">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Style="opacity: 0.3; font-size: 4rem;" Class="mb-4" />
                        <MudText Typo="Typo.h6" Class="mud-text-secondary">@(isOfficeHead ? "Your office has not handled any documents yet." : "Your unit has not handled any documents yet.")</MudText>
                    </div>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "ref")] public string? RefParam { get; set; }
    [SupplyParameterFromQuery(Name = "search")] public string? SearchParam { get; set; }

    private PagedResult<Document> historyResult = new();
    private LocationDocStats _stats = new();
    private bool isLoading = true;
    private bool isLoadingMore = false;
    private string myUnitName = "Unit";
    private bool isOfficeHead = false;
    private string searchString = "";
    private bool dialogOpened = false;
    private int currentPage = 1;
    private const int PageSize = 25;
    private int? myUnitId;
    private int? myOfficeId;
    private readonly DebounceHelper _debounce = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!string.IsNullOrEmpty(SearchParam))
                searchString = SearchParam;

            var profile = await DocService.GetProfileAsync();
            if (profile?.UnitId != null)
            {
                myUnitId = profile.UnitId;
                myUnitName = profile.Unit?.Name ?? "Unit";
                var statsTask = DocService.GetLocationDocStatsAsync(profile.UnitId, null);
                var historyTask = DocService.GetUnitHistoryAsync(profile.UnitId.Value, currentPage, PageSize);
                await Task.WhenAll(historyTask, statsTask);
                historyResult = historyTask.Result;
                _stats = statsTask.Result ?? new();
            }
            else if (profile?.OfficeId != null)
            {
                isOfficeHead = true;
                myOfficeId = profile.OfficeId;
                myUnitName = profile.Office?.Name ?? "Office";
                var statsTask = DocService.GetLocationDocStatsAsync(null, profile.OfficeId);
                var historyTask = DocService.GetOfficeHistoryAsync(profile.OfficeId.Value, currentPage, PageSize, isOfficeHead: true);
                await Task.WhenAll(historyTask, statsTask);
                historyResult = historyTask.Result;
                _stats = statsTask.Result ?? new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading history: {ex.Message}");
            Snackbar.Add("Failed to load document history.", Severity.Error);
        }
        finally { isLoading = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            NotifService.OnChange += OnNotificationReceived;

        if (!dialogOpened && !isLoading && !string.IsNullOrEmpty(RefParam))
        {
            dialogOpened = true;
            var doc = historyResult.Items.FirstOrDefault(d => d.ReferenceNumber == RefParam)
                      ?? await DocService.GetDocumentByRefAsync(RefParam);
            if (doc != null)
            {
                var tab = doc.Status == "Received" || (doc.Status == "In Motion" && doc.CurrentOfficeId != null)
                    ? OfficeDeskViewDialog.DeskTab.OnDesk
                    : OfficeDeskViewDialog.DeskTab.Outgoing;

                var parameters = new DialogParameters<OfficeDeskViewDialog>
            {
                { x => x.Doc, doc },
                { x => x.Tab, tab }
            };
                var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
                await DialogService.ShowAsync<OfficeDeskViewDialog>(doc.Name ?? "Document Details", parameters, options);
            }
        }
    }


    private async Task OnSearchChanged()
    {
        currentPage = 1;
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        try
        {
            if (myUnitId.HasValue)
            {
                historyResult = await DocService.GetUnitHistoryAsync(myUnitId.Value, currentPage, PageSize, searchString);
                _stats = await DocService.GetLocationDocStatsAsync(myUnitId, null) ?? new();
            }
            else if (myOfficeId.HasValue)
            {
                historyResult = await DocService.GetOfficeHistoryAsync(myOfficeId.Value, currentPage, PageSize, searchString, isOfficeHead: true);
                _stats = await DocService.GetLocationDocStatsAsync(null, myOfficeId) ?? new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[UnitHistory] LoadHistory error: {ex.Message}");
            Snackbar.Add("Failed to load history.", Severity.Error);
        }
    }


    private async Task LoadMore()
    {
        isLoadingMore = true;
        try
        {
            currentPage++;
            PagedResult<Document> next;

            if (myUnitId.HasValue)
                next = await DocService.GetUnitHistoryAsync(myUnitId.Value, currentPage, PageSize, searchString);
            else if (myOfficeId.HasValue)
                next = await DocService.GetOfficeHistoryAsync(myOfficeId.Value, currentPage, PageSize, searchString);
            else return;

            historyResult.Items.AddRange(next.Items);
            historyResult.TotalCount = next.TotalCount;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[UnitHistory] LoadMore error: {ex.Message}");
            Snackbar.Add("Failed to load more.", Severity.Error);
        }
        finally { isLoadingMore = false; }
    }

    private async Task OpenViewDialog(Document doc)
    {
        var parameters = new DialogParameters<DocumentViewDialog> { { x => x.Doc, doc } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<DocumentViewDialog>("Document Details", parameters, options);
    }

    private async Task OpenQRDialog(Document doc)
    {
        var parameters = new DialogParameters<QRCodeDialog>
        {
            { x => x.DocumentId, doc.Id },
            { x => x.ReferenceNumber, doc.ReferenceNumber }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<QRCodeDialog>("QR Code", parameters, options);
    }

    private void OnNotificationReceived() =>
    _debounce.Trigger(async () =>
    {
        await LoadHistory();
        await InvokeAsync(StateHasChanged);
    });

    public void Dispose()
    {
        NotifService.OnChange -= OnNotificationReceived;
        _debounce.Dispose();
    }
}
