@using DocTracking.Client
@using DocTracking.Client.Pages.Users
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@rendermode InteractiveAuto

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Class="font-weight-bold">@Doc.Name</MudText>
            <MudChip T="string" Color="@DocHelpers.GetPriorityColor(Doc.Priority)" Size="Size.Small" Variant="Variant.Filled">@Doc.Priority</MudChip>
        </div>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Type</MudText>
                <MudText Typo="Typo.body1">@Doc.Type</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                <MudChip T="string" Color="@DocHelpers.GetStatusColor(Doc.Status)" Size="Size.Small">@Doc.Status</MudChip>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Sender</MudText>
                <MudText Typo="Typo.body1">@(Doc.Creator?.Name ?? "—")</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Created On</MudText>
                <MudText Typo="Typo.body2">@Doc.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Current Location</MudText>
                @if (Doc.CurrentOffice != null)
                {
                    <MudText Typo="Typo.body1" Class="font-weight-bold">@Doc.CurrentOffice.Name</MudText>
                    @if (Doc.CurrentUnit != null)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">↳ @Doc.CurrentUnit.Name</MudText>
                    }
                }
                else
                {
                    <MudText Typo="Typo.body2"><em>None</em></MudText>
                }
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Next Destination</MudText>
                @if (Doc.NextOffice != null)
                {
                    <MudText Typo="Typo.body1" Class="font-weight-bold">@Doc.NextOffice.Name</MudText>
                    @if (Doc.NextUnit != null)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">↳ @Doc.NextUnit.Name</MudText>
                    }
                }
                else
                {
                    <MudText Typo="Typo.body2"><em>None</em></MudText>
                }
            </MudItem>
            @if (!string.IsNullOrEmpty(Doc.Description))
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Description</MudText>
                    <MudPaper Elevation="0" Class="pa-3 mt-1 mud-background-gray rounded">
                        <MudText Typo="Typo.body2">@Doc.Description</MudText>
                    </MudPaper>
                </MudItem>
            }
            @if (Doc.Attachments.Any())
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Attachments</MudText>
                    @foreach (var attachment in Doc.Attachments)
                    {
                        <div class="d-flex align-center mt-1 gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" />
                            <MudText Typo="Typo.body2">@attachment.FileName</MudText>
                            <MudIconButton Href="@attachment.FilePath" Target="_blank"
                                           Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.Download" />
                        </div>
                    }
                </MudItem>
            }

            @if (Tab == DeskTab.Incoming)
            {
                @if (!string.IsNullOrEmpty(Doc.Comment))
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Comment from Forwarding Office</MudText>
                        <MudPaper Elevation="0" Class="pa-3 mt-1 rounded" Style="background: rgba(var(--mud-palette-info-rgb), 0.08); border-left: 3px solid var(--mud-palette-info);">
                            <MudText Typo="Typo.body2">@Doc.Comment</MudText>
                        </MudPaper>
                    </MudItem>
                }
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudButton Color="Color.Success" Variant="Variant.Filled" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Inbox" OnClick="ReceiveAsync" Disabled="busy">
                        Receive Document
                    </MudButton>
                </MudItem>
            }

            @if (Tab == DeskTab.OnDesk)
            {
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudTextField @bind-Value="comment" Label="Comment (optional)" Variant="Variant.Outlined"
                                  Lines="2" Placeholder="Add a note before forwarding or finishing..."
                                  Class="mb-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-bold">Route To</MudText>
                    @if (_loadingOffices)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mb-3" />
                    }
                    else
                    {
                        <MudAutocomplete T="Office"
                                         Label="Select Office"
                                         Value="_selectedOffice"
                                         ValueChanged="OnOfficeAutoSelected"
                                         SearchFunc="SearchOffices"
                                         ToStringFunc="@(o => o == null ? string.Empty : $"{o.Name}{(string.IsNullOrEmpty(o.ReceivingSchedule) ? "" : $" ({o.ReceivingSchedule})")}")"
                                         Variant="Variant.Outlined"
                                         AdornmentIcon="@Icons.Material.Filled.Business"
                                         AdornmentColor="Color.Primary"
                                         CoerceText="false"
                                         CoerceValue="false"
                                         ResetValueOnEmptyText="true"
                                         MaxItems="null"
                                         Class="mb-3" />
                    }
                    @if (_selectedOffice != null && _loadingUnits)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mb-3" />
                    }
                    else if (_selectedOffice != null && _availableUnits.Any())
                    {
                        <MudAutocomplete T="Unit"
                                         Label="Select Unit"
                                         Value="_selectedUnit"
                                         ValueChanged="OnUnitAutoSelected"
                                         SearchFunc="SearchUnits"
                                         ToStringFunc="@(u => u?.Name ?? string.Empty)"
                                         Variant="Variant.Outlined"
                                         AdornmentIcon="@Icons.Material.Filled.Group"
                                         AdornmentColor="Color.Secondary"
                                         CoerceText="false"
                                         CoerceValue="false"
                                         ResetValueOnEmptyText="true"
                                         Placeholder="— No specific unit —"
                                         MaxItems="null"
                                         Class="mb-3" />
                    }
                    <div class="d-flex gap-2">
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" FullWidth="true"
                                   Disabled="@(selectedOfficeId == null || busy)"
                                   StartIcon="@Icons.Material.Filled.Send" OnClick="ForwardAsync">
                            Forward
                        </MudButton>
                        <MudButton Color="Color.Success" Variant="Variant.Filled" FullWidth="true"
                                   Disabled="@(selectedOfficeId != null || busy)"
                                   StartIcon="@Icons.Material.Filled.Done" OnClick="FinishAsync">
                            Finish
                        </MudButton>
                    </div>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        @if (Tab == DeskTab.Outgoing)
        {
            <MudButton Color="Color.Warning" Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Edit" OnClick="EditDocument">Edit</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    public enum DeskTab { Incoming, OnDesk, Outgoing }

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Document Doc { get; set; } = new();
    [Parameter] public DeskTab Tab { get; set; }

    private List<Office> _offices = new();
    private List<Unit> _availableUnits = new();
    private Office? _selectedOffice;
    private Unit? _selectedUnit;
    private int? selectedOfficeId;
    private int? selectedUnitId;
    private string? comment;
    private bool busy;
    private bool _loadingOffices;
    private bool _loadingUnits;

    protected override async Task OnParametersSetAsync()
    {
        if (Tab == DeskTab.OnDesk && !_offices.Any())
        {
            _loadingOffices = true;
            _offices = await DocService.GetOfficesSimpleAsync();
            _loadingOffices = false;
        }
    }

    private async Task OnOfficeSelected(int? officeId)
    {
        selectedOfficeId = officeId;
        selectedUnitId = null;
        _availableUnits = new();
        if (officeId.HasValue)
        {
            _loadingUnits = true;
            StateHasChanged();
            _availableUnits = await DocService.GetUnitsByOfficeAsync(officeId.Value);
            _loadingUnits = false;
        }
    }

    private async Task ReceiveAsync()
    {
        var parameters = new DialogParameters
        {
            { "Message", "Accept this document onto your desk?" },
            { "YesText", "Receive" },
            { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Confirm Receive", parameters);
        var result = await dialog.Result;
        if (result.Canceled) return;
        busy = true;
        try
        {
            var (ok, error) = await DocService.ReceivedDocumentAsync(Doc.Id);
            if (!ok) { Snackbar.Add(error ?? "Failed to receive document.", Severity.Warning); return; }
            Snackbar.Add("Document received!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ReceiveAsync] Error: {ex.Message}");
            Snackbar.Add("Failed to receive document. Please try again.", Severity.Error);
        }
        finally { busy = false; }
    }

    private async Task ForwardAsync()
    {
        if (!selectedOfficeId.HasValue) return;
        if (Doc.CurrentOfficeId == selectedOfficeId && Doc.CurrentUnitId == selectedUnitId)
        {
            Snackbar.Add("Cannot forward to the same office and unit.", Severity.Warning);
            return;
        }
        var dest = _selectedOffice?.Name;
        var parameters = new DialogParameters
        {
            { "Message", $"Forward this document to {dest}?" },
            { "YesText", "Forward" },
            { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Confirm Forward", parameters);
        var result = await dialog.Result;
        if (result.Canceled) return;
        busy = true;
        try
        {
            var (ok, error) = await DocService.ForwardDocumentAsync(Doc.Id, selectedOfficeId.Value, selectedUnitId, comment);
            if (!ok) { Snackbar.Add(error ?? "Failed to forward document.", Severity.Error); return; }
            Snackbar.Add("Document forwarded successfully!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ForwardAsync] Error: {ex.Message}");
            Snackbar.Add("Failed to forward document. Please try again.", Severity.Error);
        }
        finally { busy = false; }
    }

    private async Task FinishAsync()
    {
        var parameters = new DialogParameters
        {
            { "Message", "Mark this document as completed? This cannot be undone." },
            { "YesText", "Finish" },
            { "CancelText", "Cancel" }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Confirm Finish", parameters, options);
        var result = await dialog.Result;
        if (result.Canceled) return;
        busy = true;
        try
        {
            var (ok, error) = await DocService.FinishDocumentAsync(Doc.Id, comment);
            if (!ok) { Snackbar.Add(error ?? "Failed to complete document.", Severity.Error); return; }
            Snackbar.Add("Document marked as completed!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[FinishAsync] Error: {ex.Message}");
            Snackbar.Add("Failed to complete document. Please try again.", Severity.Error);
        }
        finally { busy = false; }
    }

    private async Task EditDocument()
    {
        var parameters = new DialogParameters<UserEditDocumentDialog> { { x => x.Doc, Doc } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<UserEditDocumentDialog>("Edit Document", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            MudDialog.Close(DialogResult.Ok(true));
    }

    private Task<IEnumerable<Office>> SearchOffices(string value, CancellationToken ct)
    {
        var results = _offices.Where(o => o.Id != Doc.CurrentOfficeId);
        if (!string.IsNullOrWhiteSpace(value))
            results = results.Where(o => o.Name!.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(results);
    }

    private Task<IEnumerable<Unit>> SearchUnits(string value, CancellationToken ct)
    {
        var results = string.IsNullOrWhiteSpace(value)
            ? _availableUnits
            : _availableUnits.Where(u => u.Name!.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult<IEnumerable<Unit>>(results);
    }

    private async Task OnOfficeAutoSelected(Office? office)
    {
        _selectedOffice = office;
        _selectedUnit = null;
        await OnOfficeSelected(office?.Id);
    }

    private void OnUnitAutoSelected(Unit? unit)
    {
        _selectedUnit = unit;
        selectedUnitId = unit?.Id;
    }

}
