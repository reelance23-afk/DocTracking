@page "/"
@inject IJSRuntime JS
@layout EmptyLayout
@using DocTracking.Client.Layout
@rendermode @(new InteractiveAutoRenderMode(prerender: false))

<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .landing-wrapper {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-family: 'Roboto', sans-serif;
        overflow: hidden;
        position: relative;
    }

    .glow-circle {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.15;
        pointer-events: none;
    }

    .glow-1 {
        width: 500px;
        height: 500px;
        background: #6c63ff;
        top: -100px;
        left: -100px;
    }

    .glow-2 {
        width: 400px;
        height: 400px;
        background: #e94560;
        bottom: -100px;
        right: -100px;
    }

    .glow-3 {
        width: 300px;
        height: 300px;
        background: #00d2ff;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    .landing-content {
        position: relative;
        z-index: 1;
        text-align: center;
        padding: 40px 24px;
        max-width: 900px;
        width: 100%;
    }

    .landing-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 50px;
        padding: 6px 16px;
        margin-bottom: 32px;
        color: rgba(255,255,255,0.8);
        font-size: 0.8rem;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .landing-title {
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 900;
        color: white;
        line-height: 1.1;
        margin-bottom: 20px;
        letter-spacing: -1px;
    }

        .landing-title span {
            background: linear-gradient(90deg, #6c63ff, #e94560);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

    .landing-subtitle {
        font-size: clamp(1rem, 2vw, 1.2rem);
        color: rgba(255,255,255,0.6);
        max-width: 560px;
        margin: 0 auto 40px;
        line-height: 1.7;
    }

    .landing-btn {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        background: linear-gradient(135deg, #6c63ff, #e94560);
        color: white;
        border: none;
        border-radius: 50px;
        padding: 16px 40px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow: 0 8px 32px rgba(108, 99, 255, 0.4);
        letter-spacing: 0.5px;
    }

        .landing-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 40px rgba(108, 99, 255, 0.6);
            color: white;
            text-decoration: none;
        }

    .flow-section {
        margin-top: 48px;
        margin-bottom: 0;
    }

    .flow-label {
        color: rgba(255,255,255,0.4);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 20px;
    }

    .flow-steps {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 8px;
    }

    .flow-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        padding: 16px 20px;
        min-width: 80px;
    }

    .flow-icon {
        font-size: 1.8rem;
    }

    .flow-text {
        color: rgba(255,255,255,0.8);
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .flow-arrow {
        color: rgba(255,255,255,0.3);
        font-size: 1.2rem;
        font-weight: 300;
    }

    .features {
        display: flex;
        gap: 20px;
        margin-top: 64px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .feature-card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        padding: 24px;
        width: 240px;
        text-align: left;
        backdrop-filter: blur(10px);
        transition: transform 0.2s ease, border-color 0.2s ease;
    }

        .feature-card:hover {
            transform: translateY(-4px);
            border-color: rgba(108, 99, 255, 0.5);
        }

    .feature-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
        font-size: 1.5rem;
    }

    .feature-title {
        color: white;
        font-weight: 700;
        font-size: 0.95rem;
        margin-bottom: 8px;
    }

    .feature-desc {
        color: rgba(255,255,255,0.5);
        font-size: 0.82rem;
        line-height: 1.6;
    }

    .landing-footer {
        position: relative;
        z-index: 1;
        margin-top: 48px;
        color: rgba(255,255,255,0.3);
        font-size: 0.78rem;
    }

    @@media (max-width: 600px) {
        .landing-title {
            font-size: 2.2rem;
        }

        .landing-subtitle {
            font-size: 0.95rem;
        }

        .landing-btn {
            padding: 14px 28px;
            font-size: 0.9rem;
        }

        .flow-steps {
            gap: 6px;
        }

        .flow-step {
            padding: 12px 14px;
            min-width: 60px;
        }

        .flow-icon {
            font-size: 1.4rem;
        }

        .flow-text {
            font-size: 0.7rem;
        }

        .flow-arrow {
            font-size: 0.9rem;
        }

        .features {
            flex-direction: column;
            align-items: center;
            margin-top: 40px;
        }

        .feature-card {
            width: 100%;
            max-width: 340px;
        }

        .landing-content {
            padding: 32px 16px;
        }
    }

</style>

<AuthorizeView>
    <Authorized>
        @{
            Navigation.NavigateTo("/dashboard");
        }
    </Authorized>
    <NotAuthorized>
        <div class="landing-wrapper">
            <div class="glow-circle glow-1"></div>
            <div class="glow-circle glow-2"></div>
            <div class="glow-circle glow-3"></div>

            <div class="landing-content">
                <div class="landing-badge">
                    <span>📄</span>
                    <span>Document Tracking System</span>
                </div>

                <h1 class="landing-title">
                    Track Every Document<br />
                    <span>Seamlessly</span>
                </h1>

                <p class="landing-subtitle">
                    A modern document tracking system that helps offices manage, monitor, and route documents efficiently across departments.
                </p>

                <a href="/Account/Login" class="landing-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" />
                    </svg>
                    Login with Microsoft
                </a>

                <div class="flow-section">
                    <p class="flow-label">How it works</p>
                    <div class="flow-steps">
                        <div class="flow-step">
                            <div class="flow-icon">📝</div>
                            <div class="flow-text">Create</div>
                        </div>
                        <div class="flow-arrow">→</div>
                        <div class="flow-step">
                            <div class="flow-icon">📤</div>
                            <div class="flow-text">Route</div>
                        </div>
                        <div class="flow-arrow">→</div>
                        <div class="flow-step">
                            <div class="flow-icon">📬</div>
                            <div class="flow-text">Receive</div>
                        </div>
                        <div class="flow-arrow">→</div>
                        <div class="flow-step">
                            <div class="flow-icon">🔄</div>
                            <div class="flow-text">Forward</div>
                        </div>
                        <div class="flow-arrow">→</div>
                        <div class="flow-step">
                            <div class="flow-icon">✅</div>
                            <div class="flow-text">Complete</div>
                        </div>
                    </div>
                </div>

                <div class="features">
                    <div class="feature-card">
                        <div class="feature-icon" style="background: rgba(108,99,255,0.2);">📬</div>
                        <div class="feature-title">Real-time Tracking</div>
                        <div class="feature-desc">Monitor document status and location across all offices in real-time.</div>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon" style="background: rgba(233,69,96,0.2);">🔔</div>
                        <div class="feature-title">Instant Notifications</div>
                        <div class="feature-desc">Get notified instantly when your document is received, forwarded or completed.</div>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon" style="background: rgba(0,210,255,0.2);">📊</div>
                        <div class="feature-title">Audit Trail</div>
                        <div class="feature-desc">Full history of every action taken on every document across the system.</div>
                    </div>
                </div>
            </div>

            <div class="landing-footer">
                © @DateTime.Now.Year DocTracking. All rights reserved.
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject] NavigationManager Navigation { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("eval",
                    "var el = document.getElementById('app-loading'); if(el){ el.classList.add('hide'); setTimeout(() => el.remove(), 500); }");
            }
            catch { }
        }
    }
}
