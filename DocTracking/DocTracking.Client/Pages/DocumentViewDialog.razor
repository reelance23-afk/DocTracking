@using DocTracking.Client.Models
@using DocTracking.Client.Pages.Shared
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@inject DocumentService DocService
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService
@rendermode InteractiveAuto

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Class="font-weight-bold">@Doc.Name</MudText>
            <MudChip T="string" Color="@DocHelpers.GetPriorityColor(Doc.Priority)" Size="Size.Small" Variant="Variant.Filled">@Doc.Priority</MudChip>
        </div>
    </TitleContent>
    <DialogContent>
        @if (Doc.Status == "In Motion")
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Filled.DirectionsWalk" Class="mb-4">
                <MudText Typo="Typo.caption">This document is currently in transit to <strong>@(Doc.NextOffice?.Name ?? "an office")</strong>.</MudText>
            </MudAlert>
        }
        else if (Doc.Status == "Received")
        {
            <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Filled.Inbox" Class="mb-4">
                <MudText Typo="Typo.caption">This document has been received and is currently being processed at <strong>@(Doc.CurrentOffice?.Name ?? "an office")</strong>.</MudText>
            </MudAlert>
        }
        else if (Doc.Status == "Completed")
        {
            <MudAlert Severity="Severity.Success" Dense="true" Icon="@Icons.Material.Filled.CheckCircle" Class="mb-4">
                <MudText Typo="Typo.caption">This document has been completed and closed.</MudText>
            </MudAlert>
        }
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Type</MudText>
                <MudText Typo="Typo.body1">@Doc.Type</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                <MudChip T="string" Color="@DocHelpers.GetStatusColor(Doc.Status)" Size="Size.Small">@Doc.Status</MudChip>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Sender</MudText>
                <MudText Typo="Typo.body1">@(Doc.Creator?.Name ?? "—")</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Created On</MudText>
                <MudText Typo="Typo.body2">@Doc.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Current Location</MudText>
                @if (Doc.CurrentOffice != null)
                {
                    <MudText Typo="Typo.body1" Class="font-weight-bold">@Doc.CurrentOffice.Name</MudText>
                    @if (Doc.CurrentUnit != null)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">↳ @Doc.CurrentUnit.Name</MudText>
                    }
                    @if (!string.IsNullOrEmpty(Doc.CurrentOffice.ReceivingSchedule))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Primary">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />@Doc.CurrentOffice.ReceivingSchedule
                        </MudText>
                    }
                }
                else
                {
                    <MudText Typo="Typo.body2"><em>None</em></MudText>
                }
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Next Destination</MudText>
                @if (Doc.NextOffice != null)
                {
                    <MudText Typo="Typo.body1" Class="font-weight-bold">@Doc.NextOffice.Name</MudText>
                    @if (Doc.NextUnit != null)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">↳ @Doc.NextUnit.Name</MudText>
                    }
                    @if (!string.IsNullOrEmpty(Doc.NextOffice.ReceivingSchedule))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Primary">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />@Doc.NextOffice.ReceivingSchedule
                        </MudText>
                    }
                }
                else
                {
                    <MudText Typo="Typo.body2"><em>None</em></MudText>
                }
            </MudItem>
            @if (!string.IsNullOrEmpty(Doc.Description))
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Description</MudText>
                    <MudPaper Elevation="0" Class="pa-3 mt-1 mud-background-gray rounded">
                        <MudText Typo="Typo.body2">@Doc.Description</MudText>
                    </MudPaper>
                </MudItem>
            }
            @if (Doc.Attachments.Any())
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Attachments</MudText>
                    @foreach (var attachment in Doc.Attachments)
                    {
                        <div class="d-flex align-center mt-1 gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" />
                            <MudText Typo="Typo.body2">@attachment.FileName</MudText>
                            <MudIconButton Href="@attachment.FilePath" Target="_blank"
                                           Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.Download" />
                        </div>
                    }
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="OpenFullTimeline" Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.OpenInFull" FullWidth="true">View Full Timeline</MudButton>
        <MudSpacer />
        <AuthorizeView Roles="Admin">
            <Authorized>
                <MudButton Color="Color.Secondary" Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Edit" OnClick="EditDocument">Edit</MudButton>
            </Authorized>
        </AuthorizeView>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Document Doc { get; set; } = new();

    private async Task OpenFullTimeline()
    {
        var parameters = new DialogParameters { ["Doc"] = Doc };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync(typeof(FullTimelineDialog), Doc.Name ?? "Timeline", parameters, options);
    }

    private async Task EditDocument()
    {
        var parameters = new DialogParameters { { "Doc", Doc } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<EditDocumentDialog>("Edit Document", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
            MudDialog.Close(DialogResult.Ok(result.Data));
    }
}
