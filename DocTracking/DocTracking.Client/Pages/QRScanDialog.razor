@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IAsyncDisposable
@using MudBlazor


<MudDialog>
    <DialogContent>
        <div class="d-flex flex-column align-center pa-2">
            @if (_unsupported)
            {
                <MudAlert Severity="Severity.Warning" Class="mb-3">
                    QR scanning is not supported in this browser.
                </MudAlert>
            }
            else
            {
                <div class="d-flex flex-column align-center pt-3">
                    <video id="qr-video" autoplay playsinline muted
                           style="width:100%; max-width:320px; border-radius:8px; background:#000;"></video>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
                        Point camera at a QR code
                    </MudText>
                </div>
            }
            @if (_scanSuccess)
            {
                <MudAlert Severity="Severity.Success" Class="mt-3" Dense="true">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-1" />
                    QR code detected! Redirecting...
                </MudAlert>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private bool _unsupported;
    private bool _scanSuccess;
    private string? _scannedUrl;
    private DotNetObjectReference<QRScanDialog>? _ref;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _ref = DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("qrScanner.start", "qr-video", _ref);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[QRScan] Camera start error: {ex.Message}");
            _unsupported = true;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async void OnScanned(string url)
    {
        _scanSuccess = true;
        _scannedUrl = url;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(1200);
        MudDialog.Close();
        var uri = new Uri(url);
        Navigation.NavigateTo(uri.PathAndQuery, forceLoad: true);
    }

    [JSInvokable]
    public void OnUnsupported()
    {
        _unsupported = true;
        StateHasChanged();
    }

    async void Cancel()
    {
        try { await JS.InvokeVoidAsync("qrScanner.stop"); } catch { }
        MudDialog.Cancel();
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("qrScanner.stop"); } catch { }
        _ref?.Dispose();
    }
}
