@using DocTracking.Client.Models
@using DocTracking.Client.Services.Helpers
@inject IJSRuntime JS

<style>
    .step-dot {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        flex-shrink: 0;
    }

        .step-dot:hover {
            transform: scale(1.15);
        }

        .step-dot.active {
            transform: scale(1);
        }

    .step-connector {
        flex-shrink: 0;
        width: 40px;
        height: 2px;
    }

    .stepper-scroll {
        display: flex;
        align-items: center;
        overflow-x: auto;
        padding: 8px;
        scrollbar-width: thin;
        -webkit-overflow-scrolling: touch;
        width: 100%;
    }

    .timeline-step {
        transition: background 0.3s ease;
        border-radius: 8px;
        padding: 4px;
    }

        .timeline-step.highlighted {
            background: rgba(var(--mud-palette-primary-rgb), 0.06);
        }

    @@keyframes pulse-walk {
        0% {
            transform: translateX(-8px);
            opacity: 0.7;
        }

        50% {
            transform: translateX(8px);
            opacity: 1;
        }

        100% {
            transform: translateX(-8px);
            opacity: 0.7;
        }
    }

    @@keyframes pulse-inbox {
        0% {
            transform: translateY(-10px);
            opacity: 0.6;
        }

        50% {
            transform: translateY(4px);
            opacity: 1;
        }

        100% {
            transform: translateY(-10px);
            opacity: 0.6;
        }
    }


    @@keyframes pulse-check {
        0% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.25);
            opacity: 0.8;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }


    .status-icon-motion {
        animation: pulse-walk 1.2s ease-in-out infinite;
    }

    .status-icon-received {
        animation: pulse-inbox 1.4s ease-in-out infinite;
    }

    .status-icon-completed {
        animation: pulse-check 1.6s ease-in-out infinite;
    }

    @@media (max-width: 600px) {
        .status-icon-motion, .status-icon-received, .status-icon-completed {
            font-size: 4rem;
        }
    }

</style>

@if (IsLoading)
{
    <div class="d-flex justify-center mt-8">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (!Logs.Any())
{
    <MudPaper Elevation="0" Class="pa-8 text-center mud-background-gray rounded-xl">
        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Style="opacity: 0.5; font-size: 4rem;" Class="mb-4" />
        <MudText Typo="Typo.h6" Class="mud-text-secondary">No tracking history found.</MudText>
    </MudPaper>
}
else
{
    @if (!string.IsNullOrEmpty(Status))
    {
        <div class="d-flex flex-column align-center mb-3">
            @if (Status == "In Motion")
            {
                <MudIcon Icon="@Icons.Material.Filled.DirectionsWalk"
                         Color="Color.Warning"
                         Class="status-icon-motion"
                         Style="font-size: 7rem;" />
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Document is currently in transit</MudText>
            }
            else if (Status == "Received")
            {
                <MudIcon Icon="@Icons.Material.Filled.Inbox"
                         Color="Color.Info"
                         Class="status-icon-received"
                         Style="font-size: 7rem;" />
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Document is being processed</MudText>
            }
            else if (Status == "Completed")
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                         Color="Color.Success"
                         Class="status-icon-completed"
                         Style="font-size: 7rem;" />
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Document has been completed and closed</MudText>
            }
        </div>

    }
 
<MudHidden Breakpoint="Breakpoint.SmAndDown">
<div class="stepper-scroll mb-6" style="justify-content: @(Logs.Count > 5 ? "flex-start" : "center");">
    <div style="display: flex; align-items: center; min-width: @(Logs.Count * 90)px;">

        @for (int i = Logs.Count - 1; i >= 0; i--)
        {
                var log = Logs[i];
                var index = i;
                var isActive = _selectedIndex == index;
                var isCurrent = index == 0;
                var dotColor = GetDotColor(log.Action, isCurrent);

                <div class="d-flex flex-column align-center" style="flex-shrink: 0;">
                    <div class="step-dot @(isActive ? "active" : "")"
                         style="background: @dotColor; @(isActive ? $"box-shadow: 0 0 0 3px white, 0 0 0 6px {dotColor};" : "")"
                         @onclick="() => SelectStep(index)">
                        <MudIcon Icon="@DocHelpers.GetIconForAction(log.Action)" Size="Size.Small" Style="color: white;" />
                    </div>
                    <MudText Typo="Typo.caption" Class="@(isActive ? "font-weight-bold" : "mud-text-secondary")"
                             Style="font-size: 0.65rem; margin-top: 4px; text-align: center; max-width: 60px; white-space: nowrap;">
                        @log.Action
                    </MudText>
                </div>

                @if (i > 0)
                {
                    var nextLog = Logs[i - 1];
                    var connectorColor = GetDotColor(nextLog.Action, i - 1 == 0);
                    <div style="display: flex; align-items: flex-start; flex-shrink: 0; width: 40px; margin-top: -16px;">
                        <div class="step-connector" style="background: linear-gradient(to right, @dotColor, @connectorColor); width: 100%;"></div>
                    </div>
                }
            }
        </div>
        </div>
    </MudHidden>

    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <div class="d-flex flex-column mb-4">
            @for (int i = 0; i < Logs.Count; i++)
            {
                var log = Logs[i];
                var index = i;
                var isCurrent = index == 0;
                var isCompleted = log.Action == "Completed";
                var dotColor = GetDotColor(log.Action, isCurrent);

                <div class="d-flex gap-2 align-items-start">
                    <div class="d-flex flex-column align-center" style="width: 32px; flex-shrink: 0; padding-top: 8px;">
                        <div style="width: 32px; height: 32px; border-radius: 50%; background: @dotColor; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <MudIcon Icon="@DocHelpers.GetIconForAction(log.Action)" Size="Size.Small" Style="color: white;" />
                        </div>
                    </div>
                    <MudCard Elevation="@(isCurrent ? 4 : 1)" Class="mb-3 flex-grow-1" Style="@(isCurrent ? $"border-left: 3px solid {dotColor};" : "")">
                        <MudCardContent Class="pa-3">
                            <div class="d-flex justify-space-between align-center mb-1 flex-wrap gap-1">
                                <div class="d-flex align-center gap-1">
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@log.Action</MudText>
                                    @if (isCurrent && !isCompleted)
                                    {
                                        <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">CURRENT</MudChip>
                                    }
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @log.TimeStamp.ToLocalTime().ToString("MMM dd • hh:mm tt")
                                </MudText>
                            </div>
                            <MudText Typo="Typo.body2" Class="mb-1">
                                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small" Class="mr-1 mud-text-secondary" />
                                <span class="mud-text-secondary">By:</span> <strong>@(log.AppUser?.Name ?? log.UserName ?? "System")</strong>
                            </MudText>
                            @if (log.Office != null || !string.IsNullOrEmpty(log.OfficeName))
                            {
                                <MudText Typo="Typo.body2">
                                    <MudIcon Icon="@DocHelpers.GetLocationIcon(log.Action)" Size="Size.Small" Color="@DocHelpers.GetLocationColor(log.Action)" Class="mr-1" />
                                    <span class="mud-text-secondary">@DocHelpers.GetLocationLabel(log.Action):</span>
                                    <strong>@(log.Office?.Name ?? log.OfficeName)</strong>
                                </MudText>
                                @if (log.Unit != null || !string.IsNullOrEmpty(log.UnitName))
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary ml-5">↳ @(log.Unit?.Name ?? log.UnitName)</MudText>
                                }
                            }
                            @if (!string.IsNullOrEmpty(log.Comment))
                            {
                                <MudPaper Elevation="0" Class="pa-2 mt-2 rounded" Style="background: rgba(var(--mud-palette-info-rgb), 0.08); border-left: 3px solid var(--mud-palette-info);">
                                    <div class="d-flex align-center gap-1 mb-1">
                                        <MudIcon Icon="@Icons.Material.Filled.Comment" Size="Size.Small" Color="Color.Info" />
                                        <MudText Typo="Typo.caption" Color="Color.Info" Class="font-weight-bold">Note</MudText>
                                    </div>
                                    <MudText Typo="Typo.body2">@log.Comment</MudText>
                                </MudPaper>
                            }
                            @if (isCompleted)
                            {
                                <MudAlert Severity="Severity.Success" Dense="true" Icon="@Icons.Material.Filled.CheckCircle" Class="mt-2">
                                    <MudText Typo="Typo.caption">Document processing completed successfully.</MudText>
                                </MudAlert>
                            }
                        </MudCardContent>
                    </MudCard>
                </div>
            }
        </div>
    </MudHidden>



<MudHidden Breakpoint="Breakpoint.SmAndDown">
    <MudTimeline TimelinePosition="TimelinePosition.Start" Class="w-100">
            @for (int i = 0; i < Logs.Count; i++)
            {
                var log = Logs[i];
                var index = i;
                var isCurrent = index == 0;
                var isCompleted = log.Action == "Completed";
                var isHighlighted = _selectedIndex == index;
                var dotColor = GetDotColor(log.Action, isCurrent);

                <MudTimelineItem Color="@DocHelpers.GetTimelineColor(log.Action, isCurrent)"
                                 Size="Size.Medium" Variant="Variant.Filled"
                                 Icon="@DocHelpers.GetIconForAction(log.Action)">
                    <ItemContent>
                        <div id="step-@index" class="timeline-step @(isHighlighted ? "highlighted" : "") mb-3"
                             style="@(isHighlighted ? $"border-left: 3px solid {dotColor}; padding-left: 8px;" : "padding-left: 8px;")">
                            <div class="d-flex justify-space-between align-center mb-1 flex-wrap gap-1">
                                <div class="d-flex align-center gap-2">
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@log.Action</MudText>
                                    @if (isCurrent && !isCompleted)
                                    {
                                        <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">CURRENT</MudChip>
                                    }
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @log.TimeStamp.ToLocalTime().ToString("MMM dd, yyyy • hh:mm tt")
                                </MudText>
                            </div>

                            <MudGrid Spacing="1">
                                <MudItem xs="12" sm="6">
                                    <div class="d-flex align-center gap-1">
                                        <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small" Class="mud-text-secondary" />
                                        <MudText Typo="Typo.body2">
                                            <span class="mud-text-secondary">By:</span> <strong>@(log.AppUser?.Name ?? log.UserName ?? "System")</strong>
                                        </MudText>
                                    </div>
                                </MudItem>
                                @if (log.Office != null || !string.IsNullOrEmpty(log.OfficeName))
                                {
                                    <MudItem xs="12" sm="6">
                                        <div class="d-flex align-center gap-1">
                                            <MudIcon Icon="@DocHelpers.GetLocationIcon(log.Action)" Size="Size.Small" Color="@DocHelpers.GetLocationColor(log.Action)" />
                                            <div>
                                                <MudText Typo="Typo.body2">
                                                    <span class="mud-text-secondary">@DocHelpers.GetLocationLabel(log.Action):</span>
                                                    <strong>@(log.Office?.Name ?? log.OfficeName)</strong>
                                                    @if (log.Office == null && !string.IsNullOrEmpty(log.OfficeName))
                                                    {
                                                        <span class="mud-text-secondary" style="font-style:italic;"> (deleted)</span>
                                                    }
                                                </MudText>
                                                @if (log.Unit != null || !string.IsNullOrEmpty(log.UnitName))
                                                {
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                        ↳ @(log.Unit?.Name ?? log.UnitName)
                                                        @if (log.Unit == null && !string.IsNullOrEmpty(log.UnitName))
                                                        {
                                                            <span style="font-style:italic;"> (deleted)</span>
                                                        }
                                                    </MudText>
                                                }
                                                @if (!string.IsNullOrEmpty(log.Office?.ReceivingSchedule))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Primary">
                                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />@log.Office.ReceivingSchedule
                                                    </MudText>
                                                }
                                            </div>
                                        </div>
                                    </MudItem>
                                }
                            </MudGrid>

                            @if (!string.IsNullOrEmpty(log.Comment))
                            {
                                <MudPaper Elevation="0" Class="pa-2 mt-2 rounded" Style="background: rgba(var(--mud-palette-info-rgb), 0.08); border-left: 3px solid var(--mud-palette-info);">
                                    <div class="d-flex align-center gap-1 mb-1">
                                        <MudIcon Icon="@Icons.Material.Filled.Comment" Size="Size.Small" Color="Color.Info" />
                                        <MudText Typo="Typo.caption" Color="Color.Info" Class="font-weight-bold">Note</MudText>
                                    </div>
                                    <MudText Typo="Typo.body2">@log.Comment</MudText>
                                </MudPaper>
                            }

                            @if (isCompleted)
                            {
                                <MudAlert Severity="Severity.Success" Dense="true" Icon="@Icons.Material.Filled.CheckCircle" Class="mt-2">
                                    <MudText Typo="Typo.caption">Document processing completed successfully.</MudText>
                                </MudAlert>
                            }
                        </div>
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline>
    </MudHidden>
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">Error loading data: @ErrorMessage</MudAlert>
    }
}

@code {
    [Parameter, EditorRequired] public List<DocumentLog> Logs { get; set; } = new();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string? Status { get; set; }

    private int _selectedIndex = 0;

    private async Task SelectStep(int index)
    {
        _selectedIndex = index;
        StateHasChanged();
        await Task.Delay(50);
        try
        {
            await JS.InvokeVoidAsync("eval", $"document.getElementById('step-{index}')?.scrollIntoView({{behavior:'smooth', block:'center'}})");
        }
        catch { }
    }

    private string GetDotColor(string? action, bool isCurrent) => action switch
    {
        "Created" => "#2196f3",
        "Forwarded" => "#ff9800",
        "Received" => "#1976d2",
        "Completed" => "#4caf50",
        "Edited" => "#9c27b0",
        "Admin" => "#f44336",
        _ => "#9e9e9e"
    };
}
