@page "/document-tracking"
@attribute [Authorize(Roles = "Admin")]
@using DocTracking.Client
@using DocTracking.Client.Models
@using DocTracking.Client.Pages
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@inject DocumentService DocumentService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@rendermode InteractiveAuto

<style>
    @@media (max-width: 959px) {
        .desktop-table {
            display: none !important;
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <div class="mb-6">
        <div class="d-flex align-center mb-4">
            <MudIcon Icon="@Icons.Material.Filled.TrackChanges" Size="Size.Large" Class="mr-3" Color="Color.Primary" />
            <MudText Typo="Typo.h4" Class="font-weight-bold">Tracking List</MudText>
        </div>
    </div>

    <MudPaper Elevation="3" Class="pa-4 pa-md-6 rounded-lg">
        <div class="d-flex justify-space-between align-center mb-4">
            <div>
                <MudText Typo="Typo.h6" Class="font-weight-bold">All Documents</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Browse, filter and export all documents.</MudText>
            </div>
            <div class="d-flex gap-2 align-center">
                @if (_multiSelectMode && _selectedDocs.Any())
                {
                    <MudButton Color="Color.Error" Variant="Variant.Filled" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.DeleteSweep"
                               Disabled="@_isBulkDeleting" OnClick="BulkDelete">
                        @(_isBulkDeleting ? "Deleting..." : $"Delete ({_selectedDocs.Count})")
                    </MudButton>
                }
                <MudButton Variant="@(_multiSelectMode? Variant.Filled: Variant.Outlined)"
                           Color="Color.Warning" Size="Size.Small"
                           StartIcon="@(_multiSelectMode ? Icons.Material.Filled.Close : Icons.Material.Filled.Checklist)"
                           OnClick="ToggleMultiSelect"
                           Class="d-none d-md-flex">
                    @(_multiSelectMode ? "Cancel" : "Select")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Download" OnClick="ExportCsv"
                           Class="d-none d-md-flex">
                    Export CSV
                </MudButton>
            </div>
        </div>

        <MudTextField Value="@searchString"
                      ValueChanged="@((string v) => OnSearchChanged(v))"
                      Placeholder="Search documents, senders, or locations..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" Variant="Variant.Outlined" Margin="Margin.Dense"
                      Class="mb-4" />

        <div class="d-flex gap-2 flex-wrap align-center mb-4">
            <MudSelect Value="statusFilter" Label="Status" Variant="Variant.Outlined"
                       Margin="Margin.Dense" T="string" Style="min-width:140px;"
                       ValueChanged="@(async (string v) => { statusFilter = v; await OnFilterChanged(); })">
                <MudSelectItem T="string" Value="@("")">All Statuses</MudSelectItem>
                <MudSelectItem T="string" Value="@("In Motion")">In Motion</MudSelectItem>
                <MudSelectItem T="string" Value="@("Received")">Received</MudSelectItem>
                <MudSelectItem T="string" Value="@("Completed")">Completed</MudSelectItem>
            </MudSelect>
            <MudSelect Value="officeFilter" Label="Office" Variant="Variant.Outlined"
                       Margin="Margin.Dense" T="string" Style="min-width:160px;"
                       OnOpen="OnOfficeFilterOpen"
                       ValueChanged="@(async (string v) => { officeFilter = v; await OnFilterChanged(); })">
                <MudSelectItem T="string" Value="@("")">All Offices</MudSelectItem>
                @foreach (var office in allOffices)
                {
                    <MudSelectItem T="string" Value="@office.Name">@office.Name</MudSelectItem>
                }
            </MudSelect>
            <MudDatePicker Date="dateFrom" Label="From" Variant="Variant.Outlined"
                           Margin="Margin.Dense" Style="min-width:140px;"
                           DateChanged="@(async (DateTime? v) => { dateFrom = v; await OnFilterChanged(); })" />
            <MudDatePicker Date="dateTo" Label="To" Variant="Variant.Outlined"
                           Margin="Margin.Dense" Style="min-width:140px;"
                           DateChanged="@(async (DateTime? v) => { dateTo = v; await OnFilterChanged(); })" />
            @if (!string.IsNullOrEmpty(statusFilter) || !string.IsNullOrEmpty(officeFilter) || dateFrom != null || dateTo != null)
            {
                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="ClearFilters"
                           StartIcon="@Icons.Material.Filled.Clear">Clear</MudButton>
            }
            <MudButton Variant="@(_multiSelectMode? Variant.Filled: Variant.Outlined)"
                       Color="Color.Warning" Size="Size.Small"
                       StartIcon="@(_multiSelectMode ? Icons.Material.Filled.Close : Icons.Material.Filled.Checklist)"
                       OnClick="ToggleMultiSelect"
                       Class="d-md-none">
                @(_multiSelectMode ? "Cancel" : "Select")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Download" OnClick="ExportCsv"
                       Class="d-md-none">
                Export CSV
            </MudButton>
        </div>

        <div class="desktop-table">
            <MudTable @ref="_table" ServerData="LoadServerData" Hover="true" T="Document"
                      MultiSelection="@_multiSelectMode" @bind-SelectedItems="_selectedDocs">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<Document, object>(x => x.Name)">Name</MudTableSortLabel></MudTh>
                    <MudTh>Sender</MudTh>
                    <MudTh>Location</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<Document, object>(x => x.CreatedAt)">Date</MudTableSortLabel></MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name"><strong>@context.Name</strong></MudTd>
                    <MudTd DataLabel="Sender">@context.Creator?.Name</MudTd>
                    <MudTd DataLabel="Location">
                        @if (context.CurrentOffice != null)
                        {
                            <MudText Typo="Typo.body2"><strong>@context.CurrentOffice.Name</strong><br /><span style="color: gray; font-size: 0.85em;">↳ @(context.CurrentUnit?.Name ?? "General")</span></MudText>
                        }
                        else if (context.NextOffice != null)
                        {
                            <MudText Typo="Typo.body2"><span style="color: #ff9800; font-size: 0.85em; font-style: italic;">Routing to:</span><br /><strong>@context.NextOffice.Name</strong><br /><span style="color: gray; font-size: 0.85em;">↳ @(context.NextUnit?.Name ?? "General")</span></MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Default">Unassigned</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="@DocHelpers.GetStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Filled">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Date">@context.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</MudTd>
                    <MudTd DataLabel="Actions">
                        <div class="d-flex gap-2">
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Visibility"
                                       OnClick="@(async () => await OpenViewDialog(context))">View</MudButton>
                            <MudIconButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                                           Icon="@Icons.Material.Filled.QrCode"
                                           OnClick="@(async () => await OpenQRDialog(context))" />
                            <MudIconButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                                           Icon="@Icons.Material.Filled.Edit"
                                           OnClick="@(async () => await OpenEditDialog(context))" />
                            <MudIconButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                                           Icon="@Icons.Material.Filled.Delete"
                                           OnClick="@(async () => await DeleteDocument(context))" />
                        </div>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="pa-8 text-center">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Style="opacity: 0.3; font-size: 4rem;" Class="mb-4" />
                        <MudText Typo="Typo.h6" Class="mud-text-secondary">No documents found</MudText>
                    </div>
                </NoRecordsContent>
                <PagerContent><MudTablePager /></PagerContent>
            </MudTable>
        </div>

        <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="true">
            @if (_multiSelectMode && _selectedDocs.Any())
            {
                <div class="d-flex align-center gap-2 mb-3 pa-2" style="background: rgba(var(--mud-palette-error-rgb),0.06); border-radius:8px;">
                    <MudText Typo="Typo.body2"><strong>@_selectedDocs.Count</strong> selected</MudText>
                    <MudSpacer />
                    <MudButton Color="Color.Error" Variant="Variant.Filled" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.DeleteSweep"
                               Disabled="@_isBulkDeleting" OnClick="BulkDelete">
                        @(_isBulkDeleting ? "Deleting..." : "Delete Selected")
                    </MudButton>
                </div>
            }
            @if (!_serverItems.Any())
            {
                <div class="pa-8 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Style="opacity: 0.3; font-size: 4rem;" Class="mb-4" />
                    <MudText Typo="Typo.h6" Class="mud-text-secondary">No documents found</MudText>
                </div>
            }
            else
            {
                @foreach (var doc in _serverItems)
                {
                    <MudCard Elevation="2" Class="mb-3" @onclick="@(() => { if (_multiSelectMode) ToggleMobileSelect(doc); })"
                             Style="@(_multiSelectMode && _selectedDocs.Contains(doc) ? "border: 2px solid var(--mud-palette-error);" : "")">
                        <MudCardContent Class="pa-4">
                            <div class="d-flex justify-space-between align-start mb-2">
                                @if (_multiSelectMode)
                                {
                                    <MudCheckBox T="bool" Value="@_selectedDocs.Contains(doc)"
                                                 ValueChanged="@(_ => ToggleMobileSelect(doc))"
                                                 Color="Color.Error" Class="mr-2" />
                                }
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@doc.Name</MudText>
                                <MudChip T="string" Color="@DocHelpers.GetStatusColor(doc.Status)" Size="Size.Small" Variant="Variant.Filled">@doc.Status</MudChip>
                            </div>
                            <MudText Typo="Typo.body2" Class="mb-2">Sender: <strong>@(doc.Creator?.Name ?? "—")</strong></MudText>
                            @if (doc.CurrentOffice != null)
                            {
                                <MudText Typo="Typo.body2" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Class="mr-1" />
                                    <strong>@doc.CurrentOffice.Name</strong>
                                    @if (doc.CurrentUnit != null)
                                    {
                                        <span class="mud-text-secondary"> ↳ @doc.CurrentUnit.Name</span>
                                    }
                                </MudText>
                            }
                            else if (doc.NextOffice != null)
                            {
                                <MudText Typo="Typo.body2" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.DirectionsWalk" Size="Size.Small" Class="mr-1" />
                                    <span style="color:#ff9800;">Routing to: </span><strong>@doc.NextOffice.Name</strong>
                                </MudText>
                            }
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                @doc.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                            </MudText>
                        </MudCardContent>
                        @if (!_multiSelectMode)
                        {
                            <MudCardActions Class="pa-4 pt-0">
                                <div class="d-flex gap-2 flex-wrap" style="width:100%">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Style="flex:1"
                                               StartIcon="@Icons.Material.Filled.Visibility"
                                               OnClick="@(async () => await OpenViewDialog(doc))">View</MudButton>
                                    <MudIconButton Variant="Variant.Outlined" Color="Color.Secondary"
                                                   Icon="@Icons.Material.Filled.QrCode"
                                                   OnClick="@(async () => await OpenQRDialog(doc))" />
                                    <MudIconButton Variant="Variant.Outlined" Color="Color.Error"
                                                   Icon="@Icons.Material.Filled.Delete"
                                                   OnClick="@(async () => await DeleteDocument(doc))" />
                                </div>
                            </MudCardActions>
                        }
                    </MudCard>
                }
            }
        </MudHidden>

    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "ref")] public string? RefParam { get; set; }

    private MudTable<Document>? _table;
    private List<Document> _serverItems = new();
    private List<Office> allOffices = new();
    private string searchString = "";
    private string statusFilter = "";
    private string officeFilter = "";
    private DateTime? dateFrom;
    private DateTime? dateTo;
    private bool dialogOpened = false;
    private HashSet<Document> _selectedDocs = new();
    private bool _isBulkDeleting;
    private bool _multiSelectMode;

    private void ToggleMultiSelect()
    {
        _multiSelectMode = !_multiSelectMode;
        if (!_multiSelectMode)
            _selectedDocs.Clear();
    }

    private void ToggleMobileSelect(Document doc)
    {
        if (_selectedDocs.Contains(doc))
            _selectedDocs.Remove(doc);
        else
            _selectedDocs.Add(doc);
    }

    private async Task<TableData<Document>> LoadServerData(TableState state, CancellationToken ct)
    {
        try
        {
            var result = await DocumentService.GetAllDocumentsAsync(
                page: state.Page + 1,
                pageSize: state.PageSize,
                search: searchString,
                status: statusFilter,
                office: officeFilter,
                dateFrom: dateFrom?.ToString("yyyy-MM-dd"),
                dateTo: dateTo?.ToString("yyyy-MM-dd"));
            _serverItems = result.Items;
            await InvokeAsync(StateHasChanged);
            return new TableData<Document> { Items = result.Items, TotalItems = result.TotalCount };
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); return new TableData<Document>(); }
    }

    private async Task OnFilterChanged()
    {
        if (_table != null) await _table.ReloadServerData();
    }

    private async Task OnOfficeFilterOpen(bool isOpen)
    {
        if (isOpen && !allOffices.Any())
            allOffices = await DocumentService.GetOfficesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!dialogOpened && !string.IsNullOrEmpty(RefParam))
        {
            dialogOpened = true;
            var doc = _serverItems.FirstOrDefault(d => d.ReferenceNumber == RefParam)
                      ?? await DocumentService.GetDocumentByRefAsync(RefParam);
            if (doc != null)
                await OpenViewDialog(doc);
        }
    }

    private async Task ClearFilters()
    {
        searchString = "";
        statusFilter = "";
        officeFilter = "";
        dateFrom = null;
        dateTo = null;
        await OnFilterChanged();
    }

    private async Task ExportCsv()
    {
        try
        {
            var url = DocumentService.GetDocumentsCsvUrl(
                search: searchString,
                status: statusFilter,
                office: officeFilter,
                dateFrom: dateFrom?.ToString("yyyy-MM-dd"),
                dateTo: dateTo?.ToString("yyyy-MM-dd"));
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
        catch (Exception ex) { Console.WriteLine($"[ExportCsv] Error: {ex.Message}"); }
    }

    private async Task OpenQRDialog(Document doc)
    {
        var parameters = new DialogParameters<QRCodeDialog>
        {
            { x => x.DocumentId, doc.Id },
            { x => x.ReferenceNumber, doc.ReferenceNumber }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<QRCodeDialog>("QR Code", parameters, options);
    }

    private async Task OpenEditDialog(Document doc)
    {
        var editingDoc = new Document
        {
            Id = doc.Id,
            Name = doc.Name,
            Type = doc.Type,
            Description = doc.Description,
            Priority = doc.Priority,
            FileName = doc.FileName,
            FilePath = doc.FilePath
        };
        List<Office> officeList;
        try { officeList = await DocumentService.GetOfficesAsync(); }
        catch { officeList = new(); }
        var parameters = new DialogParameters
        {
            { "Doc", editingDoc },
            { "Offices", officeList }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<EditDocumentDialog>("Edit Document", parameters, options);
        var result = await dialog.Result;
        if (!result!.Canceled)
            await OnFilterChanged();
    }

    private async Task OpenViewDialog(Document doc)
    {
        var parameters = new DialogParameters<DocumentViewDialog> { { x => x.Doc, doc } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<DocumentViewDialog>("Document Details", parameters, options);
        var result = await dialog.Result;
        if (!result!.Canceled)
            await OnFilterChanged();
    }

    private async Task DeleteDocument(Document doc)
    {
        var parameters = new DialogParameters
        {
            { "Message", $"Delete '{doc.Name}'? This cannot be undone." },
            { "YesText", "Delete" },
            { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Document", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;
        var (ok, error) = await DocumentService.DeleteDocumentAsync(doc.Id);
        if (!ok) { Snackbar.Add(error ?? "Failed to delete document.", Severity.Error); return; }
        await OnFilterChanged();
    }

    private async Task BulkDelete()
    {
        if (!_selectedDocs.Any()) return;
        var parameters = new DialogParameters
        {
            { "Message", $"Delete {_selectedDocs.Count} selected document(s)? This cannot be undone." },
            { "YesText", "Delete All" },
            { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Bulk Delete", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        _isBulkDeleting = true;
        try
        {
            var ids = _selectedDocs.Select(d => d.Id).ToList();
            var (ok, error) = await DocumentService.BulkDeleteDocumentsAsync(ids);
            if (!ok) { Snackbar.Add(error ?? "Bulk delete failed.", Severity.Error); return; }
            Snackbar.Add($"{ids.Count} document(s) deleted.", Severity.Success);
            _selectedDocs.Clear();
            _multiSelectMode = false;
            await OnFilterChanged();
        }
        finally { _isBulkDeleting = false; }
    }

    private CancellationTokenSource _searchCts = new();

    private async Task OnSearchChanged(string value)
    {
        searchString = value;
        _searchCts.Cancel();
        _searchCts = new CancellationTokenSource();
        var ct = _searchCts.Token;
        try { await Task.Delay(400, ct); } catch (OperationCanceledException) { return; }
        await OnFilterChanged();
    }
}

