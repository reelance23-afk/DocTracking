@page "/document-tracking"
@attribute [Authorize(Roles = "Admin")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@inject DocumentService DocumentService
@rendermode InteractiveAuto

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
	<MudText Typo="Typo.h4" Class="mb-4 font-weight-bold">Tracking List</MudText>

		<MudTable Items="@allDocuments" Hover="true" Striped="true" Elevation="3" Loading="@loading" Filter="new Func<Document, bool>(FilterFunc)">
			<ToolBarContent>
				<MudText Typo="Typo.h6">All Document</MudText>
				<MudSpacer />
			<MudTextField @bind-Value="searchString" Placeholder="Search documents, senders, or locations..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
			</ToolBarContent>
		<HeaderContent>
			<MudTh>Name</MudTh>
			<MudTh>Sender</MudTh>
			<MudTh>Location</MudTh>
			<MudTh>Status</MudTh>
			<MudTh>Date</MudTh>
			<MudTh>Action</MudTh>
		</HeaderContent>

		<RowTemplate>
			<MudTd DataLabel="Name">
				<MudText Typo="Typo.body1" Class="font-weight-bold">@context.Name</MudText>
			</MudTd>
			<MudTd DataLabel="Sender">@context.Creator?.Email</MudTd>

			<MudTd DataLabel="Location">
				@if (context.CurrentOffice != null)
				{
					<MudText Typo="Typo.body2">
						<strong>@context.CurrentOffice.Name</strong> <br />
						<span style="color: gray; font-size: 0.85em;">↳ @(context.CurrentUnit?.Name ?? "General")</span>
					</MudText>
				}
				else if (context.NextOffice != null)
				{
					<MudText Typo="Typo.body2">
						<span style="color: #ff9800; font-size: 0.85em; font-style: italic;">Routing to:</span><br />
						<strong>@context.NextOffice.Name</strong> <br />
						<span style="color: gray; font-size: 0.85em;">↳ @(context.NextUnit?.Name ?? "General")</span>
					</MudText>
				}
				else
				{
					<MudText Typo="Typo.body2" Color="Color.Default">Unassigned</MudText>
				}
			</MudTd>

			<MudTd DataLabel="Status">
				<MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Filled">
					@context.Status
				</MudChip>
			</MudTd>
			<MudTd DataLabel="Date">@context.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</MudTd>

			<MudTd DataLabel="Action">
				<MudButton Href="@($"/track-document/{context.Id}?ReturnUrl=document-tracking")"
						   Size="Size.Small"
						   Variant="Variant.Filled"
						   Color="Color.Primary"
						   StartIcon="@Icons.Material.Filled.Timeline">
					Track
				</MudButton>
			</MudTd>
		</RowTemplate>
			<PagerContent>
				<MudTablePager />
			</PagerContent>
		</MudTable>

</MudContainer>

@code {
	private List<Document> allDocuments = new();
	private bool loading = true;

	private string searchString = "";

	protected override async Task OnInitializedAsync()
	{
		try
		{
			allDocuments = await DocumentService.GetAllDocumentsAsync();
		}
		catch (Exception ex)
		{
			Console.WriteLine(ex.Message);
		}
		finally
		{
			loading = false;
		}
	}

	private bool FilterFunc(Document element)
	{
		if (string.IsNullOrWhiteSpace(searchString)) return true;
		if (element.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
		if (element.Creator?.Email?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
		if (element.Status?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;

		if (element.CurrentOffice?.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
		if (element.NextOffice?.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
		if (element.CurrentUnit?.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
		if (element.NextUnit?.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;

		return false;
	}

	private Color GetStatusColor(string? status)
	{
		return status switch
		{
			"Completed" => Color.Success,
			"Received" => Color.Info,
			"On Going" => Color.Warning,
			"Pending" => Color.Warning,
			"Archived" => Color.Dark,
			_ => Color.Default
		};
	}
}