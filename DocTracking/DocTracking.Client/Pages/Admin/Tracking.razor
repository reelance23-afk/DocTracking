@page "/document-tracking"
@attribute [Authorize(Roles = "Admin")]
@using DocTracking.Client
@using DocTracking.Client.Models
@using DocTracking.Client.Pages
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@inject DocumentService DocumentService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@rendermode InteractiveAuto

<style>
    .fade-slide-up {
        animation: fadeSlideUp 0.5s ease-out both;
    }

    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes rowFadeIn {
        from {
            opacity: 0;
            transform: translateX(-20px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@media (max-width: 600px) {
        .actions-cell {
            text-align: right;
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <div class="d-flex align-center justify-space-between mb-4 fade-slide-up flex-wrap gap-2">
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.TrackChanges" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
            <div>
                <MudText Typo="Typo.h4" Class="font-weight-bold">Document Tracking</MudText>
            </div>
        </div>
        <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Filled.Info" Style="width: fit-content; margin: 0;">
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Full visibility of all documents. Use filters to narrow by status, office, sender or date. Export to CSV for reporting.
            </MudText>
        </MudAlert>
    </div>


    <div class="mb-4" Style="animation: fadeSlideUp 0.5s ease-out 0.1s both;">
        <div style="width:100%;" class="mb-2">
            <MudTextField @bind-Value="searchString"
                          @bind-Value:after="OnSearchChanged"
                          DebounceInterval="400"
                          Placeholder="Search documents, senders, or locations..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Variant="Variant.Outlined" Margin="Margin.Dense" />
        </div>
        <div class="d-flex gap-2 align-center flex-wrap">
            <div style="position:relative;">
                <MudBadge Content="@ActiveFilterCount" Color="Color.Error" Overlap="true"
                          Visible="@(ActiveFilterCount > 0)">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.FilterList"
                               OnClick="@(() => _filterOpen = !_filterOpen)">
                        Filters
                    </MudButton>
                </MudBadge>
                <MudPopover Open="_filterOpen" AnchorOrigin="Origin.BottomLeft"
                            TransformOrigin="Origin.TopLeft" Paper="true" Class="pa-4"
                            Style="min-width:300px; z-index:1300;">
                    <div class="d-flex justify-space-between align-center mb-3">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Filters</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="@(() => _filterOpen = false)" />
                    </div>
                    <MudSelect Value="statusFilter" Label="Status" Variant="Variant.Outlined"
                               Margin="Margin.Dense" T="string" FullWidth="true" Class="mb-3"
                               ValueChanged="@(async (string v) => { statusFilter = v; await OnFilterChanged(); })">
                        <MudSelectItem T="string" Value="@("")">All Statuses</MudSelectItem>
                        <MudSelectItem T="string" Value="@("In Motion")">In Motion</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Received")">Received</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Completed")">Completed</MudSelectItem>
                    </MudSelect>
                    <MudAutocomplete T="string" Value="officeFilter" Label="Office" Variant="Variant.Outlined"
                                     Margin="Margin.Dense" FullWidth="true" Class="mb-3"
                                     SearchFunc="SearchOffices" Clearable="true"
                                     DebounceInterval="400"
                                     ValueChanged="@(async (string v) => { officeFilter = v; await OnFilterChanged(); })" />

                    <MudAutocomplete T="string" Value="senderFilter" Label="Sender" Variant="Variant.Outlined"
                                     Margin="Margin.Dense" FullWidth="true" Class="mb-3"
                                     SearchFunc="SearchSenders" Clearable="true"
                                     ValueChanged="@(async (string v) => { senderFilter = v; await OnFilterChanged(); })" />

                    <MudDatePicker Date="dateFrom" Label="From" Variant="Variant.Outlined"
                                   Margin="Margin.Dense" Style="width:100%;" Class="mb-3"
                                   DateChanged="@(async (DateTime? v) => { dateFrom = v; await OnFilterChanged(); })" />
                    <MudDatePicker Date="dateTo" Label="To" Variant="Variant.Outlined"
                                   Margin="Margin.Dense" Style="width:100%;" Class="mb-3"
                                   DateChanged="@(async (DateTime? v) => { dateTo = v; await OnFilterChanged(); })" />
                    @if (ActiveFilterCount > 0)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Error" FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearFilters">
                            Clear All Filters
                        </MudButton>
                    }
                </MudPopover>
            </div>
            <MudButton Variant="@(_multiSelectMode? Variant.Filled: Variant.Outlined)"
                       Color="Color.Warning" Size="Size.Small"
                       StartIcon="@(_multiSelectMode ? Icons.Material.Filled.Close : Icons.Material.Filled.Checklist)"
                       OnClick="ToggleMultiSelect">
                @(_multiSelectMode ? "Cancel" : "Select")
            </MudButton>
            @if (_multiSelectMode && _selectedDocs.Any())
            {
                <div class="d-flex align-center gap-1">
                    <MudText Typo="Typo.body2"><strong>@_selectedDocs.Count</strong> selected</MudText>
                    <MudSpacer />
                    <MudButton Color="Color.Error" Variant="Variant.Filled" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.DeleteSweep"
                               Disabled="@_isBulkDeleting" OnClick="BulkDelete">
                        @(_isBulkDeleting ? "Deleting..." : "Delete Selected")
                    </MudButton>
                </div>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Download" OnClick="ExportCsv">
                Export CSV
            </MudButton>
        </div>
    </div>

    <MudPaper Elevation="3" Style="animation: fadeSlideUp 0.5s ease-out 0.2s both;">
    <MudTable @ref="_table" ServerData="LoadServerData" Hover="true" T="Document" Dense="true"
        MultiSelection="@_multiSelectMode" @bind-SelectedItems="_selectedDocs"
              Breakpoint="Breakpoint.Sm" Elevation="0"
              RowStyleFunc="@((item, index) => $"animation: rowFadeIn 0.3s ease both; animation-delay: {Math.Min(index, 10) * 40}ms;")">
            <HeaderContent>
                <MudTh>Document</MudTh>
                <MudTh>Sender</MudTh>
                <MudTh>Location</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Created</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Document"><strong>@context.Name</strong></MudTd>
                <MudTd DataLabel="Sender">@context.Creator?.Name</MudTd>
                <MudTd DataLabel="Location">
                    @if (context.CurrentOffice != null)
                    {
                        <MudText Typo="Typo.body2"><strong>@context.CurrentOffice.Name</strong><br />
                            @if (context.CurrentUnit?.Name != null) {
                            <span style="color: gray; font-size: 0.85em;">↳ @(context.CurrentUnit?.Name)</span>
                            }
                        </MudText>
                    }
                    else if (context.NextOffice != null)
                    {
                        <MudText Typo="Typo.body2"><span style="color: #ff9800; font-size: 0.85em; font-style: italic;">Routing to:</span><br /><strong>@context.NextOffice.Name</strong><br />
                            @if(context.NextUnit?.Name != null) 
                            {
                                <span style="color: gray; font-size: 0.85em;">↳ @(context.NextUnit?.Name)</span>
                            }
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Default">Unassigned</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@DocHelpers.GetStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Filled">@context.Status</MudChip>
                </MudTd>
                <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</MudTd>
                <MudTd DataLabel="Actions">
                    <div class="actions-cell">
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Visibility"
                                   OnClick="@(async () => await OpenViewDialog(context))">View</MudButton>
                        <MudIconButton Size="Size.Small" Color="Color.Secondary"
                                       Icon="@Icons.Material.Outlined.QrCode"
                                       OnClick="@(async () => await OpenQRDialog(context))" />
                        <MudIconButton class="mr-1" Size="Size.Small" Color="Color.Warning"
                                       Icon="@Icons.Material.Outlined.Edit"
                                       OnClick="@(async () => await OpenEditDialog(context))" />
                        @if (_multiSelectMode == false)
                        {
                            <MudIconButton Size="Size.Small" Color="Color.Error"
                                           Icon="@Icons.Material.Outlined.Delete"
                                           OnClick="@(async () => await DeleteDocument(context))" />
                        }
                    </div>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <div class="pa-8 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Style="opacity: 0.3; font-size: 4rem;" Class="mb-4" />
                    <MudText Typo="Typo.h6" Class="mud-text-secondary">No documents found</MudText>
                </div>
            </NoRecordsContent>
            <PagerContent><MudTablePager /></PagerContent>
        </MudTable>
    </MudPaper>

</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "ref")] public string? RefParam { get; set; }
    [SupplyParameterFromQuery(Name = "search")] public string? SearchParam { get; set; }


    private MudTable<Document>? _table;
    private List<Office> allOffices = new();
    private string searchString = "";
    private string statusFilter = "";
    private string officeFilter = "";
    private DateTime? dateFrom;
    private DateTime? dateTo;
    private bool dialogOpened = false;
    private HashSet<Document> _selectedDocs = new();
    private bool _isBulkDeleting;
    private bool _multiSelectMode;
    private bool _filterOpen = false;
    private string senderFilter = "";
    private List<string> _senderSuggestions = new();

    private int ActiveFilterCount =>
        (string.IsNullOrEmpty(statusFilter) ? 0 : 1) +
        (string.IsNullOrEmpty(officeFilter) ? 0 : 1) +
        (string.IsNullOrEmpty(senderFilter) ? 0 : 1) +
        (dateFrom == null ? 0 : 1) +
        (dateTo == null ? 0 : 1);

    private void ToggleMultiSelect()
    {
        _multiSelectMode = !_multiSelectMode;
        if (!_multiSelectMode) _selectedDocs.Clear();
    }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(SearchParam))
            searchString = SearchParam;
    }

    private async Task<TableData<Document>> LoadServerData(TableState state, CancellationToken ct)
    {
        try
        {
            var result = await DocumentService.GetAllDocumentsAsync(
            page: state.Page + 1, pageSize: state.PageSize,
            search: searchString, status: statusFilter, office: officeFilter,
            dateFrom: dateFrom?.ToString("yyyy-MM-dd"), dateTo: dateTo?.ToString("yyyy-MM-dd"),
            sender: senderFilter);
            return new TableData<Document> { Items = result.Items, TotalItems = result.TotalCount };
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); return new TableData<Document>(); }
    }

    private async Task OnFilterChanged()
    {
        _selectedDocs.Clear();
        if (_table != null) await _table.ReloadServerData();
    }

    private async Task OnSearchChanged() => await OnFilterChanged();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!string.IsNullOrEmpty(SearchParam) && _table != null)
        {
            searchString = SearchParam;
            await _table.ReloadServerData();
        }

        if (!dialogOpened && !string.IsNullOrEmpty(RefParam))
        {
            dialogOpened = true;
            var doc = await DocumentService.GetDocumentByRefAsync(RefParam);
            if (doc != null) await OpenViewDialog(doc);
        }
    }

    private async Task ClearFilters()
    {
        searchString = "";
        statusFilter = "";
        officeFilter = "";
        senderFilter = "";
        dateFrom = null;
        dateTo = null;
        await OnFilterChanged();
    }

    private async Task ExportCsv()
    {
        try
        {
            var url = DocumentService.GetDocumentsCsvUrl(
                search: searchString, status: statusFilter, office: officeFilter,
                dateFrom: dateFrom?.ToString("yyyy-MM-dd"), dateTo: dateTo?.ToString("yyyy-MM-dd"),
                sender: senderFilter);
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
        catch (Exception ex) { Console.WriteLine($"[ExportCsv] Error: {ex.Message}"); }
    }

    private async Task OpenQRDialog(Document doc)
    {
        var parameters = new DialogParameters<QRCodeDialog>
        {
            { x => x.DocumentId, doc.Id },
            { x => x.ReferenceNumber, doc.ReferenceNumber }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<QRCodeDialog>("QR Code", parameters, options);
    }

    private async Task OpenEditDialog(Document doc)
    {
        var editingDoc = new Document
        {
            Id = doc.Id,
            Name = doc.Name,
            Type = doc.Type,
            Description = doc.Description,
            Priority = doc.Priority,
            FileName = doc.FileName,
            FilePath = doc.FilePath,
            Status = doc.Status,
            CurrentOfficeId = doc.CurrentOfficeId,
            NextOfficeId = doc.NextOfficeId,
            CurrentOffice = doc.CurrentOffice,
            NextOffice = doc.NextOffice,
            CurrentUnitId = doc.CurrentUnitId,
            NextUnitId = doc.NextUnitId
        };
        var parameters = new DialogParameters { { "Doc", editingDoc } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<EditDocumentDialog>("Edit Document", parameters, options);
        var result = await dialog.Result;
        if (!result!.Canceled) await OnFilterChanged();
    }

    private async Task OpenViewDialog(Document doc)
    {
        var parameters = new DialogParameters<DocumentViewDialog> { { x => x.Doc, doc } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<DocumentViewDialog>("Document Details", parameters, options);
        var result = await dialog.Result;
        if (!result!.Canceled) await OnFilterChanged();
    }

    private async Task DeleteDocument(Document doc)
    {
        var parameters = new DialogParameters
        {
            { "Message", $"Delete '{doc.Name}'? This cannot be undone." },
            { "YesText", "Delete" },
            { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Document", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;
        var (ok, error) = await DocumentService.DeleteDocumentAsync(doc.Id);
        if (!ok) { Snackbar.Add(error ?? "Failed to delete document.", Severity.Error); return; }
        await OnFilterChanged();
    }

    private async Task BulkDelete()
    {
        if (!_selectedDocs.Any()) return;
        var parameters = new DialogParameters
        {
            { "Message", $"Delete {_selectedDocs.Count} selected document(s)? This cannot be undone." },
            { "YesText", "Delete All" },
            { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Bulk Delete", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        _isBulkDeleting = true;
        try
        {
            var ids = _selectedDocs.Select(d => d.Id).ToList();
            var (ok, error) = await DocumentService.BulkDeleteDocumentsAsync(ids);
            if (!ok) { Snackbar.Add(error ?? "Bulk delete failed.", Severity.Error); return; }
            Snackbar.Add($"{ids.Count} document(s) deleted.", Severity.Success);
            _selectedDocs.Clear();
            _multiSelectMode = false;
            await OnFilterChanged();
        }
        finally { _isBulkDeleting = false; }
    }

    private async Task<IEnumerable<string>> SearchSenders(string value, CancellationToken ct)
    {
        return await DocumentService.GetSendersAsync(value);
    }

    private async Task<IEnumerable<string>> SearchOffices(string value, CancellationToken ct)
    {
        var offices = await DocumentService.GetOfficesSimpleAsync(string.IsNullOrWhiteSpace(value) ? null : value);
        return offices.Select(o => o.Name ?? "");
    }
}
