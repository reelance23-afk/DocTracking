@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using Microsoft.AspNetCore.Components.Forms
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@rendermode InteractiveAuto

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Class="font-weight-bold">Edit Document</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="3">

            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-primary);">
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Document Information</MudText>
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudTextField @bind-Value="Doc.Name" Label="Document Title" Variant="Variant.Outlined"
                                          Required="true" RequiredError="Document title is required" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" @bind-Value="Doc.Type" Label="Document Type" Variant="Variant.Outlined"
                                       Required="true" RequiredError="Please select a document type">
                                <MudSelectItem Value="@("Memo")">
                                    <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Class="mr-2" Color="Color.Info" />Memo</div>
                                </MudSelectItem>
                                <MudSelectItem Value="@("Letter")">
                                    <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Mail" Size="Size.Small" Class="mr-2" Color="Color.Info" />Letter</div>
                                </MudSelectItem>
                                <MudSelectItem Value="@("Voucher")">
                                    <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Class="mr-2" Color="Color.Info" />Voucher</div>
                                </MudSelectItem>
                                <MudSelectItem Value="@("Report")">
                                    <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Small" Class="mr-2" Color="Color.Info" />Report</div>
                                </MudSelectItem>
                                <MudSelectItem Value="@("Notice")">
                                    <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Announcement" Size="Size.Small" Class="mr-2" Color="Color.Info" />Notice</div>
                                </MudSelectItem>
                                <MudSelectItem Value="@("Other")">
                                    <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Size="Size.Small" Class="mr-2" Color="Color.Info" />Other</div>
                                </MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" @bind-Value="Doc.Priority" Label="Priority Level" Variant="Variant.Outlined"
                                       Required="true" RequiredError="Please select priority">
                                <MudSelectItem Value="@("Emergency")">
                                    <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.PriorityHigh" Size="Size.Small" Class="mr-2" Color="Color.Error" />Emergency</div>
                                </MudSelectItem>
                                <MudSelectItem Value="@("Urgent")">
                                    <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-2" Color="Color.Warning" />Urgent</div>
                                </MudSelectItem>
                                <MudSelectItem Value="@("Medium")">
                                    <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-2" Color="Color.Info" />Medium</div>
                                </MudSelectItem>
                                <MudSelectItem Value="@("Low")">
                                    <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.LowPriority" Size="Size.Small" Class="mr-2" Color="Color.Success" />Low</div>
                                </MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="Doc.Description" Label="Description / Notes" Variant="Variant.Outlined"
                                          Lines="3" HelperText="Optional: Add any additional details" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-success);">
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Attachment</MudText>
                    <MudFileUpload T="IBrowserFile" FilesChanged="OnFileSelected"
                                   Accept=".pdf,.doc,.docx,.jpg,.png" DragAndDrop="true" />
                    @if (!string.IsNullOrEmpty(Doc.FilePath) && selectedFile == null)
                    {
                        <MudPaper Elevation="0" Class="pa-3 mt-3" Style="border-left: 4px solid var(--mud-palette-info); background: rgba(33,150,243,0.06);">
                            <div class="d-flex align-center justify-space-between">
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.AttachFile" Color="Color.Info" Class="mr-2" />
                                    <div>
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@Doc.FileName</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Current attachment</MudText>
                                    </div>
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.Download" Color="Color.Primary"
                                               Size="Size.Small" Href="@Doc.FilePath" Target="_blank" />
                            </div>
                        </MudPaper>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4" Style="border-top: 4px solid var(--mud-palette-warning);">
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Small" Class="mr-2 mb-n1" />
                        Admin Override
                    </MudText>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudSelect @bind-Value="overrideStatus" Label="Force Status" Variant="Variant.Outlined"
                                       HelperText="Override the current document status" T="string">
                                <MudSelectItem T="string" Value="@("")">— No change —</MudSelectItem>
                                <MudSelectItem T="string" Value="@("In Motion")">In Motion</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Received")">Received</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Completed")">Completed</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Value="reassignOfficeId" Label="Reassign to Office"
                                       Variant="Variant.Outlined" T="int?"
                                       HelperText="Redirect document to another office"
                                       ValueChanged="OnOfficeChanged">
                                <MudSelectItem T="int?" Value="@((int?)null)">— No change —</MudSelectItem>
                                @foreach (var office in offices)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)office.Id)">@office.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        @if (reassignOfficeId != null && reassignOfficeUnits.Any())
                        {
                            <MudItem xs="12" md="6">
                                <MudSelect @bind-Value="reassignUnitId" Label="Reassign to Unit (optional)"
                                           Variant="Variant.Outlined" T="int?">
                                    <MudSelectItem T="int?" Value="@((int?)null)">— No specific unit —</MudSelectItem>
                                    @foreach (var unit in reassignOfficeUnits)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)unit.Id)">@unit.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            </MudItem>

        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudSpacer />
        <MudButton Color="Color.Error" Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteDocument">Delete</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Save" Disabled="@isSaving" OnClick="Submit">
            @(isSaving ? "Saving..." : "Save Changes")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Document Doc { get; set; } = new();
    [Parameter] public List<Office> Offices { get; set; } = new();

    private IBrowserFile? selectedFile;
    private List<Office> offices = new();
    private List<Unit> reassignOfficeUnits = new();
    private string overrideStatus = "";
    private int? reassignOfficeId;
    private int? reassignUnitId;
    private bool isSaving;

    private static readonly string[] AllowedExtensions = { ".pdf", ".doc", ".docx", ".jpg", ".png" };

    protected override void OnInitialized()
    {
        offices = Offices;
    }

    private void OnFileSelected(IBrowserFile file)
    {
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (!AllowedExtensions.Contains(ext))
        {
            Snackbar.Add($"File type '{ext}' is not allowed.", Severity.Error);
            return;
        }
        selectedFile = file;
        Doc.FileName = file.Name;
    }

    private void OnOfficeChanged(int? officeId)
    {
        reassignOfficeId = officeId;
        reassignUnitId = null;
        reassignOfficeUnits = offices.FirstOrDefault(o => o.Id == officeId)?.Units?.ToList() ?? new();
    }

    private async Task Submit()
    {
        isSaving = true;
        string? uploadedPath = null;
        try
        {
            if (selectedFile != null)
            {
                uploadedPath = await DocService.UploadFileAsync(selectedFile);
                if (uploadedPath != null) Doc.FilePath = uploadedPath;
                else Snackbar.Add("File upload failed, saving without new file.", Severity.Warning);
            }

            var (docOk, docError) = await DocService.UpdateDocumentAsync(Doc);
            if (!docOk)
            {
                if (uploadedPath != null)
                {
                    try { await DocService.DeleteUploadAsync(uploadedPath); }
                    catch (Exception ex) { Console.WriteLine($"[EditDoc] Cleanup failed: {ex.Message}"); }
                }
                Snackbar.Add(docError ?? "Failed to save document.", Severity.Error);
                return;
            }

            if (!string.IsNullOrEmpty(overrideStatus) || reassignOfficeId.HasValue)
            {
                var payload = new AdminOverridePayload
                {
                    Status = string.IsNullOrEmpty(overrideStatus) ? null : overrideStatus,
                    NextOfficeId = reassignOfficeId,
                    NextUnitId = reassignUnitId
                };
                var (overrideOk, overrideError) = await DocService.AdminOverrideDocumentAsync(Doc.Id, payload);
                if (!overrideOk)
                {
                    Snackbar.Add(overrideError ?? "Failed to apply admin override.", Severity.Error);
                    return;
                }
            }

            MudDialog.Close(DialogResult.Ok(Doc));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[EditDoc] Submit error: {ex.Message}");
            Snackbar.Add("An unexpected error occurred while saving.", Severity.Error);
            if (uploadedPath != null)
            {
                try { await DocService.DeleteUploadAsync(uploadedPath); }
                catch { }
            }
        }
        finally { isSaving = false; }
    }




    private void Cancel() => MudDialog.Cancel();

    private async Task DeleteDocument()
    {
        var parameters = new DialogParameters
        {
            { "Message", $"Are you sure you want to delete '{Doc.Name}'? This action cannot be undone." },
            { "YesText", "Delete" },
            { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Confirm Delete", parameters);
        var result = await dialog.Result;
        if (result.Canceled) return;

        var (success, error) = await DocService.DeleteDocumentAsync(Doc.Id);
        if (success)
        {
            Snackbar.Add("Document deleted successfully!", Severity.Success);
            MudDialog.Close(DialogResult.Ok("deleted"));
        }
        else
        {
            Snackbar.Add($"Failed to delete document: {error}", Severity.Error);
        }
    }
}
