@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using Microsoft.AspNetCore.Components.Forms
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@rendermode InteractiveAuto

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Class="font-weight-bold">Edit Document</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_loadingInit)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Filled.AdminPanelSettings" Class="mb-4">
                <MudText Typo="Typo.caption">
                    Changes to status and office routing will be applied as an admin and logged in the audit trail.
                </MudText>
            </MudAlert>
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <MudTextField @bind-Value="Doc.Name" Label="Document Title" Variant="Variant.Outlined"
                                  Required="true" RequiredError="Document title is required" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" @bind-Value="Doc.Type" Label="Document Type" Variant="Variant.Outlined"
                               Required="true" RequiredError="Please select a document type">
                        <MudSelectItem Value="@("Memo")">Memo</MudSelectItem>
                        <MudSelectItem Value="@("Letter")">Letter</MudSelectItem>
                        <MudSelectItem Value="@("Voucher")">Voucher</MudSelectItem>
                        <MudSelectItem Value="@("Report")">Report</MudSelectItem>
                        <MudSelectItem Value="@("Notice")">Notice</MudSelectItem>
                        <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" @bind-Value="Doc.Priority" Label="Priority Level" Variant="Variant.Outlined"
                               Required="true" RequiredError="Please select priority">
                        <MudSelectItem Value="@("Emergency")">Emergency</MudSelectItem>
                        <MudSelectItem Value="@("Urgent")">Urgent</MudSelectItem>
                        <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
                        <MudSelectItem Value="@("Low")">Low</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="overrideStatus" Label="Status" Variant="Variant.Outlined" T="string">
                        <MudSelectItem T="string" Value="@("In Motion")">In Motion</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Received")">Received</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Completed")">Completed</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudAutocomplete T="Office"
                                     Label="Office"
                                     Value="_selectedReassignOffice"
                                     ValueChanged="OnOfficeAutoChanged"
                                     SearchFunc="SearchReassignOffices"
                                     ToStringFunc="@(o => o?.Name ?? string.Empty)"
                                     Variant="Variant.Outlined"
                                     AdornmentIcon="@Icons.Material.Filled.Business"
                                     AdornmentColor="Color.Primary"
                                     CoerceText="false"
                                     CoerceValue="false"
                                     ResetValueOnEmptyText="true"
                                     MaxItems="null"
                                     HelperText="@($"Current: {Doc.CurrentOffice?.Name ?? Doc.NextOffice?.Name ?? "—"}")" />
                </MudItem>

                @if (reassignOfficeId != null && _loadingUnits)
                {
                    <MudItem xs="12" md="6">
                        <MudProgressLinear Indeterminate="true" />
                    </MudItem>
                }
                else if (reassignOfficeId != null && reassignOfficeUnits.Any())
                {
                    <MudItem xs="12" md="6">
                        <MudSelect @bind-Value="reassignUnitId" Label="Reassign to Unit"
                                   Variant="Variant.Outlined" T="int?">
                            <MudSelectItem T="int?" Value="@((int?)null)">— No specific unit —</MudSelectItem>
                            @foreach (var unit in reassignOfficeUnits)
                            {
                                <MudSelectItem T="int?" Value="@((int?)unit.Id)">@unit.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }
                <MudItem xs="12">
                    <MudTextField @bind-Value="Doc.Description" Label="Description / Notes" Variant="Variant.Outlined"
                                  Lines="3" />
                </MudItem>
                <MudItem xs="12">
                    <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="OnFilesSelected"
                                    Accept=".pdf,.doc,.docx,.jpg,.png" DragAndDrop="true" Multiple="true">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AttachFile">
                                Select Files
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                    @if (selectedFiles.Any())
                    {
                        <div class="mt-2">
                            @foreach (var file in selectedFiles)
                            {
                                <div class="d-flex align-center gap-2 mb-1">
                                    <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" />
                                    <MudText Typo="Typo.body2">@file.Name</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error"
                                                    OnClick="@(() => selectedFiles.Remove(file))" />
                                </div>
                            }
                        </div>
                    }
                    @if (Doc.Attachments.Any())
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-3">Current Attachments</MudText>
                        @foreach (var attachment in Doc.Attachments)
                        {
                            <div class="d-flex align-center gap-2 mb-1">
                                <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" />
                                <MudText Typo="Typo.body2">@attachment.FileName</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small" Color="Color.Primary"
                                                Href="@attachment.FilePath" Target="_blank" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                OnClick="@(async () => await RemoveAttachment(attachment))" />
                            </div>
                        }
                    }
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudSpacer />
        <MudButton Color="Color.Error" Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteDocument">Delete</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Save" Disabled="@(isSaving || _loadingInit)" OnClick="Submit">
            @(isSaving ? "Saving..." : "Save Changes")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Document Doc { get; set; } = new();

    private List<IBrowserFile> selectedFiles = new();
    private List<Office> _offices = new();
    private Office? _selectedReassignOffice;
    private List<Unit> reassignOfficeUnits = new();
    private string overrideStatus = "";
    private int? reassignOfficeId;
    private int? reassignUnitId;
    private bool isSaving;
    private bool _loadingInit = true;
    private bool _loadingUnits;

    private static readonly string[] AllowedExtensions = { ".pdf", ".doc", ".docx", ".jpg", ".png" };

    protected override async Task OnInitializedAsync()
    {
        overrideStatus = Doc.Status ?? "";
        reassignOfficeId = Doc.CurrentOfficeId ?? Doc.NextOfficeId;
        reassignUnitId = Doc.CurrentUnitId ?? Doc.NextUnitId;

        _selectedReassignOffice = _offices.FirstOrDefault(o => o.Id == reassignOfficeId);
        _offices = await DocService.GetOfficesSimpleAsync();

        if (reassignOfficeId.HasValue)
            reassignOfficeUnits = await DocService.GetUnitsByOfficeAsync(reassignOfficeId.Value);

        _loadingInit = false;
    }

    private void OnFilesSelected(IReadOnlyList<IBrowserFile> files)
    {
        if (files == null) return;
        foreach (var file in files)
        {
            var ext = Path.GetExtension(file.Name).ToLowerInvariant();
            if (!AllowedExtensions.Contains(ext))
            {
                Snackbar.Add($"'{file.Name}' is not allowed.", Severity.Error);
                continue;
            }
            if (!selectedFiles.Any(f => f.Name == file.Name))
                selectedFiles.Add(file);
        }
    }

    private async Task OnOfficeChanged(int? officeId)
    {
        reassignOfficeId = officeId;
        reassignUnitId = null;
        reassignOfficeUnits = new();
        if (officeId.HasValue)
        {
            _loadingUnits = true;
            StateHasChanged();
            reassignOfficeUnits = await DocService.GetUnitsByOfficeAsync(officeId.Value);
            _loadingUnits = false;
        }
    }

    private Task<IEnumerable<Office>> SearchReassignOffices(string value, CancellationToken ct)
    {
        var results = string.IsNullOrWhiteSpace(value)
            ? _offices
            : _offices.Where(o => o.Name!.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult<IEnumerable<Office>>(results);
    }

    private async Task OnOfficeAutoChanged(Office? office)
    {
        _selectedReassignOffice = office;
        await OnOfficeChanged(office?.Id);
    }

    private async Task Submit()
    {
        var confirm = new DialogParameters
        {
            { "Message", "Are you sure you want to save these changes?" },
            { "YesText", "Save" },
            { "CancelText", "Cancel" }
        };
        var confirmDialog = await DialogService.ShowAsync<MudMessageBox>("Confirm Save", confirm);
        var confirmResult = await confirmDialog.Result;
        if (confirmResult.Canceled) return;

        isSaving = true;
        try
        {
            var (docOk, docError) = await DocService.UpdateDocumentAsync(Doc);
            if (!docOk)
            {
                Snackbar.Add(docError ?? "Failed to save document.", Severity.Error);
                return;
            }

            if (selectedFiles.Any())
            {
                foreach (var file in selectedFiles)
                {
                    var path = await DocService.UploadFileAsync(file);
                    if (path != null)
                        await DocService.AddAttachmentAsync(Doc.Id, file.Name, path);
                    else
                        Snackbar.Add($"Failed to upload '{file.Name}'.", Severity.Warning);
                }
            }

            if (!string.IsNullOrEmpty(overrideStatus) || reassignOfficeId.HasValue)
            {
                var payload = new AdminOverridePayload
                {
                    Status = overrideStatus,
                    NextOfficeId = reassignOfficeId,
                    NextUnitId = reassignUnitId
                };
                var (overrideOk, overrideError) = await DocService.AdminOverrideDocumentAsync(Doc.Id, payload);
                if (!overrideOk)
                {
                    Snackbar.Add(overrideError ?? "Failed to apply admin override.", Severity.Error);
                    return;
                }
            }

            MudDialog.Close(DialogResult.Ok(Doc));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[EditDoc] Submit error: {ex.Message}");
            Snackbar.Add("An unexpected error occurred while saving.", Severity.Error);
        }
        finally { isSaving = false; }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task DeleteDocument()
    {
        var parameters = new DialogParameters
        {
            { "Message", $"Are you sure you want to delete '{Doc.Name}'? This action cannot be undone." },
            { "YesText", "Delete" },
            { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Confirm Delete", parameters);
        var result = await dialog.Result;
        if (result.Canceled) return;

        var (success, error) = await DocService.DeleteDocumentAsync(Doc.Id);
        if (success)
        {
            Snackbar.Add("Document deleted successfully!", Severity.Success);
            MudDialog.Close(DialogResult.Ok("deleted"));
        }
        else
        {
            Snackbar.Add($"Failed to delete document: {error}", Severity.Error);
        }
    }

    private async Task RemoveAttachment(DocumentAttachment attachment)
    {
        var (ok, error) = await DocService.DeleteAttachmentAsync(Doc.Id, attachment.Id);
        if (!ok) { Snackbar.Add(error ?? "Failed to remove attachment.", Severity.Error); return; }
        Doc.Attachments.Remove(attachment);
        await DocService.DeleteUploadAsync(attachment.FilePath);
    }
}
