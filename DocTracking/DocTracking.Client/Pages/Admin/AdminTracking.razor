@page "/admin-track-document/{DocumentId:int}"
@attribute [Authorize(Roles = "Admin")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject DocumentService DocService
@inject NavigationManager Navigation
@rendermode @(new InteractiveAutoRenderMode(prerender: false))

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-8">
    <div class="d-flex align-center mb-6">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default" OnClick="Back" Class="mr-2" Size="Size.Large" />
        <div class="d-flex flex-column flex-sm-row align-start align-sm-center gap-2">
            <MudText Typo="Typo.h4" Class="font-weight-bold">Document Tracking</MudText>
            @if (documentLogs.Any() && documentLogs.First().Document?.ReferenceNumber != null)
            {
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Medium">
                    @documentLogs.First().Document?.ReferenceNumber
                </MudChip>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-center mt-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (!documentLogs.Any())
    {
        <MudPaper Elevation="0" Class="pa-8 text-center mud-background-gray rounded-xl">
            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Style="opacity: 0.5; font-size: 4rem;" Class="mb-4" />
            <MudText Typo="Typo.h6" Class="mud-text-secondary">No tracking history found.</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="3" Class="pa-4 pa-md-6 rounded-xl">

            @* Mobile *@
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                @for (int i = 0; i < documentLogs.Count; i++)
                {
                    var log = documentLogs[i];
                    bool isCurrent = (i == 0);
                    bool isCompleted = log.Action == "Completed";

                    <MudCard Elevation="@(isCurrent ? 4 : 1)" Class="@($"mb-3 {(isCurrent ? "border-solid border-l-4 mud-border-primary" : "")}")">
                        <MudCardHeader Class="pb-1">
                            <CardHeaderContent>
                                <div class="d-flex justify-space-between align-center">
                                    <div class="d-flex align-center gap-2">
                                        <MudIcon Icon="@GetIconForAction(log.Action)" Color="@GetActionColor(log.Action)" Size="Size.Small" />
                                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@log.Action</MudText>
                                        @if (isCurrent && !isCompleted)
                                        {
                                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">CURRENT</MudChip>
                                        }
                                    </div>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @log.TimeStamp.ToLocalTime().ToString("MMM dd • hh:mm tt")
                                    </MudText>
                                </div>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent Class="pt-0">
                            <MudText Typo="Typo.body2" Class="mb-1">
                                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small" Class="mr-1 mud-text-secondary" />
                                <span class="mud-text-secondary">By:</span> <strong>@(log.AppUser?.Name ?? log.UserName ?? "System")</strong>
                            </MudText>
                            @if (log.Office != null || !string.IsNullOrEmpty(log.OfficeName))
                            {
                                <MudText Typo="Typo.body2">
                                    <MudIcon Icon="@GetLocationIcon(log.Action)" Size="Size.Small" Color="@GetLocationColor(log.Action)" Class="mr-1" />
                                    <span class="mud-text-secondary">@GetLocationLabel(log.Action):</span>
                                    <strong>@(log.Office?.Name ?? log.OfficeName)</strong>
                                    @if (log.Office == null && !string.IsNullOrEmpty(log.OfficeName))
                                    {
                                        <span class="mud-text-secondary" style="font-style: italic;"> (deleted)</span>
                                    }
                                </MudText>
                                @if (log.Unit != null || !string.IsNullOrEmpty(log.UnitName))
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary ml-5">
                                        ↳ @(log.Unit?.Name ?? log.UnitName)
                                        @if (log.Unit == null && !string.IsNullOrEmpty(log.UnitName))
                                        {
                                            <span style="font-style: italic;"> (deleted)</span>
                                        }
                                    </MudText>
                                }
                            }
                            @if (isCompleted)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Success" Class="font-weight-medium mt-1">Document processing completed successfully</MudText>
                            }
                        </MudCardContent>
                    </MudCard>
                }
            </MudHidden>

            @* Desktop *@
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudTimeline TimelinePosition="TimelinePosition.Start" Class="w-100">
                    @for (int i = 0; i < documentLogs.Count; i++)
                    {
                        var log = documentLogs[i];
                        bool isCurrent = (i == 0);
                        bool isCompleted = log.Action == "Completed";

                        <MudTimelineItem Color="@GetTimelineColor(log.Action, isCurrent)"
                                         Size="Size.Large" Variant="Variant.Filled"
                                         Icon="@GetIconForAction(log.Action)">
                            <ItemContent>
                                <MudCard Elevation="@(isCurrent ? 8 : 2)" Class="@($"mb-4 {GetCardClass(log.Action, isCurrent)}")">
                                    <MudCardHeader Class="pb-2">
                                        <CardHeaderContent>
                                            <div class="d-flex justify-space-between align-center">
                                                <div class="d-flex align-center gap-2">
                                                    <MudIcon Icon="@GetIconForAction(log.Action)" Color="@GetActionColor(log.Action)" Size="Size.Medium" />
                                                    <MudText Typo="Typo.h6" Class="font-weight-bold">@log.Action</MudText>
                                                    @if (isCurrent && !isCompleted)
                                                    {
                                                        <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">CURRENT</MudChip>
                                                    }
                                                </div>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary font-weight-medium">
                                                    @log.TimeStamp.ToLocalTime().ToString("MMM dd • hh:mm tt")
                                                </MudText>
                                            </div>
                                        </CardHeaderContent>
                                    </MudCardHeader>
                                    <MudCardContent Class="pt-0">
                                        <MudGrid>
                                            <MudItem xs="12" sm="6">
                                                <div class="d-flex align-center mb-2">
                                                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small" Class="mr-2 mud-text-secondary" />
                                                    <MudText Typo="Typo.body2">
                                                        <span class="mud-text-secondary">By:</span> <strong>@(log.AppUser?.Name ?? log.UserName ?? "System")</strong>
                                                    </MudText>
                                                </div>
                                            </MudItem>
                                            @if (log.Office != null || !string.IsNullOrEmpty(log.OfficeName))
                                            {
                                                <MudItem xs="12" sm="6">
                                                    <div class="d-flex align-center mb-2">
                                                        <MudIcon Icon="@GetLocationIcon(log.Action)" Size="Size.Small" Color="@GetLocationColor(log.Action)" Class="mr-2" />
                                                        <div>
                                                            <MudText Typo="Typo.body2">
                                                                <span class="mud-text-secondary">@GetLocationLabel(log.Action):</span>
                                                                <strong>@(log.Office?.Name ?? log.OfficeName)</strong>
                                                                @if (log.Office == null && !string.IsNullOrEmpty(log.OfficeName))
                                                                {
                                                                    <span class="mud-text-secondary" style="font-style: italic;"> (deleted)</span>
                                                                }
                                                            </MudText>
                                                            @if (log.Unit != null || !string.IsNullOrEmpty(log.UnitName))
                                                            {
                                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                                    ↳ @(log.Unit?.Name ?? log.UnitName)
                                                                    @if (log.Unit == null && !string.IsNullOrEmpty(log.UnitName))
                                                                    {
                                                                        <span style="font-style: italic;"> (deleted)</span>
                                                                    }
                                                                </MudText>
                                                            }
                                                        </div>
                                                    </div>
                                                </MudItem>
                                            }
                                        </MudGrid>
                                        @if (isCompleted)
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Success" Class="font-weight-medium mt-2">Document processing completed successfully</MudText>
                                        }
                                    </MudCardContent>
                                </MudCard>
                            </ItemContent>
                        </MudTimelineItem>
                    }
                </MudTimeline>
            </MudHidden>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4">Error loading data: @errorMessage</MudAlert>
            }
        </MudPaper>
    }

</MudContainer>

@code {
    [Parameter]
    public int DocumentId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "ReturnUrl")]
    public string? ReturnUrl { get; set; }

    private List<DocumentLog> documentLogs = new();
    private bool isLoading = true;

    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {

            var profile = await DocService.GetProfileAsync();
            int? myUnitId = profile?.UnitId;
            int? myOfficeId = profile?.Unit?.OfficeId ?? profile?.OfficeId;


            documentLogs = await DocService.GetDocumentLogsAsync(DocumentId);

        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"Error loading logs: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetIconForAction(string? action)
    {
        return action switch
        {
            "Created" => Icons.Material.Filled.NoteAdd,
            "Forwarded" => Icons.Material.Filled.DirectionsWalk,
            "Received" => Icons.Material.Filled.Inbox,
            "Completed" => Icons.Material.Filled.CheckCircle,
            _ => Icons.Material.Filled.Circle
        };
    }

    private void Back()
    {
        Navigation.NavigateTo($"/document-tracking");
    }

    private Color GetTimelineColor(string? action, bool isCurrent) => action switch
    {
        "Created" when isCurrent => Color.Info,
        "Forwarded" when isCurrent => Color.Warning,
        "Received" when isCurrent => Color.Primary,
        "Completed" when isCurrent => Color.Success,
        _ => Color.Default
    };

    private string GetCardClass(string? action, bool isCurrent) =>
        isCurrent ? "transition-all duration-300 mud-elevation-8" : "transition-all duration-300";

    private Color GetActionColor(string? action) => action switch
    {
        "Created" => Color.Info,
        "Forwarded" => Color.Warning,
        "Received" => Color.Primary,
        "Completed" => Color.Success,
        _ => Color.Default
    };

    private Color GetLocationColor(string? action) => action switch
    {
        "Created" or "Forwarded" => Color.Warning,
        _ => Color.Success
    };

    private string GetLocationIcon(string? action) => action switch
    {
        "Created" or "Forwarded" => Icons.Material.Filled.Send,
        _ => Icons.Material.Filled.LocationOn
    };

    private string GetLocationLabel(string? action) => action switch
    {
        "Created" or "Forwarded" => "Sent to",
        _ => "Location"
    };

}
