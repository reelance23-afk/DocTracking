@page "/admin-audit-log"
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@inject DocumentService DocService
@attribute [Authorize(Roles = "Admin")]

<MudText Typo="Typo.h5" class="mb-4">Audit Log</MudText>

<MudPaper Class="pa-3 mb-3" Elevation="1">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="4">
            <MudTextField @bind-Value="searchText" Label="Search document / user / action"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" Clearable="true" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect T="string" @bind-Value="filterAction" Label="Action" Clearable="true">
                @foreach (var a in actions)
                {
                    <MudSelectItem Value="@a">@a</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudDatePicker @bind-Date="filterDate" Label="Date" Clearable="true" />
        </MudItem>
        <MudItem xs="12" sm="2" Class="d-flex align-end">
            <MudButton OnClick="ClearFilters" Variant="Variant.Outlined" Size="Size.Small" FullWidth="true">Clear</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="FilteredLogs" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Timestamp</MudTh>
            <MudTh>Document</MudTh>
            <MudTh>Action</MudTh>
            <MudTh>By</MudTh>
            <MudTh>Office / Unit</MudTh>
            <MudTh>Comment</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.TimeStamp.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</MudTd>
            <MudTd>
                <MudText Typo="Typo.body2">@context.Document?.Name</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Document?.ReferenceNumber</MudText>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@GetActionColor(context.Action)">@context.Action</MudChip>
            </MudTd>
            <MudTd>@(context.AppUser?.Name ?? "—")</MudTd>
            <MudTd>
                @if (context.Unit != null)
                {
                    <span>@context.Unit.Name <MudText Typo="Typo.caption" Class="mud-text-secondary">(@context.Office?.Name)</MudText></span>
                }
                else
                {
                    <span>@(context.Office?.Name ?? "—")</span>
                }
            </MudTd>
            <MudTd>@(context.Comment ?? "—")</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4 mud-text-secondary">No log entries found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
}

@code{
	private List<DocumentLog> logs = new();
	private bool loading = true;
	private string searchText = "";
	private string? filterAction;
	private DateTime? filterDate;

	private static readonly string[] actions = { "Created", "Received", "Forwarded", "Completed", "Admin Override" };

	private IEnumerable<DocumentLog> FilteredLogs => logs.Where(l =>
		(string.IsNullOrEmpty(searchText) ||
			(l.Document?.Name?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
			(l.Document?.ReferenceNumber?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
			(l.AppUser?.Name?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
			(l.Action?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true)) &&
		(filterAction == null || l.Action == filterAction) &&
		(filterDate == null || l.TimeStamp.Date == filterDate.Value.Date)
	);

	protected override async Task OnInitializedAsync()
	{
		logs = await DocService.GetAuditLogsAsync();
		loading = false;
	}

	private void ClearFilters()
	{
		searchText = "";
		filterAction = null;
		filterDate = null;
	}

	private Color GetActionColor(string? action) => action switch
	{
		"Created" => Color.Success,
		"Received" => Color.Info,
		"Forwarded" => Color.Warning,
		"Completed" => Color.Primary,
		"Admin Override" => Color.Error,
		_ => Color.Default
	};
}
