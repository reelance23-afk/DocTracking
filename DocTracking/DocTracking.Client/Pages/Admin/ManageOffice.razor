@page "/manage-offices"
@attribute [Authorize(Roles = "Admin")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Pages.Offices
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@rendermode InteractiveAuto

<style>
    @@media (max-width: 599px) {
        .desktop-table { display: none !important; }
        .mobile-units { display: block !important; }
    }
    @@media (min-width: 600px) {
        .desktop-table { display: block !important; }
        .mobile-units { display: none !important; }
    }
</style>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-8">
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold">Office Management</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Manage offices and their respective units.</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenAddOfficeDialog" Class="d-none d-md-flex">
            Add Office
        </MudButton>
    </div>

    <MudTextField Value="@searchString"
                  ValueChanged="@((string v) => OnSearchChanged(v))"
                  Placeholder="Search Offices..." Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-6"
                  Variant="Variant.Outlined" Margin="Margin.Dense" DebounceInterval="400" />

    @if (loading)
    {
        <div class="d-flex justify-center mt-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (officeResult.Items.Any())
    {
        <MudExpansionPanels MultiExpansion="true" Elevation="2">
            @foreach (var office in officeResult.Items)
            {
                <MudExpansionPanel @key="office.Id" MaxHeight="1500">
                    <TitleContent>
                        <div class="d-flex align-center justify-space-between w-100 pr-2" style="flex-wrap: wrap; gap: 4px;">
                            <div class="d-flex align-center gap-3" style="min-width: 0; flex: 1;">
                                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                                </MudAvatar>
                                <div style="min-width: 0;">
                                    <MudText Typo="Typo.body1" Class="font-weight-bold" Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@office.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @(office.Units?.Count ?? 0) unit@(office.Units?.Count == 1 ? "" : "s") &bull;
                                        @(allUsers.Count(u => (office.Units?.Any(un => un.Id == u.UnitId) == true) || (u.OfficeId == office.Id && u.UnitId == null))) worker@(allUsers.Count(u => (office.Units?.Any(un => un.Id == u.UnitId) == true) || (u.OfficeId == office.Id && u.UnitId == null)) == 1 ? "" : "s")
                                    </MudText>
                                </div>
                            </div>
                            <div class="d-flex align-center gap-1 flex-shrink-0" @onclick:stopPropagation>
                                @if (!string.IsNullOrEmpty(office.ReceivingSchedule))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                                             Icon="@Icons.Material.Filled.Schedule" Class="mr-1">
                                        @office.ReceivingSchedule
                                    </MudChip>
                                }
                                @if (!(office.Units?.Any() ?? false))
                                {
                                    <MudTooltip Text="Assign Workers">
                                        <MudIconButton Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small"
                                                       Color="Color.Success" Disabled="@(!nonAdminUsers.Any())"
                                                       OnClick="@(() => OpenOfficeAssignDialog(office))" />
                                    </MudTooltip>
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.EditCalendar" Size="Size.Small"
                                               Color="Color.Primary" OnClick="@(() => OpenScheduleDialog(office))"
                                               Title="Set Receiving Schedule" />
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               Color="Color.Warning" OnClick="@(() => OpenEditOfficeDialog(office))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" OnClick="@(() => DeleteOffice(office))" />
                            </div>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudDivider />
                        <div class="pa-4">
                            <MudPaper Elevation="0" Class="pa-3 mb-4 rounded-lg mud-background-gray">
                                @{
                                    var officeWorkers = allUsers.Where(u => u.OfficeId == office.Id && u.UnitId == null).ToList();
                                }
                                @if (officeWorkers.Any())
                                {
                                    <MudPaper Elevation="0" Class="pa-3 mb-4 rounded-lg" Style="background: rgba(var(--mud-palette-success-rgb), 0.06);">
                                        <div class="d-flex justify-space-between align-center mb-2">
                                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Workers</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@officeWorkers.Count worker(s)</MudText>
                                        </div>
                                        <div class="d-flex align-center gap-1 flex-wrap">
                                            @foreach (var worker in officeWorkers)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">@worker.Name</MudChip>
                                            }
                                        </div>
                                    </MudPaper>
                                }
                                <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-bold">Add New Unit</MudText>
                                <div class="d-flex gap-2 align-center unit-input-row">
                                    <input type="text"
                                           value="@GetUnitName(office.Id)"
                                           @oninput="@(e => SetUnitName(office.Id, e.Value?.ToString() ?? ""))"
                                           placeholder="Unit Name"
                                           class="mud-input-root mud-input-root-outlined mud-input-root-margin-dense"
                                           style="flex:1; padding: 8px 12px; border: 1px solid #d0d7de; border-radius: 4px;" />
                                    <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                                               Disabled="@(string.IsNullOrWhiteSpace(GetUnitName(office.Id)) || isSubmittingUnit)"
                                               OnClick="@(() => SubmitUnit(office))">
                                        @(isSubmittingUnit ? "Adding..." : "Add Unit")
                                    </MudButton>
                                </div>
                            </MudPaper>

                            @if (office.Units != null && office.Units.Any())
                            {
                                <MudTable Items="office.Units" Hover="true" Dense="true" Elevation="0"
                                          Class="rounded-lg overflow-hidden desktop-table" T="Unit">
                                    <HeaderContent>
                                        <MudTh>Unit</MudTh>
                                        <MudTh>Workers</MudTh>
                                        <MudTh Style="text-align:right">Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate Context="unit">
                                        @{
                                            var unitWorkers = allUsers.Where(u => u.UnitId == unit.Id).ToList();
                                        }
                                        <MudTd>
                                            <div class="d-flex align-center gap-2">
                                                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="mud-text-secondary" />
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@unit.Name</MudText>
                                            </div>
                                        </MudTd>
                                        <MudTd>
                                            @if (unitWorkers.Any())
                                            {
                                                <div class="d-flex align-center gap-1 flex-wrap">
                                                    @foreach (var worker in unitWorkers)
                                                    {
                                                        <MudTooltip Text="@worker.Name">
                                                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled"
                                                                       Style="height:28px;width:28px;font-size:0.7rem;">
                                                                @worker.Name?.FirstOrDefault().ToString().ToUpper()
                                                            </MudAvatar>
                                                        </MudTooltip>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary font-italic">No workers</MudText>
                                            }
                                        </MudTd>
                                        <MudTd Style="text-align:right">
                                            <MudTooltip Text="Assign Workers">
                                                <MudIconButton Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small"
                                                               Color="Color.Success" Disabled="@(!nonAdminUsers.Any())"
                                                               OnClick="@(() => OpenAssignDialog(unit))" />
                                            </MudTooltip>
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                           Color="Color.Warning" OnClick="@(() => OpenEditUnitDialog(unit))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                           Color="Color.Error" OnClick="@(() => DeleteUnit(unit))" />
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>

                                <div class="mobile-units">
                                    @foreach (var unit in office.Units)
                                    {
                                        var unitWorkers = allUsers.Where(u => u.UnitId == unit.Id).ToList();
                                        <MudPaper Elevation="1" Class="pa-3 mb-3 rounded-lg">
                                            <div class="d-flex justify-space-between align-start mb-2">
                                                <div class="d-flex align-center gap-2">
                                                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Color="Color.Primary" />
                                                    <MudText Typo="Typo.body1" Class="font-weight-bold">@unit.Name</MudText>
                                                </div>
                                                <div class="d-flex gap-1">
                                                    <MudIconButton Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small"
                                                                   Color="Color.Success" Disabled="@(!nonAdminUsers.Any())"
                                                                   OnClick="@(() => OpenAssignDialog(unit))" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                   Color="Color.Warning" OnClick="@(() => OpenEditUnitDialog(unit))" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                   Color="Color.Error" OnClick="@(() => DeleteUnit(unit))" />
                                                </div>
                                            </div>
                                            <MudDivider Class="my-2" />
                                            <div>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">Workers:</MudText>
                                                @if (unitWorkers.Any())
                                                {
                                                    <div class="d-flex align-center gap-1 flex-wrap">
                                                        @foreach (var worker in unitWorkers)
                                                        {
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">@worker.Name</MudChip>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary font-italic">No workers assigned</MudText>
                                                }
                                            </div>
                                        </MudPaper>
                                    }
                                </div>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary font-italic">No units yet.</MudText>
                            }
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>

        @if (officeResult.TotalCount > officeResult.Items.Count)
        {
            <div class="d-flex justify-center mt-4">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           Disabled="@isLoadingMore" OnClick="LoadMore">
                    @(isLoadingMore ? "Loading..." : $"Load More ({officeResult.Items.Count} of {officeResult.TotalCount})")
                </MudButton>
            </div>
        }
    }
    else
    {
        <div class="d-flex flex-column align-center mt-10">
            <MudIcon Icon="@Icons.Material.Filled.BusinessCenter" Size="Size.Large" Color="Color.Default"
                     Class="mb-3" Style="opacity:0.4; font-size:4rem;" />
            <MudText Typo="Typo.body1" Class="mud-text-secondary">No offices found.</MudText>
        </div>
    }
</MudContainer>

<MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
        OnClick="OpenAddOfficeDialog" Class="d-md-none"
        Style="position: fixed; bottom: 24px; right: 24px; z-index: 1000;" />

<MudDialog @bind-Visible="isAssignOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true })">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Success" />
            <MudText Typo="Typo.h6"><strong>@(assignTargetUnit?.Name ?? assignTargetOffice?.Name)</strong></MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="assignSearch" Placeholder="Search users..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Class="mb-3" />
        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3 d-block">
            Check to assign, uncheck to remove from this unit.
        </MudText>
        <MudPaper Elevation="0" Style="max-height: 320px; overflow-y: auto;">
            @foreach (var user in assignSortedUsers.Where(u =>
                string.IsNullOrWhiteSpace(assignSearch) ||
                u.Name?.Contains(assignSearch, StringComparison.OrdinalIgnoreCase) == true))
            {
                <div class="d-flex align-center pa-1">
                    <MudCheckBox T="bool" Value="@assignSelectedIds.Contains(user.Id)"
                                 ValueChanged="@(v => ToggleAssignUser(user.Id, v))"
                                 Color="Color.Success" Class="flex-grow-1">
                        <div>
                            <MudText Typo="Typo.body2" Class="font-weight-bold">@user.Name</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@GetUserCurrentAssignment(user)</MudText>
                        </div>
                    </MudCheckBox>
                </div>
                <MudDivider />
            }
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => isAssignOpen = false)">Cancel</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" Disabled="@isAssigning" OnClick="ConfirmAssign">
            @(isAssigning ? "Saving..." : $"Save ({assignSelectedIds.Count} selected)")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private PagedResult<Office> officeResult = new();
    private List<AppUser> allUsers = new();
    private bool loading = true;
    private bool isLoadingMore = false;
    private string searchString = "";
    private int _currentPage = 1;
    private const int PageSize = 25;
    private Office? assignTargetOffice;
    private string assignSearch = "";
    private List<AppUser> assignSortedUsers = new();
    private Dictionary<int, string> unitNames = new();
    private bool isSubmittingUnit;
    private bool isSubmitting;
    private DialogOptions dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
    private bool isAssignOpen;
    private bool isAssigning;
    private Unit? assignTargetUnit;
    private HashSet<int> assignSelectedIds = new();
    private List<AppUser> nonAdminUsers => allUsers.Where(u => u.Role != "Admin").ToList();


    private string GetUnitName(int officeId) => unitNames.TryGetValue(officeId, out var name) ? name : "";
    private void SetUnitName(int officeId, string value) => unitNames[officeId] = value;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            allUsers = await DocService.GetAppUserAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] LoadUsers error: {ex.Message}");
        }
        await LoadOffices();
    }

    private async Task LoadOffices(bool showSpinner = true)
    {
        if (showSpinner) loading = true;
        try
        {
            var result = await DocService.GetOfficesPagedAsync(page: 1, pageSize: PageSize, search: searchString);
            officeResult = result;
            _currentPage = 1;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] LoadOffices error: {ex.Message}");
            Snackbar.Add("Failed to load offices.", Severity.Error);
        }
        finally { if (showSpinner) loading = false; }
    }

    private void OnSearchChanged(string value)
    {
        searchString = value;
        _ = LoadOffices();
    }

    private async Task LoadMore()
    {
        isLoadingMore = true;
        try
        {
            _currentPage++;
            var result = await DocService.GetOfficesPagedAsync(page: _currentPage, pageSize: PageSize, search: searchString);
            officeResult.Items.AddRange(result.Items);
            officeResult.TotalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] LoadMore error: {ex.Message}");
            Snackbar.Add("Failed to load more offices.", Severity.Error);
        }
        finally { isLoadingMore = false; }
    }

    private void ToggleAssignUser(int userId, bool selected)
    {
        if (selected) assignSelectedIds.Add(userId);
        else assignSelectedIds.Remove(userId);
    }

    private string GetUserCurrentAssignment(AppUser user)
    {
        if (user.UnitId.HasValue)
        {
            var unit = officeResult.Items.SelectMany(o => o.Units ?? new List<Unit>()).FirstOrDefault(u => u.Id == user.UnitId);
            var office = officeResult.Items.FirstOrDefault(o => o.Units?.Any(u => u.Id == user.UnitId) == true);
            return unit != null ? $"{office?.Name} — {unit.Name}" : "Assigned to a unit";
        }
        if (user.OfficeId.HasValue)
        {
            var office = officeResult.Items.FirstOrDefault(o => o.Id == user.OfficeId);
            return user.IsOfficeHead ? $"{office?.Name} (Office Head)" : $"{office?.Name} (No unit)";
        }
        return "Unassigned";
    }

    private async Task ConfirmAssign()
    {
        isAssigning = true;
        try
        {
            if (assignTargetUnit != null)
            {
                if (assignSelectedIds.Any())
                {
                    var usersToPromote = allUsers
                        .Where(u => assignSelectedIds.Contains(u.Id) && u.Role != "Office" && u.Role != "Admin")
                        .ToList();
                    foreach (var user in usersToPromote)
                        await DocService.UpdateAppUserAsync(new AppUser { Id = user.Id, Name = user.Name, Email = user.Email, Role = "Office", UnitId = assignTargetUnit.Id, OfficeId = null, IsOfficeHead = false });

                    var (ok, error) = await DocService.SelectiveReassignUsersAsync(assignSelectedIds.ToList(), assignTargetUnit.Id);
                    if (!ok) { Snackbar.Add(error ?? "Error assigning users.", Severity.Error); return; }
                }
                var toRemove = allUsers.Where(u => u.UnitId == assignTargetUnit.Id && !assignSelectedIds.Contains(u.Id)).ToList();
                foreach (var user in toRemove)
                {
                    var (removeOk, removeErr) = await DocService.UpdateAppUserAsync(new AppUser { Id = user.Id, Name = user.Name, Email = user.Email, Role = "User", UnitId = null, OfficeId = null, IsOfficeHead = false });
                    if (!removeOk) Snackbar.Add($"Failed to remove {user.Name}: {removeErr ?? "Unknown error"}", Severity.Warning);
                }
                var total = assignSelectedIds.Count;
                var removed = toRemove.Count;
                Snackbar.Add(total > 0 && removed > 0 ? $"{total} assigned, {removed} removed from {assignTargetUnit.Name}."
                    : total > 0 ? $"{total} user(s) assigned to {assignTargetUnit.Name}."
                    : $"{removed} user(s) removed from {assignTargetUnit.Name}.", Severity.Success);
            }
            else if (assignTargetOffice != null)
            {
                foreach (var userId in assignSelectedIds)
                {
                    var user = allUsers.FirstOrDefault(u => u.Id == userId);
                    if (user == null || user.Role == "Admin") continue;
                    await DocService.UpdateAppUserAsync(new AppUser { Id = user.Id, Name = user.Name, Email = user.Email, Role = "Office", UnitId = null, OfficeId = assignTargetOffice.Id, IsOfficeHead = false });
                }
                var toRemove = allUsers.Where(u => u.OfficeId == assignTargetOffice.Id && u.UnitId == null && !assignSelectedIds.Contains(u.Id)).ToList();
                foreach (var user in toRemove)
                {
                    var (removeOk, removeErr) = await DocService.UpdateAppUserAsync(new AppUser { Id = user.Id, Name = user.Name, Email = user.Email, Role = "User", UnitId = null, OfficeId = null, IsOfficeHead = false });
                    if (!removeOk) Snackbar.Add($"Failed to remove {user.Name}: {removeErr ?? "Unknown error"}", Severity.Warning);
                }
                var total = assignSelectedIds.Count;
                var removed = toRemove.Count;
                Snackbar.Add(total > 0 && removed > 0 ? $"{total} assigned, {removed} removed from {assignTargetOffice.Name}."
                    : total > 0 ? $"{total} user(s) assigned to {assignTargetOffice.Name}."
                    : $"{removed} user(s) removed from {assignTargetOffice.Name}.", Severity.Success);
            }
            isAssignOpen = false;
            await LoadOffices(showSpinner: false);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] ConfirmAssign error: {ex.Message}");
            Snackbar.Add("Failed to save assignments.", Severity.Error);
        }
        finally { isAssigning = false; }
    }

    private void OpenOfficeAssignDialog(Office office)
    {
        assignTargetOffice = office;
        assignTargetUnit = null;
        assignSearch = "";
        assignSelectedIds = allUsers.Where(u => u.OfficeId == office.Id && u.UnitId == null).Select(u => u.Id).ToHashSet();
        assignSortedUsers = allUsers.Where(u => u.Role != "Admin").OrderByDescending(u => assignSelectedIds.Contains(u.Id)).ThenBy(u => u.Name).ToList();
        isAssignOpen = true;
    }

    private async Task OpenAddOfficeDialog()
    {
        var parameters = new DialogParameters { { "OfficeName", "" } };
        var dialog = await DialogService.ShowAsync<OfficeFormDialog>("Add New Office", parameters, dialogOptions);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: string name })
        {
            isSubmitting = true;
            try
            {
                var (ok, error) = await DocService.AddOfficeAsync(new Office { Name = name });
                if (!ok) { Snackbar.Add(error ?? "Error adding office.", Severity.Error); return; }
                Snackbar.Add($"Office '{name}' added successfully!", Severity.Success);
                await LoadOffices(showSpinner: false);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[ManageOffice] AddOffice error: {ex.Message}");
                Snackbar.Add("Failed to add office.", Severity.Error);
            }
            finally { isSubmitting = false; }
        }
    }

    private async Task OpenEditOfficeDialog(Office office)
    {
        var parameters = new DialogParameters { { "OfficeName", office.Name ?? "" } };
        var dialog = await DialogService.ShowAsync<OfficeFormDialog>("Edit Office", parameters, dialogOptions);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: string name })
        {
            isSubmitting = true;
            try
            {
                var (ok, error) = await DocService.UpdateOfficeAsync(new Office { Id = office.Id, Name = name, ReceivingSchedule = office.ReceivingSchedule });
                if (!ok) { Snackbar.Add(error ?? "Error updating office.", Severity.Error); return; }
                Snackbar.Add("Office updated.", Severity.Success);
                await LoadOffices(showSpinner: false);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[ManageOffice] UpdateOffice error: {ex.Message}");
                Snackbar.Add("Failed to update office.", Severity.Error);
            }
            finally { isSubmitting = false; }
        }
    }

    private async Task OpenScheduleDialog(Office office)
    {
        var parameters = new DialogParameters<ReceivingScheduleDialog>
        {
            { x => x.OfficeId, office.Id },
            { x => x.OfficeName, office.Name ?? "" },
            { x => x.CurrentSchedule, office.ReceivingSchedule }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<ReceivingScheduleDialog>("Receiving Schedule", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            office.ReceivingSchedule = result.Data as string;
            StateHasChanged();
        }
    }

        private async Task OpenEditUnitDialog(Unit unit)
    {
        var parameters = new DialogParameters { { "UnitName", unit.Name ?? "" } };
        var dialog = await DialogService.ShowAsync<UnitFormDialog>("Edit Unit", parameters, dialogOptions);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: string name })
        {
            isSubmittingUnit = true;
            try
            {
                var (ok, error) = await DocService.UpdateUnitAsync(new Unit { Id = unit.Id, Name = name, OfficeId = unit.OfficeId });
                if (!ok) { Snackbar.Add(error ?? "Error updating unit.", Severity.Error); return; }
                Snackbar.Add("Unit updated.", Severity.Success);
                await LoadOffices(showSpinner: false);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[ManageOffice] UpdateUnit error: {ex.Message}");
                Snackbar.Add("Failed to update unit.", Severity.Error);
            }
            finally { isSubmittingUnit = false; }
        }
    }

    private async Task DeleteOffice(Office office)
    {
        var parameters = new DialogParameters
        {
            { "Message", $"Delete '{office.Name}'? This cannot be undone." },
            { "YesText", "Delete" },
            { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Office", parameters);
        var result = await dialog.Result;
        if (result.Canceled) return;
        try
        {
            var (ok, error) = await DocService.DeleteOfficeAsync(office.Id);
            if (!ok) { Snackbar.Add(error ?? "Error deleting office.", Severity.Error); return; }
            Snackbar.Add("Office deleted.", Severity.Success);
            await LoadOffices(showSpinner: false);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] DeleteOffice error: {ex.Message}");
            Snackbar.Add("Failed to delete office.", Severity.Error);
        }
    }

