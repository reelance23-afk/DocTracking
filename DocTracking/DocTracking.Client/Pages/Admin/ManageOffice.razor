    private async Task SubmitUnit(Office office)
    {
        if (string.IsNullOrWhiteSpace(GetUnitName(office.Id))) return;
        isSubmittingUnit = true;
        try
        {
            var unitName = unitNames[office.Id];
            var (ok, error) = await DocService.AddUnitAsync(new Unit { Name = unitName, OfficeId = office.Id });
            if (!ok) { Snackbar.Add(error ?? "Error adding unit.", Severity.Error); return; }
            Snackbar.Add($"Unit '{unitName}' added to {office.Name}!", Severity.Success);
            unitNames[office.Id] = "";
            await LoadOffices(showSpinner: false);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] SubmitUnit error: {ex.Message}");
            Snackbar.Add("Failed to add unit.", Severity.Error);
        }
        finally { isSubmittingUnit = false; }
    }

    private void OpenAssignDialog(Unit unit)
    {
        assignTargetUnit = unit;
        assignTargetOffice = null;
        assignSearch = "";
        assignSelectedIds = allUsers.Where(u => u.UnitId == unit.Id).Select(u => u.Id).ToHashSet();
        assignSortedUsers = allUsers.Where(u => u.Role != "Admin").OrderByDescending(u => assignSelectedIds.Contains(u.Id)).ThenBy(u => u.Name).ToList();
        isAssignOpen = true;
    }
}


    