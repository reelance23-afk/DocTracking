@page "/manage-offices"
@attribute [Authorize(Roles = "Admin")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Pages.Offices
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@rendermode InteractiveAuto

<style>
    @@media (max-width: 599px) {
        .desktop-table {
            display: none !important;
        }

        .mobile-units {
            display: block !important;
        }
    }

    @@media (min-width: 600px) {
        .desktop-table {
            display: block !important;
        }

        .mobile-units {
            display: none !important;
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-8">

    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold">Office Management</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Manage offices and their respective units.</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenAddOfficeDialog" Class="d-none d-md-flex">
            Add Office
        </MudButton>
    </div>

    <MudTextField @bind-Value="searchString" Placeholder="Search Offices..." Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-6"
                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" />

    @if (loading)
    {
        <div class="d-flex justify-center mt-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (FilteredOffices.Any())
    {
        <MudExpansionPanels MultiExpansion="true" Elevation="2">
            @foreach (var office in FilteredOffices)
            {
                <MudExpansionPanel @key="office.Id" MaxHeight="1500">
                    <TitleContent>
                        <div class="d-flex align-center justify-space-between w-100 pr-2" style="flex-wrap: wrap; gap: 4px;">
                            <div class="d-flex align-center gap-3" style="min-width: 0; flex: 1;">
                                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                                </MudAvatar>
                                <div style="min-width: 0;">
                                    <MudText Typo="Typo.body1" Class="font-weight-bold" Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@office.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @(office.Units?.Count ?? 0) unit@(office.Units?.Count == 1 ? "" : "s") &bull;
                                        @(allUsers.Count(u => office.Units?.Any(un => un.Id == u.UnitId) == true)) worker@(allUsers.Count(u => office.Units?.Any(un => un.Id == u.UnitId) == true) == 1 ? "" : "s")
                                    </MudText>
                                </div>
                            </div>
                            <div class="d-flex align-center gap-1 flex-shrink-0" @onclick:stopPropagation>
                                @if (!string.IsNullOrEmpty(office.ReceivingSchedule))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                                             Icon="@Icons.Material.Filled.Schedule" Class="mr-1">
                                        @office.ReceivingSchedule
                                    </MudChip>
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.EditCalendar" Size="Size.Small"
                                               Color="Color.Primary" OnClick="@(() => OpenScheduleDialog(office))"
                                               Title="Set Receiving Schedule" />
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               Color="Color.Warning" OnClick="@(() => OpenEditOfficeDialog(office))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" OnClick="@(() => DeleteOffice(office))" />
                            </div>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudDivider />
                        <div class="pa-4">
                            <MudPaper Elevation="0" Class="pa-3 mb-4 rounded-lg mud-background-gray">
                                <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-bold">Add New Unit</MudText>
                                <div class="d-flex gap-2 align-center unit-input-row">
                                    <input type="text"
                                           value="@GetUnitName(office.Id)"
                                           @oninput="@(e => SetUnitName(office.Id, e.Value?.ToString() ?? ""))"
                                           placeholder="Unit Name"
                                           class="mud-input-root mud-input-root-outlined mud-input-root-margin-dense"
                                           style="flex:1; padding: 8px 12px; border: 1px solid #d0d7de; border-radius: 4px;" />
                                    <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                                               Disabled="@(string.IsNullOrWhiteSpace(GetUnitName(office.Id)) || isSubmittingUnit)"
                                               OnClick="@(() => SubmitUnit(office))">
                                        @(isSubmittingUnit ? "Adding..." : "Add Unit")
                                    </MudButton>
                                </div>
                            </MudPaper>

                            @if (office.Units != null && office.Units.Any())
                            {
                                <MudTable Items="office.Units" Hover="true" Dense="true" Elevation="0"
                                          Class="rounded-lg overflow-hidden desktop-table" T="Unit">
                                    <HeaderContent>
                                        <MudTh>Unit</MudTh>
                                        <MudTh>Workers</MudTh>
                                        <MudTh Style="text-align:right">Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate Context="unit">
                                        @{
                                            var unitWorkers = allUsers.Where(u => u.UnitId == unit.Id).ToList();
                                        }
                                        <MudTd>
                                            <div class="d-flex align-center gap-2">
                                                <MudIcon Icon="@Icons.Material.Filled.AccountTree"
                                                         Size="Size.Small" Class="mud-text-secondary" />
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@unit.Name</MudText>
                                            </div>
                                        </MudTd>
                                        <MudTd>
                                            @if (unitWorkers.Any())
                                            {
                                                <div class="d-flex align-center gap-1 flex-wrap">
                                                    @foreach (var worker in unitWorkers)
                                                    {
                                                        <MudTooltip Text="@worker.Name">
                                                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled"
                                                                       Style="height:28px;width:28px;font-size:0.7rem;">
                                                                @worker.Name?.FirstOrDefault().ToString().ToUpper()
                                                            </MudAvatar>
                                                        </MudTooltip>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary font-italic">No workers</MudText>
                                            }
                                        </MudTd>
                                        <MudTd Style="text-align:right">
                                            <MudTooltip Text="Reassign Users">
                                                <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small"
                                                               Color="Color.Info"
                                                               Disabled="@(!unitWorkers.Any())"
                                                               OnClick="@(() => OpenReassignDialog(unit, office))" />
                                            </MudTooltip>
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                           Color="Color.Warning" OnClick="@(() => OpenEditUnitDialog(unit))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                           Color="Color.Error" OnClick="@(() => DeleteUnit(unit))" />
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>

                                <div class="mobile-units">
                                    @foreach (var unit in office.Units)
                                    {
                                        var unitWorkers = allUsers.Where(u => u.UnitId == unit.Id).ToList();
                                        <MudPaper Elevation="1" Class="pa-3 mb-3 rounded-lg">
                                            <div class="d-flex justify-space-between align-start mb-2">
                                                <div class="d-flex align-center gap-2">
                                                    <MudIcon Icon="@Icons.Material.Filled.AccountTree"
                                                             Size="Size.Small" Color="Color.Primary" />
                                                    <MudText Typo="Typo.body1" Class="font-weight-bold">@unit.Name</MudText>
                                                </div>
                                                <div class="d-flex gap-1">
                                                    <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small"
                                                                   Color="Color.Info"
                                                                   Disabled="@(!unitWorkers.Any())"
                                                                   OnClick="@(() => OpenReassignDialog(unit, office))" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                   Color="Color.Warning" OnClick="@(() => OpenEditUnitDialog(unit))" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                   Color="Color.Error" OnClick="@(() => DeleteUnit(unit))" />
                                                </div>
                                            </div>

                                            <MudDivider Class="my-2" />

                                            <div>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">Workers:</MudText>
                                                @if (unitWorkers.Any())
                                                {
                                                    <div class="d-flex align-center gap-1 flex-wrap">
                                                        @foreach (var worker in unitWorkers)
                                                        {
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                                                                @worker.Name
                                                            </MudChip>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary font-italic">No workers assigned</MudText>
                                                }
                                            </div>
                                        </MudPaper>
                                    }
                                </div>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary font-italic">No units yet.</MudText>
                            }
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    }
    else
    {
        <div class="d-flex flex-column align-center mt-10">
            <MudIcon Icon="@Icons.Material.Filled.BusinessCenter" Size="Size.Large" Color="Color.Default"
                     Class="mb-3" Style="opacity:0.4; font-size:4rem;" />
            <MudText Typo="Typo.body1" Class="mud-text-secondary">No offices found.</MudText>
        </div>
    }

</MudContainer>

<MudFab Color="Color.Primary"
        StartIcon="@Icons.Material.Filled.Add"
        OnClick="OpenAddOfficeDialog"
        Class="d-md-none"
        Style="position: fixed; bottom: 24px; right: 24px; z-index: 1000;" />

<MudDialog @bind-Visible="isReassignOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Reassign Users from <strong>@reassignFromUnit?.Name</strong></MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-bold">Select Users to Reassign</MudText>
        <MudPaper Elevation="0" Class="mb-4" Style="max-height: 220px; overflow-y: auto;">
            @foreach (var user in reassignUnitUsers)
            {
                <MudCheckBox T="bool"
                             Value="@selectedUserIds.Contains(user.Id)"
                             ValueChanged="@(v => ToggleUser(user.Id, v))"
                             Label="@user.Name"
                             Color="Color.Primary"
                             Class="d-block" />
            }
        </MudPaper>
        <MudDivider Class="mb-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-bold">Move To</MudText>
        <MudSelect T="int?" Label="Target Unit" @bind-Value="reassignToUnitId" Variant="Variant.Outlined">
            @foreach (var office in offices)
            {
                @if (office.Units != null)
                {
                    @foreach (var unit in office.Units.Where(u => u.Id != reassignFromUnit?.Id))
                    {
                        <MudSelectItem T="int?" Value="@((int?)unit.Id)">@office.Name — @unit.Name</MudSelectItem>
                    }
                }
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => isReassignOpen = false)">Cancel</MudButton>
        <MudButton Color="Color.Info" Variant="Variant.Filled"
                   Disabled="@(!selectedUserIds.Any() || reassignToUnitId == null || isReassigning)"
                   OnClick="ConfirmReassign">
            @(isReassigning ? "Moving..." : $"Reassign ({selectedUserIds.Count})")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Office> offices = new();
    private List<AppUser> allUsers = new();
    private bool loading = true
