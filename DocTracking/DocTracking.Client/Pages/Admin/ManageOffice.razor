@page "/manage-offices"
@attribute [Authorize(Roles = "Admin")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Pages.Offices
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@rendermode InteractiveAuto

<style>
    .office-panel {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .office-panel:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.1) !important;
        }

    .fade-slide-up {
        animation: fadeSlideUp 0.5s ease-out both;
    }

    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 mb-8">

    <div class="d-flex align-center justify-space-between mb-4 fade-slide-up flex-wrap gap-2">
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
            <div>
                <MudText Typo="Typo.h4" Class="font-weight-bold">Office Management</MudText>
            </div>
        </div>
        <div class="d-flex align-center gap-2 flex-wrap">
            <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Filled.Info" Style="width: fit-content; margin: 0;">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Offices with active documents or assigned users cannot be deleted. Set receiving schedules per office.
                </MudText>
            </MudAlert>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenAddOfficeDialog" Class="d-none d-md-flex">
                Manage Office/Unit
            </MudButton>
        </div>
    </div>


    <MudTextField @bind-Value="searchString"
                  @bind-Value:after="OnSearchChanged"
                  DebounceInterval="400"
                  Placeholder="Search Offices..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-6 fade-slide-up" />

    @if (loading)
    {
        <MudPaper Elevation="2">
            @for (int i = 0; i < 10; i++)
            {
                <div class="d-flex align-center justify-space-between pa-4">
                    <div class="d-flex align-center gap-3" style="flex: 1;">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" />
                        <div style="flex: 1;">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="160px" Class="mb-1" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="100px" />
                        </div>
                    </div>
                    <div class="d-flex gap-1 d-none d-md-flex">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" />
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" />
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" />
                    </div>
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" Class="d-md-none" />
                </div>
                @if (i < 5)
                {
                    <MudDivider />
                }
            }
        </MudPaper>
    }
    else if (officeResult.Items.Any())
    {
        <MudExpansionPanels MultiExpansion="true" Elevation="2">
            @for (int i = 0; i < officeResult.Items.Count; i++)
            {
                var office = officeResult.Items[i];
                <MudExpansionPanel @key="office.Id" MaxHeight="1500"
                                   Class="office-panel"
                                   Style="@($"animation: fadeSlideUp 0.4s ease-out {i * 0.05}s both;")">
                    <TitleContent>
                        <div class="d-flex align-center justify-space-between w-100 pr-2" style="flex-wrap: wrap; gap: 4px;">
                            <div class="d-flex align-center gap-3" style="min-width: 0; flex: 1;">
                                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                                </MudAvatar>
                                <div style="min-width: 0;">
                                    <MudText Typo="Typo.body1" Class="font-weight-bold" Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@office.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @(office.Units?.Count ?? 0) unit@(office.Units?.Count == 1 ? "" : "s") &bull;
                                        @office.WorkerCount worker@(office.WorkerCount == 1 ? "" : "s")
                                    </MudText>
                                </div>
                            </div>
                            <div class="d-flex align-center gap-1 flex-shrink-0" @onclick:stopPropagation>
                                @if (!string.IsNullOrEmpty(office.ReceivingSchedule))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                                             Icon="@Icons.Material.Filled.Schedule" Class="mr-1 d-none d-md-flex">
                                        @office.ReceivingSchedule
                                    </MudChip>
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.EditCalendar" Size="Size.Small"
                                               Color="Color.Primary" OnClick="@(() => OpenScheduleDialog(office))"
                                               Title="Set Receiving Schedule" Class="d-none d-md-flex" />
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               Color="Color.Warning" OnClick="@(() => OpenEditOfficeDialog(office))"
                                               Class="d-none d-md-flex" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" OnClick="@(() => DeleteOffice(office))"
                                               Class="d-none d-md-flex" />
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                                         Class="d-md-none">
                                    <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" IconColor="Color.Primary" Variant="Variant.Outlined"
                                                 OnClick="@(() => OpenScheduleDialog(office))">Schedule</MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Warning" Variant="Variant.Outlined"
                                                 OnClick="@(() => OpenEditOfficeDialog(office))">Edit</MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" Variant="Variant.Outlined"
                                                 OnClick="@(() => DeleteOffice(office))">Delete</MudMenuItem>
                                </MudMenu>
                            </div>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudDivider />
                        <div class="pa-4">
                            @if (office.Units != null && office.Units.Any())
                            {
                                <MudTable Items="office.Units" Hover="true" Dense="true" Elevation="0"
                                          Class="rounded-lg overflow-hidden" T="Unit"
                                          Breakpoint="Breakpoint.Sm">
                                    <HeaderContent>
                                        <MudTh>Unit</MudTh>
                                        <MudTh Style="text-align:right">Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate Context="unit">
                                        <MudTd DataLabel="Unit">
                                            <div class="d-flex align-center gap-2">
                                                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="mud-text-secondary" />
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@unit.Name</MudText>
                                            </div>
                                        </MudTd>
                                        <MudTd DataLabel="Actions" Style="text-align:right">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" 
                                                           Color="Color.Warning" OnClick="@(() => OpenEditUnitDialog(unit))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" 
                                                           Color="Color.Error" OnClick="@(() => DeleteUnit(unit))" />
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                            else
                            {
                                <div class="d-flex flex-column align-center pa-4">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Medium" Color="Color.Default" Style="opacity:0.3;" Class="mb-2" />
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary font-italic">No units yet.</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Add a unit to this office to assign workers to specific groups</MudText>
                                </div>
                            }
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>

        @if (officeResult.TotalCount > officeResult.Items.Count)
        {
            <div class="d-flex justify-center mt-4">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           Disabled="@isLoadingMore" OnClick="LoadMore">
                    @(isLoadingMore ? "Loading..." : $"Load More ({officeResult.Items.Count} of {officeResult.TotalCount})")
                </MudButton>
            </div>
        }
    }
    else
    {
        <div class="d-flex flex-column align-center mt-10">
            <MudIcon Icon="@Icons.Material.Filled.BusinessCenter" Size="Size.Large" Color="Color.Default"
                     Class="mb-3" Style="opacity:0.4; font-size:4rem;" />
            <MudText Typo="Typo.body1" Class="mud-text-secondary">No offices found.</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">Try adjusting your search or add a new office to get started</MudText>
        </div>
    }

</MudContainer>

<MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
        OnClick="OpenAddOfficeDialog" Class="d-md-none"
        Style="position: fixed; bottom: 24px; right: 24px; z-index: 1000;" />

@code {
    [SupplyParameterFromQuery(Name = "search")] public string? SearchParam { get; set; }

    private PagedResult<Office> officeResult = new();
    private bool loading = true;
    private bool isLoadingMore = false;
    private string searchString = "";
    private int _currentPage = 1;
    private const int PageSize = 25;
    private DialogOptions dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(SearchParam))
            searchString = SearchParam;
        await LoadOffices();
    }

    private async Task OnSearchChanged()
    {
        await LoadOffices(showSpinner: false);
    }

    private async Task LoadOffices(bool showSpinner = true)
    {
        if (showSpinner) loading = true;
        try
        {
            var result = await DocService.GetOfficesPagedAsync(page: 1, pageSize: PageSize, search: searchString);
            officeResult = result;
            _currentPage = 1;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] LoadOffices error: {ex.Message}");
            Snackbar.Add("Failed to load offices.", Severity.Error);
        }
        finally { if (showSpinner) loading = false; }
    }

    private async Task LoadMore()
    {
        isLoadingMore = true;
        try
        {
            _currentPage++;
            var result = await DocService.GetOfficesPagedAsync(page: _currentPage, pageSize: PageSize, search: searchString);
            officeResult.Items.AddRange(result.Items);
            officeResult.TotalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] LoadMore error: {ex.Message}");
            Snackbar.Add("Failed to load more offices.", Severity.Error);
        }
        finally { isLoadingMore = false; }
    }

    private async Task OpenAddOfficeDialog()
    {
        var dialog = await DialogService.ShowAsync<OfficeFormDialog>("Add Office", dialogOptions);
        var result = await dialog.Result;
        if (result is not { Canceled: false, Data: OfficeFormDialog.OfficeFormResult data }) return;

        try
        {
            if (data.ExistingOfficeId.HasValue)
            {
                if (!string.IsNullOrWhiteSpace(data.UnitName))
                {
                    var (ok, error) = await DocService.AddUnitAsync(new Unit { Name = data.UnitName, OfficeId = data.ExistingOfficeId.Value });
                    if (!ok) { Snackbar.Add(error ?? "Error adding unit.", Severity.Error); return; }
                    Snackbar.Add($"Unit '{data.UnitName}' added to '{data.OfficeName}'!", Severity.Success);
                    await LoadOffices(showSpinner: false);
                }
            }
            else
            {
                var (ok, error, created) = await DocService.AddOfficeAsync(new Office { Name = data.OfficeName });
                if (!ok) { Snackbar.Add(error ?? "Error adding office.", Severity.Error); return; }

                if (!string.IsNullOrWhiteSpace(data.UnitName) && created != null)
                {
                    var (unitOk, unitError) = await DocService.AddUnitAsync(new Unit { Name = data.UnitName, OfficeId = created.Id });
                    if (!unitOk) Snackbar.Add(unitError ?? "Office created but failed to add unit.", Severity.Warning);
                }

                Snackbar.Add($"Office '{data.OfficeName}' added!", Severity.Success);
                await LoadOffices(showSpinner: false);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] AddOffice error: {ex.Message}");
            Snackbar.Add("Failed to save.", Severity.Error);
        }
    }

    private async Task OpenEditOfficeDialog(Office office)
    {
        var dialog = await DialogService.ShowAsync<OfficeFormDialog>("Edit Office", dialogOptions);
        var result = await dialog.Result;
        if (result is not { Canceled: false, Data: OfficeFormDialog.OfficeFormResult data }) return;

        try
        {
            var (ok, error) = await DocService.UpdateOfficeAsync(new Office { Id = office.Id, Name = data.OfficeName, ReceivingSchedule = office.ReceivingSchedule });
            if (!ok) { Snackbar.Add(error ?? "Error updating office.", Severity.Error); return; }

            if (!string.IsNullOrWhiteSpace(data.UnitName))
            {
                var (unitOk, unitError) = await DocService.AddUnitAsync(new Unit { Name = data.UnitName, OfficeId = office.Id });
                if (!unitOk) { Snackbar.Add(unitError ?? "Office updated but failed to add unit.", Severity.Warning); return; }
                Snackbar.Add($"Unit '{data.UnitName}' added to '{data.OfficeName}'!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Office updated.", Severity.Success);
            }

            await LoadOffices(showSpinner: false);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] UpdateOffice error: {ex.Message}");
            Snackbar.Add("Failed to update office.", Severity.Error);
        }
    }

    private async Task OpenScheduleDialog(Office office)
    {
        var parameters = new DialogParameters<ReceivingScheduleDialog>
        {
            { x => x.OfficeId, office.Id },
            { x => x.OfficeName, office.Name ?? "" },
            { x => x.CurrentSchedule, office.ReceivingSchedule }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<ReceivingScheduleDialog>("Receiving Schedule", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            office.ReceivingSchedule = result.Data as string;
            StateHasChanged();
        }
    }

    private async Task OpenEditUnitDialog(Unit unit)
    {
        var parameters = new DialogParameters { { "UnitName", unit.Name ?? "" } };
        var dialog = await DialogService.ShowAsync<UnitFormDialog>("Edit Unit", parameters, dialogOptions);
        var result = await dialog.Result;
        if (result is not { Canceled: false, Data: string name }) return;

        try
        {
            var (ok, error) = await DocService.UpdateUnitAsync(new Unit { Id = unit.Id, Name = name, OfficeId = unit.OfficeId });
            if (!ok) { Snackbar.Add(error ?? "Error updating unit.", Severity.Error); return; }
            Snackbar.Add("Unit updated.", Severity.Success);
            await LoadOffices(showSpinner: false);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] UpdateUnit error: {ex.Message}");
            Snackbar.Add("Failed to update unit.", Severity.Error);
        }
    }

    private async Task DeleteOffice(Office office)
    {
        var parameters = new DialogParameters
        {
            { "Message", $"Delete '{office.Name}'? This cannot be undone." },
            { "YesText", "Delete" },
            { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Office", parameters);
        var result = await dialog.Result;
        if (result.Canceled) return;
        try
        {
            var (ok, error) = await DocService.DeleteOfficeAsync(office.Id);
            if (!ok) { Snackbar.Add(error ?? "Error deleting office.", Severity.Error); return; }
            Snackbar.Add("Office deleted.", Severity.Success);
            await LoadOffices(showSpinner: false);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] DeleteOffice error: {ex.Message}");
            Snackbar.Add("Failed to delete office.", Severity.Error);
        }
    }

    private async Task DeleteUnit(Unit unit)
    {
        var parameters = new DialogParameters
        {
            { "Message", $"Delete '{unit.Name}'? This cannot be undone." },
            { "YesText", "Delete" },
            { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Unit", parameters);
        var result = await dialog.Result;
        if (result.Canceled) return;
        try
        {
            var (ok, error) = await DocService.DeleteUnitAsync(unit.Id);
            if (!ok) { Snackbar.Add(error ?? "Error deleting unit.", Severity.Error); return; }
            Snackbar.Add("Unit deleted.", Severity.Success);
            await LoadOffices(showSpinner: false);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageOffice] DeleteUnit error: {ex.Message}");
            Snackbar.Add("Failed to delete unit.", Severity.Error);
        }
    }
}
