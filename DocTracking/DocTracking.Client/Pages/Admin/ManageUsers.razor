@page "/manage-users"
@attribute [Authorize(Roles = "Admin")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@rendermode InteractiveAuto

<style>
    .fade-slide-up {
        animation: fadeSlideUp 0.5s ease-out both;
    }

    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes rowFadeIn {
        from {
            opacity: 0;
            transform: translateX(-20px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@media (max-width: 600px) {
        .actions-cell {
            text-align: right;
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <div class="d-flex align-center justify-space-between mb-4 fade-slide-up flex-wrap gap-2">
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
            <div>
                <MudText Typo="Typo.h4" Class="font-weight-bold">Manage Users</MudText>
            </div>
        </div>
        <div class="d-flex align-center gap-2 flex-wrap">
            <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Filled.Info" Style="width: fit-content; margin: 0;">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Assign roles, offices and units to users. Use the Assign button to bulk-assign users to offices or units.
                </MudText>
            </MudAlert>
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.PersonAdd"
                           OnClick="OpenAssignDialog">
                    Assign
                </MudButton>
            </MudHidden>
        </div>
    </div>


    <MudGrid Spacing="2" Class="mb-4" Style="animation: fadeSlideUp 0.5s ease-out 0.1s both;">
        <MudItem xs="12" sm="6" Class="mt-1">
            <MudTextField @bind-Value="searchString"
                          @bind-Value:after="OnFilterChanged"
                          DebounceInterval="300"
                          Placeholder="Search users..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"                             
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudAutocomplete T="Office"
                             Label="Filter by Office"
                             Value="_selectedOfficeFilter"
                             ValueChanged="OnOfficeFilterChanged"
                             SearchFunc="SearchFilterOffices"
                             ToStringFunc="@(o => o?.Name ?? string.Empty)"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             ResetValueOnEmptyText="true"
                             CoerceText="false"
                             CoerceValue="false"
                             AdornmentIcon="@Icons.Material.Filled.Business"
                             AdornmentColor="Color.Primary" 
                             MaxItems="null" />
        </MudItem>
    </MudGrid>

    @if (isLoading)
    {
        <MudPaper Elevation="2">
            @for (int i = 0; i < 8; i++)
            {
                <div class="d-flex align-center justify-space-between pa-3">
                    <div class="d-flex align-center gap-2" style="flex: 1;">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" />
                        <div style="flex: 1;">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="140px" Class="mb-1" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="180px" />
                        </div>
                    </div>
                    <div class="d-flex gap-1">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" />
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" />
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" />
                    </div>
                </div>
                @if (i < 7)
                {
                    <MudDivider />
                }
            }
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="3" Style="animation: fadeSlideUp 0.5s ease-out 0.2s both;">
            <MudTable @ref="_table" ServerData="LoadServerData" Dense="true" Hover="true" Elevation="0"
                      Breakpoint="Breakpoint.Sm" RowStyleFunc="@((item, index) => $"animation: rowFadeIn 0.3s ease both; animation-delay: {Math.Min(index, 10) * 40}ms;")">
                <HeaderContent>
                    <MudTh>User</MudTh>
                    <MudTh>Office</MudTh>
                    <MudTh>Unit</MudTh>
                    <MudTh>Role</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="User">
                        <div class="d-flex align-center gap-2">
                            <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Small" Style="font-size:0.75rem;">
                                @(context.Name?.FirstOrDefault().ToString().ToUpper() ?? "?")
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.body2" Class="font-weight-bold">@context.Name</MudText>
                                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Email</MudText>
                                </MudHidden>
                            </div>
                            @if (context.IsOfficeHead)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">Head</MudChip>
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Office">
                        <MudText Typo="Typo.body2">
                            @(context.Office?.Name ?? allOffices.FirstOrDefault(o => o.Id == context.Unit?.OfficeId)?.Name ?? "—")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Unit">
                        <MudText Typo="Typo.body2">@(context.Unit?.Name ?? "—")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Role">
                        <MudChip T="string" Color="@GetRoleColor(context.Role)" Size="Size.Small" Variant="Variant.Text">@context.Role</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <div class="actions-cell" >
                            <MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" Color="Color.Info"
                                           OnClick="@(async () => await OpenActivityDialog(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Warning"
                                           OnClick="@(() => OpenEditDialog(context))" />
                            @if (context.Role != "Admin")
                            {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(async () => await DeleteUser(context))" />
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="pa-8 text-center">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Style="opacity:0.3; font-size:4rem;" Class="mb-4" />
                        <MudText Typo="Typo.h6" Class="mud-text-secondary">No users found</MudText>
                    </div>
                </NoRecordsContent>
                <PagerContent><MudTablePager /></PagerContent>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

<MudFab Color="Color.Success" StartIcon="@Icons.Material.Filled.PersonAdd"
        OnClick="OpenAssignDialog" Class="d-md-none"
        Style="position: fixed; bottom: 24px; right: 24px; z-index: 1000;" />

<MudDialog @bind-Visible="isEditDialogOpen" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Class="font-weight-bold">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2 mb-n1" /> Edit User
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (editingUser != null)
        {
            <MudText Typo="Typo.body1" Class="mb-4 font-weight-bold">@editingUser.Name</MudText>
            @if (_isLastAdmin && editingUser.Role == "Admin")
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                    This is the last Admin in the system. Role cannot be changed.
                </MudAlert>
            }
            <MudSelect @bind-Value="editingUser.Role" Label="Role" Variant="Variant.Outlined" Class="mb-4"
                       Disabled="@(_isLastAdmin && editingUser.Role == "Admin")">
                <MudSelectItem Value="@("Admin")">Admin</MudSelectItem>
                <MudSelectItem Value="@("Office")">Office Worker</MudSelectItem>
                <MudSelectItem Value="@("User")">User</MudSelectItem>
            </MudSelect>
            @if (editingUser.Role == "Office" || editingUser.Role == "Admin")
            {
                <MudSelect T="int?" Value="GetActiveOfficeId(editingUser)"
                           ValueChanged="@((int? id) => OnOfficeChanged(editingUser, id))"
                           Label="Select Office" Variant="Variant.Outlined" Class="mb-3">
                    <MudSelectItem T="int?" Value="@((int?)null)">— No office —</MudSelectItem>
                    @foreach (var office in allOffices)
                    {
                        <MudSelectItem T="int?" Value="@((int?)office.Id)">@office.Name</MudSelectItem>
                    }
                </MudSelect>
                @if (GetActiveOfficeId(editingUser) != null)
                {
                    <MudCheckBox @bind-Value="isOfficeHead" Label="@($"Office Head of {allOffices.FirstOrDefault(o => o.Id == GetActiveOfficeId(editingUser))?.Name}")" Color="Color.Warning" Class="mb-2" />
                    @if (!isOfficeHead && GetUnitsForActiveOffice(editingUser).Any())
                    {
                        <MudSelect @bind-Value="editingUser.UnitId" Label="Select Unit" Variant="Variant.Outlined" Class="mb-3">
                            <MudSelectItem T="int?" Value="@((int?)null)">— No specific unit —</MudSelectItem>
                            @foreach (var unit in GetUnitsForActiveOffice(editingUser))
                            {
                                <MudSelectItem T="int?" Value="@((int?)unit.Id)">@unit.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    @if (isOfficeHead)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">
                            This user will become an Office Head of @(allOffices.FirstOrDefault(o => o.Id == GetActiveOfficeId(editingUser))?.Name).
                        </MudAlert>
                    }
                }
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Warning">Units are only for Office Workers</MudText>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => isEditDialogOpen = false)" Class="mr-2">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="@isSaving" OnClick="SaveUser">
            @(isSaving ? "Saving..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="isActivityDialogOpen" Options="activityDialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Info" />
            <MudText Typo="Typo.h6" Class="font-weight-bold">@activityUser?.Name — Document Activity</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (activityLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (!activityDocs.Any())
        {
            <div class="text-center pa-8">
                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Style="opacity:0.3;" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">No document activity found.</MudText>
            </div>
        }
        else
        {
            <MudTable Items="@activityDocs" Dense="true" Hover="true" Elevation="0"
                      Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Priority</MudTh>
                    <MudTh>Last Action</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name"><strong>@context.Name</strong></MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="@DocHelpers.GetStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Filled">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Priority">
                        <MudChip T="string" Color="@DocHelpers.GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">@context.Priority</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Last Action">@((context.LastActionDate ?? context.CreatedAt).ToLocalTime().ToString("MMM dd, yyyy"))</MudTd>
                </RowTemplate>
                <PagerContent><MudTablePager /></PagerContent>
            </MudTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => isActivityDialogOpen = false)">Close</MudButton>
    </DialogActions>
</MudDialog>


@code {
    [SupplyParameterFromQuery(Name = "search")] public string? SearchParam { get; set; }

    private MudTable<AppUser>? _table;
    private List<Office> allOffices = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isOfficeHead = false;
    private bool _isLastAdmin = false;
    private string searchString = "";
    private int? _selectedOfficeId;
    private Dictionary<int, int?> activeOfficeEdits = new();
    private List<Unit> _editUnits = new();

    private AppUser? editingUser;
    private bool isEditDialogOpen = false;
    private DialogOptions dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };

    private AppUser? activityUser;
    private List<Document> activityDocs = new();
    private bool isActivityDialogOpen = false;
    private bool activityLoading = false;
    private DialogOptions activityDialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };

    private Office? _selectedOfficeFilter;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            allOffices = await DocService.GetOfficesSimpleAsync();
            if (!string.IsNullOrEmpty(SearchParam))
                searchString = SearchParam;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageUsers] Load error: {ex.Message}");
            Snackbar.Add("Failed to load data.", Severity.Error);
        }
        finally { isLoading = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!string.IsNullOrEmpty(SearchParam) && _table != null)
        {
            searchString = SearchParam;
            await _table.ReloadServerData();
        }
    }


    private async Task<TableData<AppUser>> LoadServerData(TableState state, CancellationToken ct)
    {
        try
        {
            var result = await DocService.GetAppUsersPagedAsync(
                page: state.Page + 1, pageSize: state.PageSize,
                search: searchString, officeId: _selectedOfficeId,
                filterByOffice: _selectedOfficeId.HasValue);
            return new TableData<AppUser> { Items = result.Items, TotalItems = result.TotalCount };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageUsers] LoadServerData error: {ex.Message}");
            return new TableData<AppUser>();
        }
    }

    private async Task OnFilterChanged()
    {
        if (_table != null) await _table.ReloadServerData();
    }

    private int? GetActiveOfficeId(AppUser user)
    {
        if (activeOfficeEdits.ContainsKey(user.Id)) return activeOfficeEdits[user.Id];
        return user.Unit?.OfficeId ?? user.OfficeId;
    }

    private async Task OnOfficeChanged(AppUser user, int? newOfficeId)
    {
        activeOfficeEdits[user.Id] = newOfficeId;
        user.UnitId = null;
        user.OfficeId = newOfficeId;
        isOfficeHead = false;
        _editUnits = newOfficeId.HasValue
            ? await DocService.GetUnitsByOfficeAsync(newOfficeId.Value)
            : new();
        StateHasChanged();
    }

    private IEnumerable<Unit> GetUnitsForActiveOffice(AppUser user) => _editUnits;

    private async Task OpenEditDialog(AppUser user)
    {
        editingUser = new AppUser
        {
            Id = user.Id,
            Name = user.Name,
            Role = user.Role,
            OfficeId = user.OfficeId,
            UnitId = user.UnitId,
            Unit = user.Unit,
            Office = user.Office,
            Email = user.Email,
            IsOfficeHead = user.IsOfficeHead
        };
        activeOfficeEdits.Remove(editingUser.Id);
        isOfficeHead = user.IsOfficeHead;
        var officeId = user.Unit?.OfficeId ?? user.OfficeId;
        _editUnits = officeId.HasValue
            ? await DocService.GetUnitsByOfficeAsync(officeId.Value)
            : new();

        if (user.Role == "Admin")
        {
            var allUsers = await DocService.GetAppUserAsync();
            _isLastAdmin = allUsers.Count(u => u.Role == "Admin") <= 1;
        }
        else
        {
            _isLastAdmin = false;
        }

        isEditDialogOpen = true;
    }


    private async Task SaveUser()
    {
        if (editingUser == null) return;
        isSaving = true;
        try
        {
            if (editingUser.Role != "Office" && editingUser.Role != "Admin")
            {
                editingUser.UnitId = null;
                editingUser.OfficeId = null;
                editingUser.IsOfficeHead = false;
            }
            else if (isOfficeHead)
            {
                editingUser.UnitId = null;
                editingUser.OfficeId = GetActiveOfficeId(editingUser);
                editingUser.IsOfficeHead = true;
            }
            else
            {
                editingUser.IsOfficeHead = false;
                editingUser.OfficeId = editingUser.UnitId != null ? null : GetActiveOfficeId(editingUser);
            }
            var (ok, error) = await DocService.UpdateAppUserAsync(editingUser);
            if (!ok) { Snackbar.Add(error ?? "Failed to update user.", Severity.Error); return; }
            Snackbar.Add($"Updated {editingUser.Name} successfully!", Severity.Success);
            activeOfficeEdits.Remove(editingUser.Id);
            isEditDialogOpen = false;
            if (_table != null) await _table.ReloadServerData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageUsers] SaveUser error: {ex.Message}");
            Snackbar.Add("Failed to update user.", Severity.Error);
        }
        finally { isSaving = false; }
    }

    private async Task OpenActivityDialog(AppUser user)
    {
        activityUser = user;
        activityDocs = new();
        isActivityDialogOpen = true;
        activityLoading = true;
        try { activityDocs = await DocService.GetUserActivityAsync(user.Id); }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageUsers] Activity error: {ex.Message}");
            Snackbar.Add("Failed to load activity.", Severity.Error);
        }
        finally { activityLoading = false; }
    }

    private async Task DeleteUser(AppUser user)
    {
        var parameters = new DialogParameters
        {
            { "Message", $"Delete '{user.Name ?? "this user"}'? This cannot be undone." },
            { "YesText", "Delete" }, { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete User", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;
        var (ok, error) = await DocService.DeleteAppUserAsync(user.Id);
        if (!ok) { Snackbar.Add(error ?? "Error deleting user.", Severity.Error); return; }
        Snackbar.Add("User deleted.", Severity.Success);
        if (_table != null) await _table.ReloadServerData();
    }

    private async Task OpenAssignDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<AssignUsersDialog>("Assign Users", new DialogParameters(), options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            if (_table != null) await _table.ReloadServerData();
    }

    private Task<IEnumerable<Office>> SearchFilterOffices(string value, CancellationToken ct)
    {
        var results = string.IsNullOrWhiteSpace(value)
            ? allOffices
            : allOffices.Where(o => o.Name!.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult<IEnumerable<Office>>(results);
    }

    private async Task OnOfficeFilterChanged(Office? office)
    {
        _selectedOfficeFilter = office;
        _selectedOfficeId = office?.Id;
        await OnFilterChanged();
    }

    private Color GetRoleColor(string? role) => role switch
    {
        "Admin" => Color.Error,
        "Office" => Color.Info,
        _ => Color.Default
    };
}
