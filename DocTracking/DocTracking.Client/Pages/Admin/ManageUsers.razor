@page "/manage-users"
@attribute [Authorize(Roles = "Admin")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@inject DocumentService DocService
@inject ISnackbar Snackbar
@rendermode InteractiveAuto

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4 font-weight-bold">User Management</MudText>

        <MudTable T="AppUser" Items="@appUsers" Hover="true" Elevation="3" Loading="@Loading" Filter="new Func<AppUser, bool>(FilterFunc)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">System Users</MudText>
                <MudSpacer />
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Email</MudTh>
                <MudTh>System Role</MudTh>
                <MudTh>Assigned Office</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Email">
                    <MudText Typo="Typo.body2" Class="font-weight-bold">@context.Email</MudText>
                </MudTd>

                <MudTd DataLabel="System Role">
                    <MudSelect @bind-Value="context.Role" Margin="Margin.Dense" Variant="Variant.Outlined" Dense="true">
                        <MudSelectItem Value="@("User")">Standard User</MudSelectItem>
                        <MudSelectItem Value="@("Office")">Office Worker</MudSelectItem>
                        <MudSelectItem Value="@("Admin")">Administrator</MudSelectItem>
                    </MudSelect>
                </MudTd>

                <MudTd DataLabel="Assigned Office">
                    <MudSelect @bind-Value="context.UnitId" Margin="Margin.Dense" Variant="Variant.Outlined"
                               Disabled="@(context.Role != "Office")" Clearable="true" Dense="true">
                        @foreach (var off in allOffices)
                        {
                            <MudSelectItem T="int?" Value="@((int?)off.Id)">@off.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>

                <MudTd DataLabel="Actions">
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                               OnClick="@(() => SaveUser(context))" StartIcon="@Icons.Material.Filled.Save">
                        Save Changes
                    </MudButton>
                </MudTd>
            </RowTemplate>

            <PagerContent>
                <MudTablePager/>
            </PagerContent>
        </MudTable>
</MudContainer>

@code {
    private List<AppUser> appUsers = new();
    private List<Office> allOffices = new();
    private bool Loading = true;

    private string searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData(); 
    }


    private async Task LoadData()
    {
        Loading = true;
        try
        {
            appUsers = await DocService.GetAppUserAsync();
            allOffices = await DocService.GetOfficesAsync();
        }
        catch (Exception )
        {
            Snackbar.Add("error");
        }
        finally
        {
            Loading = false;
        }
    }

    private async Task SaveUser(AppUser user)
    {
        try
        {
            if(user.Role != "Office")
            {
                user.UnitId = null;
            }

            await DocService.UpdateAppUserAsync(user);
            Snackbar.Add("Successfully updated user");
        }
        catch (Exception)
        {
            Snackbar.Add("Error");
        }
    }

    private bool FilterFunc(AppUser user)
    {
        if (String.IsNullOrWhiteSpace(searchString)) return true;
        if (user.Email?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;

        return false;
    }
}
