@page "/manage-users"
@attribute [Authorize(Roles = "Admin")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@inject DocumentService DocService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@rendermode InteractiveAuto

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold">Manage Users</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">View and manage all registered users.</MudText>
        </div>
    </div>

    <MudTextField @bind-Value="searchString"
                  @bind-Value:after="StateHasChanged"
                  DebounceInterval="300"
                  Placeholder="Search users..."
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Class="mb-4" />

    @if (isLoading)
    {
        <div class="d-flex justify-center mt-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else
    {
        <MudExpansionPanels MultiExpansion="true" Elevation="2">
            @foreach (var office in offices.Where(OfficeShouldShow))
            {
                <MudExpansionPanel @key="office.Id" IsInitiallyExpanded="true">
                    <TitleContent>
                        <div class="d-flex align-center justify-space-between w-100 pr-2">
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                                </MudAvatar>
                                <MudText Typo="Typo.body1" Class="font-weight-bold">@office.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @GetOfficeUserCount(office) user@(GetOfficeUserCount(office) == 1 ? "" : "s")
                                </MudText>
                            </div>
                            <div @onclick:stopPropagation="true">
                                <MudIconButton Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small"
                                               Color="Color.Success" Title="Assign to Office"
                                               OnClick="@(async () => await OpenAssignDialog(office, null))" />
                            </div>

                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudDivider />
                        <div class="pa-2">
                            @{
                                var officeHead = GetOfficeHead(office);
                                var officeWorkers = GetOfficeWorkers(office);
                            }
                            @if (officeHead != null || officeWorkers.Any())
                            {
                                <div class="pa-2 mb-2">
                                    @if (officeHead != null)
                                    {
                                        @UserRow(officeHead)
                                    }
                                    @foreach (var worker in officeWorkers)
                                    {
                                        @UserRow(worker)
                                    }
                                </div>
                            }

                            @if (office.Units != null)
                            {
                                <MudExpansionPanels MultiExpansion="true" Elevation="0">
                                    @foreach (var unit in office.Units.Where(u => UnitShouldShow(office, u)))
                                    {
                                        var unitUsers = GetUnitUsers(unit);
                                        <MudExpansionPanel @key="unit.Id" IsInitiallyExpanded="true">
                                            <TitleContent>
                                                <div class="d-flex align-center justify-space-between w-100 pr-2">
                                                    <div class="d-flex align-center gap-2">
                                                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Color="Color.Primary" />
                                                        <MudText Typo="Typo.body2" Class="font-weight-bold">@unit.Name</MudText>
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                            @unitUsers.Count user@(unitUsers.Count == 1 ? "" : "s")
                                                        </MudText>
                                                    </div>
                                                    <div @onclick:stopPropagation="true">
                                                        <MudIconButton Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small"
                                                                       Color="Color.Success" Title="Assign to Unit"
                                                                       OnClick="@(async () => await OpenAssignDialog(null, unit))" />
                                                    </div>
                                                </div>
                                            </TitleContent>
                                            <ChildContent>
                                                <MudDivider />
                                                <div class="pa-2">
                                                    @if (unitUsers.Any())
                                                    {
                                                        @foreach (var user in unitUsers)
                                                        {
                                                            @UserRow(user)
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary font-italic pa-2">
                                                            No users in this unit.
                                                        </MudText>
                                                    }
                                                </div>
                                            </ChildContent>
                                        </MudExpansionPanel>
                                    }
                                </MudExpansionPanels>
                            }
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>

        @if (allUsers.Any(u => u.OfficeId == null && u.UnitId == null && MatchesSearch(u)))
        {
            <MudExpansionPanels MultiExpansion="true" Elevation="2">
                <MudExpansionPanel IsInitiallyExpanded="true">
                    <TitleContent>
                        <div class="d-flex align-center gap-2">
                            <MudAvatar Color="Color.Default" Variant="Variant.Filled" Size="Size.Small">
                                <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="Size.Small" />
                            </MudAvatar>
                            <MudText Typo="Typo.body1" Class="font-weight-bold">Unassigned</MudText>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudDivider />
                        <div class="pa-2">
                            @foreach (var user in allUsers.Where(u => u.OfficeId == null && u.UnitId == null && MatchesSearch(u)))
                            {
                                @UserRow(user)
                            }
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
        @if (_totalOffices > offices.Count)
        {
            <div class="d-flex justify-center mt-4">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           Disabled="@isLoadingMore" OnClick="LoadMore">
                    @(isLoadingMore ? "Loading..." : $"Load More ({offices.Count} of {_totalOffices})")
                </MudButton>
            </div>
        }
    }
</MudContainer>

<MudDialog @bind-Visible="isEditDialogOpen" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Class="font-weight-bold">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2 mb-n1" /> Edit User
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (editingUser != null)
        {
            <MudText Typo="Typo.body1" Class="mb-4 font-weight-bold">@editingUser.Name</MudText>
            <MudSelect @bind-Value="editingUser.Role" Label="Role" Variant="Variant.Outlined" Class="mb-4">
                <MudSelectItem Value="@("Admin")">Admin</MudSelectItem>
                <MudSelectItem Value="@("Office")">Office Worker</MudSelectItem>
                <MudSelectItem Value="@("User")">User</MudSelectItem>
            </MudSelect>
            @if (editingUser.Role == "Office")
            {
                <MudSelect T="int?" Value="GetActiveOfficeId(editingUser)"
                           ValueChanged="@((int? id) => OnOfficeChanged(editingUser, id))"
                           Label="Select Office" Variant="Variant.Outlined" Class="mb-3">
                    @foreach (var office in offices)
                    {
                        <MudSelectItem T="int?" Value="@((int?)office.Id)">@office.Name</MudSelectItem>
                    }
                </MudSelect>
                @if (GetActiveOfficeId(editingUser) != null)
                {
                    <MudCheckBox @bind-Value="isOfficeHead" Label="Office Head" Color="Color.Warning" Class="mb-2" />
                    @if (!isOfficeHead && GetUnitsForActiveOffice(editingUser).Any())
                    {
                        <MudSelect @bind-Value="editingUser.UnitId" Label="Select Unit" Variant="Variant.Outlined" Class="mb-3">
                            @foreach (var unit in GetUnitsForActiveOffice(editingUser))
                            {
                                <MudSelectItem T="int?" Value="@((int?)unit.Id)">@unit.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    @if (isOfficeHead)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">
                            This user will become an Office Head of @(offices.FirstOrDefault(o => o.Id == GetActiveOfficeId(editingUser))?.Name).
                        </MudAlert>
                    }
                }
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Warning">Units are only for Office Workers</MudText>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => isEditDialogOpen = false)" Class="mr-2">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="@isSaving" OnClick="SaveUser">
            @(isSaving ? "Saving..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="isActivityDialogOpen" Options="activityDialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Info" />
            <MudText Typo="Typo.h6" Class="font-weight-bold">@activityUser?.Name — Document Activity</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (activityLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (!activityDocs.Any())
        {
            <div class="text-center pa-8">
                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Style="opacity:0.3;" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">No document activity found.</MudText>
            </div>
        }
        else
        {
            <MudTable Items="@activityDocs" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Priority</MudTh>
                    <MudTh>Last Action</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name"><strong>@context.Name</strong></MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="@DocHelpers.GetStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Filled">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Priority">
                        <MudChip T="string" Color="@DocHelpers.GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">@context.Priority</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Last Action">@((context.LastActionDate ?? context.CreatedAt).ToLocalTime().ToString("MMM dd, yyyy"))</MudTd>
                </RowTemplate>
                <PagerContent><MudTablePager /></PagerContent>
            </MudTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => isActivityDialogOpen = false)">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Office> offices = new();
    private List<AppUser> allUsers = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isOfficeHead = false;
    private string searchString = "";
    private Dictionary<int, int?> activeOfficeEdits = new();

    private AppUser? editingUser;
    private bool isEditDialogOpen = false;
    private DialogOptions dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };

    private AppUser? activityUser;
    private List<Document> activityDocs = new();
    private bool isActivityDialogOpen = false;
    private bool activityLoading = false;
    private DialogOptions activityDialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };

    private int _currentPage = 1;
    private const int PageSize = 25;
    private int _totalOffices = 0;
    private bool isLoadingMore = false;

private RenderFragment UserRow(AppUser user) =>
    @<div class="d-flex align-center justify-space-between pa-2 mb-1 rounded"
          style="background: var(--mud-palette-background);">
        <div class="d-flex align-center gap-2">
            <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Small" Style="font-size:0.75rem;">
                @(user.Name?.FirstOrDefault().ToString().ToUpper() ?? "?")
            </MudAvatar>
            <MudText Typo="Typo.body2" Class="font-weight-bold">@user.Name</MudText>
            <MudChip T="string" Color="@GetRoleColor(user.Role)" Size="Size.Small" Variant="Variant.Text">@user.Role</MudChip>
            @if (user.IsOfficeHead)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">Head</MudChip>
            }
        </div>
        <div class="d-flex gap-1">
            <MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" Color="Color.Info"
                           OnClick="@(async () => await OpenActivityDialog(user))"
                           Class="d-none d-md-flex" />
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Warning"
                           OnClick="@(() => OpenEditDialog(user))"
                           Class="d-none d-md-flex" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="@(async () => await DeleteUser(user))"
                           Class="d-none d-md-flex" />
            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                     AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                     Class="d-md-none">
                <MudMenuItem Icon="@Icons.Material.Filled.History" IconColor="Color.Info"
                             OnClick="@(async () => await OpenActivityDialog(user))">Activity</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Warning"
                             OnClick="@(() => OpenEditDialog(user))">Edit</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error"
                             OnClick="@(async () => await DeleteUser(user))">Delete</MudMenuItem>
            </MudMenu>
        </div>
    </div>;


    private bool MatchesSearch(AppUser u) =>
        string.IsNullOrWhiteSpace(searchString) ||
        u.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true;

    private bool OfficeMatchesSearch(Office o) =>
        string.IsNullOrWhiteSpace(searchString) ||
        o.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true;

    private bool UnitMatchesSearch(Unit u) =>
        string.IsNullOrWhiteSpace(searchString) ||
        u.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true;

    private bool OfficeShouldShow(Office office) =>
        OfficeMatchesSearch(office) ||
        (office.Units?.Any(UnitMatchesSearch) == true) ||
        allUsers.Any(u => (u.OfficeId == office.Id || u.Unit?.OfficeId == office.Id) && MatchesSearch(u));

    private bool UnitShouldShow(Office office, Unit unit) =>
        OfficeMatchesSearch(office) || UnitMatchesSearch(unit) ||
        allUsers.Any(u => u.UnitId == unit.Id && MatchesSearch(u));

    private AppUser? GetOfficeHead(Office office) =>
        allUsers.FirstOrDefault(u => u.OfficeId == office.Id && u.IsOfficeHead &&
            (OfficeMatchesSearch(office) || MatchesSearch(u)));

    private List<AppUser> GetOfficeWorkers(Office office) =>
        allUsers.Where(u => u.OfficeId == office.Id && u.UnitId == null && !u.IsOfficeHead &&
            (OfficeMatchesSearch(office) || MatchesSearch(u))).ToList();

    private List<AppUser> GetUnitUsers(Unit unit)
    {
        var office = offices.FirstOrDefault(o => o.Id == unit.OfficeId);
        return allUsers.Where(u => u.UnitId == unit.Id &&
            (office != null && OfficeMatchesSearch(office) || UnitMatchesSearch(unit) || MatchesSearch(u))).ToList();
    }

    private int GetOfficeUserCount(Office office) =>
        allUsers.Count(u => u.OfficeId == office.Id || u.Unit?.OfficeId == office.Id);

protected override async Task OnInitializedAsync()
{
    try
    {
        var officesTask = DocService.GetOfficesPagedAsync(page: 1, pageSize: PageSize);
        var usersTask = DocService.GetAppUserAsync();
        await Task.WhenAll(officesTask, usersTask);
        var officeResult = officesTask.Result;
        offices = officeResult.Items;
        _totalOffices = officeResult.TotalCount;
        allUsers = usersTask.Result;
    }
    catch (Exception ex)
    {
        Console.WriteLine($"[ManageUsers] Load error: {ex.Message}");
        Snackbar.Add("Failed to load data.", Severity.Error);
    }
    finally { isLoading = false; }
}

private async Task RefreshAll()
{
    try
    {
        var officesTask = DocService.GetOfficesPagedAsync(page: 1, pageSize: PageSize);
        var usersTask = DocService.GetAppUserAsync();
        await Task.WhenAll(officesTask, usersTask);
        var officeResult = officesTask.Result;
        offices = officeResult.Items;
        _totalOffices = officeResult.TotalCount;
        _currentPage = 1;
        allUsers = usersTask.Result;
    }
    catch (Exception ex) { Console.WriteLine($"[ManageUsers] Refresh error: {ex.Message}"); }
}

private async Task LoadMore()
{
    isLoadingMore = true;
    try
    {
        _currentPage++;
        var result = await DocService.GetOfficesPagedAsync(page: _currentPage, pageSize: PageSize);
        offices.AddRange(result.Items);
        _totalOffices = result.TotalCount;
    }
    catch (Exception ex)
    {
        Console.WriteLine($"[ManageUsers] LoadMore error: {ex.Message}");
        Snackbar.Add("Failed to load more offices.", Severity.Error);
    }
    finally { isLoadingMore = false; }
}

    private int? GetActiveOfficeId(AppUser user)
    {
        if (activeOfficeEdits.ContainsKey(user.Id)) return activeOfficeEdits[user.Id];
        return user.Unit?.OfficeId ?? user.OfficeId;
    }

    private void OnOfficeChanged(AppUser user, int? newOfficeId)
    {
        activeOfficeEdits[user.Id] = newOfficeId;
        user.UnitId = null;
        user.OfficeId = newOfficeId;
        isOfficeHead = false;
    }

    private IEnumerable<Unit> GetUnitsForActiveOffice(AppUser user)
    {
        var officeId = GetActiveOfficeId(user);
        if (officeId == null) return new List<Unit>();
        return offices.FirstOrDefault(o => o.Id == officeId)?.Units ?? new List<Unit>();
    }

    private void OpenEditDialog(AppUser user)
    {
        editingUser = new AppUser
        {
            Id = user.Id, Name = user.Name, Role = user.Role,
            OfficeId = user.OfficeId, UnitId = user.UnitId,
            Unit = user.Unit, Office = user.Office,
            Email = user.Email, IsOfficeHead = user.IsOfficeHead
        };
        activeOfficeEdits.Remove(editingUser.Id);
        isOfficeHead = user.IsOfficeHead;
        isEditDialogOpen = true;
    }

    private async Task SaveUser()
    {
        if (editingUser == null) return;
        isSaving = true;
        try
        {
            if (editingUser.Role != "Office")
            {
                editingUser.UnitId = null;
                editingUser.OfficeId = null;
                editingUser.IsOfficeHead = false;
            }
            else if (isOfficeHead)
            {
                editingUser.UnitId = null;
                editingUser.OfficeId = GetActiveOfficeId(editingUser);
                editingUser.IsOfficeHead = true;
            }
            else
            {
                editingUser.IsOfficeHead = false;
                editingUser.OfficeId = editingUser.UnitId != null ? null : GetActiveOfficeId(editingUser);
            }
            var (ok, error) = await DocService.UpdateAppUserAsync(editingUser);
            if (!ok) { Snackbar.Add(error ?? "Failed to update user.", Severity.Error); return; }
            Snackbar.Add($"Updated {editingUser.Name} successfully!", Severity.Success);
            activeOfficeEdits.Remove(editingUser.Id);
            isEditDialogOpen = false;
            await RefreshAll();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageUsers] SaveUser error: {ex.Message}");
            Snackbar.Add("Failed to update user.", Severity.Error);
        }
        finally { isSaving = false; }
    }

    private async Task OpenActivityDialog(AppUser user)
    {
        activityUser = user;
        activityDocs = new();
        isActivityDialogOpen = true;
        activityLoading = true;
        try { activityDocs = await DocService.GetUserActivityAsync(user.Id); }
        catch (Exception ex)
        {
            Console.WriteLine($"[ManageUsers] Activity error: {ex.Message}");
            Snackbar.Add("Failed to load activity.", Severity.Error);
        }
        finally { activityLoading = false; }
    }

    private async Task DeleteUser(AppUser user)
    {
        var parameters = new DialogParameters
        {
            { "Message", $"Delete '{user.Name ?? "this user"}'? This cannot be undone." },
            { "YesText", "Delete" },
            { "CancelText", "Cancel" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete User", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;
        var (ok, error) = await DocService.DeleteAppUserAsync(user.Id);
        if (!ok) { Snackbar.Add(error ?? "Error deleting user.", Severity.Error); return; }
        Snackbar.Add("User deleted.", Severity.Success);
        await RefreshAll();
    }

    private async Task OpenAssignDialog(Office? office, Unit? unit)
    {
        var parameters = new DialogParameters<AssignUsersDialog>
        {
            { x => x.Office, office },
            { x => x.Unit, unit },
            { x => x.AllUsers, allUsers }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<AssignUsersDialog>("Assign Users", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await RefreshAll();
    }

    private Color GetRoleColor(string? role) => role switch
    {
        "Admin" => Color.Error,
        "Office" => Color.Info,
        _ => Color.Default
    };
}
