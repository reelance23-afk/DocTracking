@using DocTracking.Client.Models
@using DocTracking.Client.Services
@inject DocumentService DocService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Success" />
            <MudText Typo="Typo.h6" Class="font-weight-bold">Assign Users</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_selectedOffice == null)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">Select an office to assign users to.</MudText>
            <MudTextField Value="_officeSearch" ValueChanged="@((string v) => OnOfficeSearchChanged(v))"
                          Placeholder="Search offices..." DebounceInterval="300"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" />
            @if (_loadingOffices)
            {
                <MudProgressLinear Indeterminate="true" Class="mb-2" />
            }
            <MudPaper Elevation="0" Style="max-height: 360px; overflow-y: auto;">
                @foreach (var office in _offices)
                {
                    <MudListItem T="string" OnClick="@(() => SelectOffice(office))"
                                 Class="rounded mb-1" Style="cursor:pointer;">
                        <div class="d-flex align-center gap-2">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                            </MudAvatar>
                            <MudText Typo="Typo.body2" Class="font-weight-bold">@office.Name</MudText>
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudPaper>
        }
        else if (_selectedUnit == null)
        {
            <div class="d-flex align-center gap-2 mb-3">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" OnClick="BackToOffices" />
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                </MudAvatar>
                <MudText Typo="Typo.body2" Class="font-weight-bold">@_selectedOffice.Name</MudText>
            </div>

            @if (_officeUnits.Any())
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2 d-block">
                    Assign to the office directly, or pick a unit below.
                </MudText>
                <MudPaper Elevation="0" Class="pa-2 mb-3 rounded"
                          Style="background: rgba(var(--mud-palette-primary-rgb), 0.05);">
                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-bold">Units</MudText>
                    @foreach (var unit in _officeUnits)
                    {
                        <MudListItem T="string" OnClick="@(() => SelectUnit(unit))"
                                     Class="rounded mb-1" Style="cursor:pointer;">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2" Class="font-weight-bold">@unit.Name</MudText>
                            </div>
                        </MudListItem>
                        <MudDivider />
                    }
                </MudPaper>
                <MudDivider Class="mb-3" />
                <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-bold">Office-level Assignment</MudText>
            }

            <MudTextField Value="searchString" ValueChanged="@((string v) => OnUserSearchChanged(v))"
                          Placeholder="Search users..." DebounceInterval="300"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Class="mb-2" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3 d-block">
                Check to assign to office, uncheck to remove.
            </MudText>
            @if (_loadingUsers)
            {
                <MudProgressLinear Indeterminate="true" Class="mb-2" />
            }
            <MudPaper Elevation="0" Style="max-height: 260px; overflow-y: auto;">
                @foreach (var user in _sortedUsers)
                {
                    <div class="d-flex align-center pa-1">
                        <MudCheckBox T="bool" Value="@selectedIds.Contains(user.Id)"
                                     ValueChanged="@(v => Toggle(user.Id, v))"
                                     Color="Color.Success" Class="flex-grow-1">
                            <div>
                                <MudText Typo="Typo.body2" Class="font-weight-bold">@user.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@GetCurrentAssignment(user)</MudText>
                            </div>
                        </MudCheckBox>
                    </div>
                    <MudDivider />
                }
            </MudPaper>
            @if (_userTotal > _sortedUsers.Count)
            {
                <div class="d-flex justify-center mt-2">
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                               Disabled="_loadingUsers" OnClick="LoadMoreUsers">
                        @(_loadingUsers ? "Loading..." : $"Load More ({_sortedUsers.Count} of {_userTotal})")
                    </MudButton>
                </div>
            }
        }
        else
        {
            <div class="d-flex align-center gap-2 mb-3">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" OnClick="BackToOffice" />
                <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Small">
                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.body2" Class="font-weight-bold">@_selectedUnit.Name</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@_selectedOffice!.Name</MudText>
                </div>
            </div>
            <MudTextField Value="searchString" ValueChanged="@((string v) => OnUserSearchChanged(v))"
                          Placeholder="Search users..." DebounceInterval="300"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Class="mb-2" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3 d-block">
                Check to assign to this unit, uncheck to remove.
            </MudText>
            @if (_loadingUsers)
            {
                <MudProgressLinear Indeterminate="true" Class="mb-2" />
            }
            <MudPaper Elevation="0" Style="max-height: 300px; overflow-y: auto;">
                @foreach (var user in _sortedUsers)
                {
                    <div class="d-flex align-center pa-1">
                        <MudCheckBox T="bool" Value="@selectedIds.Contains(user.Id)"
                                     ValueChanged="@(v => Toggle(user.Id, v))"
                                     Color="Color.Secondary" Class="flex-grow-1">
                            <div>
                                <MudText Typo="Typo.body2" Class="font-weight-bold">@user.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@GetCurrentAssignment(user)</MudText>
                            </div>
                        </MudCheckBox>
                    </div>
                    <MudDivider />
                }
            </MudPaper>
            @if (_userTotal > _sortedUsers.Count)
            {
                <div class="d-flex justify-center mt-2">
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                               Disabled="_loadingUsers" OnClick="LoadMoreUsers">
                        @(_loadingUsers ? "Loading..." : $"Load More ({_sortedUsers.Count} of {_userTotal})")
                    </MudButton>
                </div>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">Cancel</MudButton>
        @if (_selectedOffice != null && _selectedUnit == null)
        {
            <MudButton Color="Color.Success" Variant="Variant.Filled" Disabled="@isSaving" OnClick="SaveOfficeAssignment">
                @(isSaving ? "Saving..." : $"Save ({selectedIds.Count} selected)")
            </MudButton>
        }
        @if (_selectedUnit != null)
        {
            <MudButton Color="Color.Secondary" Variant="Variant.Filled" Disabled="@isSaving" OnClick="SaveUnitAssignment">
                @(isSaving ? "Saving..." : $"Save ({selectedIds.Count} selected)")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private List<Office> _offices = new();
    private List<Unit> _officeUnits = new();
    private List<AppUser> _sortedUsers = new();
    private Office? _selectedOffice;
    private Unit? _selectedUnit;
    private string _officeSearch = "";
    private string searchString = "";
    private HashSet<int> selectedIds = new();
    private bool isSaving;
    private bool _loadingOffices;
    private bool _loadingUsers;
    private int _userPage = 1;
    private int _userTotal = 0;
    private const int UserPageSize = 25;

    protected override async Task OnInitializedAsync() => await LoadOffices();

    private async Task LoadOffices()
    {
        _loadingOffices = true;
        _offices = await DocService.GetOfficesSimpleAsync(_officeSearch);
        _loadingOffices = false;
    }

    private async Task OnOfficeSearchChanged(string val)
    {
        _officeSearch = val;
        await LoadOffices();
    }

    private async Task SelectOffice(Office office)
    {
        _selectedOffice = office;
        _selectedUnit = null;
        searchString = "";
        _officeUnits = await DocService.GetUnitsByOfficeAsync(office.Id);
        await LoadUsersForOffice();
    }

   private async Task LoadUsersForOffice()
    {   
    _loadingUsers = true;
    _userPage = 1;
    var result = await DocService.GetAppUsersPagedAsync(
        page: 1, pageSize: UserPageSize, search: searchString,
        officeId: _selectedOffice?.Id);
    _sortedUsers = result.Items;
    _userTotal = result.TotalCount;
    selectedIds = _sortedUsers
        .Where(u => u.OfficeId == _selectedOffice?.Id || u.Unit?.OfficeId == _selectedOffice?.Id)
        .Select(u => u.Id)
        .ToHashSet();
    _loadingUsers = false;
    StateHasChanged();
    }

    private async Task LoadUsersForUnit()
    {
        _loadingUsers = true;
        _userPage = 1;
        var result = await DocService.GetAppUsersPagedAsync(
            page: 1, pageSize: UserPageSize, search: searchString,
            officeId: _selectedOffice?.Id, unitId: _selectedUnit?.Id);
        _sortedUsers = result.Items;
        _userTotal = result.TotalCount;
        selectedIds = _sortedUsers
            .Where(u => u.UnitId == _selectedUnit?.Id)
            .Select(u => u.Id)
            .ToHashSet();
        _loadingUsers = false;
        StateHasChanged();
    }

    private async Task LoadMoreUsers()
    {
        _loadingUsers = true;
        _userPage++;
        var result = _selectedUnit != null
            ? await DocService.GetAppUsersPagedAsync(page: _userPage, pageSize: UserPageSize,
                search: searchString, officeId: _selectedOffice?.Id, unitId: _selectedUnit?.Id)
            : await DocService.GetAppUsersPagedAsync(page: _userPage, pageSize: UserPageSize,
                search: searchString, officeId: _selectedOffice?.Id);
        _sortedUsers.AddRange(result.Items);
        _userTotal = result.TotalCount;
        _loadingUsers = false;
        StateHasChanged();
    }

    private async Task OnUserSearchChanged(string val)
    {
        searchString = val;
        if (_selectedUnit != null) await LoadUsersForUnit();
        else if (_selectedOffice != null) await LoadUsersForOffice();
    }

    private async Task SelectUnit(Unit unit)
    {
        _selectedUnit = unit;
        searchString = "";
        await LoadUsersForUnit();
    }

    private void BackToOffices()
    {
        _selectedOffice = null;
        _selectedUnit = null;
        _officeSearch = "";
        searchString = "";
        selectedIds.Clear();
        _sortedUsers.Clear();
        _officeUnits.Clear();
    }

    private void BackToOffice()
    {
        _selectedUnit = null;
        searchString = "";
        _ = LoadUsersForOffice();
    }

    private void Toggle(int userId, bool selected)
    {
        if (selected) selectedIds.Add(userId);
        else selectedIds.Remove(userId);
    }

    private string GetCurrentAssignment(AppUser user)
    {
        if (user.UnitId.HasValue)
            return $"{user.Unit?.Office?.Name ?? "?"} — {user.Unit?.Name ?? "?"}";
        if (user.OfficeId.HasValue)
            return user.IsOfficeHead ? $"{user.Office?.Name} (Office Head)" : $"{user.Office?.Name}";
        return "Unassigned";
    }

    private async Task SaveOfficeAssignment()
    {
        if (_selectedOffice == null) return;
        isSaving = true;
        try
        {
            var toAssign = _sortedUsers
                .Where(u => selectedIds.Contains(u.Id) &&
                    u.OfficeId != _selectedOffice.Id && u.Unit?.OfficeId != _selectedOffice.Id)
                .ToList();
            foreach (var user in toAssign)
            {
                await DocService.UpdateAppUserAsync(new AppUser
                {
                    Id = user.Id,
                    Name = user.Name,
                    Email = user.Email,
                    Role = "Office",
                    UnitId = null,
                    OfficeId = _selectedOffice.Id,
                    IsOfficeHead = false
                });
            }

            var toRemove = _sortedUsers
                .Where(u => !u.IsOfficeHead && !selectedIds.Contains(u.Id) &&
                    (u.OfficeId == _selectedOffice.Id || u.Unit?.OfficeId == _selectedOffice.Id))
                .ToList();
            foreach (var user in toRemove)
            {
                await DocService.UpdateAppUserAsync(new AppUser
                {
                    Id = user.Id,
                    Name = user.Name,
                    Email = user.Email,
                    Role = "User",
                    UnitId = null,
                    OfficeId = null,
                    IsOfficeHead = false
                });
            }

            var assigned = toAssign.Count;
            var removed = toRemove.Count;
            Snackbar.Add(assigned > 0 && removed > 0
                ? $"{assigned} assigned, {removed} removed from {_selectedOffice.Name}."
                : assigned > 0 ? $"{assigned} user(s) assigned to {_selectedOffice.Name}."
                : removed > 0 ? $"{removed} user(s) removed from {_selectedOffice.Name}."
                : "No changes made.", Severity.Success);

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AssignUsersDialog] SaveOffice error: {ex.Message}");
            Snackbar.Add("Failed to save assignments.", Severity.Error);
        }
        finally { isSaving = false; }
    }

    private async Task SaveUnitAssignment()
    {
        if (_selectedUnit == null) return;
        isSaving = true;
        try
        {
            var toAssign = _sortedUsers
                .Where(u => selectedIds.Contains(u.Id) && u.UnitId != _selectedUnit.Id)
                .Select(u => u.Id)
                .ToList();

            if (toAssign.Any())
            {
                var (ok, error) = await DocService.SelectiveReassignUsersAsync(toAssign, _selectedUnit.Id);
                if (!ok) { Snackbar.Add(error ?? "Failed to assign users.", Severity.Error); return; }
            }

            var toRemove = _sortedUsers
                .Where(u => u.UnitId == _selectedUnit.Id && !selectedIds.Contains(u.Id))
                .ToList();
            foreach (var user in toRemove)
            {
                await DocService.UpdateAppUserAsync(new AppUser
                {
                    Id = user.Id,
                    Name = user.Name,
                    Email = user.Email,
                    Role = "Office",
                    UnitId = null,
                    OfficeId = _selectedOffice!.Id,
                    IsOfficeHead = false
                });
            }

            var assigned = toAssign.Count;
            var removed = toRemove.Count;
            Snackbar.Add(assigned > 0 && removed > 0
                ? $"{assigned} assigned, {removed} moved to office level in {_selectedUnit.Name}."
                : assigned > 0 ? $"{assigned} user(s) assigned to {_selectedUnit.Name}."
                : removed > 0 ? $"{removed} user(s) moved to office level."
                : "No changes made.", Severity.Success);

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AssignUsersDialog] SaveUnit error: {ex.Message}");
            Snackbar.Add("Failed to save unit assignments.", Severity.Error);
        }
        finally { isSaving = false; }
    }
}

