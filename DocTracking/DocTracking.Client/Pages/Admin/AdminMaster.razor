@page "/admin-dashboard"
@attribute [Authorize(Roles = "Admin")]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@inject DocumentService DocumentService
@rendermode InteractiveAuto

<style>
    .text-muted {
        color: #64748b !important;
    }

    .ticket-card:hover {
        border-color: #fecdd3 !important;
        box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    }                                                                                        
</style>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

    <div class="d-flex flex-wrap align-end justify-space-between gap-4 mb-8">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold mb-1">System Overview</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="font-weight-medium">Here is what's happening across your offices today.</MudText>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center pa-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Class="mt-4">Loading dashboard data...</MudText>
        </div>
    }
    else
    {
        <MudPaper Elevation="0" Class="rounded-xl d-flex flex-wrap mb-8 overflow-hidden"
                  Style="border: 1px solid var(--mud-palette-lines-default);">
            <div class="pa-6 flex-grow-1" style="flex-basis: 200px; border-right: 1px solid var(--mud-palette-lines-default);">
                <MudText Typo="Typo.body2" Class="font-weight-bold text-muted d-flex align-center gap-2 mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" /> Total Documents
                </MudText>
                <div class="d-flex align-baseline gap-2">
                    <MudText Typo="Typo.h3" Class="font-weight-bold">@totalDocuments</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="font-weight-medium">total</MudText>
                </div>
            </div>
            <div class="pa-6 flex-grow-1" style="flex-basis: 200px; border-right: 1px solid var(--mud-palette-lines-default);">
                <MudText Typo="Typo.body2" Class="font-weight-bold text-muted d-flex align-center gap-2 mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" /> Registered Offices
                </MudText>
                <div class="d-flex align-baseline gap-2">
                    <MudText Typo="Typo.h3" Class="font-weight-bold">@totalOffices</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="font-weight-medium">departments</MudText>
                </div>
            </div>
            <div class="pa-6 flex-grow-1" style="flex-basis: 200px;">
                <MudText Typo="Typo.body2" Class="font-weight-bold text-muted d-flex align-center gap-2 mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" /> Total Users
                </MudText>
                <div class="d-flex align-baseline gap-2">
                    <MudText Typo="Typo.h3" Class="font-weight-bold">@totalUsers</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="font-weight-medium">accounts</MudText>
                </div>
            </div>
        </MudPaper>


        <MudGrid Spacing="4">


            <MudItem xs="12" md="8">
                <div class="d-flex flex-column gap-6">


                    <div>
                        <div class="d-flex align-center justify-space-between mb-4">
                            <MudText Typo="Typo.h6" Class="font-weight-bold d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" />
                                Priority Documents
                            </MudText>
                        </div>

                        <MudGrid Spacing="3">
                            @if (!priorityDocs.Any())
                            {
                                <MudItem xs="12">
                                    <MudPaper Elevation="0" Class="rounded-xl pa-8 d-flex flex-column align-center justify-center"
                                              Style="border: 1px dashed var(--mud-palette-lines-default); min-height: 140px;">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Size="Size.Large" Class="mb-2 mud-text-secondary" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="font-weight-medium">No priority documents</MudText>
                                    </MudPaper>
                                </MudItem>
                            }
                            else
                            {
                                @foreach (var doc in priorityDocs.Take(4))
                                {
                                    var (borderColor, chipBg, chipText, accentColor) = GetPriorityStyle(doc.Priority);
                                    <MudItem xs="12" md="6">
                                        <MudPaper Elevation="0" Class="rounded-xl pa-5 position-relative overflow-hidden ticket-card cursor-pointer"
                                                  Style="@($"border: 2px solid {borderColor};")">
                                            <div style="@($"position:absolute;top:0;left:0;width:6px;height:100%;background-color:{accentColor};")"></div>
                                            <div class="d-flex justify-space-between align-start mb-4 ml-2">
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Class="font-weight-bold"
                                                         Style="@($"background-color:{chipBg};color:{chipText};border:1px solid {borderColor};")">
                                                    @doc.Priority
                                                </MudChip>
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Class="font-weight-bold"
                                                         Style="background-color:#fffbeb;color:#d97706;">
                                                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" /> @doc.Status
                                                </MudChip>
                                            </div>
                                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-1 ml-2 text-truncate">@doc.Name</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4 font-weight-medium ml-2">
                                                @(doc.CurrentOffice != null ? $"At {doc.CurrentOffice.Name}" : doc.NextOffice != null ? $"Routing to {doc.NextOffice.Name}" : "In transit")
                                            </MudText>
                                            <MudDivider Class="mb-3 ml-2" />
                                            <div class="d-flex align-center gap-2 ml-2">
                                                <MudAvatar Size="Size.Small" Style="background-color:#f1f5f9;color:#475569;font-size:10px;font-weight:bold;">
                                                    @(doc.Creator?.Name?.Length > 0 ? doc.Creator.Name[0].ToString() : "?")
                                                </MudAvatar>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="font-weight-medium">
                                                    Submitted by @(doc.Creator?.Name ?? "Unknown")
                                                </MudText>
                                            </div>
                                        </MudPaper>
                                    </MudItem>
                                }
                            }
                        </MudGrid>
                    </div>

                    <MudPaper Elevation="0" Class="rounded-xl pa-6" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-6 d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Info" />
                            Office Workload Distribution
                        </MudText>
                        @if (!officeWorkLoads.Any())
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">No workload data available.</MudText>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-5">
                                @foreach (var w in officeWorkLoads)
                                {
                                    <div>
                                        <div class="d-flex justify-space-between mb-2 align-center">
                                            <MudText Typo="Typo.body2" Class="font-weight-bold text-truncate" Style="max-width:70%;">@w.OfficeName</MudText>
                                            <MudChip T="string" Size="Size.Small" Class="font-weight-bold rounded" Style="background-color:#f1f5f9;">
                                                @w.DocumentCount @(w.DocumentCount == 1 ? "Document" : "Documents")
                                            </MudChip>
                                        </div>
                                        <MudProgressLinear Color="Color.Info" Value="@w.Percentage" Rounded="true" Size="Size.Small" />
                                    </div>
                                }
                            </div>
                        }
                    </MudPaper>

                </div>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="4" Class="rounded-xl d-flex flex-column overflow-hidden"
                          Style="height: 600px; border: 1px solid #1e293b; background-color: #0f172a;">
                    <div class="pa-5 d-flex align-center justify-space-between"
                         style="border-bottom: 1px solid #1e293b; background-color: rgba(15,23,42,0.95);">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold d-flex align-center gap-2" Style="color:white;">
                            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Style="color:#94a3b8;" /> Activity Stream
                        </MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Style="color:#64748b;" Href="/document-tracking">
                            View All
                        </MudButton>
                    </div>
                    <div class="pa-4 flex-grow-1 overflow-auto">
                        @if (!recentDocuments.Any())
                        {
                            <div class="d-flex flex-column align-center justify-center h-100">
                                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Style="color:#334155;" />
                                <MudText Typo="Typo.body2" Style="color:#475569;" Class="mt-2">No recent activity</MudText>
                            </div>
                        }
                        else
                        {
                            <MudTimeline TimelinePosition="TimelinePosition.Start" Class="pa-0 ma-0">
                                @foreach (var doc in recentDocuments)
                                {
                                    var dotColor = doc.Status == "In Motion" ? Color.Warning : doc.Status == "Completed" ? Color.Success : Color.Info;
                                    var statusColor = doc.Status == "In Motion" ? "#fbbf24" : doc.Status == "Completed" ? "#34d399" : "#60a5fa";
                                    <MudTimelineItem Color="@dotColor" Size="Size.Small" Elevation="0">
                                        <div class="d-flex flex-column w-100">
                                            <div class="d-flex justify-space-between align-start mb-1">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold text-truncate" Style="color:white; max-width:140px;">@doc.Name</MudText>
                                                <MudText Typo="Typo.caption" Style="color:#64748b;font-weight:500;white-space:nowrap;">
                                                    @doc.LastActionDate?.ToLocalTime().ToString("hh:mm tt")
                                                </MudText>
                                            </div>
                                            <MudText Typo="Typo.caption" Class="mb-3 font-weight-medium" Style="color:#94a3b8;">
                                                <span style="color:@statusColor;">@doc.Status</span> · @(doc.Creator?.Name ?? "Unknown")
                                            </MudText>
                                            <div class="pa-3 rounded-lg" style="background-color:rgba(30,41,59,0.5);border:1px solid rgba(51,65,85,0.5);">
                                                <div class="d-flex align-center gap-2">
                                                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Style="color:#64748b;font-size:14px;" />
                                                    <MudText Typo="Typo.caption" Style="color:#cbd5e1;">
                                                        @doc.LastActionDate?.ToLocalTime().ToString("MMM dd, yyyy")
                                                    </MudText>
                                                </div>
                                            </div>
                                        </div>
                                    </MudTimelineItem>
                                }
                            </MudTimeline>
                        }
                    </div>
                </MudPaper>
            </MudItem>

        </MudGrid>
    }
</MudContainer>

@code {
    private List<Document> allDocuments = new();
    private List<Document> recentDocuments = new();
    private List<Document> priorityDocs = new();
    private int totalDocuments, totalOffices, totalUsers;
    private bool isLoading = true;
    private List<OfficeWorkLoad> officeWorkLoads = new();

    public class OfficeWorkLoad
    {
        public string? OfficeName { get; set; }
        public int DocumentCount { get; set; }
        public int Percentage { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            allDocuments = await DocumentService.GetAllDocumentsAsync();
            var allAppUsers = await DocumentService.GetAppUserAsync();
            var allOffices = await DocumentService.GetOfficesAsync();

            totalDocuments = allDocuments.Count;
            totalOffices = allOffices.Count;
            totalUsers = allAppUsers.Count;

            priorityDocs = allDocuments
                .Where(d => d.Status != "Completed" && (d.Priority == "Emergency" || d.Priority == "Urgent"))
                .OrderBy(d => d.Priority == "Emergency" ? 0 : 1)
                .ToList();

            recentDocuments = allDocuments
                .OrderByDescending(d => d.LastActionDate ?? d.CreatedAt)
                .Take(6)
                .ToList();

            int maxDoc = Math.Max(totalDocuments, 1);
            officeWorkLoads = allOffices.Select(office =>
            {
                int count = allDocuments.Count(d => d.CurrentOffice?.Name == office.Name);
                return new OfficeWorkLoad
                {
                    OfficeName = office.Name,
                    DocumentCount = count,
                    Percentage = (int)Math.Round((double)count / maxDoc * 100)
                };
            })
            .Where(w => w.DocumentCount > 0)
            .OrderByDescending(w => w.DocumentCount)
            .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private (string borderColor, string chipBg, string chipText, string accentColor) GetPriorityStyle(string? priority) => priority switch
    {
        "Emergency" => ("#ffe4e6", "#fff1f2", "#e11d48", "#f43f5e"),
        "Urgent" => ("#fef3c7", "#fffbeb", "#d97706", "#f59e0b"),
        _ => ("#e2e8f0", "#f8fafc", "#475569", "#94a3b8")
    };
}
