@page "/admin-dashboard"
@attribute [Authorize(Roles = "Admin")]
@using DocTracking.Client
@using DocTracking.Client.Pages
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@inject DocumentService DocumentService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NotificationService NotifService
@inject NavigationManager Navigation
@implements IDisposable
@rendermode InteractiveAuto

<style>
    .stat-card {
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.12) !important;
        }

    .fade-slide-up {
        animation: fadeSlideUp 0.5s ease-out both;
    }

    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @if (isLoading)
    {
        <div class="d-flex align-center mb-6">
            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" Class="mr-3" />
            <div>
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="180px" Height="32px" Class="mb-1" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="280px" />
            </div>
        </div>

        <MudGrid Class="mb-6">
            @for (int i = 0; i < 3; i++)
            {
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="2" Class="pa-4">
                        <div class="d-flex justify-space-between align-center">
                            <div style="flex: 1;">
                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="60px" Height="48px" Class="mb-1" />
                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="120px" />
                            </div>
                            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

        <MudPaper Elevation="2" Class="pa-4 mb-6">
            <div class="d-flex align-center mb-3">
                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="24px" Height="24px" Class="mr-2" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="200px" />
            </div>
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="7">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="80px" />
                </MudItem>
                <MudItem xs="12" sm="5">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="56px" />
                </MudItem>
                <MudItem xs="12">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="40px" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudGrid Class="mb-6">
            <MudItem xs="12" md="7">
                <MudPaper Elevation="2" Class="pa-4" Style="min-height: 500px;">
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="160px" />
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" />
                    </div>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" Class="mb-3" />
                            @for (int i = 0; i < 4; i++)
                            {
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="64px" Class="mb-2" />
                            }
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="100px" Class="mb-3" />
                            @for (int i = 0; i < 4; i++)
                            {
                                <MudSkeleton SkeletonType="SkeletonType.Text" Class="mb-2" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="8px" Class="mb-3 rounded-lg" />
                            }
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="5">
                <MudPaper Elevation="2" Class="pa-4" Style="min-height: 500px;">
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="140px" Class="mb-4" />
                    @for (int i = 0; i < 5; i++)
                    {
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="72px" Class="mb-3" />
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    else
    {
        <div class="d-flex align-center justify-space-between mb-6 fade-slide-up flex-wrap gap-2">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.h4" Class="font-weight-bold">Admin Dashboard</MudText>
                </div>
            </div>
            <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Filled.Info" Style="width: fit-content; margin: 0;">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Monitor system activity in real-time. Click on any stat card to navigate directly to its section. Use the Broadcast feature to send announcements to all users or a specific office.
                </MudText>
            </MudAlert>
        </div>

        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="4" Style="animation: fadeSlideUp 0.5s ease-out 0.1s both;">
                <MudPaper Elevation="2" Class="pa-4 stat-card" Style="border-top: 4px solid var(--mud-palette-info);"
                          @onclick="@(() => Navigation.NavigateTo("/document-tracking"))">
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Info">@stats.TotalDocuments</MudText>
                            <MudText Typo="Typo.body2">Total Documents</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Info" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4" Style="animation: fadeSlideUp 0.5s ease-out 0.2s both;">
                <MudPaper Elevation="2" Class="pa-4 stat-card" Style="border-top: 4px solid var(--mud-palette-warning);"
                          @onclick="@(() => Navigation.NavigateTo("/manage-offices"))">
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Warning">@stats.TotalOffices</MudText>
                            <MudText Typo="Typo.body2">Total Offices</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Color="Color.Warning" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4" Style="animation: fadeSlideUp 0.5s ease-out 0.3s both;">
                <MudPaper Elevation="2" Class="pa-4 stat-card" Style="border-top: 4px solid var(--mud-palette-success);"
                          @onclick="@(() => Navigation.NavigateTo("/manage-users"))">
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Success">@stats.TotalUsers</MudText>
                            <MudText Typo="Typo.body2">Total Users</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Success" />
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="2" Class="pa-4 mb-6 fade-slide-up" Style="border-top: 4px solid var(--mud-palette-secondary); animation-delay: 0.4s;">
            <div class="d-flex align-center mb-3">
                <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Class="mr-3">
                    <MudIcon Icon="@Icons.Material.Filled.Campaign" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.h6" Class="font-weight-bold">Broadcast Notification</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Send an announcement directly to all users or target a specific office from here</MudText>
                </div>
            </div>
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="7">
                    <MudTextField @bind-Value="broadcastMessage" Label="Message" Variant="Variant.Outlined"
                                  Placeholder="Type your announcement..." Lines="2" MaxLength="300"
                                  Counter="300" Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="5">
                    <MudSelect T="int?" @bind-Value="broadcastOfficeId" Label="Target Office (optional)"
                               Variant="Variant.Outlined" Clearable="true">
                        @foreach (var office in allOffices)
                        {
                            <MudSelectItem T="int?" Value="@((int?)office.Id)">@office.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                        Leave blank to send to all users
                    </MudText>
                </MudItem>
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Send"
                               Disabled="@(string.IsNullOrWhiteSpace(broadcastMessage) || isBroadcasting)"
                               OnClick="SendBroadcast">
                        @(isBroadcasting ? "Sending..." : "Send")
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudGrid Class="mb-6" Style="align-items: stretch; animation: fadeSlideUp 0.5s ease-out 0.5s both;">
            <MudItem xs="12" md="7" Style="display: flex; flex-direction: column;">
                <MudPaper Elevation="2" Class="pa-4 flex-grow-1">
                    <div class="d-flex align-center justify-space-between mb-4">
                        <div class="d-flex align-center">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Class="mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.ViewKanban" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">Document Status</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">Get a live view of all documents currently in motion and see which offices are handling the most workload</MudText>
                            </div>
                        </div>
                        <MudButton Href="/document-tracking" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">
                            View All
                        </MudButton>
                    </div>
                    <MudGrid Spacing="2" Style="align-items: stretch; height: 100%;">
                        <MudItem xs="12" sm="6" Style="display: flex; flex-direction: column;">
                            <MudPaper Elevation="0" Class="pa-3 rounded-lg flex-grow-1" Style="background: rgba(var(--mud-palette-warning-rgb), 0.08); max-height: 400px; overflow-y: auto;">
                                <MudText Typo="Typo.subtitle2" Color="Color.Warning" Class="font-weight-bold">In Motion</MudText>
                                @if (!stats.InMotionDocs.Any())
                                {
                                    <div class="d-flex flex-column align-center pa-4">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Size="Size.Large" Color="Color.Success" Style="opacity:0.5;" />
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">All clear! No documents in motion</MudText>
                                    </div>
                                }
                                else
                                {
                                    @foreach (var doc in stats.InMotionDocs)
                                    {
                                        <MudPaper Elevation="1" Class="pa-3 mb-2" Style="@($"border-left: 3px solid {GetPriorityHex(doc.Priority)};")">
                                            <MudText Typo="Typo.body2" Class="font-weight-bold mb-1">@doc.Name</MudText>
                                            <div class="d-flex justify-space-between align-center">
                                                <MudChip T="string" Size="Size.Small" Color="@DocHelpers.GetPriorityColor(doc.Priority)" Variant="Variant.Filled">@doc.Priority</MudChip>
                                                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Primary" OnClick="@(async () => await OpenViewDialog(doc))" />
                                            </div>
                                        </MudPaper>
                                    }
                                }
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" Style="display: flex; flex-direction: column;">
                            <MudPaper Elevation="0" Class="pa-3 rounded-lg flex-grow-1" Style="background: rgba(var(--mud-palette-info-rgb), 0.08); max-height: 400px; overflow-y: auto;">
                                <MudText Typo="Typo.subtitle2" Color="Color.Info" Class="font-weight-bold">Office Workload</MudText>
                                @if (!stats.OfficeWorkloads.Any())
                                {
                                    <div class="d-flex flex-column align-center pa-4">
                                        <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Color="Color.Default" Style="opacity:0.3;" />
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">No workload data available</MudText>
                                    </div>
                                }
                                else
                                {
                                    @foreach (var workload in stats.OfficeWorkloads)
                                    {
                                        <div class="mb-3">
                                            <div class="d-flex justify-space-between mb-1">
                                                <MudText Typo="Typo.caption" Class="font-weight-bold text-truncate" Style="max-width: 70%;">@workload.OfficeName</MudText>
                                            </div>
                                            <MudProgressLinear Color="@GetWorkloadColor(workload.Percentage)" Value="@workload.Percentage" Class="rounded-lg" Size="Size.Small" />
                                            @if (workload.UnitWorkloads.Any())
                                            {
                                                <div class="ml-3 mt-1">
                                                    @foreach (var unit in workload.UnitWorkloads)
                                                    {
                                                        <div class="d-flex justify-space-between">
                                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@unit.UnitName</MudText>
                                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@unit.DocumentCount</MudText>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="5" Style="display: flex; flex-direction: column;">
                <MudPaper Elevation="2" Class="pa-4 flex-grow-1">
                    <div class="d-flex align-center mb-4">
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Class="mr-3">
                            <MudIcon Icon="@Icons.Material.Filled.Timeline" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.h6" Class="font-weight-bold">Recent Activity</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">A live feed of the most recently updated documents across the entire system</MudText>
                        </div>
                    </div>
                    @if (!stats.RecentDocuments.Any())
                    {
                        <div class="d-flex flex-column align-center pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Style="opacity: 0.3; font-size: 4rem;" />
                            <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">No recent activity</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Documents will appear here once created</MudText>
                        </div>
                    }
                    else
                    {
                        <MudTimeline TimelinePosition="TimelinePosition.Start">
                            @foreach (var doc in stats.RecentDocuments)
                            {
                                <MudTimelineItem Color="@(doc.Status == "Completed" ? Color.Success : Color.Warning)"
                                                 Size="Size.Small" TimelineAlign="TimelineAlign.Default">
                                    <ItemContent>
                                        <MudCard Elevation="1" Class="mb-1" Style="min-width:0;">
                                            <MudCardContent Class="pa-3">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold text-truncate">@doc.Name</MudText>
                                                <div class="d-flex align-center justify-space-between mt-1 flex-wrap gap-1">
                                                    <MudChip T="string" Size="Size.Small"
                                                             Color="@(doc.Status == "Completed" ? Color.Success : Color.Warning)"
                                                             Variant="Variant.Outlined">
                                                        @doc.Status
                                                    </MudChip>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                        @doc.LastActionDate?.ToLocalTime().ToString("MMM dd, hh:mm tt")
                                                    </MudText>
                                                </div>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                                                    @doc.Creator?.Name
                                                </MudText>
                                            </MudCardContent>
                                        </MudCard>
                                    </ItemContent>
                                </MudTimelineItem>
                            }
                        </MudTimeline>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private AdminDashboardStats stats = new();
    private List<Office> allOffices = new();
    private bool isLoading = true;
    private string broadcastMessage = "";
    private int? broadcastOfficeId;
    private bool isBroadcasting;
    private readonly DebounceHelper _debounce = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            allOffices = await DocumentService.GetOfficesSimpleAsync();
            await LoadStats();
        }
        finally { isLoading = false; }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            NotifService.OnChange += OnNotificationReceived;
        return Task.CompletedTask;
    }

    private void OnNotificationReceived() =>
        _debounce.Trigger(async () =>
        {
            await LoadStats();
            await InvokeAsync(StateHasChanged);
        });

    private async Task LoadStats()
    {
        try
        {
            var result = await DocumentService.GetDashboardStatsAsync();
            if (result != null) stats = result;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AdminMaster] LoadStats error: {ex.Message}");
        }
    }

    private async Task SendBroadcast()
    {
        if (string.IsNullOrWhiteSpace(broadcastMessage)) return;
        isBroadcasting = true;
        try
        {
            var (ok, error) = await DocumentService.BroadcastNotificationAsync(broadcastMessage, broadcastOfficeId);
            if (!ok) { Snackbar.Add(error ?? "Failed to send broadcast.", Severity.Error); return; }
            Snackbar.Add("Broadcast sent successfully.", Severity.Success);
            broadcastMessage = "";
            broadcastOfficeId = null;
        }
        finally { isBroadcasting = false; }
    }

    private async Task OpenViewDialog(Document doc)
    {
        var parameters = new DialogParameters<DocumentViewDialog> { { x => x.Doc, doc } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<DocumentViewDialog>("Document Details", parameters, options);
    }

    private Color GetWorkloadColor(int percentage) => percentage switch
    {
        <= 30 => Color.Success,
        <= 60 => Color.Warning,
        _ => Color.Error
    };

    private string GetPriorityHex(string? priority) => priority switch
    {
        "Emergency" => "#f44336",
        "Urgent" => "#ff9800",
        "Medium" => "#2196f3",
        "Low" => "#4caf50",
        _ => "#9e9e9e"
    };

    public void Dispose()
    {
        NotifService.OnChange -= OnNotificationReceived;
        _debounce.Dispose();
    }
}
