@page "/admin-master"
@attribute [Authorize]
@using DocTracking.Client.Models
@using DocTracking.Client.Services
@inject DocumentService DocumentService
@rendermode InteractiveAuto

<MudContainer>
	<MudText Typo="Typo.h4" Class="mb-4">Tracking List</MudText>

	@if (loading)
	{
		<MudProgressCircular Color="Color.Primary" Indeterminate="true" />
	}
	else
	{
		<MudTable Items="@allDocuments" Hover="true" Striped="true" Elevation="2">
			<ToolBarContent>
				<MudText Typo="Typo.h6">All Document</MudText>
				<MudSpacer />
			</ToolBarContent>
			<HeaderContent>
				<MudTh>Id</MudTh>
				<MudTh>Name</MudTh>
				<MudTh>Sender</MudTh>
				<MudTh>Location</MudTh>
				<MudTh>Status</MudTh>
				<MudTh>Date</MudTh>
			</HeaderContent>
			<RowTemplate>
				<MudTd DataLabel="Id">@context.Id</MudTd>
				<MudTd DataLabel="Name">@context.Name</MudTd>
				<MudTd DataLabel="Sender">@context.OriginalUserEmail</MudTd>
				<MudTd DataLabel="Location">
					@(context.CurrentOffice?.Name ?? context.NextOffice?.Name ?? "Unassigned")
				</MudTd>
				<MudTd DataLabel="Status">@context.Status</MudTd>
				<MudTd DataLabel="Date">@context.CreatedAt.ToShortTimeString()</MudTd>
			</RowTemplate>
			<PagerContent>
				<MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
			</PagerContent>
		</MudTable>

		
	}
</MudContainer>

@code {
	private List<Document> allDocuments = new();
	private bool loading = true;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			allDocuments = await DocumentService.GetAllDocumentsAsync();
		}
		catch (Exception ex)
		{
			Console.WriteLine(ex.Message);
		}
		finally
		{
			loading = false;
		}
	}	
}