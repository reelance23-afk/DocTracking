@using System.Security.Claims
@using DocTracking.Client.Models
@using DocTracking.Client.Pages.Offices
@using DocTracking.Client.Pages.Shared
@using DocTracking.Client.Services
@using DocTracking.Client.Services.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@inject DocumentService DocService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IDialogService DialogService
@attribute [StreamRendering]

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">
    @if (isLoading)
    {
        <div class="d-flex flex-column align-center mt-10">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mb-4" />
            <MudText>Loading document...</MudText>
        </div>
    }
    else if (doc == null)
    {
        <MudPaper Elevation="3" Class="pa-8 text-center rounded-xl mt-8">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Style="opacity:0.4; font-size:4rem;" Class="mb-4" />
            <MudText Typo="Typo.h5" Class="mud-text-secondary">Document not found</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">Reference: @ReferenceNumber</MudText>
        </MudPaper>
    }
    else
    {
        <div class="d-flex align-center mb-4 gap-3">
            <MudIcon Icon="@Icons.Material.Filled.QrCodeScanner" Size="Size.Large" Color="Color.Primary" />
            <div>
                <MudText Typo="Typo.h5" Class="font-weight-bold">@doc.Name</MudText>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@doc.ReferenceNumber</MudChip>
            </div>
            <MudSpacer />
            <MudChip T="string" Color="@DocHelpers.GetStatusColor(doc.Status)" Variant="Variant.Filled">@doc.Status</MudChip>
        </div>

        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="6" sm="3">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Type</MudText>
                <MudText Typo="Typo.body1">@doc.Type</MudText>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Priority</MudText>
                <MudChip T="string" Color="@DocHelpers.GetPriorityColor(doc.Priority)" Size="Size.Small">@doc.Priority</MudChip>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Current Location</MudText>
                @if (doc.CurrentOffice != null)
                {
                    <MudText Typo="Typo.body2"><strong>@doc.CurrentOffice.Name</strong></MudText>
                    @if (doc.CurrentUnit != null)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">↳ @doc.CurrentUnit.Name</MudText>
                    }
                    @if (!string.IsNullOrEmpty(doc.CurrentOffice.ReceivingSchedule))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Primary">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />@doc.CurrentOffice.ReceivingSchedule
                        </MudText>
                    }
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary"><em>None</em></MudText>
                }
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Next Destination</MudText>
                @if (doc.NextOffice != null)
                {
                    <MudText Typo="Typo.body2"><strong>@doc.NextOffice.Name</strong></MudText>
                    @if (doc.NextUnit != null)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">↳ @doc.NextUnit.Name</MudText>
                    }
                    @if (!string.IsNullOrEmpty(doc.NextOffice.ReceivingSchedule))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Primary">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />@doc.NextOffice.ReceivingSchedule
                        </MudText>
                    }
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary"><em>None</em></MudText>
                }
            </MudItem>
        </MudGrid>

        <MudDivider Class="mb-4" />

        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">
            <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Small" Class="mr-1" />
            Tracking Timeline
        </MudText>

        <TrackingTimeline Logs="logs" IsLoading="false" />
    }
</MudContainer>

@code {
    [Parameter] public string ReferenceNumber { get; set; } = "";

    private Document? doc;
    private List<DocumentLog> logs = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            doc = await DocService.GetDocumentByRefAsync(ReferenceNumber);
            if (doc == null) { isLoading = false; return; }

            var context = await DocService.GetDocumentContextAsync(ReferenceNumber);
            if (context != null)
            {
                switch (context.RedirectTo)
                {
                    case "my-tracking":
                        Navigation.NavigateTo($"/my-tracking?ref={ReferenceNumber}");
                        return;
                    case "document-tracking":
                        Navigation.NavigateTo($"/document-tracking?ref={ReferenceNumber}");
                        return;
                    case "office-desk":
                        Navigation.NavigateTo($"/office-desk?ref={ReferenceNumber}&tab={context.Tab}");
                        return;
                    case "unit-history":
                        Navigation.NavigateTo($"/unit-history?ref={ReferenceNumber}");
                        return;
                }
            }

            logs = await DocService.GetDocumentLogsAsync(doc.Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Track] Load error: {ex.Message}");
        }
        finally { isLoading = false; }
    }

}

