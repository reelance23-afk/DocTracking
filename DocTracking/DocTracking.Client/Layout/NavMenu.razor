<style>
    .nav-section {
        border-bottom: 1px solid var(--mud-palette-divider);
        padding-bottom: 16px;
        margin-bottom: 16px;
    }

        .nav-section:last-child {
            border-bottom: none;
            margin-bottom: 0;
        }
</style>

@if (ShowText)
{
    <div class="px-4 mb-1">
        <MudText Typo="Typo.overline" Class="mud-text-secondary font-weight-bold" Style="font-size:0.65rem; letter-spacing:0.1em;">MENU</MudText>
    </div>
}

<MudNavMenu Rounded="true" Margin="Margin.Dense" Class="px-2">

    <div class="nav-section">
        <MudNavLink Href="/"
                    Match="NavLinkMatch.All"
                    ForceLoad="true"
                    Icon="@Icons.Material.Filled.Home"
                    IconColor="Color.Primary">
            @if (ShowText)
            {
                <MudText Typo="Typo.body1" Style="font-weight:500;">Dashboard</MudText>
            }
        </MudNavLink>
    </div>

    <AuthorizeView>
        <Authorized>
            @if (!context.User.IsInRole("Admin") && !context.User.IsInRole("Office"))
            {
                <div class="nav-section">
                    <MudNavLink Href="/create-document" Icon="@Icons.Material.Filled.NoteAdd" IconColor="Color.Success">
                        @if (ShowText)
                        {
                            <MudText Typo="Typo.body2">Create Document</MudText>
                        }
                    </MudNavLink>
                    <MudNavLink Href="/my-tracking" Icon="@Icons.Material.Filled.History" IconColor="Color.Info">
                        @if (ShowText)
                        {
                            <MudText Typo="Typo.body2">My Tracking</MudText>
                        }
                    </MudNavLink>
                </div>
            }

            @if (context.User.IsInRole("Office"))
            {
                <div class="nav-section">
                    <MudNavLink Href="/office-desk" Icon="@Icons.Material.Filled.InsertDriveFile" IconColor="Color.Warning">
                        @if (ShowText)
                        {
                            <MudText Typo="Typo.body2">Pending Documents</MudText>
                        }
                    </MudNavLink>
                    <MudNavLink Href="/unit-history" Icon="@Icons.Material.Filled.History" IconColor="Color.Info">
                        @if (ShowText)
                        {
                            <MudText Typo="Typo.body2">Document History</MudText>
                        }
                    </MudNavLink>
                    <MudDivider Class="my-2" />
                    <MudNavLink Href="/create-document" Icon="@Icons.Material.Filled.NoteAdd" IconColor="Color.Success">
                        @if (ShowText)
                        {
                            <MudText Typo="Typo.body2">Create Document</MudText>
                        }
                    </MudNavLink>
                    <MudNavLink Href="/my-tracking" Icon="@Icons.Material.Filled.History" IconColor="Color.Info">
                        @if (ShowText)
                        {
                            <MudText Typo="Typo.body2">My Tracking</MudText>
                        }
                    </MudNavLink>
                </div>
            }

            @if (context.User.IsInRole("Admin"))
            {
                <div class="nav-section">
                    <MudNavLink Href="/manage-offices" Icon="@Icons.Material.Filled.Business" IconColor="Color.Secondary">
                        @if (ShowText)
                        {
                            <MudText Typo="Typo.body2">Manage Offices</MudText>
                        }
                    </MudNavLink>
                    <MudNavLink Href="/manage-users" Icon="@Icons.Material.Filled.People" IconColor="Color.Tertiary">
                        @if (ShowText)
                        {
                            <MudText Typo="Typo.body2">User Management</MudText>
                        }
                    </MudNavLink>
                    <MudNavLink Href="/document-tracking" Icon="@Icons.Material.Filled.Description" IconColor="Color.Info">
                        @if (ShowText)
                        {
                            <MudText Typo="Typo.body2">Document Tracking</MudText>
                        }
                    </MudNavLink>
                    <MudDivider Class="my-2" />
                    <MudNavLink Href="/create-document" Icon="@Icons.Material.Filled.NoteAdd" IconColor="Color.Success">
                        @if (ShowText)
                        {
                            <MudText Typo="Typo.body2">Create Document</MudText>
                        }
                    </MudNavLink>
                    <MudNavLink Href="/my-tracking" Icon="@Icons.Material.Filled.History" IconColor="Color.Info">
                        @if (ShowText)
                        {
                            <MudText Typo="Typo.body2">My Tracking</MudText>
                        }
                    </MudNavLink>
                    <MudNavLink Href="/admin-audit-log" Icon="@Icons.Material.Filled.ManageSearch" IconColor="Color.Warning">
                        @if (ShowText)
                        {
                            <MudText Typo="Typo.body2">Audit Log</MudText>
                        }
                    </MudNavLink>
                </div>
            }
        </Authorized>
    </AuthorizeView>

    <div class="mt-auto">
        <AuthorizeView>
            <Authorized>
                <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Default">
                    @if (ShowText)
                    {
                        <MudText Typo="Typo.body2">Settings</MudText>
                    }
                </MudNavLink>
                <MudNavLink Href="/Account/Logout" ForceLoad="true" Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">
                    @if (ShowText)
                    {
                        <MudText Typo="Typo.body2" Class="mud-error-text">Logout</MudText>
                    }
                </MudNavLink>
            </Authorized>
        </AuthorizeView>
    </div>

</MudNavMenu>

@code {
    [CascadingParameter]
    public bool ShowText { get; set; } = true;
}
