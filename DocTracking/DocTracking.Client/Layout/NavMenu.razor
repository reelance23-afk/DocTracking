@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Authorization

<div class="nav-wrapper">
    <div class="nav-body">

        @if (ShowText)
        {
            <div class="nav-label">
                <MudText Typo="Typo.overline" Class="mud-text-secondary">Navigation</MudText>
            </div>
        }

        <MudNavMenu Rounded="true" Margin="Margin.Dense" Class="px-2 mb-2">
            <MudNavLink Href="/"
                        Match="NavLinkMatch.All"
                        ForceLoad="true"
                        Icon="@Icons.Material.Filled.Home"
                        IconColor="Color.Primary">
                @if (ShowText)
                {
                    <span>Dashboard</span>
                }
            </MudNavLink>
        </MudNavMenu>

        <AuthorizeView>
            <Authorized>

                @if (!context.User.IsInRole("Admin") && !context.User.IsInRole("Office"))
                {
                    @if (ShowText)
                    {
                        <div class="nav-label">
                            <MudText Typo="Typo.overline" Class="mud-text-secondary">Documents</MudText>
                        </div>
                    }
                    <MudNavMenu Rounded="true" Margin="Margin.Dense" Class="px-2 mb-2">
                        <MudNavLink Href="/create-document" Icon="@Icons.Material.Filled.NoteAdd" IconColor="Color.Success">
                            @if (ShowText)
                            {
                                <span>Create Document</span>
                            }
                        </MudNavLink>
                        <MudNavLink Href="/my-tracking" Icon="@Icons.Material.Filled.TrackChanges" IconColor="Color.Info">
                            @if (ShowText)
                            {
                                <span>My Tracking</span>
                            }
                        </MudNavLink>
                    </MudNavMenu>
                }

                @if (context.User.IsInRole("Office"))
                {
                    @if (ShowText)
                    {
                        <div class="nav-label">
                            <MudText Typo="Typo.overline" Class="mud-text-secondary">Office</MudText>
                        </div>
                    }
                    <MudNavMenu Rounded="true" Margin="Margin.Dense" Class="px-2 mb-2">
                        <MudNavLink Href="/office-desk" Icon="@Icons.Material.Filled.Inbox" IconColor="Color.Warning">
                            @if (ShowText)
                            {
                                <span>Pending Documents</span>
                            }
                        </MudNavLink>
                        <MudNavLink Href="/unit-history" Icon="@Icons.Material.Filled.Folder" IconColor="Color.Info">
                            @if (ShowText)
                            {
                                <span>Document History</span>
                            }
                        </MudNavLink>
                        @if (ShowText)
                        {
                            <div class="nav-label">
                                <MudText Typo="Typo.overline" Class="mud-text-secondary">My Documents</MudText>
                            </div>
                        }
                        <MudNavLink Href="/create-document" Icon="@Icons.Material.Filled.NoteAdd" IconColor="Color.Success"> 
                            @if (ShowText)
                            {
                                <span>Create Document</span>
                            }
                        </MudNavLink>
                        <MudNavLink Href="/my-tracking" Icon="@Icons.Material.Filled.TrackChanges" IconColor="Color.Info">
                            @if (ShowText)
                            {
                                <span>My Tracking</span>
                            }
                        </MudNavLink>
                    </MudNavMenu>
                }

                @if (context.User.IsInRole("Admin"))
                {
                    @if (ShowText)
                    {
                        <div class="nav-label">
                            <MudText Typo="Typo.overline" Class="mud-text-secondary">Admin</MudText>
                        </div>
                    }
                    <MudNavMenu Rounded="true" Margin="Margin.Dense" Class="px-2 mb-2">
                        <MudNavLink Href="/manage-offices" Icon="@Icons.Material.Filled.Business" IconColor="Color.Secondary">
                            @if (ShowText)
                            {
                                <span>Manage Offices</span>
                            }
                        </MudNavLink>
                        <MudNavLink Href="/manage-users" Icon="@Icons.Material.Filled.People" IconColor="Color.Tertiary">
                            @if (ShowText)
                            {
                                <span>User Management</span>
                            }
                        </MudNavLink>
                        <MudNavLink Href="/document-tracking" Icon="@Icons.Material.Filled.Description" IconColor="Color.Info">
                            @if (ShowText)
                            {
                                <span>Document Tracking</span>
                            }
                        </MudNavLink>
                        <MudNavLink Href="/admin-audit-log" Icon="@Icons.Material.Filled.ManageSearch" IconColor="Color.Warning">
                            @if (ShowText)
                            {
                                <span>Audit Log</span>
                            }
                        </MudNavLink>
                        @if (ShowText)
                        {
                            <div class="nav-label">
                                <MudText Typo="Typo.overline" Class="mud-text-secondary">My Documents</MudText>
                            </div>
                        }
                        <MudNavLink Href="/create-document" Icon="@Icons.Material.Filled.NoteAdd" IconColor="Color.Success">
                            @if (ShowText)
                            {
                                <span>Create Document</span>
                            }
                        </MudNavLink>
                        <MudNavLink Href="/my-tracking" Icon="@Icons.Material.Filled.TrackChanges" IconColor="Color.Info">
                            @if (ShowText)
                            {
                                <span>My Tracking</span>
                            }
                        </MudNavLink>
                    </MudNavMenu>
                }

            </Authorized>
        </AuthorizeView>
    </div>

    <div class="nav-footer">
        <MudDivider Class="mb-2" />
        <AuthorizeView>
            <Authorized>
                <MudNavMenu Rounded="true" Margin="Margin.Dense" Class="px-2">
                    <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Default">
                        @if (ShowText)
                        {
                            <span>Settings</span>
                        }
                    </MudNavLink>
                    <MudNavLink Href="/Account/Logout" ForceLoad="true" Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">
                        @if (ShowText)
                        {
                            <MudText Color="Color.Error">Logout</MudText>
                        }
                    </MudNavLink>
                </MudNavMenu>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@code {
    [CascadingParameter]
    public bool ShowText { get; set; } = true;
}

