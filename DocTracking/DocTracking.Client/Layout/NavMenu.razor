<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" ForceLoad="true" Icon="@Icons.Material.Filled.Home">Dashboard</MudNavLink>

    <AuthorizeView>
        <Authorized>
            @if (!context.User.IsInRole("Admin") && !context.User.IsInRole("Office"))
            {
                <MudNavLink Href="/create-document" Icon="@Icons.Material.Filled.NoteAdd">Create Document</MudNavLink>
                <MudNavLink Href="/my-tracking" Icon="@Icons.Material.Filled.History">My Tracking</MudNavLink>
            }
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="Office">
        <Authorized>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="Admin">
        <Authorized>
            <MudNavLink Href="/manage-office" Icon="@Icons.Material.Filled.Business">Manage Offices</MudNavLink>
        </Authorized>
    </AuthorizeView>

</MudNavMenu>