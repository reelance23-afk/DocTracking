@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using DocTracking.Client.Pages
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ThemeService ThemeService
@inject DocumentService DocService
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime

<MudThemeProvider Theme="CurrentTheme" IsDarkMode="ThemeService.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<style>
    @@keyframes fadeIn {
        0% {
            opacity: 0;
        }

        100% {
            opacity: 1;
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.05);
            opacity: 0.8;
        }
    }

    @@keyframes slideUp {
        from {
            transform: translateY(20px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .loading-container {
        animation: fadeIn 0.3s ease-in;
    }

    .loading-icon {
        animation: pulse 2s ease-in-out infinite;
    }

    .loading-text {
        animation: slideUp 0.5s ease-out 0.2s both;
    }

    .loading-subtext {
        animation: slideUp 0.5s ease-out 0.4s both;
    }
</style>

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Transparent">

        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Default"
                       Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)"
                       Class="mr-2" />

        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                <div style="flex:1; max-width:600px; padding: 0 8px;">
                    <MudTextField @bind-Value="_refSearch" Placeholder="Track by ref no..."
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  AdornmentAriaLabel="Track"
                                  OnAdornmentClick="GoToRef"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  OnKeyDown="OnSearchKeyDown"
                                  Style="width:100%;" />
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.QrCodeScanner"
                               Color="Color.Default"
                               OnClick="OpenScanDialog" />
            </Authorized>
        </AuthorizeView>

        <NotificationBell />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="1"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Never">

        <MudDrawerHeader Class="pa-4">
            <AuthorizeView>
                <Authorized>
                    <MudPaper Outlined="true" Class="d-flex align-center pa-2 rounded-lg w-100" Elevation="0"
                              Style="background-color: var(--mud-palette-background-grey);">
                        <MudAvatar Color="Color.Dark" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3 font-weight-bold">
                            @(displayName?.Length > 0 ? displayName[0].ToString().ToUpper() : "?")
                        </MudAvatar>
                        @if (_showText)
                        {
                            <div class="d-flex flex-column overflow-hidden" style="animation: fadeIn 0.4s ease-out;">
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold text-truncate">@(displayName ?? "User")</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@(displayRole ?? "—")</MudText>
                            </div>
                        }
                    </MudPaper>
                </Authorized>
            </AuthorizeView>
        </MudDrawerHeader>

        <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; min-height: 0;">
            <CascadingValue Value="_showText">
                <NavMenu />
            </CascadingValue>
        </div>

    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="h-100 pb-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    bool _showText = true;
    private string _refSearch = "";
    private MudTheme CurrentTheme = new();
    private string? displayName;
    private string? displayRole;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.LoadAsync();
            ThemeService.OnChange += () => { CurrentTheme = BuildTheme(); StateHasChanged(); };
            CurrentTheme = BuildTheme();

            try { await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('app-loading')?.remove()"); }
            catch { }

            try
            {
                var profile = await DocService.GetProfileAsync();
                displayName = profile?.Name;
                displayRole = profile?.Role switch
                {
                    "Admin" => "System Administrator",
                    "Office" => "Office Worker",
                    _ => "User"
                };
            }
            catch (Exception ex) { Console.WriteLine($"[MainLayout] Profile load error: {ex.Message}"); }

            StateHasChanged();
        }
    }

    private void GoToRef()
    {
        var trimmed = _refSearch.Trim();
        if (!string.IsNullOrEmpty(trimmed))
        {
            _refSearch = "";
            Navigation.NavigateTo($"/track/{Uri.EscapeDataString(trimmed)}", forceLoad: true);
        }
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") GoToRef();
    }

    private MudTheme BuildTheme() => ThemeService.SelectedTheme switch
    {
        "Ocean" => new MudTheme { PaletteLight = new PaletteLight { Primary = "#0077B6", Secondary = "#00B4D8" }, PaletteDark = new PaletteDark { Primary = "#0077B6", Secondary = "#00B4D8" } },
        "Forest" => new MudTheme { PaletteLight = new PaletteLight { Primary = "#2D6A4F", Secondary = "#74C69D" }, PaletteDark = new PaletteDark { Primary = "#2D6A4F", Secondary = "#74C69D" } },
        "Sunset" => new MudTheme { PaletteLight = new PaletteLight { Primary = "#E63946", Secondary = "#F4A261" }, PaletteDark = new PaletteDark { Primary = "#E63946", Secondary = "#F4A261" } },
        "Slate" => new MudTheme { PaletteLight = new PaletteLight { Primary = "#334155", Secondary = "#64748B" }, PaletteDark = new PaletteDark { Primary = "#334155", Secondary = "#64748B" } },
        "Rose" => new MudTheme { PaletteLight = new PaletteLight { Primary = "#BE185D", Secondary = "#F472B6" }, PaletteDark = new PaletteDark { Primary = "#BE185D", Secondary = "#F472B6" } },
        _ => new MudTheme()
    };

    private async Task OpenScanDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<QRScanDialog>("Scan QR Code", options);
    }
}
