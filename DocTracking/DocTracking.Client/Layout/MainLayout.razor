@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using DocTracking.Client.Pages
@inject AuthenticationStateProvider AuthStateProvider
@inject NotificationService NotifService
@inject NavigationManager Navigation
@inject ThemeService ThemeService
@inject DocumentService DocService
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime

<MudThemeProvider Theme="CurrentTheme" IsDarkMode="ThemeService.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<style>
    @@keyframes fadeIn {
        0% {
            opacity: 0;
        }

        100% {
            opacity: 1;
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.05);
            opacity: 0.8;
        }
    }

    @@keyframes slideUp {
        from {
            transform: translateY(20px);
            opacity: 0;
		}
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .loading-container {
        animation: fadeIn 0.3s ease-in;
    }

    .loading-icon {
        animation: pulse 2s ease-in-out infinite;
    }

    .loading-text {
        animation: slideUp 0.5s ease-out 0.2s both;
    }

    .loading-subtext {
        animation: slideUp 0.5s ease-out 0.4s both;
    }

    .page-fade-in {
        animation: pageFadeIn 0.3s ease-out both;
    }

    .page-fade-out {
        animation: pageFadeOut 0.3s ease-out both;
    }

    @@keyframes pageFadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes pageFadeOut {
        from {
            opacity: 1;
        }

        to {
            opacity: 0;
        }
    }
</style>


<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Transparent">

        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Default"
                       Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)"
                       Class="mr-2" />

        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                <div style="flex:1; max-width:600px; padding: 0 8px; position: relative;"
                     @onfocusout="OnSearchFocusOut">
                    <MudTextField @bind-Value="_refSearch"
                                  @bind-Value:after="@(() => OnSearchChanged(_refSearch))"
                                  DebounceInterval="400"
                                  Placeholder="Search documents..."
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_searchLoading? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.Search)"
                                  AdornmentAriaLabel="Search"
                                  OnAdornmentClick="@(async () => await OnSearch())"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  OnKeyDown="OnSearchKeyDown"
                                  Style="width:100%;" />

                    @if (_searchOpen)
                    {
                        <MudPaper Elevation="8"
                                  Style="position:absolute; top:100%; left:0; right:0; z-index:2000; max-height:450px; overflow-y:auto;"
                                  @onmousedown:stopPropagation="true">
                            @if (_searchLoading)
                            {
                                <div class="pa-4 d-flex justify-center">
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                                </div>
                            }
                            else if (!HasAnyResults)
                            {
                                <div class="pa-4 text-center">
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">No results found</MudText>
                                </div>
                            }
                            else
                            {
                                @if (_groupedResults.DocumentTracking.Any())
                                {
                                    <div class="px-3 pt-3 pb-1">
                                        <MudText Typo="Typo.caption" Class="font-weight-bold mud-text-secondary">
                                            <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Class="mr-1" />
                                            DOCUMENT TRACKING
                                        </MudText>
                                    </div>
                                    @foreach (var item in _groupedResults.DocumentTracking)
                                    {
                                        <MudListItem T="string" OnClick="@(() => OnResultClick($"/document-tracking?search={Uri.EscapeDataString(item.Name ?? "")}"))" Style="cursor:pointer;">
                                            <div class="d-flex flex-column py-1">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@item.Name</MudText>
                                                <div class="d-flex align-center gap-2">
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@item.ReferenceNumber</MudText>
                                                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(item.Status)" Variant="Variant.Text" Style="height:18px; font-size:0.7rem;">@item.Status</MudChip>
                                                </div>
                                            </div>
                                        </MudListItem>
                                        <MudDivider />
                                    }
                                    @if (_groupedResults.DocumentTrackingTotal > _groupedResults.DocumentTracking.Count)
                                    {
                                        <div class="d-flex justify-center pb-1">
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                                       OnClick="@(() => OnResultClick($"/document-tracking?search={Uri.EscapeDataString(_refSearch)}"))">
                                                See all @_groupedResults.DocumentTrackingTotal results
                                            </MudButton>
                                        </div>
                                    }
                                }

                                @if (_groupedResults.AuditLog.Any())
                                {
                                    <div class="px-3 pt-3 pb-1">
                                        <MudText Typo="Typo.caption" Class="font-weight-bold mud-text-secondary">
                                            <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Size="Size.Small" Class="mr-1" />
                                            AUDIT LOG
                                        </MudText>
                                    </div>
                                    @foreach (var item in _groupedResults.AuditLog)
                                    {
                                        <MudListItem T="string" OnClick="@(() => OnResultClick($"/admin-audit-log?search={Uri.EscapeDataString(item.DocumentName ?? "")}"))" Style="cursor:pointer;">
                                            <div class="d-flex flex-column py-1">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@item.DocumentName</MudText>
                                                <div class="d-flex align-center gap-2">
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@item.ReferenceNumber</MudText>
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text" Style="height:18px; font-size:0.7rem;">@item.Action</MudChip>
                                                    @if (!string.IsNullOrEmpty(item.ByName))
                                                    {
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">by @item.ByName</MudText>
                                                    }
                                                </div>
                                            </div>
                                        </MudListItem>
                                        <MudDivider />
                                    }
                                    @if (_groupedResults.AuditLogTotal > _groupedResults.AuditLog.Count)
                                    {
                                        <div class="d-flex justify-center pb-1">
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                                       OnClick="@(() => OnResultClick($"/admin-audit-log?search={Uri.EscapeDataString(_refSearch)}"))">
                                                See all @_groupedResults.AuditLogTotal results
                                            </MudButton>
                                        </div>
                                    }
                                }

                                @if (_groupedResults.Incoming.Any())
                                {
                                    <div class="px-3 pt-3 pb-1">
                                        <MudText Typo="Typo.caption" Class="font-weight-bold mud-text-secondary">
                                            <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Small" Class="mr-1" />
                                            INCOMING
                                        </MudText>
                                    </div>
                                    @foreach (var item in _groupedResults.Incoming)
                                    {
                                        <MudListItem T="string" OnClick="@(() => OnResultClick($"/office-desk?search={Uri.EscapeDataString(item.Name ?? "")}&tab=Incoming"))" Style="cursor:pointer;">
                                            <div class="d-flex flex-column py-1">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@item.Name</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@item.ReferenceNumber</MudText>
                                            </div>
                                        </MudListItem>
                                        <MudDivider />
                                    }
                                    @if (_groupedResults.IncomingTotal > _groupedResults.Incoming.Count)
                                    {
                                        <div class="d-flex justify-center pb-1">
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                                       OnClick="@(() => OnResultClick($"/office-desk?search={Uri.EscapeDataString(_refSearch)}&tab=Incoming"))">
                                                See all @_groupedResults.IncomingTotal results
                                            </MudButton>
                                        </div>
                                    }
                                }

                                @if (_groupedResults.OnDesk.Any())
                                {
                                    <div class="px-3 pt-3 pb-1">
                                        <MudText Typo="Typo.caption" Class="font-weight-bold mud-text-secondary">
                                            <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" Class="mr-1" />
                                            ON DESK
                                        </MudText>
                                    </div>
                                    @foreach (var item in _groupedResults.OnDesk)
                                    {
                                        <MudListItem T="string" OnClick="@(() => OnResultClick($"/office-desk?search={Uri.EscapeDataString(item.Name ?? "")}&tab=OnDesk"))" Style="cursor:pointer;">
                                            <div class="d-flex flex-column py-1">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@item.Name</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@item.ReferenceNumber</MudText>
                                            </div>
                                        </MudListItem>
                                        <MudDivider />
                                    }
                                    @if (_groupedResults.OnDeskTotal > _groupedResults.OnDesk.Count)
                                    {
                                        <div class="d-flex justify-center pb-1">
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                                       OnClick="@(() => OnResultClick($"/office-desk?search={Uri.EscapeDataString(_refSearch)}&tab=OnDesk"))">
                                                See all @_groupedResults.OnDeskTotal results
                                            </MudButton>
                                        </div>
                                    }
                                }

                                @if (_groupedResults.Outgoing.Any())
                                {
                                    <div class="px-3 pt-3 pb-1">
                                        <MudText Typo="Typo.caption" Class="font-weight-bold mud-text-secondary">
                                            <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Small" Class="mr-1" />
                                            OUTGOING
                                        </MudText>
                                    </div>
                                    @foreach (var item in _groupedResults.Outgoing)
                                    {
                                        <MudListItem T="string" OnClick="@(() => OnResultClick($"/office-desk?search={Uri.EscapeDataString(item.Name ?? "")}&tab=Outgoing"))" Style="cursor:pointer;">
                                            <div class="d-flex flex-column py-1">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@item.Name</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@item.ReferenceNumber</MudText>
                                            </div>
                                        </MudListItem>
                                        <MudDivider />
                                    }
                                    @if (_groupedResults.OutgoingTotal > _groupedResults.Outgoing.Count)
                                    {
                                        <div class="d-flex justify-center pb-1">
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                                       OnClick="@(() => OnResultClick($"/office-desk?search={Uri.EscapeDataString(_refSearch)}&tab=Outgoing"))">
                                                See all @_groupedResults.OutgoingTotal results
                                            </MudButton>
                                        </div>
                                    }
                                }

                                @if (_groupedResults.Offices.Any())
                                {
                                    <div class="px-3 pt-3 pb-1">
                                        <MudText Typo="Typo.caption" Class="font-weight-bold mud-text-secondary">
                                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Class="mr-1" />
                                            MANAGE OFFICES
                                        </MudText>
                                    </div>
                                    @foreach (var item in _groupedResults.Offices)
                                    {
                                        <MudListItem T="string" OnClick="@(() => OnResultClick($"/manage-offices?search={Uri.EscapeDataString(item.Name ?? "")}"))" Style="cursor:pointer;">
                                            <div class="d-flex align-center py-1 gap-2">
                                                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Class="mud-text-secondary" />
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@item.Name</MudText>
                                            </div>
                                        </MudListItem>
                                        <MudDivider />
                                    }
                                    @if (_groupedResults.OfficesTotal > _groupedResults.Offices.Count)
                                    {
                                        <div class="d-flex justify-center pb-1">
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                                       OnClick="@(() => OnResultClick($"/manage-offices?search={Uri.EscapeDataString(_refSearch)}"))">
                                                See all @_groupedResults.OfficesTotal results
                                            </MudButton>
                                        </div>
                                    }
                                }

                                @if (_groupedResults.Users.Any())
                                {
                                    <div class="px-3 pt-3 pb-1">
                                        <MudText Typo="Typo.caption" Class="font-weight-bold mud-text-secondary">
                                            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Class="mr-1" />
                                            USER MANAGEMENT
                                        </MudText>
                                    </div>
                                    @foreach (var item in _groupedResults.Users)
                                    {
                                        <MudListItem T="string" OnClick="@(() => OnResultClick($"/manage-users?search={Uri.EscapeDataString(item.Name ?? "")}"))" Style="cursor:pointer;">
                                            <div class="d-flex align-center py-1 gap-2">
                                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mud-text-secondary" />
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@item.Name</MudText>
                                            </div>
                                        </MudListItem>
                                        <MudDivider />
                                    }
                                    @if (_groupedResults.UsersTotal > _groupedResults.Users.Count)
                                    {
                                        <div class="d-flex justify-center pb-1">
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                                       OnClick="@(() => OnResultClick($"/manage-users?search={Uri.EscapeDataString(_refSearch)}"))">
                                                See all @_groupedResults.UsersTotal results
                                            </MudButton>
                                        </div>
                                    }
                                }


                                @if (_groupedResults.MyTracking.Any())
                                {
                                    <div class="px-3 pt-3 pb-1">
                                        <MudText Typo="Typo.caption" Class="font-weight-bold mud-text-secondary">
                                            <MudIcon Icon="@Icons.Material.Filled.TrackChanges" Size="Size.Small" Class="mr-1" />
                                            MY TRACKING
                                        </MudText>
                                    </div>
                                    @foreach (var item in _groupedResults.MyTracking)
                                    {
                                        <MudListItem T="string" OnClick="@(() => OnResultClick($"/my-tracking?search={Uri.EscapeDataString(item.Name ?? "")}"))" Style="cursor:pointer;">
                                            <div class="d-flex flex-column py-1">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@item.Name</MudText>
                                                <div class="d-flex align-center gap-2">
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@item.ReferenceNumber</MudText>
                                                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(item.Status)" Variant="Variant.Text" Style="height:18px; font-size:0.7rem;">@item.Status</MudChip>
                                                </div>
                                            </div>
                                        </MudListItem>
                                        <MudDivider />
                                    }
                                    @if (_groupedResults.MyTrackingTotal > _groupedResults.MyTracking.Count)
                                    {
                                        <div class="d-flex justify-center pb-1">
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                                       OnClick="@(() => OnResultClick($"/my-tracking?search={Uri.EscapeDataString(_refSearch)}"))">
                                                See all @_groupedResults.MyTrackingTotal results
                                            </MudButton>
                                        </div>
                                    }
                                }
                            }
                        </MudPaper>

                    }
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.QrCodeScanner"
                               Color="Color.Default"
                               OnClick="OpenScanDialog" />
            </Authorized>
        </AuthorizeView>

        <NotificationBell />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="1"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Never">

        <MudDrawerHeader Class="pa-4">
            <AuthorizeView>
                <Authorized>
                    <MudPaper Outlined="true" Class="d-flex align-center pa-2 rounded-lg w-100" Elevation="0"
                              Style="background-color: var(--mud-palette-background-grey);">
                        <MudAvatar Color="Color.Dark" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3 font-weight-bold">
                            @(displayName?.Length > 0 ? displayName[0].ToString().ToUpper() : "?")
                        </MudAvatar>
                        @if (_showText)
                        {
                            <div class="d-flex flex-column overflow-hidden" style="animation: fadeIn 0.4s ease-out;">
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold text-truncate">@(displayName ?? "User")</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@(displayRole ?? "—")</MudText>
                            </div>
                        }
                    </MudPaper>
                </Authorized>
            </AuthorizeView>
        </MudDrawerHeader>

        <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; min-height: 0;">
            <CascadingValue Value="_showText">
                <NavMenu />
            </CascadingValue>
        </div>

    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="h-100 pb-8">
            <div class="@(_fadingOut ? "page-fade-out" : "page-fade-in")">
                @Body
            </div>
        </MudContainer>
    </MudMainContent>
    @if (_roleChanged)
    {
        <div style="position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.7); display:flex; align-items:center; justify-content:center;">
            <MudPaper Elevation="8" Class="pa-8 rounded-xl text-center" Style="max-width:400px; width:90%;">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Large" Color="Color.Warning" Class="mb-4" Style="font-size:4rem;" />
                <MudText Typo="Typo.h5" Class="font-weight-bold mb-2">Your role has been updated</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
                    An administrator has changed your account role. Please log out and log back in for the changes to take effect.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Logout"
                           Href="/Account/Logout">
                    Log Out Now
                </MudButton>
            </MudPaper>
        </div>
    }
</MudLayout>


@code {
    bool _drawerOpen = true;
    bool _showText = true;
    private string _refSearch = "";
    private MudTheme CurrentTheme = new();
    private string? displayName;
    private string? displayRole;
    private string? _userRole;

    private GroupedSearchResult _groupedResults = new();
    private bool _searchOpen = false;
    private bool _searchLoading = false;
    private CancellationTokenSource _searchCts = new();

    private bool _fadingOut = false;
    private bool _roleChanged = false;

    private bool HasAnyResults =>
        _groupedResults.DocumentTracking.Any() ||
        _groupedResults.AuditLog.Any() ||
        _groupedResults.MyTracking.Any() ||
        _groupedResults.Incoming.Any() ||
        _groupedResults.OnDesk.Any() ||
        _groupedResults.Outgoing.Any() ||
        _groupedResults.Offices.Any() ||
        _groupedResults.Users.Any();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.LoadAsync();
            ThemeService.OnChange += () => { CurrentTheme = BuildTheme(); StateHasChanged(); };
            CurrentTheme = BuildTheme();

            try
            {
                var profile = await DocService.GetProfileAsync();
                if (profile != null)
                {
                    displayName = profile.Name;
                    _userRole = profile.Role;
                    displayRole = _userRole switch
                    {
                        "Admin" => "System Administrator",
                        "Office" => "Office Worker",
                        _ => "User"
                    };

                    await InvokeAsync(StateHasChanged);

                    var groups = new List<string>();
                    var resolvedOfficeId = profile.OfficeId ?? profile.Unit?.OfficeId;

                    if (profile.UnitId.HasValue)
                        groups.Add($"unit-{profile.UnitId}");

                    if (profile.IsOfficeHead && resolvedOfficeId.HasValue)
                        groups.Add($"office-head-{resolvedOfficeId}");
                    else if (!profile.IsOfficeHead && resolvedOfficeId.HasValue && !profile.UnitId.HasValue)
                        groups.Add($"office-{resolvedOfficeId}");

                    await NotifService.ConnectAsync($"user-{profile.Id}", groups);
                    Console.WriteLine($"[MainLayout] SignalR connected for user-{profile.Id}");
                    NotifService.OnRoleChanged += OnRoleChangedReceived;
                }
            }
            catch (Exception ex) { Console.WriteLine($"[MainLayout] Profile load error: {ex.Message}"); }

            try
            {
                await JSRuntime.InvokeVoidAsync("eval",
                    "var el = document.getElementById('app-loading'); if(el){ el.classList.add('hide'); setTimeout(() => el.remove(), 500); }");
            }
            catch { }

            StateHasChanged();
        }
    }



    private async void OnSearchChanged(string value)
    {
        _refSearch = value;
        _searchCts.Cancel();
        _searchCts = new CancellationTokenSource();

        if (string.IsNullOrWhiteSpace(value))
        {
            _searchOpen = false;
            _groupedResults = new();
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            _searchLoading = true;
            _searchOpen = true;
            await InvokeAsync(StateHasChanged);
            _groupedResults = await DocService.SearchDocumentsGroupedAsync(value, take: 5);
        }
        catch (Exception ex) { Console.WriteLine($"[Search] Error: {ex.Message}"); }
        finally
        {
            _searchLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }


    private async Task OnSearch()
    {
        if (string.IsNullOrWhiteSpace(_refSearch)) return;
        _searchLoading = true;
        _searchOpen = true;
        await InvokeAsync(StateHasChanged);
        _groupedResults = await DocService.SearchDocumentsGroupedAsync(_refSearch, take: 5);
        _searchLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void OnResultClick(string url)
    {
        _searchOpen = false;
        _refSearch = "";
        _groupedResults = new();
        Navigation.NavigateTo(url, forceLoad: true);
    }

    private void CloseSearch()
    {
        _searchOpen = false;
        StateHasChanged();
    }

    private async Task OnSearchFocusOut()
    {
        await Task.Delay(200);
        _searchOpen = false;
        await InvokeAsync(StateHasChanged);
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = OnSearch();
        if (e.Key == "Escape") CloseSearch();
    }

    private Color GetStatusColor(string? status) => status switch
    {
        "Completed" => Color.Success,
        "Received" => Color.Info,
        "In Motion" => Color.Warning,
        _ => Color.Default
    };

    private MudTheme BuildTheme() => ThemeService.SelectedTheme switch
    {
        "Ocean" => new MudTheme { PaletteLight = new PaletteLight { Primary = "#0077B6", Secondary = "#00B4D8" }, PaletteDark = new PaletteDark { Primary = "#0077B6", Secondary = "#00B4D8" } },
        "Forest" => new MudTheme { PaletteLight = new PaletteLight { Primary = "#2D6A4F", Secondary = "#74C69D" }, PaletteDark = new PaletteDark { Primary = "#2D6A4F", Secondary = "#74C69D" } },
        "Sunset" => new MudTheme { PaletteLight = new PaletteLight { Primary = "#E63946", Secondary = "#F4A261" }, PaletteDark = new PaletteDark { Primary = "#E63946", Secondary = "#F4A261" } },
        "Slate" => new MudTheme { PaletteLight = new PaletteLight { Primary = "#334155", Secondary = "#64748B" }, PaletteDark = new PaletteDark { Primary = "#334155", Secondary = "#64748B" } },
        "Rose" => new MudTheme { PaletteLight = new PaletteLight { Primary = "#BE185D", Secondary = "#F472B6" }, PaletteDark = new PaletteDark { Primary = "#BE185D", Secondary = "#F472B6" } },
        _ => new MudTheme()
    };

    private async Task OpenScanDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<QRScanDialog>("Scan QR Code", options);
    }

    private IDisposable? _locationChangingRegistration;

    protected override void OnInitialized()
    {
        _locationChangingRegistration = Navigation.RegisterLocationChangingHandler(OnLocationChanging);
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        _fadingOut = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(300);
        _fadingOut = false;
    }

    private void OnRoleChangedReceived()
    {
        _roleChanged = true;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _locationChangingRegistration?.Dispose();
        NotifService.OnRoleChanged -= OnRoleChangedReceived;
    }
}

