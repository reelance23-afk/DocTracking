@using DocTracking.Client.Models
@using DocTracking.Client.Services
@inject NotificationService NotifService
@inject DocumentService DocService
@implements IAsyncDisposable
@rendermode InteractiveAuto

<div style="position: relative; display: inline-block;">
    <MudBadge Content="@NotifService.UnreadCount" Visible="@(NotifService.UnreadCount > 0)"
              Color="Color.Error" Overlap="true" BadgeClass="z-10">
        <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                       Size="Size.Small"
                       Color="Color.Primary"
                       OnClick="ToggleMenu" />
    </MudBadge>

    <MudPopover Open="_menuOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                Paper="true" Elevation="8" Style="z-index: 1300;">
        <MudPaper MinWidth="300px" MaxWidth="360px" Elevation="0">
            <div class="d-flex align-center justify-space-between pa-3 pb-1">
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Notifications</MudText>
                @if (NotifService.UnreadCount > 0)
                {
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="MarkAllRead">Mark all read</MudButton>
                }
            </div>
            <MudDivider />
            @if (!NotifService.Notifications.Any())
            {
                <div class="pa-4 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.NotificationsNone" Size="Size.Large" Class="mud-text-secondary mb-2" />
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">No notifications yet</MudText>
                </div>
            }
            else
            {
                <div style="max-height: 360px; overflow-y: auto;">
                    @foreach (var notif in NotifService.Notifications.Take(20))
                    {
                        <MudListItem T="string" Style="@(!notif.IsRead ? "background: rgba(var(--mud-palette-primary-rgb), 0.06);" : "")">
                            <div class="d-flex align-start gap-2 py-1">
                                <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Size="Size.Small" Class="mt-1" />
                                <div>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@notif.DocumentName</MudText>
                                    <MudText Typo="Typo.caption">@notif.Message</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@notif.Time.ToLocalTime().ToString("MMM dd • hh:mm tt")</MudText>
                                </div>
                            </div>
                        </MudListItem>
                        <MudDivider />
                    }
                </div>
            }
            <MudDivider />
            <div class="pa-2 d-flex justify-end">
                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="ToggleMenu">Close</MudButton>
            </div>
        </MudPaper>
    </MudPopover>
</div>

@if (_menuOpen)
{
    <MudOverlay Visible="_menuOpen" OnClick="ToggleMenu" ZIndex="1299" DarkBackground="false" />
}

@code {
    private bool _menuOpen = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        NotifService.OnChange += StateHasChanged;

        try
        {
            var profile = await DocService.GetProfileAsync();
            if (profile == null) return;

            var groups = new List<string>();
            var resolvedOfficeId = profile.OfficeId ?? profile.Unit?.OfficeId;

            if (profile.UnitId.HasValue)
                groups.Add($"unit-{profile.UnitId}");

            if (profile.IsOfficeHead && resolvedOfficeId.HasValue)
                groups.Add($"office-head-{resolvedOfficeId}");
            else if (!profile.IsOfficeHead && resolvedOfficeId.HasValue && !profile.UnitId.HasValue)
                groups.Add($"office-{resolvedOfficeId}");

            await NotifService.ConnectAsync($"user-{profile.Id}", groups);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Bell] ERROR: {ex.Message}");
        }
    }

    private async Task ToggleMenu()
    {
        _menuOpen = !_menuOpen;
        if (_menuOpen && NotifService.UnreadCount > 0)
            await NotifService.MarkAllReadAsync();
    }

    private async Task MarkAllRead()
    {
        await NotifService.MarkAllReadAsync();
    }

    public ValueTask DisposeAsync()
    {
        NotifService.OnChange -= StateHasChanged;
        return ValueTask.CompletedTask;
    }
}
